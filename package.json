{
  "name": "susufinance",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:env": "node src/scripts/envCheck.mjs",
    "build": "astro build",
    "start": "HOST=0.0.0.0 PORT=${PORT:-10000} node --import dotenv/config ./dist/server/entry.mjs",
    "check": "astro check",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "node --env-file-if-exists=.env src/scripts/pgMigrate.mjs",
    "db:migrate:turso": "node src/scripts/dbMigrate.mjs",
    "seed:addresses": "node src/scripts/seedKnownAddresses.mjs",
    "seed:circle": "node --env-file-if-exists=.env src/scripts/seedDemoCircle.mjs",
    "seed:beta": "node --env-file-if-exists=.env src/scripts/seedBetaCircle.mjs",
    "seed:forming": "node --env-file-if-exists=.env src/scripts/seedFormingTins.mjs"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.4",
    "@astrojs/react": "^5.0.7",
    "@auth/core": "^0.34.3",
    "@bgd-labs/aave-address-book": "^4.44.22",
    "@google-analytics/data": "^5.2.1",
    "@libsql/client": "^0.17.0",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@types/geoip-lite": "^1.4.4",
    "@types/pdfkit": "^0.17.5",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "astro": "^6.4.8",
    "bcryptjs": "^3.0.3",
    "canonicalize": "^3.0.0",
    "chart.js": "^4.5.1",
    "dotenv": "^17.2.4",
    "geoip-lite": "^1.4.10",
    "imapflow": "^1.4.7",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.554.0",
    "mailparser": "^3.9.14",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@playwright/test": "^1.58.2",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.12",
    "@types/pdf-parse": "^1.1.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "description": "SSF (SusuFinance) — the community storehouse. Non-custodial susu/tontine savings circles: the app sees the circle, it never holds the pot."
}
