<script>
  // ── Demo tracking ─────────────────────────────────────────────────────────
  const isDemo = document.cookie.split(';').some(c => c.trim() === 'almstins-demo=1');
  if (isDemo && typeof window.gtag === 'function') {
    window.gtag('event', 'demo_year_end', { event_category: 'demo' });
  }

  // ── Disclaimer modal — shows once per tax season (resets Feb 1) ────────────
  const now = new Date();
  // Feb 1 onwards = new filing season for the prior year
  const seasonYear = now.getMonth() >= 1 ? now.getFullYear() : now.getFullYear() - 1;
  const discKey    = `tax_disclaimer_seen_${seasonYear}`;
  const modal      = document.getElementById('disclaimer-modal') as HTMLElement;

  if (!localStorage.getItem(discKey)) {
    modal.hidden = false;
  }
  document.getElementById('disc-ok')?.addEventListener('click', () => {
    localStorage.setItem(discKey, '1');
    modal.hidden = true;
  });
  document.getElementById('disc-link-btn')?.addEventListener('click', () => {
    modal.hidden = false;
  });

  // ── Restore checkbox state from localStorage ───────────────────────────────
  document.querySelectorAll<HTMLInputElement>('.check-box[data-key]').forEach(cb => {
    const key = cb.dataset.key!;
    cb.checked = localStorage.getItem(key) === '1';
    cb.addEventListener('change', () => {
      if (cb.checked) localStorage.setItem(key, '1');
      else localStorage.removeItem(key);
    });
  });

  // ── Tax document uploads (W-2, 1099-INT, etc.) ────────────────────────────
  const taxYear = new URLSearchParams(location.search).get('year') ?? String(new Date().getFullYear() - 1);

  function renderDocChip(doc: { id: string; filename: string }, container: HTMLElement, cb: HTMLInputElement) {
    const chip = document.createElement('a');
    chip.href = `/api/yearEnd/documents/${doc.id}`;
    chip.target = '_blank';
    chip.rel = 'noopener';
    chip.className = 'doc-chip';
    chip.title = doc.filename;

    const name = document.createElement('span');
    name.textContent = doc.filename.length > 18 ? doc.filename.slice(0, 15) + '…' : doc.filename;
    chip.appendChild(name);

    const del = document.createElement('span');
    del.className = 'doc-chip-del';
    del.textContent = '✕';
    del.title = 'Remove';
    del.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!confirm(`Remove "${doc.filename}"?`)) return;
      const res = await fetch(`/api/yearEnd/documents/${doc.id}`, { method: 'DELETE' });
      if (res.ok) {
        chip.remove();
        // Uncheck the checkbox if no more docs for this type
        if (container.childElementCount === 0) {
          cb.checked = false;
          localStorage.removeItem(cb.dataset.key!);
        }
      }
    });
    chip.appendChild(del);
    container.appendChild(chip);
  }

  // Load existing documents and render chips
  async function loadDocs() {
    try {
      const res = await fetch(`/api/yearEnd/documents?year=${taxYear}`);
      if (!res.ok) return;
      const { docs } = await res.json();
      for (const doc of docs) {
        const li = document.querySelector<HTMLElement>(`[data-doc-type="${doc.docType}"]`);
        const container = li?.querySelector<HTMLElement>('[data-doc-attachments]');
        const cb = li?.querySelector<HTMLInputElement>('.check-box');
        if (!container || !cb) continue;
        renderDocChip(doc, container, cb);
        cb.checked = true;
        localStorage.setItem(cb.dataset.key!, '1');
      }
    } catch { /* ignore */ }
  }
  loadDocs();

  // Handle per-doc-type file uploads
  document.querySelectorAll<HTMLInputElement>('.doc-file-input').forEach(input => {
    input.addEventListener('change', async () => {
      const file = input.files?.[0];
      if (!file) return;
      const docType = input.dataset.docType!;
      const li = input.closest<HTMLElement>('[data-doc-type]');
      const container = li?.querySelector<HTMLElement>('[data-doc-attachments]');
      const cb = li?.querySelector<HTMLInputElement>('.check-box');
      if (!container || !cb) return;

      const label = input.closest<HTMLLabelElement>('.doc-upload-btn');
      if (label) label.textContent = '⏳';

      const fd = new FormData();
      fd.append('file', file);
      fd.append('docType', docType);
      fd.append('taxYear', taxYear);
      try {
        const res = await fetch('/api/yearEnd/documents', { method: 'POST', body: fd });
        const json = await res.json();
        if (json.ok) {
          renderDocChip(json.doc, container, cb);
          cb.checked = true;
          localStorage.setItem(cb.dataset.key!, '1');
        } else {
          alert(`Upload failed: ${json.error ?? 'Unknown error'}`);
        }
      } catch {
        alert('Network error — please try again.');
      } finally {
        if (label) label.textContent = '📎';
        input.value = ''; // reset so same file can be re-picked
      }
    });
  });

  // ── Upload drop zone ───────────────────────────────────────────────────────
  const dropzone  = document.getElementById('upload-dropzone') as HTMLElement;
  const fileInput = document.getElementById('csv-file-input') as HTMLInputElement;
  const statusEl  = document.getElementById('upload-status') as HTMLElement;

  dropzone?.addEventListener('click', () => fileInput?.click());
  dropzone?.addEventListener('dragover', e => { e.preventDefault(); dropzone.classList.add('dragover'); });
  dropzone?.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
  dropzone?.addEventListener('drop', e => {
    e.preventDefault();
    dropzone.classList.remove('dragover');
    const file = e.dataTransfer?.files[0];
    if (file) handleUpload(file);
  });
  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) handleUpload(fileInput.files[0]);
  });

  async function handleUpload(file: File) {
    statusEl.hidden = false;
    statusEl.className = 'upload-status';
    statusEl.textContent = `Uploading ${file.name}…`;
    const fd = new FormData();
    fd.append('file', file);
    fd.append('formType', '1099-da');
    fd.append('taxYear', String(new URLSearchParams(location.search).get('year') ?? new Date().getFullYear() - 1));
    try {
      const r = await fetch('/api/yearEnd/1099/upload', { method: 'POST', body: fd });
      const j = await r.json();
      if (j.ok) {
        statusEl.className = 'upload-status ok';
        statusEl.textContent = `✓ ${j.rowCount} rows imported — ${j.reconciliation?.filter((x: {matchStatus:string}) => x.matchStatus === 'matched').length ?? 0} matched.`;
      } else {
        statusEl.className = 'upload-status err';
        statusEl.textContent = `✗ ${j.error ?? 'Upload failed'}`;
      }
    } catch {
      statusEl.className = 'upload-status err';
      statusEl.textContent = '✗ Network error — please try again.';
    }
  }

  // ── Delete exchange account ────────────────────────────────────────────────
  document.getElementById('exchange-list')?.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.del-account-btn');
    if (!btn) return;

    const accountId = btn.dataset.accountId!;
    const label     = btn.dataset.label ?? 'this account';

    if (!confirm(`Remove "${label}" and all its imported data?\n\nThis cannot be undone.`)) return;

    btn.disabled = true;
    btn.textContent = '…';

    try {
      const res  = await fetch(`/api/exchange-accounts/${accountId}`, { method: 'DELETE' });
      const data = await res.json();

      if (res.ok && data.ok) {
        // Fade out and remove the row
        const row = btn.closest<HTMLLIElement>('.sync-item');
        if (row) {
          row.style.transition = 'opacity 0.3s';
          row.style.opacity = '0';
          setTimeout(() => row.remove(), 320);
        }
      } else {
        alert(`Could not delete: ${data.error ?? 'unknown error'}`);
        btn.disabled = false;
        btn.textContent = '✕';
      }
    } catch {
      alert('Network error — please try again.');
      btn.disabled = false;
      btn.textContent = '✕';
    }
  });

  // ── Sync All — exchange snapshot + lifecycle rebuild, stays on page ──────────
  const syncBtn = document.getElementById('sync-all-btn') as HTMLButtonElement | null;
  syncBtn?.addEventListener('click', async () => {
    syncBtn.disabled = true;
    syncBtn.textContent = '⏳ Syncing…';

    try {
      // Step 1: pull latest exchange snapshots (CEX accounts)
      await fetch('/api/import/snapshot-all', { method: 'POST' });

      // Step 2: sync on-chain wallet balances + write wallet_snapshots
      // Long-running — race against a 90s timeout so we never block forever
      syncBtn.textContent = '⏳ Syncing wallets…';
      await Promise.race([
        fetch('/api/wallets/value/sync-all', { method: 'POST' }).catch(() => {}),
        new Promise(resolve => setTimeout(resolve, 90_000)),
      ]);

      // Step 3: rebuild FIFO lifecycle for this year
      syncBtn.textContent = '⏳ Rebuilding…';
      await fetch('/api/lifecycle/rebuild', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ year: selectedYear }),
      });

      syncBtn.textContent = '✓ Done';
      syncBtn.style.background = 'rgba(52,211,153,.25)';
      syncBtn.style.borderColor = 'rgba(52,211,153,.5)';
      syncBtn.style.color = '#6ee7b7';
      // Reload after a short pause so status dots + progress bar refresh
      setTimeout(() => window.location.reload(), 1200);
    } catch {
      syncBtn.textContent = '✗ Network error';
      syncBtn.disabled = false;
    }
  });
</script>
