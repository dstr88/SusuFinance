---
import PetroTinsLayout from '@/layouts/PetroTinsLayout.astro';
import Wordmark from '@/components/petro-tins/Wordmark.astro';
import SiteFooter from '@/components/petro-tins/SiteFooter.astro';
import { getAuthSession } from '@/lib/authSession';

const { searchParams } = Astro.url;
const error        = searchParams.get('error');
const callbackUrl  = '/dashboard/petro-tins';  // always land here after login
const safeCallback = callbackUrl;

const message =
  error === 'Configuration' ? 'Sign-in is temporarily unavailable. Please try again.' :
  error === 'OAuthAccountNotLinked' ? 'LOCKED_OUT' :
  error ? 'Sign-in failed. Please try again.' : '';

const session = await getAuthSession(Astro.request);
if (session?.user?.id) return Astro.redirect('/dashboard/petro-tins', 302);

let csrfToken = '';
try {
  const authBase = process.env.AUTH_URL
    ? (/^https?:\/\//i.test(process.env.AUTH_URL)
        ? process.env.AUTH_URL.replace(/\/$/, '')
        : `https://${process.env.AUTH_URL}`)
    : Astro.url.origin;
  const csrfRes = await fetch(`${authBase}/api/auth/csrf`, {
    headers: { cookie: Astro.request.headers.get('cookie') ?? '' },
  });
  if (csrfRes.ok) csrfToken = (await csrfRes.json())?.csrfToken ?? '';
} catch {}
---
<PetroTinsLayout
  title="PetroTins — Debt, Budget & Business P&L"
  description="Track every credit card, log your budget like a checkbook, and see your small business P&L — all in one place. No bank connection required."
  noindex
>
  <div class="pt-landing">
    <div class="pt-page">

      <!-- ── Left: hero ─────────────────────────────────────────── -->
      <div class="pt-left">
        <Wordmark sub="by Almstins" />

        <div class="pt-coming-soon">Early access</div>

        <h1 class="pt-hero__headline">
          The <em>real numbers</em><br/>behind your money.
        </h1>
        <p class="pt-hero__sub">
          Debt tins, a checkbook budget register, and small-business P&L —
          all in one place. No bank connection. No API keys. Pure math.
        </p>

        <div class="pt-features">
          <div class="pt-feature">
            <div class="pt-feature__icon">💳</div>
            <div>
              <div class="pt-feature__title">Debt Tins</div>
              <div class="pt-feature__desc">Track every credit card — balance, APR, daily interest cost, and utilization bar. Watch the number go down.</div>
            </div>
          </div>
          <div class="pt-feature">
            <div class="pt-feature__icon">📒</div>
            <div>
              <div class="pt-feature__title">Budget Register</div>
              <div class="pt-feature__desc">A checkbook-style register for your income and expenses. Running balance updates as you type.</div>
            </div>
          </div>
          <div class="pt-feature">
            <div class="pt-feature__icon">📈</div>
            <div>
              <div class="pt-feature__title">Business P&L</div>
              <div class="pt-feature__desc">Revenue minus expenses, month by month. Simple enough to actually use.</div>
            </div>
          </div>
          <div class="pt-feature">
            <div class="pt-feature__icon">🔐</div>
            <div>
              <div class="pt-feature__title">No bank connection. Ever.</div>
              <div class="pt-feature__desc">You enter the numbers. We do the math. Nothing connects to your bank.</div>
            </div>
          </div>
        </div>

        <div class="pt-privacy">
          <div class="pt-privacy__title">Your data is yours. Full stop.</div>
          <ul class="pt-privacy__list">
            <li>No bank login. No Plaid. No OAuth to your accounts.</li>
            <li>Your numbers are never sold, shared, or used for ads.</li>
            <li>You type the numbers in. We store them. That's the whole deal.</li>
            <li>Delete your account anytime — everything goes with it.</li>
          </ul>
        </div>

        <div class="pt-changelog">
          <div class="pt-changelog__title">Changelog</div>
          <div class="pt-changelog__list">
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">Jun 2026</span>
              <span class="pt-changelog__desc"><strong>Formula support</strong> — type =1200+150 in any amount field; evaluates live <span class="pt-changelog__new">New</span></span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">Jun 2026</span>
              <span class="pt-changelog__desc"><strong>Splits bill grid</strong> — add a bill and set each person's share in one form, with split-evenly and copy-to-all <span class="pt-changelog__new">New</span></span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">Jun 2026</span>
              <span class="pt-changelog__desc"><strong>Splits Tin</strong> — shared expense calculator with per-person assignments, partial payments, and carried balances</span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">May 2026</span>
              <span class="pt-changelog__desc"><strong>Slush Fund</strong> — simple balance card for tracking a shared pool of money</span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">May 2026</span>
              <span class="pt-changelog__desc"><strong>Budget Register</strong> — checkbook-style income and expense log with running balance</span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">May 2026</span>
              <span class="pt-changelog__desc"><strong>Debt Tins</strong> — track credit cards with APR math, utilization bar, and payment history</span>
            </div>
            <div class="pt-changelog__item">
              <span class="pt-changelog__date">May 2026</span>
              <span class="pt-changelog__desc"><strong>Cash Flow Summary</strong> — monthly income, expenses, and net in one panel</span>
            </div>
          </div>
          <p style="margin-top:0.75rem; font-size:0.72rem; color:var(--muted);">
            <a href="/petro-tins/docs" style="color:var(--pt); text-decoration:none;">Read the docs →</a>
          </p>
        </div>
      </div>

      <!-- ── Right: sign-in card ────────────────────────────────── -->
      <div class="pt-signin">
        <div>
          <div class="pt-signin__title">Sign in to PetroTins</div>
          <div class="pt-signin__sub">Your account works across PetroTins and Almstins — one login, both tools.</div>
        </div>

        {message && message !== 'LOCKED_OUT' && (
          <div class="pt-error">{message}</div>
        )}

        <!-- Google -->
        <form class="provider-form" method="POST" action="/api/auth/signin/google">
          <input type="hidden" name="callbackUrl" value={safeCallback} />
          <input type="hidden" name="csrfToken" value={csrfToken} />
          <button class="provider-btn" type="submit" disabled={!csrfToken || undefined}>
            <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="rgba(255,255,255,0.8)" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="rgba(255,255,255,0.6)" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="rgba(255,255,255,0.7)" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continue with Google
          </button>
        </form>

        <!-- GitHub -->
        <form class="provider-form" method="POST" action="/api/auth/signin/github">
          <input type="hidden" name="callbackUrl" value={safeCallback} />
          <input type="hidden" name="csrfToken" value={csrfToken} />
          <button class="provider-btn" type="submit" disabled={!csrfToken || undefined}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Continue with GitHub
          </button>
        </form>

        <div class="pt-divider">or</div>

        <!-- Email / password -->
        <form class="pt-email-form" method="POST" action="/api/auth/callback/credentials">
          <input type="hidden" name="callbackUrl" value={safeCallback} />
          <input type="hidden" name="csrfToken" value={csrfToken} />
          <input class="pt-input" type="email" name="email" placeholder="Email address" required autocomplete="email" />
          <input class="pt-input" type="password" name="password" placeholder="Password" required autocomplete="current-password" />
          <button class="pt-submit" type="submit">Sign in →</button>
        </form>

        <p class="pt-signin__note">
          No account yet? Just sign in — we'll create one automatically.<br/>
          <a href="/login">Looking for Almstins? →</a>
        </p>

        <div class="pt-demo-divider"><span>or</span></div>

        <a href="/api/petro-tins/demo" class="pt-demo-btn">
          ⛽ Try the demo
        </a>
      </div>

    </div>

    <SiteFooter />
  </div>

  <script is:inline>
    // Re-fetch CSRF if buttons are still disabled after load
    document.addEventListener('DOMContentLoaded', () => {
      const disabled = document.querySelectorAll('[data-needs-csrf]');
      if (!disabled.length) return;
      fetch('/api/auth/csrf').then(r => r.json()).then(d => {
        if (!d?.csrfToken) return;
        document.querySelectorAll('input[name="csrfToken"]').forEach(el => el.value = d.csrfToken);
        document.querySelectorAll('button[disabled]').forEach(el => el.removeAttribute('disabled'));
      }).catch(() => {});
    });
  </script>
</PetroTinsLayout>

<style>
  /* Landing-specific styles. Tokens, reset, body, wordmark, and footer are shared
     (petro-tins.css + components), so only the hero / sign-in chrome lives here. */
  .pt-landing {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .pt-page {
    width: 100%;
    max-width: 960px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 720px) {
    .pt-page { grid-template-columns: 1fr 380px; gap: 4rem; align-items: center; }
  }

  /* ── Hero copy ── */
  .pt-hero__headline {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .pt-hero__headline em { font-style: normal; color: var(--pt); }
  .pt-hero__sub {
    font-size: 1rem;
    color: var(--sub);
    line-height: 1.6;
    max-width: 480px;
    margin-bottom: 2rem;
  }

  /* ── Feature list ── */
  .pt-features { display: flex; flex-direction: column; gap: 1rem; }
  .pt-feature { display: flex; align-items: flex-start; gap: 0.875rem; }
  .pt-feature__icon {
    width: 34px; height: 34px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .pt-feature__title { font-size: 0.9rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem; }
  .pt-feature__desc { font-size: 0.8rem; color: var(--muted); line-height: 1.5; }

  /* ── Privacy block ── */
  .pt-privacy {
    margin-top: 1.75rem;
    background: rgba(245,158,11,0.06);
    border: 1px solid rgba(245,158,11,0.18);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }
  .pt-privacy__title { font-size: 0.82rem; font-weight: 700; color: var(--pt); margin-bottom: 0.6rem; letter-spacing: 0.01em; }
  .pt-privacy__list { list-style: none; display: flex; flex-direction: column; gap: 0.35rem; }
  .pt-privacy__list li { font-size: 0.78rem; color: var(--sub); padding-left: 1.1rem; position: relative; line-height: 1.45; }
  .pt-privacy__list li::before { content: '✓'; position: absolute; left: 0; color: var(--pt); font-weight: 700; }

  /* ── Coming-soon ribbon ── */
  .pt-coming-soon {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--pt-soft);
    border: 1px solid var(--pt-glow);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--pt);
    margin: 2rem 0 1.5rem;  /* top margin replaces the old wordmark margin-bottom */
  }
  .pt-coming-soon::before { content: '⚗️'; font-size: 0.85rem; }

  /* ── Sign-in card ── */
  .pt-signin {
    background: var(--card);
    border: 1px solid var(--border-hi);
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
  }
  .pt-signin__title { font-size: 1.1rem; font-weight: 700; color: var(--text); margin-bottom: 0.25rem; }
  .pt-signin__sub { font-size: 0.8rem; color: var(--muted); line-height: 1.5; margin-bottom: 0.5rem; }
  .pt-signin__note { font-size: 0.75rem; color: var(--muted); text-align: center; padding-top: 0.25rem; line-height: 1.5; }
  .pt-signin__note a { color: var(--pt); text-decoration: none; }
  .pt-signin__note a:hover { text-decoration: underline; }

  /* Provider buttons */
  .provider-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.7rem 1rem;
    border-radius: 9px;
    border: 1px solid var(--border-hi);
    background: var(--card-2);
    color: var(--text);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
    text-align: left;
  }
  .provider-btn:hover { background: #1a1f2e; border-color: var(--pt-glow); }
  .provider-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .provider-btn svg { flex-shrink: 0; }
  .provider-form { width: 100%; }

  /* Divider */
  .pt-divider { display: flex; align-items: center; gap: 0.75rem; color: var(--muted); font-size: 0.75rem; }
  .pt-divider::before, .pt-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }

  /* Email form */
  .pt-email-form { display: flex; flex-direction: column; gap: 0.75rem; }
  .pt-input {
    width: 100%;
    background: var(--card-2);
    border: 1px solid var(--border-hi);
    border-radius: 8px;
    padding: 0.6rem 0.875rem;
    color: var(--text);
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s;
  }
  .pt-input:focus { border-color: var(--pt); }
  .pt-input::placeholder { color: var(--muted); }
  .pt-submit {
    width: 100%;
    background: var(--pt);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    padding: 0.7rem 1rem;
    font-size: 0.875rem;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .pt-submit:hover { opacity: 0.88; }

  .pt-error {
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.25);
    border-radius: 8px;
    padding: 0.6rem 0.875rem;
    font-size: 0.8rem;
    color: #fca5a5;
  }
  .pt-demo-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(245,248,255,0.3);
    font-size: 0.75rem;
    margin: 0.25rem 0;
  }
  .pt-demo-divider::before, .pt-demo-divider::after { content: ''; flex: 1; border-top: 1px solid rgba(245,248,255,0.1); }
  .pt-demo-btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.65rem 1rem;
    border: 1px solid var(--pt-glow);
    border-radius: 8px;
    background: var(--pt-soft);
    color: var(--pt);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }
  .pt-demo-btn:hover { background: rgba(245,158,11,0.2); border-color: var(--pt); }

  /* ── Changelog ── */
  .pt-changelog { margin-top: 2rem; }
  .pt-changelog__title { font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 0.75rem; }
  .pt-changelog__list { display: flex; flex-direction: column; gap: 0.6rem; }
  .pt-changelog__item { display: flex; align-items: baseline; gap: 0.75rem; font-size: 0.78rem; line-height: 1.45; }
  .pt-changelog__date { font-size: 0.7rem; color: var(--muted); white-space: nowrap; font-variant-numeric: tabular-nums; min-width: 60px; }
  .pt-changelog__desc { color: var(--sub); }
  .pt-changelog__desc strong { color: var(--text); font-weight: 600; }
  .pt-changelog__new {
    display: inline-block;
    background: var(--pt-soft);
    border: 1px solid var(--pt-glow);
    color: var(--pt);
    border-radius: 4px;
    padding: 1px 5px;
    font-size: 0.62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    vertical-align: middle;
    margin-left: 0.35rem;
  }
</style>
