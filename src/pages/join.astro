---
// /onboarding/join — the self-serve way in. "Someone logs in, names their sponsor
// and group" (§5a). She fills it in, and a candidacy opens; her sponsor's yes admits
// her (sponsor-yes v1). Until then she is a candidate and sees nothing of the circle.
//
// A tenant-less login lands here — she is not in any programme yet. So it uses
// getAuthSession (not requireTenantSession), and posts to /api/circles/join-request,
// which resolves the typed names to ids against the one programme.
import LoginLayout from '../layouts/LoginLayout.astro';
import { getAuthSession } from '@/lib/authSession';
import { langFromCookieHeader } from '@/lib/i18n/locale';

const auth = await getAuthSession(Astro.request).catch(() => null);
if (!auth?.user?.id) return Astro.redirect('/login?next=/join');

const lang = langFromCookieHeader(Astro.request.headers.get('cookie'));

const COPY: Record<string, Record<string, string>> = {
  en: {
    title: 'Ask to join a group',
    intro: 'Tell us who you are, which group you are joining, and who invited you. Your sponsor confirms, and you are in.',
    username: 'Your name in the group', usernameHint: 'What the group will call you.',
    group: 'Group name', groupHint: 'The circle you are joining.',
    sponsor: 'Who invited you', sponsorHint: 'The member who is bringing you in.',
    submit: 'Ask to join', sending: 'Sending…',
    pendingTitle: 'Sent', pendingBody: (s: string) => `Your request is with ${s}. Once she confirms, you are in the group.`,
    back: 'Back to the lobby',
    e_missing_fields: 'Please fill in all three.',
    e_group_not_found: 'No group by that name. Check the spelling with your sponsor.',
    e_sponsor_not_found: 'No member by that name in that group. Check the spelling.',
    e_sponsor_ambiguous: 'More than one member has that name. Ask your sponsor for her invite code.',
    e_already_member: 'You are already in that group.',
    e_already_pending: 'You have already asked — it is waiting for her.',
    e_generic: 'That did not send. Try again.',
  },
  fr: {
    title: 'Demander à rejoindre un groupe',
    intro: 'Dites-nous qui vous êtes, quel groupe vous rejoignez, et qui vous a invitée. Votre parrain confirme, et vous y êtes.',
    username: 'Votre nom dans le groupe', usernameHint: 'Le nom que le groupe utilisera.',
    group: 'Nom du groupe', groupHint: 'Le cercle que vous rejoignez.',
    sponsor: 'Qui vous a invitée', sponsorHint: 'Le membre qui vous fait entrer.',
    submit: 'Demander à rejoindre', sending: 'Envoi…',
    pendingTitle: 'Envoyé', pendingBody: (s: string) => `Votre demande est chez ${s}. Dès qu’elle confirme, vous êtes dans le groupe.`,
    back: 'Retour au hall',
    e_missing_fields: 'Veuillez remplir les trois champs.',
    e_group_not_found: 'Aucun groupe de ce nom. Vérifiez l’orthographe avec votre parrain.',
    e_sponsor_not_found: 'Aucun membre de ce nom dans ce groupe. Vérifiez l’orthographe.',
    e_sponsor_ambiguous: 'Plusieurs membres portent ce nom. Demandez son code d’invitation.',
    e_already_member: 'Vous êtes déjà dans ce groupe.',
    e_already_pending: 'Vous avez déjà demandé — c’est en attente chez elle.',
    e_generic: 'L’envoi a échoué. Réessayez.',
  },
  es: {
    title: 'Pedir unirse a un grupo',
    intro: 'Díganos quién es, a qué grupo se une y quién la invitó. Su padrino lo confirma y ya está dentro.',
    username: 'Su nombre en el grupo', usernameHint: 'Cómo la llamará el grupo.',
    group: 'Nombre del grupo', groupHint: 'El círculo al que se une.',
    sponsor: 'Quién la invitó', sponsorHint: 'La integrante que la trae.',
    submit: 'Pedir unirse', sending: 'Enviando…',
    pendingTitle: 'Enviado', pendingBody: (s: string) => `Su solicitud está con ${s}. Cuando confirme, estará en el grupo.`,
    back: 'Volver al vestíbulo',
    e_missing_fields: 'Por favor complete los tres campos.',
    e_group_not_found: 'No hay ningún grupo con ese nombre. Verifique con su padrino.',
    e_sponsor_not_found: 'No hay integrante con ese nombre en ese grupo. Verifique la ortografía.',
    e_sponsor_ambiguous: 'Más de una integrante tiene ese nombre. Pida su código de invitación.',
    e_already_member: 'Ya está en ese grupo.',
    e_already_pending: 'Ya lo pidió — está esperando su confirmación.',
    e_generic: 'No se envió. Inténtelo de nuevo.',
  },
};
const t = COPY[lang] ?? COPY.en;
---

<LoginLayout title={t.title} noindex={true} lang={lang}>
  <section class="jn">
    <div class="jn-card" id="jn-form-card">
      <h1 class="jn-title">{t.title}</h1>
      <p class="jn-intro">{t.intro}</p>

      <form id="jn-form" class="jn-fields">
        <label class="jn-field">
          <span class="jn-label">{t.username}</span>
          <input type="text" name="username" required maxlength="60" autocomplete="off" />
          <span class="jn-fieldhint">{t.usernameHint}</span>
        </label>
        <label class="jn-field">
          <span class="jn-label">{t.group}</span>
          <input type="text" name="groupName" required maxlength="120" autocomplete="off" />
          <span class="jn-fieldhint">{t.groupHint}</span>
        </label>
        <label class="jn-field">
          <span class="jn-label">{t.sponsor}</span>
          <input type="text" name="sponsorName" required maxlength="60" autocomplete="off" />
          <span class="jn-fieldhint">{t.sponsorHint}</span>
        </label>
        <p class="jn-error" id="jn-error" hidden></p>
        <button type="submit" class="jn-submit" id="jn-submit">{t.submit}</button>
      </form>
    </div>

    <div class="jn-card jn-card--done" id="jn-done-card" hidden>
      <h1 class="jn-title">{t.pendingTitle}</h1>
      <p class="jn-intro" id="jn-done-body"></p>
      <a class="jn-link" href="/dashboard/lobby">{t.back}</a>
    </div>
  </section>
</LoginLayout>

<script is:inline define:vars={{ t }}>
  const form = document.getElementById('jn-form');
  const errEl = document.getElementById('jn-error');
  const submit = document.getElementById('jn-submit');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.hidden = true;
    submit.disabled = true;
    const orig = submit.textContent;
    submit.textContent = t.sending;
    const fd = new FormData(form);
    try {
      const res = await fetch('/api/circles/join-request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          username: fd.get('username'),
          groupName: fd.get('groupName'),
          sponsorName: fd.get('sponsorName'),
        }),
      });
      const j = await res.json().catch(() => ({}));
      if (j && j.ok) {
        document.getElementById('jn-form-card').hidden = true;
        document.getElementById('jn-done-body').textContent = t.pendingBody(j.sponsorName || fd.get('sponsorName'));
        document.getElementById('jn-done-card').hidden = false;
        return;
      }
      const key = 'e_' + (j && j.error ? j.error : 'generic');
      errEl.textContent = t[key] || t.e_generic;
      errEl.hidden = false;
    } catch {
      errEl.textContent = t.e_generic;
      errEl.hidden = false;
    } finally {
      submit.disabled = false;
      submit.textContent = orig;
    }
  });
</script>

<style>
  .jn { min-height: 70svh; display: flex; align-items: center; justify-content: center; padding: 2rem 1.25rem; }
  .jn-card { max-width: 30rem; width: 100%; background: var(--surface-card); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 2rem 1.75rem; }
  .jn-card--done { text-align: center; border-color: var(--accent-soft); }
  .jn-title { margin: 0 0 0.6rem; font-size: 1.4rem; font-weight: 700; color: var(--text-primary); }
  .jn-intro { margin: 0 0 1.5rem; font-size: 0.85rem; color: var(--text-secondary); line-height: 1.6; }
  .jn-fields { display: flex; flex-direction: column; gap: 1rem; }
  .jn-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .jn-label { font-size: 0.8rem; font-weight: 600; color: var(--text-primary); }
  .jn-field input {
    min-height: 44px; padding: 0.5rem 0.75rem; border-radius: 8px;
    border: 1px solid var(--border-bright); background: var(--surface-card-2);
    color: var(--text-primary); font-size: 0.9rem; font-family: inherit;
  }
  .jn-field input:focus-visible { outline: 2px solid var(--accent); outline-offset: 1px; }
  .jn-fieldhint { font-size: 0.72rem; color: var(--text-muted); }
  .jn-error { margin: 0; padding: 0.5rem 0.75rem; border-radius: 8px; border: 1px solid var(--loss-border); background: var(--loss-bg); color: var(--loss); font-size: 0.8rem; }
  .jn-submit {
    min-height: 44px; margin-top: 0.5rem; padding: 0.7rem 1.4rem; border-radius: 999px; border: none;
    background: var(--accent); color: var(--surface-bg); font-size: 0.9rem; font-weight: 700; cursor: pointer;
  }
  .jn-submit:disabled { opacity: 0.6; cursor: default; }
  .jn-submit:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .jn-link { display: inline-block; margin-top: 1rem; font-size: 0.8rem; color: var(--text-muted); text-decoration: none; }
  .jn-link:hover { color: var(--accent); }
</style>
