---
// /dashboard/circles — the operator vault.
//
// A vault of contract tins: each card one contract, a rotating circle or a
// targeted savings group. Drill-in (the member table) is the next slice.
//
// A new route rather than a refit of vault.astro: the Almstins surfaces are dead
// scaffolding awaiting the feature strip, and building the circle layer clean lets
// them be removed together instead of being untangled from live code.
//
// All stats within-tenant. No cross-tenant benchmarks, ever.
import Layout from '../../layouts/Layout.astro';
import ContractTinsGrid from '../../components/circles/ContractTinsGrid';
import { db } from '@/lib/db';
import { requireTenantSession } from '@/lib/requireTenantSession';
import { getAuthSession } from '@/lib/authSession';
import { getCirclesLocale } from '@/i18n/dashboard/circles';
import { langFromCookieHeader } from '@/lib/i18n/locale';

const session = await requireTenantSession(Astro.request);
if (!session) return Astro.redirect('/login?next=/dashboard/circles');

const lang = langFromCookieHeader(Astro.request.headers.get('cookie'));
const t = getCirclesLocale(lang);

// Only the operator sees "New circle" — creation is owner/admin (the endpoint
// re-checks). A member viewing the grid does not get the control.
const auth = await getAuthSession(Astro.request).catch(() => null);
const uid = auth?.user?.id ? String(auth.user.id) : '';
let isAdmin = false;
if (uid) {
  const r = await db.execute({ sql: `SELECT role FROM tenant_memberships WHERE tenant_id = ? AND user_id = ? LIMIT 1`, args: [session.tenantId, uid] });
  const role = r.rows[0] ? String((r.rows[0] as any).role ?? '') : '';
  isAdmin = role === 'owner' || role === 'admin';
}
const newCircleLabel = lang === 'fr' ? '+ Nouveau cercle' : lang === 'es' ? '+ Nuevo círculo' : '+ New circle';
---

<Layout title={`${t.page.title} | SusuFinance`} noindex={true}>
  <section class="ct-page">
    <header class="ct-page__head">
      <div class="ct-page__headrow">
        <div>
          <h1 class="ct-page__title">{t.page.title}</h1>
          <p class="ct-page__sub">{t.page.subtitle}</p>
        </div>
        <div class="ct-page__headactions">
          {isAdmin && <a class="ct-page__newlink" href="/dashboard/circles/new">{newCircleLabel}</a>}
          <a class="ct-page__statslink" href="/dashboard/circles/stats">{t.stats.title} →</a>
        </div>
      </div>
    </header>

    {/* `lang`, not `t`: Astro serializes island props to JSON and would drop the
        locale's interpolation functions. The component resolves its own locale. */}
    <ContractTinsGrid client:load lang={lang} />
  </section>
</Layout>

<style>
  .ct-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 1rem 4rem;
  }
  .ct-page__head { margin-bottom: 1.75rem; }
  .ct-page__headrow {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ct-page__headactions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .ct-page__newlink {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--accent-soft);
    border-radius: 999px;
    background: var(--accent-soft);
  }
  .ct-page__newlink:hover { background: var(--accent-glow); }
  .ct-page__statslink {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    text-decoration: none;
    white-space: nowrap;
    padding-top: 0.35rem;
  }
  .ct-page__statslink:hover { color: var(--accent); }
  .ct-page__title {
    margin: 0 0 0.3rem;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .ct-page__sub {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  @media (min-width: 768px) {
    .ct-page { padding: 2.5rem 2rem 5rem; }
  }
</style>
