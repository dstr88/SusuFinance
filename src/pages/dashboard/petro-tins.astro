    // ── Delete entry ───────────────────────────────────────────────────────────
    async function deleteEntry(entryId) {
      await fetch('/api/petro-tins/entries', {
        method: 'DELETE',
        headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ entryId }),
      });
      await loadTins();
