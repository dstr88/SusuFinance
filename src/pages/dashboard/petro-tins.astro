    .dt-tin__entry-del:hover { color: var(--loss); }
    .dt-tin__no-entries { font-size: 0.8rem; color: var(--text-muted); padding: 0.25rem 0; }

    /* Add entry button at bottom of tin */
    .dt-tin__footer {
      padding: 0.5rem 1rem 0.875rem;
      display: flex;
      gap: 0.5rem;
    }
    .dt-add-entry-btn {
      background: var(--accent-soft);
      border: 1px solid var(--accent-glow);
      color: var(--accent);
      border-radius: 6px;
      padding: 0.35rem 0.85rem;
      font-size: 0.78rem;
      cursor: pointer;
      transition: background 0.15s;
    }
    .dt-add-entry-btn:hover { background: var(--accent-glow); }

    /* Modal */
    .dt-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.6);
      z-index: 1000;
