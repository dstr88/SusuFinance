      const tin = _tins.find(t => t.id === tinId);
      if (!tin) return;
      if (!confirm(`Delete "${tin.name}"? This cannot be undone.`)) return;
      await fetch(`/api/petro-tins/${tinId}`, { method: 'DELETE' });
      await loadTins();
      window.dispatchEvent(new Event('petro-tins-changed'));
    }
    window.deleteTin = deleteTin;

