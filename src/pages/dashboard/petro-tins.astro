    /* Saved indicator flash */
    @keyframes rowSaved { 0%{background:var(--gain-bg)} 100%{background:transparent} }
    .dt-reg-saved.just-saved { animation: rowSaved 1.2s ease forwards; }

    /* Accordion / entry list */
    .dt-tin__accordion {
      border-top: 1px solid var(--border-subtle);
    }
    .dt-tin__accordion-toggle {
      width: 100%;
      background: none;
      border: none;
      padding: 0.6rem 1rem;
      display: flex;
      justify-content: space-between;
