    }
    .dt-tin__accordion-toggle:hover { background: var(--surface-hover); }
    .dt-tin__accordion-toggle .chevron { transition: transform 0.2s; }
    .dt-tin__accordion-toggle[aria-expanded="true"] .chevron { transform: rotate(180deg); }

    .dt-tin__entries {
      padding: 0 1rem 0.75rem;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      max-height: 220px;
      overflow-y: auto;
    }
    .dt-tin__entry {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      font-size: 0.8rem;
      padding: 0.3rem 0;
      border-bottom: 1px solid var(--border-subtle);
      gap: 0.5rem;
    }
    .dt-tin__entry:last-child { border-bottom: none; }
    .dt-tin__entry-left { display: flex; flex-direction: column; gap: 2px; }
    .dt-tin__entry-kind {
      font-size: 0.65rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--text-muted);
    }
    .dt-tin__entry-desc { color: var(--text-secondary); }
    .dt-tin__entry-date { color: var(--text-muted); font-size: 0.7rem; }
    .dt-tin__entry-amount { font-weight: 600; flex-shrink: 0; }
    .dt-tin__entry-amount.payment  { color: var(--gain); }
    .dt-tin__entry-amount.charge   { color: var(--loss); }
    .dt-tin__entry-amount.income   { color: var(--gain); }
    .dt-tin__entry-amount.expense  { color: var(--loss); }
    .dt-tin__entry-del {
      background: none; border: none; cursor: pointer;
      color: var(--text-muted); font-size: 0.75rem; padding: 0 4px;
      flex-shrink: 0;
