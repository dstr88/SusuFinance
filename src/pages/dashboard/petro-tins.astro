    .dt-tin__progress-fill--debt     { background: var(--loss); }
    .dt-tin__progress-fill--business { background: var(--gain); }
    .dt-tin__progress-labels {
      display: flex;
      justify-content: space-between;
      font-size: 0.7rem;
