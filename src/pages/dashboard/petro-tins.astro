    // ── Register row auto-save ────────────────────────────────────────────────
    function bindRegisterRow(row) {
      const tinId   = row.dataset.tinId;
      const dateI   = row.querySelector('.dt-reg-date-i');
      const descI   = row.querySelector('.dt-reg-desc-i');
      const payI    = row.querySelector('.dt-reg-pay-i');
      const depI    = row.querySelector('.dt-reg-dep-i');
      const balCell = row.querySelector('.col-bal');

      // Live balance preview as user types
      function previewBalance() {
        const pay = parseFloat(payI.value) || 0;
        const dep = parseFloat(depI.value) || 0;
        if (!pay && !dep) { balCell.textContent = '—'; return; }
        // Find running balance of last saved row
        const tbody = row.closest('tbody');
        const saved = [...tbody.querySelectorAll('.dt-reg-saved')];
        const lastBal = saved.length
          ? parseFloat(saved[saved.length-1].querySelector('.col-bal').dataset.raw ?? 0)
          : 0;
        const preview = lastBal + dep - pay;
        balCell.textContent = fmt(preview);
        balCell.style.color = preview >= 0 ? 'var(--gain)' : 'var(--loss)';
      }
      payI.addEventListener('input', previewBalance);
      depI.addEventListener('input', previewBalance);

      // Mutually exclusive: filling payment clears deposit and vice versa
      payI.addEventListener('input', () => { if (payI.value) depI.value = ''; });
      depI.addEventListener('input', () => { if (depI.value) payI.value = ''; });

      async function trySave() {
        const date = dateI.value;
        const desc = descI.value.trim();
        const pay  = parseFloat(payI.value);
        const dep  = parseFloat(depI.value);
        if (!date || !desc) return;
        if (!pay && !dep) return;

        const kind   = dep > 0 ? 'income' : 'expense';
        const amount = dep > 0 ? dep : pay;

        // Disable row while saving
        [dateI, descI, payI, depI].forEach(el => el.disabled = true);

        await fetch('/api/petro-tins/entries', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tinId, kind, amount, entryDate: date, description: desc }),
        });

        await loadTins();  // re-render — the blank rows repopulate with fresh data
      }

      // Save on Enter in any field
      [dateI, descI, payI, depI].forEach(el => {
        el.addEventListener('keydown', e => { if (e.key === 'Enter') trySave(); });
      });
      // Save on blur out of the row
      [payI, depI].forEach(el => {
        el.addEventListener('blur', () => {
          setTimeout(() => {
            if (!row.contains(document.activeElement)) trySave();
          }, 120);
        });
      });
    }

    // ── Monthly bills check-in ─────────────────────────────────────────────────
    function buildMonthlyCheckin() {
      const panel  = document.getElementById('dt-monthly-panel');
      const body   = document.getElementById('dt-monthly-body');
      const meta   = document.getElementById('dt-monthly-meta');
      const toggle = document.getElementById('dt-monthly-toggle');
      const chev   = document.getElementById('dt-monthly-chevron');
      if (!panel || !body) return;

      const now       = new Date();
      const today     = now.getDate();
      const thisMonth = now.toISOString().slice(0, 7);           // YYYY-MM
      const lastMonth = new Date(now.getFullYear(), now.getMonth() - 1, 1).toISOString().slice(0, 7);

      // Collect last month's expense entries across all budget tins
      // Also collect last month's payment entries across all debt tins
      const rows = [];
      for (const tin of _tins) {
        const isDebt   = tin.type === 'debt';
        const isBudget = tin.type === 'budget';
        if (!isDebt && !isBudget) continue;

        const targetKind = isDebt ? 'payment' : 'expense';
        const lastEntries = (tin.entries ?? []).filter(e =>
          e.entryDate.startsWith(lastMonth) && e.kind === targetKind
        );

        // Deduplicate by description within this tin
        const seen = new Map();
        for (const e of lastEntries) {
          const key = (e.description ?? '').toLowerCase().trim() || `__unnamed_${e.id}`;
          if (!seen.has(key) || e.amount > seen.get(key).amount) seen.set(key, e);
        }

        for (const e of seen.values()) {
          rows.push({ tinId: tin.id, tinName: tin.name, kind: targetKind, description: e.description ?? '', lastAmount: e.amount });
        }
      }

      if (!rows.length) { panel.style.display = 'none'; return; }

      panel.style.display = '';
      if (meta) meta.textContent = `${rows.length} recurring item${rows.length === 1 ? '' : 's'} from last month`;

      // Auto-open on the 1st of the month
      const autoOpen = (today === 1);
      if (autoOpen) {
        toggle.setAttribute('aria-expanded', 'true');
        body.style.display = 'flex';
        chev.classList.add('open');
      }

      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        body.style.display = expanded ? 'none' : 'flex';
        chev.classList.toggle('open', !expanded);
      });

      // Check if any of these have already been logged this month
      const loggedThisMonth = new Set();
      for (const tin of _tins) {
        for (const e of (tin.entries ?? [])) {
          if (e.entryDate.startsWith(thisMonth)) {
            loggedThisMonth.add(`${tin.id}::${(e.description ?? '').toLowerCase().trim()}`);
          }
        }
      }

      body.innerHTML = rows.length ? rows.map((row, idx) => {
        const alreadyLogged = loggedThisMonth.has(`${row.tinId}::${row.description.toLowerCase().trim()}`);
        return `
          <div class="dt-monthly-row${alreadyLogged ? ' logged' : ''}" id="dt-mrow-${idx}" data-idx="${idx}" data-tin-id="${row.tinId}" data-kind="${row.kind}" data-last="${row.lastAmount}" data-desc="${escHtml(row.description)}">
            <label class="dt-monthly-check" title="Check to use last month&#39;s amount">
              <input type="checkbox" class="dt-mrow-chk" data-idx="${idx}" ${alreadyLogged ? '' : 'checked'} />
              <span class="dt-monthly-desc">${escHtml(row.description || '(no description)')}</span>
            </label>
            <span class="dt-monthly-tin-name">${escHtml(row.tinName)}</span>
            <input type="number" class="dt-monthly-amount-input dt-mrow-amt" data-idx="${idx}"
              value="${row.lastAmount.toFixed(2)}" step="0.01" min="0.01"
              ${alreadyLogged ? 'disabled' : ''} />
            ${alreadyLogged
              ? '<span class="dt-monthly-logged-badge">✓ Logged</span>'
              : `<button class="dt-monthly-log-btn dt-mrow-btn" data-idx="${idx}">✓ Log</button>`}
          </div>`;
      }).join('') : '<div class="dt-monthly-empty">No recurring bills from last month.</div>';

      // Wire up interactions
      body.querySelectorAll('.dt-mrow-btn').forEach(btn => {
        btn.addEventListener('click', () => logMonthlyRow(parseInt(btn.dataset.idx), rows));
      });
      // Enter key on amount field triggers log
      body.querySelectorAll('.dt-mrow-amt').forEach(input => {
        input.addEventListener('keydown', e => {
          if (e.key === 'Enter') logMonthlyRow(parseInt(input.dataset.idx), rows);
        });
      });
    }

    async function logMonthlyRow(idx, rows) {
      const row      = rows[idx];
      const rowEl    = document.getElementById(`dt-mrow-${idx}`);
      const amtInput = rowEl?.querySelector('.dt-mrow-amt');
      const amount   = parseFloat(amtInput?.value ?? row.lastAmount);
      if (!amount || amount <= 0) { amtInput?.focus(); return; }

      const today = new Date().toISOString().slice(0, 10);
      await fetch('/api/petro-tins/entries', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ tinId: row.tinId, kind: row.kind, amount, entryDate: today, description: row.description || null }),
      });

      // Mark row as logged without full reload
      if (rowEl) {
        rowEl.classList.add('logged');
        const btn = rowEl.querySelector('.dt-mrow-btn');
        if (btn) btn.outerHTML = '<span class="dt-monthly-logged-badge">✓ Logged</span>';
        if (amtInput) amtInput.disabled = true;
      }

      // Refresh tin data silently
      try {
        const res = await fetch('/api/petro-tins');
        const data = await res.json();
        _tins = data.tins ?? [];
        renderSummary();
        renderAll();
      } catch {}
    }

    // ── Add tin buttons ────────────────────────────────────────────────────────
    document.querySelectorAll('.dt-add-btn').forEach(btn => {
      btn.addEventListener('click', () => openAddTin(btn.dataset.addType));
    });

    // ── Close modals on overlay click ──────────────────────────────────────────
    ['dt-modal', 'dt-entry-modal', 'dt-splits-modal'].forEach(modalId => {
      const modalEl = document.getElementById(modalId);
      if (modalEl) {
        modalEl.addEventListener('click', e => {
          if (e.target.id === modalId) e.target.style.display = 'none';
        });
        // Prevent backspace from closing modal when typing in inputs
        modalEl.addEventListener('keydown', e => {
          if (e.key === 'Backspace' && (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement)) {
            e.stopPropagation();
          }
        });
      }
    });

    // ── Load sample data ───────────────────────────────────────────────────────
    document.getElementById('dt-load-sample')?.addEventListener('click', async () => {
      const btn = document.getElementById('dt-load-sample');
      if (btn) btn.textContent = 'Loading…';
      const res = await fetch('/api/petro-tins/seed', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
      if (res.ok) {
        await loadTins();
      } else {
        const data = await res.json().catch(() => ({}));
        alert(data.error ?? 'Could not load sample data.');
        if (btn) btn.textContent = 'Load sample data →';
      }
    });

    document.getElementById('dt-sample-dismiss')?.addEventListener('click', () => {
      const banner = document.getElementById('dt-sample-banner');
      if (banner) banner.style.display = 'none';
    });

    // ── Page timer ─────────────────────────────────────────────────────────────
    (function() {
      const start = Date.now();
      const el = document.getElementById('dt-page-timer');
      if (!el) return;
      setInterval(() => {
        const s = Math.floor((Date.now() - start) / 1000);
        const m = Math.floor(s / 60);
        const ss = String(s % 60).padStart(2, '0');
        el.textContent = `${m}:${ss}`;
      }, 1000);
    })();

    // ── Visit logger (non-owner only) ─────────────────────────────────────────
    (function() {
      const start = Date.now();
      if (window.__petroOwner) return;
      function logVisit() {
        const duration = Math.round((Date.now() - start) / 1000);
        navigator.sendBeacon('/api/petro-tins/visit', JSON.stringify({ duration }));
      }
      window.addEventListener('pagehide', logVisit);
      window.addEventListener('beforeunload', logVisit);
    })();

    // ── Boot ───────────────────────────────────────────────────────────────────
    loadTins();
  </script>
</Layout>
