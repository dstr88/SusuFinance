    }
    .dt-reg-input::placeholder { color: var(--text-muted); opacity: 1; }
    .dt-reg-input.col-amt-input { text-align: right; font-variant-numeric: tabular-nums; }
    .dt-reg-input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(0.7); cursor: pointer; }
    .dt-reg-blank td.col-bal { text-align: right; color: var(--text-muted); font-size: 0.78rem; padding-right: 0.75rem; }
