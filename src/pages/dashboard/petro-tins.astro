      background: var(--surface-card-2);
      border: 1px solid var(--border-bright);
      border-radius: 14px;
      padding: 1.5rem;
      width: 100%;
      max-width: 440px;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .dt-modal h2 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-primary);
      margin: 0;
    }
    .dt-label {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .dt-optional { color: var(--text-muted); font-size: 0.75rem; }
    .dt-input {
      background: var(--surface-card);
      border: 1px solid var(--border-bright);
      border-radius: 7px;
      padding: 0.5rem 0.75rem;
      color: var(--text-primary);
      font-size: 0.9rem;
      width: 100%;
      box-sizing: border-box;
    }
    .dt-input:focus { outline: 2px solid var(--accent-glow); border-color: var(--accent); }
    #dt-modal-form, #dt-entry-form {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }
    .dt-fields-debt, .dt-fields-business {
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }
    .dt-modal-actions {
      display: flex;
      gap: 0.75rem;
      justify-content: flex-end;
      margin-top: 0.25rem;
    }
    .dt-btn-primary {
      background: var(--accent);
      color: var(--surface-bg);
      border: none;
      border-radius: 7px;
      padding: 0.5rem 1.25rem;
      font-size: 0.875rem;
      font-weight: 600;
      cursor: pointer;
    }
    .dt-btn-primary:hover { opacity: 0.9; }
    .dt-btn-ghost {
      background: none;
      border: 1px solid var(--border-bright);
      color: var(--text-secondary);
      border-radius: 7px;
      padding: 0.5rem 1.1rem;
      font-size: 0.875rem;
      cursor: pointer;
    }
    .dt-btn-ghost:hover { background: var(--surface-hover); }

    /* Splits modal extras */
    .dt-splits-modal-desc {
      font-size: 0.85rem;
      color: var(--text-secondary);
      margin: -0.5rem 0 0;
      line-height: 1.5;
    }
    .dt-input--bright {
      background: var(--surface-hover);
      border-color: var(--text-secondary);
      color: var(--text-primary);
      font-size: 0.95rem;
    }
    .dt-input--bright::placeholder { color: var(--text-muted); }
    .dt-input--bright:focus { border-color: var(--text-primary); outline: 2px solid var(--accent-glow); }
  </style>

  <script is:inline define:vars={{ isOwner }}>
    window.__petroOwner = isOwner;
  </script>
  <script is:inline>
    // ── Utilities ──────────────────────────────────────────────────────────────
    const $ = (sel, ctx = document) => ctx.querySelector(sel);
    const $$ = (sel, ctx = document) => [...ctx.querySelectorAll(sel)];
    const fmt  = n => '$' + Number(n).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const fmtPct = n => (Number(n) * 100).toFixed(2) + '%';

    let _tins = [];

    // Sort state: { tinId: { column: 'date'|'amount'|'checked', direction: 'asc'|'desc' } }
    const _sortState = {};

    // ── Load tins from API ─────────────────────────────────────────────────────
    async function loadTins() {
      try {
        const res = await fetch('/api/petro-tins');
        const data = await res.json();
        _tins = data.tins ?? [];
      } catch { _tins = []; }
      renderAll();
      buildMonthlyCheckin();
    }

    // ── Summaries ──────────────────────────────────────────────────────────────
    function computeSummary() {
      let totalDebt = 0, monthlyInterest = 0, annualInterest = 0;
      let totalIncome = 0, totalExpense = 0;
      const now = new Date();
      const thisMonth = now.toISOString().slice(0, 7); // YYYY-MM

      for (const tin of _tins) {
        if (tin.type === 'debt') {
          const bal = tin.balance ?? 0;
          const apr = tin.apr ?? 0;
          totalDebt += bal;
          monthlyInterest += bal * (apr / 12);
          annualInterest  += bal * apr;
        }
        if (tin.type === 'budget' || tin.type === 'business') {
          for (const e of (tin.entries ?? [])) {
            if (!e.entryDate.startsWith(thisMonth)) continue;
            if (e.kind === 'income')  totalIncome  += e.amount;
            if (e.kind === 'expense') totalExpense += e.amount;
          }
        }
      }
      return { totalDebt, monthlyInterest, annualInterest, netCashflow: totalIncome - totalExpense };
    }

    function renderSummary() {
      const { totalDebt, monthlyInterest, annualInterest, netCashflow } = computeSummary();
      // Top stats bar
      const debtEl = document.getElementById('dt-total-debt');
      const miEl   = document.getElementById('dt-monthly-interest');
      const aiEl   = document.getElementById('dt-annual-interest');
      const cfEl   = document.getElementById('dt-net-cashflow');
      if (debtEl) debtEl.textContent = fmt(totalDebt);
      if (miEl)   miEl.textContent   = fmt(monthlyInterest);
      if (aiEl)   aiEl.textContent   = fmt(annualInterest);
      if (cfEl) {
        cfEl.textContent = fmt(Math.abs(netCashflow));
        cfEl.classList.toggle('gain', netCashflow >= 0);
        cfEl.classList.toggle('loss', netCashflow < 0);
      }
      // Side summary panel
      const { totalIncome, totalExpense } = (() => {
        const now = new Date();
        const thisMonth = now.toISOString().slice(0, 7);
        let inc = 0, exp = 0;
        for (const tin of _tins) {
          if (tin.type === 'budget' || tin.type === 'business') {
            for (const e of (tin.entries ?? [])) {
              if (!e.entryDate.startsWith(thisMonth)) continue;
              if (e.kind === 'income')  inc += e.amount;
              if (e.kind === 'expense') exp += e.amount;
            }
          }
        }
        return { totalIncome: inc, totalExpense: exp };
      })();
      const netEl  = document.getElementById('dss-net');
      const incEl  = document.getElementById('dss-income');
      const expEl  = document.getElementById('dss-expense');
      const sdEl   = document.getElementById('dss-debt');
      const siEl   = document.getElementById('dss-interest');
      const saEl   = document.getElementById('dss-annual');
      if (incEl)  incEl.textContent  = fmt(totalIncome);
      if (expEl)  expEl.textContent  = fmt(totalExpense);
      if (netEl) {
        netEl.textContent = fmt(Math.abs(netCashflow));
        netEl.className = 'dt-summary-side__val ' + (netCashflow >= 0 ? 'gain' : 'loss');
      }
      if (sdEl) sdEl.textContent  = fmt(totalDebt);
      if (siEl) siEl.textContent  = fmt(monthlyInterest);
      if (saEl) saEl.textContent  = fmt(annualInterest);
    }

    // ── Render all tins ────────────────────────────────────────────────────────
    function renderAll() {
      renderSummary();
      const emptyMsg    = document.getElementById('dt-empty');
      const budgetSlot  = document.getElementById('dt-budget-slot');
      const debtGrid    = document.getElementById('dt-debt-grid');
      const incomeGrid  = document.getElementById('dt-income-grid');
      const zoneTop     = document.getElementById('dt-zone-top');
      const zoneDebt    = document.getElementById('dt-zone-debt');
      const zoneIncome  = document.getElementById('dt-zone-income');
      const sampleBanner = document.getElementById('dt-sample-banner');
      const hasSample = _tins.some(t => t.notes === '__sample__');

      // Clear zones
      if (budgetSlot) budgetSlot.innerHTML = '';
      if (debtGrid)   debtGrid.innerHTML   = '';
      if (incomeGrid) incomeGrid.innerHTML  = '';

      if (!_tins.length) {
        if (emptyMsg) emptyMsg.style.display = 'flex';
        if (zoneDebt)   zoneDebt.style.display   = 'none';
        if (zoneIncome) zoneIncome.style.display  = 'none';
        if (sampleBanner) sampleBanner.style.display = 'none';
        return;
      }
      if (emptyMsg) emptyMsg.style.display = 'none';
      if (sampleBanner) sampleBanner.style.display = hasSample ? 'flex' : 'none';

      const debtTins     = _tins.filter(t => t.type === 'debt');
      const budgetTins   = _tins.filter(t => t.type === 'budget');
      const businessTins = _tins.filter(t => t.type === 'business');

      // Row 1 col 2: budget tin(s)
      for (const tin of budgetTins) {
        budgetSlot?.insertAdjacentHTML('beforeend', buildTinHTML(tin));
      }

      // Row 2: debt tins
      if (debtTins.length && zoneDebt) {
        zoneDebt.style.display = 'block';
        for (const tin of debtTins) {
          debtGrid?.insertAdjacentHTML('beforeend', buildTinHTML(tin));
        }
      } else if (zoneDebt) {
        zoneDebt.style.display = 'none';
      }

      // Below divider: business/income tins
      if (businessTins.length && zoneIncome) {
        zoneIncome.style.display = 'block';
        for (const tin of businessTins) {
          incomeGrid?.insertAdjacentHTML('beforeend', buildTinHTML(tin));
        }
      } else if (zoneIncome) {
        zoneIncome.style.display = 'none';
      }

      // Bind accordion toggles
      $$('.dt-tin__accordion-toggle').forEach(btn => {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          const target = document.getElementById(btn.dataset.target);
          if (target) target.style.display = expanded ? 'none' : 'flex';
        });
      });

      // Bind delete entry buttons (debt/business tins)
      $$('.dt-tin__entry-del').forEach(btn => {
        btn.addEventListener('click', () => deleteEntry(btn.dataset.entryId));
      });

      // Bind register row delete buttons (budget tins)
      $$('.dt-reg-del').forEach(btn => {
        btn.addEventListener('click', () => deleteEntry(btn.dataset.entryId));
      });

      // Bind register blank row auto-save
      $$('.dt-reg-blank').forEach(row => bindRegisterRow(row));
    }

    function buildTinHTML(tin) {
      const badgeClass = `dt-tin__badge--${tin.type}`;
      const badgeLabel = tin.type === 'debt' ? 'Debt' : tin.type === 'budget' ? 'Budget' : 'Business';
      const sampleBadge = tin.notes === '__sample__' ? '<span class="dt-tin__sample-badge">sample</span>' : '';

      let progressHTML = '';
      if (tin.type === 'debt' && tin.creditLimit) {
        const pct = Math.min(100, ((tin.balance ?? 0) / tin.creditLimit) * 100);
        progressHTML = `
          <div class="dt-tin__progress-wrap">
            <div class="dt-tin__progress-track">
              <div class="dt-tin__progress-fill dt-tin__progress-fill--debt" style="width:${pct.toFixed(1)}%"></div>
            </div>
            <div class="dt-tin__progress-labels">
              <span>${fmt(tin.balance ?? 0)} owed</span>
              <span>${pct.toFixed(0)}% of ${fmt(tin.creditLimit)}</span>
            </div>
          </div>`;
      }
      if (tin.type === 'business' && tin.goalRevenue) {
        const monthRevenue = (tin.entries ?? [])
          .filter(e => e.kind === 'income' && e.entryDate.startsWith(new Date().toISOString().slice(0,7)))
          .reduce((s, e) => s + e.amount, 0);
        const pct = Math.min(100, (monthRevenue / tin.goalRevenue) * 100);
        progressHTML = `
          <div class="dt-tin__progress-wrap">
            <div class="dt-tin__progress-track">
              <div class="dt-tin__progress-fill dt-tin__progress-fill--business" style="width:${pct.toFixed(1)}%"></div>
            </div>
            <div class="dt-tin__progress-labels">
              <span>${fmt(monthRevenue)} this month</span>
              <span>${pct.toFixed(0)}% of ${fmt(tin.goalRevenue)} goal</span>
            </div>
          </div>`;
      }

      let numsHTML = '';
      if (tin.type === 'debt') {
        const monthly = (tin.balance ?? 0) * ((tin.apr ?? 0) / 12);
        numsHTML = `
          <div class="dt-tin__nums">
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Balance</span>
              <span class="dt-tin__num-value loss">${fmt(tin.balance ?? 0)}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">APR</span>
              <span class="dt-tin__num-value">${tin.apr ? fmtPct(tin.apr) : '—'}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Monthly interest</span>
              <span class="dt-tin__num-value loss">${tin.apr ? fmt(monthly) : '—'}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Min payment</span>
              <span class="dt-tin__num-value">${tin.minPayment ? fmt(tin.minPayment) : '—'}</span>
            </div>
          </div>`;
      } else if (tin.type === 'business') {
        const entries = tin.entries ?? [];
        const thisMonth = new Date().toISOString().slice(0,7);
        const revenue = entries.filter(e => e.kind === 'income'  && e.entryDate.startsWith(thisMonth)).reduce((s,e) => s+e.amount,0);
        const costs   = entries.filter(e => e.kind === 'expense' && e.entryDate.startsWith(thisMonth)).reduce((s,e) => s+e.amount,0);
        const profit  = revenue - costs;
        numsHTML = `
          <div class="dt-tin__nums">
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Revenue (this month)</span>
              <span class="dt-tin__num-value gain">${fmt(revenue)}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Expenses (this month)</span>
              <span class="dt-tin__num-value loss">${fmt(costs)}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Net profit</span>
              <span class="dt-tin__num-value ${profit >= 0 ? 'gain' : 'loss'}">${fmt(profit)}</span>
            </div>
          </div>`;
      } else {
        // Budget: show this month income vs expenses
        const entries = tin.entries ?? [];
        const thisMonth = new Date().toISOString().slice(0,7);
        const income  = entries.filter(e => e.kind === 'income'  && e.entryDate.startsWith(thisMonth)).reduce((s,e) => s+e.amount,0);
        const expense = entries.filter(e => e.kind === 'expense' && e.entryDate.startsWith(thisMonth)).reduce((s,e) => s+e.amount,0);
        const net = income - expense;
        numsHTML = `
          <div class="dt-tin__nums">
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Income (this month)</span>
              <span class="dt-tin__num-value gain">${fmt(income)}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Expenses (this month)</span>
              <span class="dt-tin__num-value loss">${fmt(expense)}</span>
            </div>
            <div class="dt-tin__num-row">
              <span class="dt-tin__num-label">Net</span>
              <span class="dt-tin__num-value ${net >= 0 ? 'gain' : 'loss'}">${fmt(net)}</span>
            </div>
          </div>`;
      }

      const entries = tin.entries ?? [];
      const entriesId = `entries-${tin.id}`;
      const entriesLabel = tin.type === 'debt'
        ? 'Payments & charges'
        : tin.type === 'budget' ? 'Income & expenses' : 'Transactions';

      const entryRows = entries.length
        ? entries.slice(0, 30).map(e => {
            const sign = (e.kind === 'payment' || e.kind === 'income') ? '−' : '+';
            return `<div class="dt-tin__entry">
              <div class="dt-tin__entry-left">
                <span class="dt-tin__entry-kind">${e.kind}</span>
                <span class="dt-tin__entry-desc">${e.description ?? '—'}</span>
                <span class="dt-tin__entry-date">${e.entryDate}</span>
              </div>
              <span class="dt-tin__entry-amount ${e.kind}">${sign}${fmt(e.amount)}</span>
              <button class="dt-tin__entry-del" data-entry-id="${e.id}" title="Remove">✕</button>
            </div>`;
          }).join('')
        : '<p class="dt-tin__no-entries">No entries yet.</p>';

      const addEntryKind = tin.type === 'debt' ? 'payment' : 'income';

      // Budget tins get the full-width checkbook register layout
      if (tin.type === 'budget') {
        return buildBudgetRegister(tin, badgeClass, badgeLabel, sampleBadge);
      }

      return `
        <div class="dt-tin dt-tin--${tin.type}" data-tin-id="${tin.id}" data-tin-type="${tin.type}">
          <div class="dt-tin__header">
            <span class="dt-tin__name">${escHtml(tin.name)}</span>
            <span class="dt-tin__badge ${badgeClass}">${badgeLabel}</span>
            ${sampleBadge}
            <div class="dt-tin__actions">
              <button class="dt-tin__icon-btn" title="Edit" onclick="openEditTin('${tin.id}')">✏️</button>
              <button class="dt-tin__icon-btn dt-tin__icon-btn--delete" title="Delete" onclick="deleteTin('${tin.id}')">🗑</button>
            </div>
          </div>
          ${progressHTML}
          ${numsHTML}
          <div class="dt-tin__accordion">
            <button class="dt-tin__accordion-toggle" aria-expanded="false" data-target="${entriesId}">
              ${entriesLabel} (${entries.length})
              <span class="chevron">▼</span>
            </button>
            <div class="dt-tin__entries" id="${entriesId}" style="display:none">
              ${entryRows}
            </div>
          </div>
          <div class="dt-tin__footer">
            <button class="dt-add-entry-btn" onclick="openAddEntry('${tin.id}', '${tin.type}')">＋ Add entry</button>
          </div>
        </div>`;
    }

    function sortEntries(entries, tinId) {
      const sort = _sortState[tinId] ?? { column: 'date', direction: 'desc' };
      const sorted = entries.slice();

      if (sort.column === 'date') {
        sorted.sort((a, b) => a.entryDate.localeCompare(b.entryDate));
      } else if (sort.column === 'amount') {
        sorted.sort((a, b) => a.amount - b.amount);
      } else if (sort.column === 'checked') {
        sorted.sort((a, b) => (a.checked ? 1 : 0) - (b.checked ? 1 : 0));
      }

      return sort.direction === 'desc' ? sorted.reverse() : sorted;
    }

    function toggleSort(tinId, column) {
      const current = _sortState[tinId] ?? { column: 'date', direction: 'desc' };
      if (current.column === column) {
        current.direction = current.direction === 'asc' ? 'desc' : 'asc';
      } else {
        current.column = column;
        current.direction = 'desc';
      }
      _sortState[tinId] = current;
      renderAll();
    }

    function getSortArrow(tinId, column) {
      const sort = _sortState[tinId];
      if (!sort || sort.column !== column) return '⇅';
      return sort.direction === 'asc' ? '↑' : '↓';
    }

    function buildBudgetRegister(tin, badgeClass, badgeLabel, sampleBadge) {
      const entries = sortEntries(tin.entries ?? [], tin.id);
      const BLANK_ROWS = 10;

      // Compute running balance
      let running = 0;
      const savedRows = entries.map(e => {
        if (e.kind === 'income')  running += e.amount;
        if (e.kind === 'expense') running -= e.amount;
        const pay = e.kind === 'expense' ? fmt(e.amount) : '';
        const dep = e.kind === 'income'  ? fmt(e.amount) : '';
        const balClass = running >= 0 ? 'gain' : 'loss';
        return `<tr class="dt-reg-saved" data-entry-id="${e.id}">
          <td class="col-date">${e.entryDate}</td>
          <td class="col-desc">${escHtml(e.description ?? '')}</td>
          <td class="col-pay">${pay}</td>
          <td class="col-dep">${dep}</td>
          <td class="col-bal ${balClass}">${fmt(running)}</td>
          <td class="col-del"><button class="dt-reg-del" data-entry-id="${e.id}" title="Delete">✕</button></td>
        </tr>`;
      }).join('');

      const today = new Date().toISOString().slice(0, 10);
      const blankRows = Array.from({ length: BLANK_ROWS }, (_, i) => `
        <tr class="dt-reg-blank" data-row="${i}" data-tin-id="${tin.id}">
          <td><input class="dt-reg-input dt-reg-date-i" type="date" value="${today}" /></td>
          <td><input class="dt-reg-input dt-reg-desc-i" type="text" placeholder="Description" maxlength="120" /></td>
          <td><input class="dt-reg-input dt-reg-input col-amt-input dt-reg-pay-i" type="number" step="0.01" min="0" placeholder="—" /></td>
          <td><input class="dt-reg-input dt-reg-input col-amt-input dt-reg-dep-i" type="number" step="0.01" min="0" placeholder="—" /></td>
          <td class="col-bal">—</td>
          <td class="col-del"></td>
        </tr>`).join('');

      const balClass = running >= 0 ? 'gain' : 'loss';
      const thisMonth = new Date().toISOString().slice(0, 7);
      const income  = entries.filter(e => e.kind === 'income'  && e.entryDate.startsWith(thisMonth)).reduce((s, e) => s + e.amount, 0);
      const expense = entries.filter(e => e.kind === 'expense' && e.entryDate.startsWith(thisMonth)).reduce((s, e) => s + e.amount, 0);
      const net = income - expense;

      return `
        <div class="dt-tin dt-tin--budget" data-tin-id="${tin.id}" data-tin-type="budget">
          <div class="dt-tin__header">
            <span class="dt-tin__name">${escHtml(tin.name)}</span>
            <span class="dt-tin__badge ${badgeClass}">${badgeLabel}</span>
            ${sampleBadge}
            <span style="font-size:0.75rem;color:var(--text-muted);margin-left:0.5rem">
              Income <span style="color:var(--gain);font-weight:600">${fmt(income)}</span>
              &nbsp;·&nbsp;
              Expenses <span style="color:var(--loss);font-weight:600">${fmt(expense)}</span>
              &nbsp;·&nbsp;
              Net <span style="color:var(--${net>=0?'gain':'loss'});font-weight:600">${fmt(net)}</span>
            </span>
            <div class="dt-tin__actions" style="margin-left:auto">
              <button class="dt-tin__icon-btn" title="Edit" onclick="openEditTin('${tin.id}')">✏️</button>
              <button class="dt-tin__icon-btn dt-tin__icon-btn--delete" title="Delete" onclick="deleteTin('${tin.id}')">🗑</button>
            </div>
          </div>
          <div class="dt-register">
            <table>
              <thead>
                <tr>
                  <th style="width:110px"><button class="dt-sort-btn" onclick="toggleSort('${tin.id}', 'date')">Date <span class="dt-sort-arrow">${getSortArrow(tin.id, 'date')}</span></button></th>
                  <th>Description</th>
                  <th class="col-amt" style="width:110px"><button class="dt-sort-btn" onclick="toggleSort('${tin.id}', 'amount')">Amount <span class="dt-sort-arrow">${getSortArrow(tin.id, 'amount')}</span></button></th>
                  <th class="col-amt" style="width:110px"><button class="dt-sort-btn" onclick="toggleSort('${tin.id}', 'amount')">Deposit <span class="dt-sort-arrow">${getSortArrow(tin.id, 'amount')}</span></button></th>
                  <th class="col-bal" style="width:110px">Balance</th>
                  <th style="width:28px"></th>
                </tr>
              </thead>
              <tbody id="reg-body-${tin.id}">
                ${savedRows}
                ${blankRows}
              </tbody>
            </table>
          </div>
        </div>`;
    }

    function escHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Modal: Add / Edit Tin ─────────────────────────────────────────────────
    function openAddTin(type) {
      // Splits tins use a dedicated modal
      if (type === 'splits') {
        const modal = document.getElementById('dt-splits-modal');
        const input = document.getElementById('dt-splits-name');
        input.value = '';
        modal.style.display = 'flex';
        setTimeout(() => input.focus(), 50);
        return;
      }

      const modal = document.getElementById('dt-modal');
      document.getElementById('dt-modal-id').value = '';
      document.getElementById('dt-modal-type').value = type;
      document.getElementById('dt-modal-title').textContent = type === 'debt' ? 'Add Debt Tin' : type === 'budget' ? 'Add Budget' : 'Add Business Tin';
      document.getElementById('dt-modal-name').value = '';
      document.getElementById('dt-debt-balance').value = '';
      document.getElementById('dt-debt-limit').value = '';
      document.getElementById('dt-debt-apr').value = '';
      document.getElementById('dt-debt-min').value = '';
      document.getElementById('dt-biz-goal').value = '';
      document.querySelector('.dt-fields-debt').style.display     = type === 'debt'     ? 'flex' : 'none';
      document.querySelector('.dt-fields-business').style.display = type === 'business' ? 'flex' : 'none';
      modal.style.display = 'flex';
      document.getElementById('dt-modal-name').focus();
    }

    function openEditTin(tinId) {
      const tin = _tins.find(t => t.id === tinId);
      if (!tin) return;
      document.getElementById('dt-modal-id').value = tin.id;
      document.getElementById('dt-modal-type').value = tin.type;
      document.getElementById('dt-modal-title').textContent = 'Edit ' + tin.name;
      document.getElementById('dt-modal-name').value = tin.name;
      document.getElementById('dt-debt-balance').value = tin.balance ?? '';
      document.getElementById('dt-debt-limit').value = tin.creditLimit ?? '';
      document.getElementById('dt-debt-apr').value = tin.apr ? (tin.apr * 100).toFixed(2) : '';
      document.getElementById('dt-debt-min').value = tin.minPayment ?? '';
      document.getElementById('dt-biz-goal').value = tin.goalRevenue ?? '';
      document.querySelector('.dt-fields-debt').style.display     = tin.type === 'debt'     ? 'flex' : 'none';
      document.querySelector('.dt-fields-business').style.display = tin.type === 'business' ? 'flex' : 'none';
      document.getElementById('dt-modal').style.display = 'flex';
      document.getElementById('dt-modal-name').focus();
    }

    document.getElementById('dt-modal-cancel')?.addEventListener('click', () => {
      document.getElementById('dt-modal').style.display = 'none';
    });

    // ── Splits modal ───────────────────────────────────────────────────────────
    document.getElementById('dt-splits-cancel')?.addEventListener('click', () => {
      document.getElementById('dt-splits-modal').style.display = 'none';
    });

    document.getElementById('dt-splits-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      const name = document.getElementById('dt-splits-name').value.trim();
      if (!name) return;
      const btn = e.target.querySelector('button[type="submit"]');
      btn.disabled = true;
      btn.textContent = 'Creating…';
      try {
        const res = await fetch('/api/petro-tins/splits', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action: 'create_splits', name }),
        });
        if (res.ok) {
          document.getElementById('dt-splits-modal').style.display = 'none';
          window.dispatchEvent(new Event('petro-tins-changed'));
          location.reload();
        } else {
          const data = await res.json().catch(() => ({}));
          alert('Could not create splits tin: ' + (data.error ?? `server error ${res.status}`));
          btn.disabled = false;
          btn.textContent = 'Create';
        }
      } catch (err) {
        alert('Could not reach the server. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Create';
      }
    });

    document.getElementById('dt-modal-form')?.addEventListener('submit', async e => {
      e.preventDefault();
      const id   = document.getElementById('dt-modal-id').value;
      const type = document.getElementById('dt-modal-type').value;
      const name = document.getElementById('dt-modal-name').value.trim();
      const aprRaw = parseFloat(document.getElementById('dt-debt-apr').value);

      const body = {
        name,
        type,
        balance:     parseFloat(document.getElementById('dt-debt-balance').value) || null,
        creditLimit: parseFloat(document.getElementById('dt-debt-limit').value)   || null,
        apr:         isNaN(aprRaw) ? null : aprRaw / 100,  // store as decimal
        minPayment:  parseFloat(document.getElementById('dt-debt-min').value)     || null,
        goalRevenue: parseFloat(document.getElementById('dt-biz-goal').value)     || null,
      };

      if (id) {
        await fetch(`/api/petro-tins/${id}`, { method: 'PATCH', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
      } else {
        const res = await fetch('/api/petro-tins', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
        if (res.status === 403) {
          const data = await res.json().catch(() => ({}));
          if (data.error === 'upgrade_required') {
            document.getElementById('dt-modal').style.display = 'none';
            window.location.href = '/dashboard/petro-tins/upgrade';
            return;
          }
        }
      }

      document.getElementById('dt-modal').style.display = 'none';
      await loadTins();
      // Notify React component to refresh
      window.dispatchEvent(new Event('petro-tins-changed'));
    });

    // Expose to onclick handlers
    window.openEditTin = openEditTin;

    // ── Delete tin ─────────────────────────────────────────────────────────────
