---
/**
 * /dashboard/alerts
 *
 * Manage price alerts. Users set a coin + threshold + direction (above/below)
 * and receive an email when the price crosses it.
 */
import Layout from '../../layouts/Layout.astro';
import { requireTenantSession } from '@/lib/requireTenantSession';
import { getAuthSession } from '@/lib/authSession';
import { db } from '@/lib/db';
import { getLang } from '@/lib/i18n/locale';
import { getAlerts } from '@/i18n/dashboard/alerts';
import '../../styles/alerts.css';

const lang = getLang(Astro.request);
const t = getAlerts(lang);

const _authSess = await requireTenantSession(Astro.request);
if (!_authSess) return Astro.redirect('/login');

const session = await getAuthSession(Astro.request).catch(() => null);
const userId = session?.user?.id ?? null;
let alertEmail: string | null = null;
if (userId) {
	try {
		const row = await db.execute({ sql: 'SELECT alert_email FROM auth_users WHERE id = ? LIMIT 1', args: [userId] });
		alertEmail = row.rows[0] ? String((row.rows[0] as Record<string, unknown>).alert_email ?? '') || null : null;
	} catch {}
}
---

<Layout title={t.pageTitle} noindex={true}>
	<div class="dash-page">
		<div class="dash-content">
		<div class="alerts-body">

			<!-- Header -->
			<div>
				<h1 class="alerts-page__title">{t.heroTitle}</h1>
				<p class="alerts-page__intro">{t.intro}</p>
			</div>

			<!-- Sticky note -->
			<div style="
				background: rgba(45,212,168,0.08);
				border: 1px solid rgba(45,212,168,0.22);
				border-left: 4px solid var(--accent);
				border-radius: 0 8px 8px 0;
				padding: 1rem 1.4rem;
				display: flex;
				gap: 0.75rem;
				align-items: flex-start;
				margin-bottom: 0.5rem;
			">
				<span style="font-size:1.1rem; line-height:1.4;"></span>
				<div style="display:flex; flex-direction:column; gap:0.4rem;">
					<p style="margin:0; font-size:0.85rem; font-weight:600; color:var(--accent);">{t.noteHeading}</p>
					<p style="margin:0; font-size:0.83rem; color:var(--text-secondary); line-height:1.55;" set:html={t.notePriceAlert}></p>
					<p style="margin:0; font-size:0.83rem; color:var(--text-secondary); line-height:1.55;" set:html={t.noteHealthAlert}></p>
					<p style="margin:0; font-size:0.78rem; color:var(--text-muted);">{t.noteTip}</p>
				</div>
			</div>

			<!-- No alert email warning -->
			{!alertEmail && (
				<div class="dash-notice dash-notice--warn">
					<span class="dash-notice__icon"></span>
					<div class="dash-notice__body">
						<p class="dash-notice__title">{t.noEmailTitle}</p>
						<p class="dash-notice__text">
							{t.noEmailTextBefore}
							<a href="/dashboard/account" class="dash-notice__link">{t.noEmailLink}</a>{t.noEmailTextAfter}
						</p>
					</div>
				</div>
			)}

			<!-- Email confirmed -->
			{alertEmail && (
				<p class="alerts__email-line">
					{t.emailLineBefore}<span class="alerts__email-value">{alertEmail}</span>{t.emailLineAfter}
					<a href="/dashboard/account" class="alerts__email-change">{t.emailChange}</a>
				</p>
			)}

			<!-- Add Alert form -->
			<div class="alerts__form-card">
				<h2 class="alerts__section-heading">{t.addHeading}</h2>
				<form id="add-alert-form">
					<div class="alerts__form-row">
						<!-- Asset symbol -->
						<div class="alerts__field">
							<label class="alerts__label" for="new-symbol">{t.labelAsset}</label>
							<input type="text" id="new-symbol" class="alerts__input"
							       placeholder="BTC, ETH, SOL…" maxlength="20" required />
						</div>
						<!-- Direction -->
						<div class="alerts__field">
							<label class="alerts__label" for="new-direction">{t.labelCondition}</label>
							<select id="new-direction" class="alerts__input">
								<option value="above">{t.optionAbove}</option>
								<option value="below">{t.optionBelow}</option>
							</select>
						</div>
						<!-- Threshold -->
						<div class="alerts__field alerts__field--price">
							<label class="alerts__label" for="new-threshold">{t.labelPrice}</label>
							<span class="alerts__price-prefix">$</span>
							<input type="number" id="new-threshold" class="alerts__input"
							       step="any" min="0.000001" placeholder={t.pricePlaceholder} required />
						</div>
					</div>
					<div class="alerts__form-footer">
						<span id="add-status" class="alerts__status" hidden></span>
						<button type="submit" id="add-btn" class="alerts__submit">{t.addBtn}</button>
					</div>
				</form>
			</div>

			<!-- Existing alerts list -->
			<div class="alerts__list-section">
				<h2 class="alerts__section-heading">{t.listHeading}</h2>

				<div id="alerts-loading" class="alerts__loading">{t.loading}</div>

				<div id="alerts-empty" class="alerts__empty" hidden>
					<span class="alerts__empty-icon"></span>
					<p class="alerts__empty-title">{t.emptyTitle}</p>
					<p class="alerts__empty-text">{t.emptyText}</p>
				</div>

				<p id="alerts-error" class="alerts__error" hidden>{t.loadError}</p>

				<div id="alerts-list" class="alerts__list" hidden></div>
			</div>

		</div>
		</div>
	</div>
</Layout>

<script is:inline define:vars={{ i18n: {
	pillAbove: t.pillAbove,
	pillBelow: t.pillBelow,
	deleteTitle: t.deleteTitle,
	deleteBefore: t.deleteBefore,
	deleteSuffix: t.deleteSuffix,
	saving: t.saving,
	added: t.added,
	failed: t.failed,
	networkError: t.networkError,
} }}>window.__alertsI18n = i18n;</script>

<script>
const USD = (n: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);

// Localized strings injected by the inline <script is:inline define:vars> above.
// English fallbacks keep the script working if that block ever fails to run.
interface AlertsI18n {
	pillAbove: string; pillBelow: string; deleteTitle: string;
	deleteBefore: string; deleteSuffix: string;
	saving: string; added: string; failed: string; networkError: string;
}
const I18N: AlertsI18n = (window as unknown as { __alertsI18n?: AlertsI18n }).__alertsI18n ?? {
	pillAbove: '↑ above', pillBelow: '↓ below', deleteTitle: 'Delete alert',
	deleteBefore: 'Delete alert for ', deleteSuffix: '?',
	saving: 'Saving…', added: '✓ Alert added!', failed: 'Failed', networkError: 'Network error',
};

interface Alert {
	id: string;
	assetSymbol: string;
	direction: string;
	threshold: number;
	enabled: boolean;
	lastAlertedAt: string | null;
}

let alerts: Alert[] = [];

async function loadAlerts() {
	const loadingEl = document.getElementById('alerts-loading') as HTMLElement;
	const emptyEl   = document.getElementById('alerts-empty') as HTMLElement;
	const errorEl   = document.getElementById('alerts-error') as HTMLElement;
	const listEl    = document.getElementById('alerts-list') as HTMLElement;

	loadingEl.hidden = false;
	emptyEl.hidden   = true;
	errorEl.hidden   = true;
	listEl.hidden    = true;

	try {
		const res = await fetch('/api/account/price-alerts');
		if (!res.ok) throw new Error(`HTTP ${res.status}`);
		const data = await res.json() as { ok: boolean; alerts: Alert[] };

		loadingEl.hidden = true;

		if (!data.ok) throw new Error('API error');
		alerts = data.alerts;

		if (alerts.length === 0) {
			emptyEl.hidden = false;
			return;
		}

		renderAlerts();
		listEl.hidden = false;
	} catch (err) {
		console.error('[alerts] load failed', err);
		loadingEl.hidden = true;
		errorEl.hidden   = false;
	}
}

function renderAlerts() {
	const listEl = document.getElementById('alerts-list')!;
	listEl.innerHTML = '';

	for (const alert of alerts) {
		const card = document.createElement('div');
		card.className = 'alerts__item';
		card.dataset.id = alert.id;

		const dirLabel = alert.direction === 'above' ? I18N.pillAbove : I18N.pillBelow;

		card.innerHTML = `
			<span class="alerts__item-symbol">${alert.assetSymbol}</span>
			<span class="alerts__item-pill">${dirLabel}</span>
			<span class="alerts__item-price">${USD(alert.threshold)}</span>
			<button class="alerts__item-delete delete-btn" title="${I18N.deleteTitle}" type="button">×</button>
		`;

		const delBtn = card.querySelector<HTMLButtonElement>('.delete-btn')!;
		delBtn.addEventListener('click', async () => {
			if (!confirm(`${I18N.deleteBefore}${alert.assetSymbol} ${alert.direction} ${USD(alert.threshold)}${I18N.deleteSuffix}`)) return;
			try {
				const res = await fetch(`/api/account/price-alerts?id=${alert.id}`, { method: 'DELETE' });
				if ((await res.json()).ok) {
					card.style.transition = 'opacity 0.3s';
					card.style.opacity = '0';
					setTimeout(() => {
						card.remove();
						alerts = alerts.filter(a => a.id !== alert.id);
						if (alerts.length === 0) {
							(document.getElementById('alerts-list') as HTMLElement).hidden = true;
							(document.getElementById('alerts-empty') as HTMLElement).hidden = false;
						}
					}, 300);
				}
			} catch (err) {
				console.error('[alerts] delete failed', err);
			}
		});

		listEl.appendChild(card);
	}
}

// ── Add alert form ────────────────────────────────────────────────────────────
document.getElementById('add-alert-form')?.addEventListener('submit', async (e) => {
	e.preventDefault();

	const symbolEl    = document.getElementById('new-symbol') as HTMLInputElement;
	const directionEl = document.getElementById('new-direction') as HTMLSelectElement;
	const thresholdEl = document.getElementById('new-threshold') as HTMLInputElement;
	const addBtn      = document.getElementById('add-btn') as HTMLButtonElement;
	const statusEl    = document.getElementById('add-status') as HTMLElement;

	const assetSymbol = symbolEl.value.toUpperCase().trim();
	const direction   = directionEl.value;
	const threshold   = parseFloat(thresholdEl.value);

	if (!assetSymbol || !threshold || threshold <= 0) return;

	addBtn.disabled       = true;
	statusEl.textContent  = I18N.saving;
	statusEl.hidden       = false;

	try {
		const res = await fetch('/api/account/price-alerts', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({ assetSymbol, direction, threshold }),
		});
		const data = await res.json() as { ok: boolean; id?: string; error?: string };

		if (data.ok) {
			statusEl.textContent = I18N.added;
			symbolEl.value   = '';
			thresholdEl.value = '';
			setTimeout(() => {
				statusEl.hidden  = true;
				addBtn.disabled  = false;
				loadAlerts();
			}, 800);
		} else {
			statusEl.textContent = `${data.error ?? I18N.failed}`;
			addBtn.disabled = false;
		}
	} catch {
		statusEl.textContent = I18N.networkError;
		addBtn.disabled = false;
	}
});

// Force symbol input uppercase
document.getElementById('new-symbol')?.addEventListener('input', (e) => {
	const el = e.target as HTMLInputElement;
	const pos = el.selectionStart ?? 0;
	el.value = el.value.toUpperCase();
	el.setSelectionRange(pos, pos);
});

loadAlerts();
</script>
