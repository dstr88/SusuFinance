---
import Layout from '@/layouts/Layout.astro';
import { db } from '@/lib/db';
import { getGA4Summary } from '@/lib/ga4';
import { getLang } from '@/lib/i18n/locale';
import { getAnalytics } from '@/i18n/dashboard/analytics';

const lang = getLang(Astro.request);
const t = getAnalytics(lang);

// You already gate /dashboard/* in middleware.
// This is just a belt-and-suspenders check if you ever bypass middleware in dev.
const today = new Date().toISOString().slice(0, 10);
const dayParam = Astro.url.searchParams.get('day') ?? today;

// Helpers
const num = (v: unknown) => (typeof v === 'number' ? v : Number(v ?? 0));
const str = (v: unknown) => (typeof v === 'string' ? v : String(v ?? ''));

async function query<T extends Record<string, unknown>>(sql: string, args: unknown[] = []) {
	const res = await db.execute({ sql, args });
	return res.rows as T[];
}

// A) Today totals
const totalsRows = await query<{
	day: string;
	requests: number;
	avg_ms: number;
	max_ms: number;
}>(
	`
	SELECT
	  day,
	  SUM(count) AS requests,
	  ROUND(SUM(ms_total) * 1.0 / NULLIF(SUM(count),0), 2) AS avg_ms,
	  MAX(ms_max) AS max_ms
	FROM request_agg_daily
	WHERE day = ?
	GROUP BY day
	`,
	[dayParam],
);

// B) By route
const byRoute = await query<{
	route_key: string;
	requests: number;
	avg_ms: number;
}>(
	`
	SELECT
	  route_key,
	  SUM(count) AS requests,
	  ROUND(SUM(ms_total) * 1.0 / NULLIF(SUM(count),0), 2) AS avg_ms
	FROM request_agg_daily
	WHERE day = ?
	GROUP BY route_key
	ORDER BY requests DESC
	LIMIT 25
	`,
	[dayParam],
);

// C) By status
const byStatus = await query<{
	status: number;
	requests: number;
}>(
	`
	SELECT
	  status,
	  SUM(count) AS requests
	FROM request_agg_daily
	WHERE day = ?
	GROUP BY status
	ORDER BY requests DESC
	`,
	[dayParam],
);

// D) By country
const byCountry = await query<{
	country_code: string;
	requests: number;
}>(
	`
	SELECT
	  country_code,
	  SUM(count) AS requests
	FROM request_agg_daily
	WHERE day = ?
	GROUP BY country_code
	ORDER BY requests DESC
	LIMIT 50
	`,
	[dayParam],
);

// E) GA4 summary (last 28 days)
const ga4 = await getGA4Summary(28).catch(() => null);

// F) Scam checker usage (all-time + per-person breakdown)
const checkerTotals = await query<{
	total_checks: number;
	unique_users: number;
	unique_addresses: number;
	cache_hits: number;
}>(
	`SELECT
	   COUNT(*)                     AS total_checks,
	   COUNT(DISTINCT ip_hash)      AS unique_users,
	   COUNT(DISTINCT addr_hash)    AS unique_addresses,
	   SUM(cache_hit)               AS cache_hits
	 FROM wallet_check_log`,
);

const checkerByUser = await query<{
	ip_hash: string;
	checks: number;
	unique_addrs: number;
	last_check: string;
}>(
	`SELECT
	   ip_hash,
	   COUNT(*)                  AS checks,
	   COUNT(DISTINCT addr_hash) AS unique_addrs,
	   MAX(created_at)           AS last_check
	 FROM wallet_check_log
	 GROUP BY ip_hash
	 ORDER BY checks DESC
	 LIMIT 50`,
);

const checkerByDay = await query<{
	day: string;
	checks: number;
	unique_users: number;
}>(
	`SELECT
	   substr(created_at, 1, 10) AS day,
	   COUNT(*)                   AS checks,
	   COUNT(DISTINCT ip_hash)    AS unique_users
	 FROM wallet_check_log
	 GROUP BY day
	 ORDER BY day DESC
	 LIMIT 30`,
);

// Optional: recent detailed events (only if you want it)
const showLogs = Astro.url.searchParams.get('logs') === '1';
const recentLogs = showLogs
	? await query<{
			ts: string;
			route: string;
			route_key: string;
			method: string;
			status: number;
			ms: number;
			country_code: string;
			wallet_address: string | null;
			cache_hit: number;
	  }>(
			`
			SELECT ts, route, route_key, method, status, ms, country_code, wallet_address, cache_hit
			FROM request_log
			ORDER BY ts DESC
			LIMIT 100
			`,
	  )
	: [];
---

<Layout title={t.pageTitle} noindex={true}>
	<section style="max-width: 1100px; margin: 0 auto; padding: 1.25rem;">
		<h1 style="font-size: 1.6rem; margin-bottom: 0.25rem;">{t.heading}</h1>
		<p style="opacity: 0.85; margin-top: 0;">
			{t.subheading}
		</p>

		<!-- ── Google Analytics 4 — last 28 days ── -->
		{ga4 ? (
			<div style="margin-bottom: 2rem;">
				<h2 style="font-size: 1.1rem; margin: 0 0 0.75rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">
					{t.ga4Heading}
				</h2>

				<!-- Stat cards -->
				<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 1.25rem;">
					{[
						{ label: t.ga4LabelUsers,        value: ga4.totalUsers.toLocaleString()  },
						{ label: t.ga4LabelNewUsers,     value: ga4.newUsers.toLocaleString()    },
						{ label: t.ga4LabelSessions,     value: ga4.sessions.toLocaleString()    },
						{ label: t.ga4LabelCheckerViews, value: ga4.checkerViews.toLocaleString()},
						{ label: t.ga4LabelLoginViews,   value: ga4.loginViews.toLocaleString()  },
						{ label: t.ga4LabelCheckerToLogin, value: ga4.conversionRate             },
					].map((s) => (
						<div style="padding: 0.9rem 1rem; border-radius: 1rem; border: 1px solid rgba(87,103,255,0.3); background: rgba(87,103,255,0.07);">
							<div style="font-size: 0.75rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem;">{s.label}</div>
							<div style="font-size: 1.5rem; font-weight: 800;">{s.value}</div>
						</div>
					))}
				</div>

				<div style="display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 1rem;">
					<!-- Top pages -->
					<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.12); background: rgba(0,0,0,0.12);">
						<h3 style="margin: 0 0 0.75rem; font-size: 0.9rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.06em;">{t.ga4TopPages}</h3>
						<table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
							<thead>
								<tr style="opacity: 0.6; text-align: left;">
									<th style="padding: 0.3rem 0;">{t.ga4PageCol}</th>
									<th style="padding: 0.3rem 0;">{t.ga4ViewsCol}</th>
									<th style="padding: 0.3rem 0;">{t.ga4UsersCol}</th>
								</tr>
							</thead>
							<tbody>
								{ga4.topPages.map((p) => (
									<tr style="border-top: 1px solid rgba(255,255,255,0.07);">
										<td style="padding: 0.4rem 0; font-family: ui-monospace, monospace; font-size: 0.8rem;">{p.page}</td>
										<td style="padding: 0.4rem 0;">{p.views.toLocaleString()}</td>
										<td style="padding: 0.4rem 0;">{p.users.toLocaleString()}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<!-- Traffic sources -->
					<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.12); background: rgba(0,0,0,0.12);">
						<h3 style="margin: 0 0 0.75rem; font-size: 0.9rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.06em;">{t.ga4Sources}</h3>
						<table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
							<thead>
								<tr style="opacity: 0.6; text-align: left;">
									<th style="padding: 0.3rem 0;">{t.ga4SourceCol}</th>
									<th style="padding: 0.3rem 0;">{t.ga4SessionsCol}</th>
								</tr>
							</thead>
							<tbody>
								{ga4.topSources.map((s) => (
									<tr style="border-top: 1px solid rgba(255,255,255,0.07);">
										<td style="padding: 0.4rem 0;">{s.source || '(direct)'}</td>
										<td style="padding: 0.4rem 0;">{s.sessions.toLocaleString()}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>

					<!-- Countries -->
					<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.12); background: rgba(0,0,0,0.12);">
						<h3 style="margin: 0 0 0.75rem; font-size: 0.9rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.06em;">{t.ga4Countries}</h3>
						<table style="width: 100%; border-collapse: collapse; font-size: 0.875rem;">
							<thead>
								<tr style="opacity: 0.6; text-align: left;">
									<th style="padding: 0.3rem 0;">{t.ga4CountryCol}</th>
									<th style="padding: 0.3rem 0;">{t.ga4SessionsCol}</th>
								</tr>
							</thead>
							<tbody>
								{ga4.topCountries.map((c) => (
									<tr style="border-top: 1px solid rgba(255,255,255,0.07);">
										<td style="padding: 0.4rem 0;">{c.country}</td>
										<td style="padding: 0.4rem 0;">{c.sessions.toLocaleString()}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			</div>
		) : (
			<div style="margin-bottom: 1.5rem; padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.1); background: rgba(0,0,0,0.1); opacity: 0.6; font-size: 0.875rem;">
				{t.ga4Unavailable}
			</div>
		)}

		<form method="GET" style="display:flex; gap:0.75rem; align-items:end; flex-wrap: wrap; margin: 1rem 0;">
			<div>
				<label for="day" style="display:block; font-weight:600; margin-bottom:0.25rem;">{t.formDayLabel}</label>
				<input
					id="day"
					name="day"
					type="date"
					value={dayParam}
					style="padding:0.5rem; border-radius:0.5rem; border:1px solid rgba(255,255,255,0.25); background: rgba(0,0,0,0.15); color: inherit;"
				/>
			</div>

			<label style="display:flex; gap:0.5rem; align-items:center; padding-bottom:0.15rem;">
				<input type="checkbox" name="logs" value="1" checked={showLogs} />
				{t.formShowLogs}
			</label>

			<button
				type="submit"
				style="padding:0.6rem 0.9rem; border-radius:0.6rem; border:1px solid rgba(255,255,255,0.25); background: rgba(255,255,255,0.1); color: inherit; cursor:pointer;"
			>
				{t.formRefresh}
			</button>
		</form>

		<!-- Totals -->
		<div style="display:grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 0.75rem; margin: 1rem 0;">
			{(totalsRows.length ? totalsRows : [{ day: dayParam, requests: 0, avg_ms: 0, max_ms: 0 }]).map((row) => (
				<>
					<div style="padding: 0.9rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.15);">
						<div style="opacity:0.8;">{t.cardDay}</div>
						<div style="font-size:1.1rem; font-weight:700;">{str(row.day)}</div>
					</div>
					<div style="padding: 0.9rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.15);">
						<div style="opacity:0.8;">{t.cardRequests}</div>
						<div style="font-size:1.4rem; font-weight:800;">{num(row.requests)}</div>
					</div>
					<div style="padding: 0.9rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.15);">
						<div style="opacity:0.8;">{t.cardAvgMs}</div>
						<div style="font-size:1.4rem; font-weight:800;">{num(row.avg_ms)}</div>
					</div>
					<div style="padding: 0.9rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.15);">
						<div style="opacity:0.8;">{t.cardMaxMs}</div>
						<div style="font-size:1.4rem; font-weight:800;">{num(row.max_ms)}</div>
					</div>
				</>
			))}
		</div>

		<div style="display:grid; grid-template-columns: 2fr 1fr; gap: 1rem;">
			<!-- By route -->
			<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.12);">
				<h2 style="margin-top:0;">{t.topRoutes}</h2>
				<table style="width:100%; border-collapse: collapse;">
					<thead>
						<tr style="text-align:left; opacity:0.85;">
							<th style="padding:0.4rem 0;">{t.colRoute}</th>
							<th style="padding:0.4rem 0;">{t.colRequests}</th>
							<th style="padding:0.4rem 0;">{t.colAvgMs}</th>
						</tr>
					</thead>
					<tbody>
						{byRoute.map((r) => (
							<tr style="border-top: 1px solid rgba(255,255,255,0.12);">
								<td style="padding:0.45rem 0; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;">
									{str(r.route_key)}
								</td>
								<td style="padding:0.45rem 0;">{num(r.requests)}</td>
								<td style="padding:0.45rem 0;">{num(r.avg_ms)}</td>
							</tr>
						))}
						{byRoute.length === 0 && (
							<tr><td colspan="3" style="padding:0.75rem 0; opacity:0.8;">{t.noRowsForDay}</td></tr>
						)}
					</tbody>
				</table>
			</div>

			<!-- Status + Country -->
			<div style="display:flex; flex-direction:column; gap: 1rem;">
				<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.12);">
					<h2 style="margin-top:0;">{t.statusCodes}</h2>
					<table style="width:100%; border-collapse: collapse;">
						<thead>
							<tr style="text-align:left; opacity:0.85;">
								<th style="padding:0.4rem 0;">{t.colStatus}</th>
								<th style="padding:0.4rem 0;">{t.colRequests}</th>
							</tr>
						</thead>
						<tbody>
							{byStatus.map((s) => (
								<tr style="border-top: 1px solid rgba(255,255,255,0.12);">
									<td style="padding:0.45rem 0;">{num(s.status)}</td>
									<td style="padding:0.45rem 0;">{num(s.requests)}</td>
								</tr>
							))}
							{byStatus.length === 0 && (
								<tr><td colspan="2" style="padding:0.75rem 0; opacity:0.8;">{t.noRows}</td></tr>
							)}
						</tbody>
					</table>
				</div>

				<div style="padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.12);">
					<h2 style="margin-top:0;">{t.countries}</h2>
					<table style="width:100%; border-collapse: collapse;">
						<thead>
							<tr style="text-align:left; opacity:0.85;">
								<th style="padding:0.4rem 0;">{t.colCountry}</th>
								<th style="padding:0.4rem 0;">{t.colRequests}</th>
							</tr>
						</thead>
						<tbody>
							{byCountry.map((c) => (
								<tr style="border-top: 1px solid rgba(255,255,255,0.12);">
									<td style="padding:0.45rem 0;">{str(c.country_code)}</td>
									<td style="padding:0.45rem 0;">{num(c.requests)}</td>
								</tr>
							))}
							{byCountry.length === 0 && (
								<tr><td colspan="2" style="padding:0.75rem 0; opacity:0.8;">{t.noRows}</td></tr>
							)}
						</tbody>
					</table>
				</div>
			</div>
		</div>

		{showLogs && (
			<div style="margin-top: 1.25rem; padding: 1rem; border-radius: 1rem; border: 1px solid rgba(255,255,255,0.18); background: rgba(0,0,0,0.12);">
				<h2 style="margin-top:0;">{t.recentLogs}</h2>
				<div style="overflow:auto;">
					<table style="width:100%; border-collapse: collapse; min-width: 900px;">
						<thead>
							<tr style="text-align:left; opacity:0.85;">
								<th style="padding:0.4rem 0;">ts</th>
								<th style="padding:0.4rem 0;">route_key</th>
								<th style="padding:0.4rem 0;">route</th>
								<th style="padding:0.4rem 0;">m</th>
								<th style="padding:0.4rem 0;">st</th>
								<th style="padding:0.4rem 0;">ms</th>
								<th style="padding:0.4rem 0;">cc</th>
								<th style="padding:0.4rem 0;">wallet</th>
								<th style="padding:0.4rem 0;">cache</th>
							</tr>
						</thead>
						<tbody>
							{recentLogs.map((r) => (
								<tr style="border-top: 1px solid rgba(255,255,255,0.12);">
									<td style="padding:0.45rem 0; font-family: ui-monospace, monospace;">{str(r.ts)}</td>
									<td style="padding:0.45rem 0; font-family: ui-monospace, monospace;">{str(r.route_key)}</td>
									<td style="padding:0.45rem 0; font-family: ui-monospace, monospace;">{str(r.route)}</td>
									<td style="padding:0.45rem 0;">{str(r.method)}</td>
									<td style="padding:0.45rem 0;">{num(r.status)}</td>
									<td style="padding:0.45rem 0;">{num(r.ms)}</td>
									<td style="padding:0.45rem 0;">{str(r.country_code)}</td>
									<td style="padding:0.45rem 0; font-family: ui-monospace, monospace;">{r.wallet_address ?? ''}</td>
									<td style="padding:0.45rem 0;">{num(r.cache_hit) ? 'Y' : 'N'}</td>
								</tr>
							))}
							{recentLogs.length === 0 && (
								<tr><td colspan="9" style="padding:0.75rem 0; opacity:0.8;">{t.noDetailedLogs}</td></tr>
							)}
						</tbody>
					</table>
				</div>
			</div>
		)}

		<!-- ── Scam Checker Usage ── -->
		<div style="margin-top: 2.5rem;">
			<h2 style="font-size: 1.1rem; margin: 0 0 0.75rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600;">
				{t.checkerHeading}
			</h2>

			{checkerTotals[0] ? (() => {
				const chk = checkerTotals[0];
				return (
					<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem; margin-bottom: 1.5rem;">
						{[
							{ label: t.checkerLabelTotal,           value: num(chk.total_checks).toLocaleString()    },
							{ label: t.checkerLabelUniqueUsers,     value: num(chk.unique_users).toLocaleString()    },
							{ label: t.checkerLabelUniqueAddresses, value: num(chk.unique_addresses).toLocaleString() },
							{ label: t.checkerLabelCacheHits,       value: num(chk.cache_hits).toLocaleString()      },
						].map((s) => (
							<div style="padding: 0.9rem 1rem; border-radius: 1rem; border: 1px solid rgba(234,179,8,0.3); background: rgba(234,179,8,0.06);">
								<div style="font-size: 0.75rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.3rem;">{s.label}</div>
								<div style="font-size: 1.5rem; font-weight: 800;">{s.value}</div>
							</div>
						))}
					</div>
				);
			})() : <p style="opacity:0.6;">{t.checkerNoData}</p>}

			<!-- Per-day trend -->
			{checkerByDay.length > 0 && (
				<div style="margin-bottom: 1.5rem;">
					<h3 style="font-size: 0.9rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.5rem;">{t.checkerDailyHeading}</h3>
					<div style="overflow-x: auto;">
						<table style="width: 100%; border-collapse: collapse; font-size: 0.82rem;">
							<thead>
								<tr style="opacity: 0.6; text-align: left;">
									<th style="padding: 0.3rem 0.75rem 0.3rem 0;">{t.checkerColDate}</th>
									<th style="padding: 0.3rem 0.75rem;">{t.checkerColChecks}</th>
									<th style="padding: 0.3rem 0.75rem;">{t.checkerColUniqueUsers}</th>
								</tr>
							</thead>
							<tbody>
								{checkerByDay.map((r) => (
									<tr style="border-top: 1px solid rgba(255,255,255,0.08);">
										<td style="padding: 0.4rem 0.75rem 0.4rem 0; font-family: ui-monospace, monospace;">{str(r.day)}</td>
										<td style="padding: 0.4rem 0.75rem;">{num(r.checks)}</td>
										<td style="padding: 0.4rem 0.75rem;">{num(r.unique_users)}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			)}

			<!-- Per-user breakdown -->
			{checkerByUser.length > 0 && (
				<div>
					<h3 style="font-size: 0.9rem; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 0.5rem;">{t.checkerPerUserHeading}</h3>
					<div style="overflow-x: auto;">
						<table style="width: 100%; border-collapse: collapse; font-size: 0.82rem;">
							<thead>
								<tr style="opacity: 0.6; text-align: left;">
									<th style="padding: 0.3rem 0.75rem 0.3rem 0;">{t.checkerColUserHash}</th>
									<th style="padding: 0.3rem 0.75rem;">{t.checkerColTotalChecks}</th>
									<th style="padding: 0.3rem 0.75rem;">{t.checkerColUniqueAddresses}</th>
									<th style="padding: 0.3rem 0.75rem;">{t.checkerColLastSeen}</th>
								</tr>
							</thead>
							<tbody>
								{checkerByUser.map((r) => (
									<tr style="border-top: 1px solid rgba(255,255,255,0.08);">
										<td style="padding: 0.4rem 0.75rem 0.4rem 0; font-family: ui-monospace, monospace; font-size: 0.75rem; opacity: 0.7;">{str(r.ip_hash).slice(0, 12)}…</td>
										<td style="padding: 0.4rem 0.75rem; font-weight: 700;">{num(r.checks)}</td>
										<td style="padding: 0.4rem 0.75rem;">{num(r.unique_addrs)}</td>
										<td style="padding: 0.4rem 0.75rem; opacity: 0.7; font-family: ui-monospace, monospace; font-size: 0.75rem;">{str(r.last_check).slice(0, 10)}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</div>
			)}
		</div>

	</section>
</Layout>
