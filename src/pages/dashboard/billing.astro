---
import './billing.css';
import Layout from '../../layouts/Layout.astro';
import { requireTenantSession } from '@/lib/requireTenantSession';
import { getActivePlan, PLANS } from '@/lib/subscriptions';
import { db } from '@/lib/db';
import { getLang } from '@/lib/i18n/locale';
import { getBilling } from '@/i18n/dashboard/billing';

const lang = getLang(Astro.request);
const t = getBilling(lang);
const dateLocale = lang === 'es' ? 'es-ES' : lang === 'fr' ? 'fr-FR' : 'en-US';

const { tenantId } = await requireTenantSession(Astro.request);
const currentPlan = await getActivePlan(tenantId);

// Load full subscription row for renewal date / cancel status
const subResult = await db.execute({
  sql: `SELECT current_period_end, cancel_at_period_end, stripe_subscription_id FROM subscriptions WHERE tenant_id = ? LIMIT 1`,
  args: [tenantId],
});
const sub = subResult.rows[0] as Record<string, unknown> | undefined;
const periodEnd = sub?.current_period_end as string | null;
const cancelAtEnd = sub?.cancel_at_period_end === 1;
const hasStripeSubscription = !!(sub?.stripe_subscription_id);

const successParam = Astro.url.searchParams.get('success');
const cancelledParam = Astro.url.searchParams.get('cancelled');

const priceIds = {
  starter: {
    monthly: import.meta.env.STRIPE_PRICE_STARTER_MONTHLY,
    yearly:  import.meta.env.STRIPE_PRICE_STARTER_YEARLY,
  },
  pro: {
    monthly: import.meta.env.STRIPE_PRICE_PRO_MONTHLY,
    yearly:  import.meta.env.STRIPE_PRICE_PRO_YEARLY,
  },
  unlimited: {
    monthly: import.meta.env.STRIPE_PRICE_UNLIMITED_MONTHLY,
    yearly:  import.meta.env.STRIPE_PRICE_UNLIMITED_YEARLY,
  },
};
---

<Layout title={t.pageTitle} noindex={true}>
  <main class="billing-page">

    <header class="billing-header">
      <h1 class="billing-title">{t.heroTitle}</h1>
      {successParam && (
        <div class="billing-banner billing-banner--success">
          {t.successBanner(currentPlan.label)}
        </div>
      )}
      {cancelledParam && (
        <div class="billing-banner billing-banner--warn">
          {t.cancelledBanner}
        </div>
      )}
    </header>

    <!-- Current plan status -->
    <section class="billing-current">
      <div class="billing-current__card">
        <div class="billing-current__info">
          <div class="billing-current__label">{t.currentPlanLabel}</div>
          <div class="billing-current__plan">{currentPlan.label}</div>
          <div class="billing-current__limits">
            {currentPlan.walletLimit === 0
              ? t.unlimitedTins
              : t.upToTins(currentPlan.walletLimit)}
          </div>
          {periodEnd && (
            <div class="billing-current__renewal">
              {cancelAtEnd
                ? t.cancelsOn(new Date(periodEnd).toLocaleDateString(dateLocale))
                : t.renews(new Date(periodEnd).toLocaleDateString(dateLocale))}
            </div>
          )}
        </div>
        {hasStripeSubscription && (
          <button class="billing-portal-btn" id="portal-btn">
            {t.manageSubscription}
          </button>
        )}
      </div>
    </section>

    <!-- Billing interval toggle -->
    <div class="billing-toggle">
      <span class="billing-toggle__label">{t.intervalMonthly}</span>
      <button class="billing-toggle__btn" id="interval-toggle" aria-pressed="false">
        <span class="billing-toggle__knob"></span>
      </button>
      <span class="billing-toggle__label">
        {t.intervalYearly} <em class="billing-toggle__save">{t.yearlySave}</em>
      </span>
    </div>

    <!-- Plan cards -->
    <div class="billing-plans">

      <!-- Starter -->
      <div class={`billing-plan ${currentPlan.id === 'starter' ? 'billing-plan--current' : ''}`}>
        <div class="billing-plan__name">Starter</div>
        <div class="billing-plan__price">
          <span class="billing-plan__amount" data-monthly="$7" data-yearly="$70">$7</span>
          <span class="billing-plan__per" data-monthly="/mo" data-yearly="/yr">/mo</span>
        </div>
        <ul class="billing-plan__features">
          <li>{t.starterFeat1}</li>
          <li>{t.starterFeat2}</li>
          <li>{t.starterFeat3}</li>
          <li>{t.starterFeat4}</li>
        </ul>
        {currentPlan.id === 'starter' ? (
          <div class="billing-plan__badge">{t.currentPlanBadge}</div>
        ) : (
          <button
            class="billing-plan__btn"
            data-monthly={priceIds.starter.monthly}
            data-yearly={priceIds.starter.yearly}
          >
            {currentPlan.id === 'free' ? t.upgradeToStarter : t.switchToStarter}
          </button>
        )}
      </div>

      <!-- Pro -->
      <div class={`billing-plan billing-plan--featured ${currentPlan.id === 'pro' ? 'billing-plan--current' : ''}`}>
        <div class="billing-plan__badge-top">{t.mostPopular}</div>
        <div class="billing-plan__name">Pro</div>
        <div class="billing-plan__price">
          <span class="billing-plan__amount" data-monthly="$20" data-yearly="$200">$20</span>
          <span class="billing-plan__per" data-monthly="/mo" data-yearly="/yr">/mo</span>
        </div>
        <ul class="billing-plan__features">
          <li>{t.proFeat1}</li>
          <li>{t.proFeat2}</li>
          <li>{t.proFeat3}</li>
          <li>{t.proFeat4}</li>
        </ul>
        {currentPlan.id === 'pro' ? (
          <div class="billing-plan__badge">{t.currentPlanBadge}</div>
        ) : (
          <button
            class="billing-plan__btn billing-plan__btn--featured"
            data-monthly={priceIds.pro.monthly}
            data-yearly={priceIds.pro.yearly}
          >
            {['free','starter'].includes(currentPlan.id) ? t.upgradeToPro : t.switchToPro}
          </button>
        )}
      </div>

      <!-- Unlimited -->
      <div class={`billing-plan ${currentPlan.id === 'unlimited' ? 'billing-plan--current' : ''}`}>
        <div class="billing-plan__name">Unlimited</div>
        <div class="billing-plan__price">
          <span class="billing-plan__amount" data-monthly="$39" data-yearly="$400">$39</span>
          <span class="billing-plan__per" data-monthly="/mo" data-yearly="/yr">/mo</span>
        </div>
        <ul class="billing-plan__features">
          <li>{t.unlimitedFeat1}</li>
          <li>{t.unlimitedFeat2}</li>
          <li>{t.unlimitedFeat3}</li>
          <li>{t.unlimitedFeat4}</li>
        </ul>
        {currentPlan.id === 'unlimited' ? (
          <div class="billing-plan__badge">{t.currentPlanBadge}</div>
        ) : (
          <button
            class="billing-plan__btn"
            data-monthly={priceIds.unlimited.monthly}
            data-yearly={priceIds.unlimited.yearly}
          >
            {t.upgradeToUnlimited}
          </button>
        )}
      </div>

    </div>

    <p class="billing-fine">
      {t.finePrint}
      <a href="mailto:donnie@titaniumhut.com">{t.contactUs}</a>.
    </p>

  </main>
</Layout>

<div
  id="billing-i18n"
  hidden
  data-redirecting={t.redirecting}
  data-checkout-error={t.checkoutError}
  data-network-error={t.networkError}
  data-opening-portal={t.openingPortal}
  data-portal-error={t.portalError}
  data-manage-subscription={t.manageSubscription}
></div>

<script>
  const toggle = document.getElementById('interval-toggle') as HTMLButtonElement;
  let yearly = false;

  // Localized status strings injected from the page (see #billing-i18n)
  const i18n = document.getElementById('billing-i18n')?.dataset ?? {};
  const T = {
    redirecting: i18n.redirecting ?? 'Redirecting…',
    checkoutError: i18n.checkoutError ?? 'Unable to start checkout. Please try again.',
    networkError: i18n.networkError ?? 'Network error. Please try again.',
    openingPortal: i18n.openingPortal ?? 'Opening portal…',
    portalError: i18n.portalError ?? 'Unable to open billing portal.',
    manageSubscription: i18n.manageSubscription ?? 'Manage subscription →',
  };

  // Sync all price amounts and per-labels
  function syncInterval() {
    const key = yearly ? 'yearly' : 'monthly';
    document.querySelectorAll<HTMLElement>('.billing-plan__amount').forEach(el => {
      el.textContent = el.dataset[key] ?? el.textContent;
    });
    document.querySelectorAll<HTMLElement>('.billing-plan__per').forEach(el => {
      el.textContent = el.dataset[key] ?? el.textContent;
    });
    toggle?.setAttribute('aria-pressed', String(yearly));
    toggle?.classList.toggle('is-yearly', yearly);
  }

  toggle?.addEventListener('click', () => {
    yearly = !yearly;
    syncInterval();
  });

  // Plan upgrade buttons → create Stripe checkout session
  document.querySelectorAll<HTMLButtonElement>('.billing-plan__btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const priceId = yearly ? btn.dataset.yearly : btn.dataset.monthly;
      if (!priceId) return;
      btn.disabled = true;
      btn.textContent = T.redirecting;

      try {
        const res = await fetch('/api/billing/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ priceId }),
        });
        const data = await res.json();
        if (data.url) {
          window.location.href = data.url;
        } else {
          alert(data.message ?? T.checkoutError);
          btn.disabled = false;
        }
      } catch {
        alert(T.networkError);
        btn.disabled = false;
      }
    });
  });

  // Manage subscription → Stripe Customer Portal
  document.getElementById('portal-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('portal-btn') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = T.openingPortal;
    try {
      const res = await fetch('/api/billing/portal', { method: 'POST' });
      const data = await res.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert(data.message ?? T.portalError);
        btn.disabled = false;
        btn.textContent = T.manageSubscription;
      }
    } catch {
      alert(T.networkError);
      btn.disabled = false;
      btn.textContent = T.manageSubscription;
    }
  });
</script>

