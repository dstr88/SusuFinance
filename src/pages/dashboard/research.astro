---
import './research.css';
import Layout from '../../layouts/Layout.astro';
import NetWorthHero from '../../components/dashboard/NetWorthHero.astro';
import AddTransactionModal from '../../components/dashboard/AddTransactionModal.astro';
import ResearchTour from '../../components/tours/ResearchTour.astro';
import LostTxTour from '../../components/tours/LostTxTour.astro';
import { requireTenantSession } from '../../lib/requireTenantSession';
import { isAdminSession } from '../../lib/adminGuard';
import { db } from '../../lib/db';
import { runNeedsAttentionQueries } from '../../lib/getNeedsAttention';
import { getCache, setCache } from '../../lib/tursoCache';
import { getLang } from '@/lib/i18n/locale';
import { getResearch } from '@/i18n/dashboard/research';

const lang = getLang(Astro.request);
const t = getResearch(lang);

const session = await requireTenantSession(Astro.request);
if (!session) return Astro.redirect('/login');
const { tenantId } = session;
const isAdmin = await isAdminSession(Astro.request);

// Pre-fetch NA data server-side so the page is never blank on cold start.
// Render's cold-start takes 30-60s; the client's AbortController fires at 28s,
// causing an infinite "Loading…" loop. By embedding the data in the HTML we
// guarantee the first render is instant regardless of service-wake timing.
const NA_TURSO_KEY = `t:${tenantId}:research:needs-attention:v2`;
const NA_CACHE_TTL = 900;
const NA_STALE_MAX = 3600;
let naData: object | null = null;
const ssrT0 = Date.now();

// Step 1: try cache with a short timeout — treat any failure as a miss
let cachedValue: object | null = null;
try {
  const cacheResult = await Promise.race([
    getCache<object>(NA_TURSO_KEY, { allowStale: true, staleMaxAgeSeconds: NA_STALE_MAX }),
    new Promise<null>((resolve) => setTimeout(() => resolve(null), 4_000)),
  ]);
  if (cacheResult?.value != null) cachedValue = cacheResult.value;
} catch { /* cache unavailable — fall through to live query */ }

if (cachedValue != null) {
  naData = cachedValue;
  console.log(`[research SSR] NA cache hit (${Date.now() - ssrT0}ms) total=${(naData as any)?.total ?? '?'}`);
} else {
  // Step 2: live query — fail fast so Render's 30s HTTP cutoff isn't hit
  try {
    naData = await Promise.race([
      runNeedsAttentionQueries(tenantId),
      new Promise<never>((_, reject) =>
        setTimeout(() => reject(new Error('SSR NA query timed out')), 20_000)
      ),
    ]);
    void setCache(NA_TURSO_KEY, naData, NA_CACHE_TTL);
    console.log(`[research SSR] NA live query (${Date.now() - ssrT0}ms) total=${(naData as any)?.total ?? '?'}`);
  } catch (err) {
    console.error('[research SSR] NA prefetch failed, client will fetch:', err);
  }
}
console.log(`[research SSR] naData is ${naData == null ? 'NULL — client will fetch' : `present (total=${(naData as any)?.total ?? '?'})`}`);

// Load all distinct symbols the user has data for (for the chip row)
const symbolResult = await db.execute({
  sql: `SELECT DISTINCT upper(asset_symbol) as sym
        FROM import_transactions
        WHERE tenant_id = ? AND asset_symbol IS NOT NULL
        ORDER BY upper(asset_symbol) ASC`,
  args: [tenantId],
});
const allSymbols = symbolResult.rows.map(r => String((r as any).sym ?? '')).filter(Boolean);

// Load tenant wallets for the "Add Transaction" picker
const walletResult = await db.execute({
  sql: `SELECT id, address, label FROM wallets WHERE tenant_id = ? ORDER BY label ASC`,
  args: [tenantId],
});
const tenantWallets = walletResult.rows.map(r => ({
  id:      String((r as any).id      ?? ''),
  address: String((r as any).address ?? ''),
  label:   String((r as any).label   ?? ''),
}));

// Prevent Render's edge / CDN layer from caching this authenticated page.
// Without this, the HTML response can be served stale from cache — the
// client never gets a fresh page and the na-ssr-data element is never
// updated, causing NA to show "Loading…" indefinitely.
Astro.response.headers.set('Cache-Control', 'no-store');
---

<Layout title={t.pageTitle} noindex={true}>
  <section class="research-page">

    <div class="hero-bleed">
      <NetWorthHero title="Research" subtitle="Explore & resolve your transactions" />
    </div>

    <!-- ── Sticky note ──────────────────────────────────────────────────────── -->
    <div style="
      background: rgba(45,212,168,0.08);
      border: 1px solid rgba(45,212,168,0.22);
      border-left: 4px solid var(--accent);
      border-radius: 0 8px 8px 0;
      padding: 1rem 1.4rem;
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
      margin: 0 0 1.5rem;
    ">
      <span style="font-size:1.1rem; line-height:1.4;"></span>
      <div style="display:flex; flex-direction:column; gap:0.4rem;">
        <p style="margin:0; font-size:0.85rem; font-weight:600; color:var(--accent);">{t.stickyHeading}</p>
        <p style="margin:0; font-size:0.83rem; color:var(--text-secondary); line-height:1.55;">
          {t.stickyBody}
        </p>
        <ul style="margin:0.2rem 0 0; padding-left:1.2rem; font-size:0.83rem; color:var(--text-secondary); line-height:1.7;">
          <li><strong style="color:var(--text-primary);">{t.stickyLi1Strong}</strong>{t.stickyLi1Rest}</li>
          <li><strong style="color:var(--text-primary);">{t.stickyLi2Strong}</strong>{t.stickyLi2Rest}</li>
          <li><strong style="color:var(--text-primary);">{t.stickyLi3Strong}</strong>{t.stickyLi3Rest}</li>
        </ul>
        <p style="margin:0.3rem 0 0; font-size:0.78rem; color:var(--text-muted);">
          {t.stickyTip}
        </p>
      </div>
    </div>

    <!-- ── Address lookup panel ───────────────────────────────────────────────── -->
    <div id="addr-panel" class="addr-panel" style="display:none">
      <div id="addr-panel-inner"></div>
    </div>

    <!-- ── Two-column body ─────────────────────────────────────────────────── -->
    <div class="research-body">

      <!-- Left: Needs Attention -->
      <div class="col-left">
        <div class="col-header">
          <h2>{t.colNeedsAttention} <span id="na-count" class="count-badge"></span> <ResearchTour /> <LostTxTour /></h2>
          <p class="col-scope">{t.colScope} <span id="na-synced" class="na-synced-badge" style="display:none"></span></p>
          <div class="na-ai-actions">
            <button id="btn-ai-triage" class="btn-ai-triage" type="button">{t.btnAiTriage}</button>
            <button id="btn-backfill" class="btn-backfill" type="button">{t.btnFillPrices}</button>
          </div>
        </div>
        <div id="triage-panel" class="triage-panel" style="display:none"></div>
        <div id="na-list" class="item-list">
          <div class="loading-msg">Loading…</div>
        </div>

        <!-- Resolved tin -->
        <div class="resolved-header" id="resolved-header" style="display:none">
          <span>{t.resolved}</span>
          <span id="resolved-count" class="count-badge-green"></span>
          <button id="resolved-toggle" class="resolved-toggle" type="button">{t.resolvedShow}</button>
        </div>
        <div id="resolved-list" class="resolved-list" style="display:none"></div>
      </div>

      <!-- Right: Search + Results -->
      <div class="col-right">

        <!-- Search card — lives at top of the results panel -->
        <div class="search-card">
          <div class="search-tier-1">
            <span class="search-icon"></span>
            <input
              id="q"
              type="text"
              placeholder={t.searchPlaceholder}
              autocomplete="off"
              spellcheck="false"
            />
          </div>

          <div class="search-tier-2">
            <select id="filter-symbol">
              <option value="">{t.filterAllSymbols}</option>
              {allSymbols.map(sym => <option value={sym}>{sym}</option>)}
            </select>

            <input id="filter-from" type="date" title="From date" />
            <span class="date-sep">→</span>
            <input id="filter-to"   type="date" title="To date"   />

            <input id="filter-note" type="text" placeholder={t.filterNotePlaceholder} autocomplete="off" />
          </div>

          <!-- Symbol chips -->
          <div class="chip-row" id="chip-row">
            {allSymbols.map(sym => (
              <button class="chip" data-sym={sym} type="button">{sym}</button>
            ))}
          </div>

          <div class="search-actions">
            <button id="btn-resolve" class="btn-secondary" type="button">{t.btnResolve}</button>
            <button id="btn-ignore-dust" class="btn-secondary" type="button">{t.btnIgnoreDust}</button>
            <button id="btn-classify-p2p" class="btn-secondary" type="button">{t.btnP2p}</button>
            <div class="wallet-picker-wrap">
              <button id="btn-add-tx" class="btn-secondary" type="button">{t.btnAddTransaction}</button>
              <div id="wallet-picker" class="wallet-picker" style="display:none">
                <div class="wallet-picker-header">{t.walletPickerHeader}</div>
                {tenantWallets.length === 0 ? (
                  <div class="wallet-picker-empty">{t.walletPickerEmpty}</div>
                ) : (
                  tenantWallets.map(w => (
                    <button
                      class="wallet-picker-item"
                      type="button"
                      data-wallet-id={w.id}
                      data-wallet-label={w.label || w.address.slice(0, 8) + '…'}
                      data-wallet-address={w.address}
                    >
                      <span class="wpi-label">{w.label || <span style="opacity:0.5">{t.walletUnnamed}</span>}</span>
                      <span class="wpi-addr">{w.address.slice(0, 6)}…{w.address.slice(-4)}</span>
                    </button>
                  ))
                )}
              </div>
            </div>
            <button id="btn-search" class="btn-primary" type="button">{t.btnSearch}</button>
          </div>
          <div id="resolve-status-bar" class="resolve-status-bar" style="display:none">
            <span id="resolve-status" class="resolve-status"></span>
          </div>
          <div id="p2p-panel" class="p2p-panel" style="display:none">
            <span class="p2p-panel__label">{t.p2pPanelLabel}</span>
            <button id="btn-p2p-own" class="btn-secondary" type="button">{t.p2pOwnAccount}</button>
            <button id="btn-p2p-disposal" class="btn-secondary" type="button">{t.p2pThirdParty}</button>
            <button id="btn-p2p-cancel" class="btn-secondary" type="button">✕</button>
          </div>
        </div>

        <!-- Results header -->
        <div class="col-header">
          <h2>{t.colResults} <span id="results-count" class="count-badge"></span></h2>
          <div id="results-label" class="results-label" style="display:none"></div>
        </div>

        <!-- Sort controls -->
        <div id="results-sort-bar" class="results-sort-bar" style="display:none">
          <span class="sort-label">{t.sortLabel}</span>
          <button id="sort-btn-date"   class="sort-btn active" onclick="setResultsSort('date')">{t.sortDate}</button>
          <button id="sort-btn-amount" class="sort-btn"        onclick="setResultsSort('amount')">{t.sortAmount}</button>
        </div>

        <!-- Action panel: shown when an NA item is selected -->
        <div id="na-action-panel" style="display:none"></div>

        <div id="results-list" class="item-list">
          <div class="empty-msg">{t.emptySearch}</div>
        </div>
      </div>

    </div>

    <!-- ── Dataset Health Check ──────────────────────────────────────────── -->
    <div class="health-section" id="health-section">
      <div class="health-header">
        <h2>{t.healthTitle}</h2>
        <div class="health-header-right">
          <span id="health-last-run" class="health-last-run"></span>
          <button id="btn-run-health" class="btn-secondary" type="button">{t.btnRunDiagnostics}</button>
        </div>
      </div>

      <div id="health-grid" class="health-grid"></div>

      <div class="intake-launch-row">
        <button id="btn-open-questionnaire" class="btn-questionnaire-launch" type="button">
          {t.btnDatasetQuestionnaire}
        </button>
        <span id="intake-completion-badge" class="intake-completion-badge" style="display:none"></span>
      </div>
    </div>

  <!-- ── Dataset Questionnaire Wizard ───────────────────────────────────────── -->
  <div id="intake-wizard-overlay" class="intake-wizard-overlay" style="display:none" aria-modal="true" role="dialog">
    <div class="intake-wizard-modal">
      <button class="intake-wizard-close" id="intake-wizard-close" aria-label="Close">✕</button>
      <div class="intake-wizard-progress" id="intake-wizard-progress"></div>
      <div class="intake-wizard-body" id="intake-wizard-body"></div>
      <div class="intake-wizard-nav">
        <button class="btn-secondary intake-wizard-back" id="intake-wizard-back" type="button">← Back</button>
        <button class="btn-primary intake-wizard-next" id="intake-wizard-next" type="button">Next →</button>
      </div>
    </div>
  </div>

  </section>

  {isAdmin && (
    <>
      <!-- ── Admin activity log pill ──────────────────────────────────────── -->
      <button id="log-pill" aria-label="Activity log">Log</button>

      <!-- ── Admin activity log panel ────────────────────────────────────── -->
      <div id="log-panel" aria-hidden="true">
        <div class="log-panel-header">
          <span class="log-panel-title">Activity Log</span>
          <span class="log-panel-note">Counts only — no private data stored</span>
          <button id="log-panel-close" aria-label="Close">✕</button>
        </div>
        <div class="log-filter-row" id="log-filter-row">
          <button class="log-chip log-chip-active" data-filter="all" data-group="source">All sources</button>
          <button class="log-chip log-chip-active" data-filter="all" data-group="chain">All chains</button>
        </div>
        <div id="log-entries" class="log-entries">
          <div class="log-empty">Loading…</div>
        </div>
      </div>
    </>
  )}
</Layout>

<!-- ── Suggested match confirmation modal ──────────────────────────────────── -->
<div class="modal-overlay" id="match-modal" style="display:none">
  <div class="modal-content">
    <button class="modal-close" id="match-modal-close">×</button>
    <h2>{t.matchModalTitle}</h2>
    <div id="match-modal-body"></div>
    <div class="modal-actions">
      <button class="btn-danger"    id="match-reject">{t.matchModalReject}</button>
      <button class="btn-primary"   id="match-confirm">{t.matchModalConfirm}</button>
    </div>
  </div>
</div>

{naData && (
  <div id="na-ssr-data" style="display:none" set:text={JSON.stringify(naData)}></div>
)}

<script is:inline define:vars={{ researchI18n: {
  loading:                   t.colNeedsAttention === 'Needs Attention' ? 'Loading…' : (t.lang === 'es' ? 'Cargando…' : 'Chargement…'),
  retrying:                  t.lang === 'es' ? "Reintentando…" : t.lang === 'fr' ? "Nouvelle tentative…" : "Retrying…",
  stillWorking:              t.lang === 'es' ? "Aún procesando — vuelve en un momento." : t.lang === 'fr' ? "Toujours en cours — revenez dans un instant." : "Still working on it — check back in a moment.",
  nothingToReview:           t.lang === 'es' ? "✓ Todo al día — nada por revisar." : t.lang === 'fr' ? "✓ Tout est à jour — rien à examiner." : "✓ You're all caught up — nothing to review.",
  everythingMatched:         t.lang === 'es' ? "✓ Todo coincide. Nada pendiente por revisar." : t.lang === 'fr' ? "✓ Tout est rapproché. Rien à examiner." : "✓ Everything's matched. Nothing left to review.",
  cleanSlate:                t.lang === 'es' ? "✓ Tabla rasa — sin transacciones pendientes." : t.lang === 'fr' ? "✓ Ardoise vierge — aucune transaction à traiter." : "✓ Clean slate — no transactions need attention.",
  syncedAt:                  t.lang === 'es' ? "· sincronizado a las __T__" : t.lang === 'fr' ? "· synchronisé à __T__" : "· synced __T__",
  suggestedMatches:          t.lang === 'es' ? "Coincidencias sugeridas" : t.lang === 'fr' ? "Correspondances suggérées" : "Suggested matches",
  unresolvedTxs:             t.lang === 'es' ? "Transacciones sin resolver" : t.lang === 'fr' ? "Transactions non résolues" : "Unresolved transactions",
  confidence:                t.lang === 'es' ? "confianza" : t.lang === 'fr' ? "confiance" : "confidence",
  sent:                      t.lang === 'es' ? "Enviado" : t.lang === 'fr' ? "Envoyé" : "Sent",
  received:                  t.lang === 'es' ? "Recibido" : t.lang === 'fr' ? "Reçu" : "Received",
  fee:                       t.lang === 'es' ? "Comisión" : t.lang === 'fr' ? "Frais" : "Fee",
  clickToFindLanded:         t.lang === 'es' ? "Haz clic para ver a dónde fue →" : t.lang === 'fr' ? "Cliquer pour voir où cela est allé →" : "Click to find where this landed →",
  clickToFindSource:         t.lang === 'es' ? "Haz clic para ver de dónde vino →" : t.lang === 'fr' ? "Cliquer pour voir d'où cela vient →" : "Click to find where this came from →",
  dispose:                   t.lang === 'es' ? "Disponer" : t.lang === 'fr' ? "Céder" : "Dispose",
  editDisposal:              t.lang === 'es' ? "Editar disposición" : t.lang === 'fr' ? "Modifier la cession" : "Edit disposal",
  forward:                   t.lang === 'es' ? "↗ Reenviar" : t.lang === 'fr' ? "↗ Transférer" : "↗ Forward",
  addNote:                   t.lang === 'es' ? "Añadir nota" : t.lang === 'fr' ? "Ajouter une note" : "Add note",
  editNote:                  t.lang === 'es' ? "Editar nota" : t.lang === 'fr' ? "Modifier la note" : "Edit note",
  legacyExchange:            t.lang === 'es' ? "Exchange heredado" : t.lang === 'fr' ? "Exchange défunt" : "Legacy exchange",
  attach:                    t.lang === 'es' ? "Adjuntar" : t.lang === 'fr' ? "Joindre" : "Attach",
  helpBtn:                   t.lang === 'es' ? "? Ayuda" : t.lang === 'fr' ? "? Aide" : "? Help",
  aboutTxHistory:            t.lang === 'es' ? "Sobre mi historial de transacciones" : t.lang === 'fr' ? "À propos de mon historique de transactions" : "About my transaction history",
  resolvedAuto:              t.lang === 'es' ? "auto" : t.lang === 'fr' ? "auto" : "auto",
  resolvedConfirmed:         t.lang === 'es' ? "✓ confirmado" : t.lang === 'fr' ? "✓ confirmé" : "✓ confirmed",
  resolvedShow:              t.resolvedShow,
  resolvedHide:              t.resolvedHide,
  searchCleared:             t.lang === 'es' ? "Búsqueda borrada." : t.lang === 'fr' ? "Recherche effacée." : "Search cleared.",
  searching:                 t.lang === 'es' ? "Buscando…" : t.lang === 'fr' ? "Recherche en cours…" : "Searching…",
  noTransactionsFound:       t.lang === 'es' ? "No se encontraron transacciones." : t.lang === 'fr' ? "Aucune transaction trouvée." : "No transactions found.",
  searchFailed:              t.lang === 'es' ? "Búsqueda fallida: __MSG__" : t.lang === 'fr' ? "Échec de la recherche : __MSG__" : "Search failed: __MSG__",
  matching:                  t.lang === 'es' ? "Cotejando…" : t.lang === 'fr' ? "Mise en correspondance…" : "Matching…",
  classifying:               t.lang === 'es' ? "Clasificando…" : t.lang === 'fr' ? "Classification…" : "Classifying…",
  nothingNewToResolve:       t.lang === 'es' ? "✓ Nada nuevo por resolver" : t.lang === 'fr' ? "✓ Rien de nouveau à résoudre" : "✓ Nothing new to resolve",
  matched:                   t.lang === 'es' ? "cotejadas" : t.lang === 'fr' ? "rapprochées" : "matched",
  classified:                t.lang === 'es' ? "clasificadas" : t.lang === 'fr' ? "classifiées" : "classified",
  scanned:                   t.lang === 'es' ? "analizadas" : t.lang === 'fr' ? "analysées" : "scanned",
  dismissing:                t.lang === 'es' ? "Descartando…" : t.lang === 'fr' ? "Rejet en cours…" : "Dismissing…",
  dustDismissed:             t.lang === 'es' ? "✓ __N__ transacciones de polvo descartadas" : t.lang === 'fr' ? "✓ __N__ transactions poussière rejetées" : "✓ __N__ dust transactions dismissed",
  noDust:                    t.lang === 'es' ? "✓ Sin polvo por descartar" : t.lang === 'fr' ? "✓ Aucune poussière à rejeter" : "✓ No dust to dismiss",
  p2pClassified:             t.lang === 'es' ? "✓ __N__ transferencias P2P clasificadas" : t.lang === 'fr' ? "✓ __N__ transferts P2P classifiés" : "✓ __N__ P2P transfers classified",
  noP2p:                     t.lang === 'es' ? "✓ No se encontraron transferencias P2P" : t.lang === 'fr' ? "✓ Aucun transfert P2P trouvé" : "✓ No P2P transfers found",
  failedTryAgain:            t.lang === 'es' ? "Fallido — inténtalo de nuevo" : t.lang === 'fr' ? "Échec — veuillez réessayer" : "Failed — try again",
  loadNaFirst:               t.lang === 'es' ? "Carga primero Needs Attention." : t.lang === 'fr' ? "Chargez d'abord Needs Attention." : "Load Needs Attention first.",
  triaging:                  t.lang === 'es' ? "Triando…" : t.lang === 'fr' ? "Triage en cours…" : "Triaging…",
  analysingTxs:              t.lang === 'es' ? "Analizando __N__ transacciones…" : t.lang === 'fr' ? "Analyse de __N__ transactions…" : "Analysing __N__ transactions…",
  upgradeForTriage:          t.lang === 'es' ? "Actualiza a un plan de pago para usar AI Triage." : t.lang === 'fr' ? "Passez à un forfait payant pour utiliser AI Triage." : "Upgrade to a paid plan to use AI Triage.",
  triageFailed:              t.lang === 'es' ? "Triage fallido: __MSG__" : t.lang === 'fr' ? "Échec du triage : __MSG__" : "Triage failed: __MSG__",
  triageAutoNote:            t.lang === 'es' ? "✓ __N__ elemento(s) resueltos automáticamente y eliminados de Needs Attention. Los backfills de precios quedan para tu revisión." : t.lang === 'fr' ? "✓ __N__ élément(s) résolu(s) automatiquement et retiré(s) de Needs Attention. Les complétions de prix restent pour votre examen." : "✓ __N__ item__S__ auto-resolved and removed from Needs Attention. Price backfills stay for your review.",
  triageAdvisory:            t.lang === 'es' ? "El triage es orientativo — revisa antes de actuar." : t.lang === 'fr' ? "Le triage est indicatif — vérifiez avant d'agir." : "Triage is advisory — review before acting on AI suggestions.",
  triageLabelAnnotated:      t.lang === 'es' ? "Ya anotado" : t.lang === 'fr' ? "Déjà annoté" : "Already annotated",
  triageLabelPurchase:       t.lang === 'es' ? "Compra obvia" : t.lang === 'fr' ? "Achat évident" : "Obvious purchase",
  triageLabelIncome:         t.lang === 'es' ? "Ingreso obvio" : t.lang === 'fr' ? "Revenu évident" : "Obvious income",
  triageLabelOwnWallet:      t.lang === 'es' ? "Wallet propia obvia" : t.lang === 'fr' ? "Wallet propre évident" : "Obvious own-wallet",
  triageLabelSale:           t.lang === 'es' ? "Venta/disposición obvia" : t.lang === 'fr' ? "Vente/cession évidente" : "Obvious sale/disposal",
  triageLabelNeedsReview:    t.lang === 'es' ? "Necesita revisión manual" : t.lang === 'fr' ? "Nécessite une révision manuelle" : "Needs manual review",
  fetchingPrices:            t.lang === 'es' ? "Obteniendo precios…" : t.lang === 'fr' ? "Récupération des prix…" : "Fetching prices…",
  paidFeature:               t.lang === 'es' ? "Función de pago" : t.lang === 'fr' ? "Fonctionnalité payante" : "Paid feature",
  pricedSkipped:             t.lang === 'es' ? "✓ __P__ valorados · __S__ omitidos" : t.lang === 'fr' ? "✓ __P__ valorisés · __S__ ignorés" : "✓ __P__ priced · __S__ skipped",
  backfillFailed:            t.lang === 'es' ? "Backfill fallido" : t.lang === 'fr' ? "Échec du backfill" : "Backfill failed",
  fillMissingPrices:         t.btnFillPrices,
