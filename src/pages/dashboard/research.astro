// ── Chip row ──────────────────────────────────────────────────────────────────
function setActiveChip(sym) {
  activeChip = sym;
  document.querySelectorAll('.chip').forEach(c => {
    c.classList.toggle('active', c.getAttribute('data-sym') === sym);
  });
}

document.querySelectorAll('.chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const sym = chip.getAttribute('data-sym');
    if (activeChip === sym) {
      setActiveChip('');
      naContext = null;
      $('filter-symbol').value = '';
      $('results-label').textContent = '';
      $('results-label').style.display = 'none';
      $('results-list').innerHTML = '<div class="empty-msg">' + i18n('searchCleared', 'Search cleared.') + '</div>';
      $('results-count').textContent = '';
    } else {
      setActiveChip(sym);
      naContext = null;
      $('results-label').textContent = '';
      $('results-label').style.display = 'none';
      $('filter-symbol').value = sym;
      runSearch();
    }
  });
});

// ── NA-triggered search (opposite direction, ±7-day window) ──────────────────
async function runSearchNa(sym, direction, ts) {
  const params = new URLSearchParams({ symbol: sym, direction });

  // Narrow results to ±7 days around the selected transaction's date
  // so the user only sees plausible matches, not their entire history.
  let windowLabel = '';
  if (ts) {
    const center = new Date(ts);
    const before = new Date(center); before.setDate(before.getDate() - 7);
    const after  = new Date(center); after.setDate(after.getDate()  + 7);
    const toDate  = d => d.toISOString().slice(0, 10);   // YYYY-MM-DD
    params.set('from', toDate(before));
    params.set('to',   toDate(after));
    // Also pre-fill the date inputs so the user can see / adjust the window
    $('filter-from').value = toDate(before);
    $('filter-to').value   = toDate(after);
    windowLabel = i18n('within7Days',' within 7 days of __D__').replace('__D__',center.toLocaleDateString(undefined, { month:'short', day:'numeric', year:'numeric' }));
  }

  const list = $('results-list');
  const fromLabel = direction === 'in'
    ? i18n('showingReceived','Showing __S__ received__W__ — potential sources for your __S__ send').replace(/__S__/g,sym).replace('__W__',windowLabel)
    : i18n('showingSent','Showing __S__ sent__W__ — potential destinations for your __S__ deposit').replace(/__S__/g,sym).replace('__W__',windowLabel);

  list.innerHTML = '<div class="loading-msg">' + i18n('searching', 'Searching…') + '</div>';
  $('results-count').textContent = '';
  $('results-label').textContent = fromLabel;
  $('results-label').style.display = 'block';

  try {
    const res  = await fetch('/api/research/search?' + params.toString());
    const data = await res.json();
    renderResults(data);
  } catch (e) {
    list.innerHTML = '<div class="empty-msg">' + i18n('searchFailed', 'Search failed: __MSG__').replace('__MSG__', e.message) + '</div>';
  }
}

// ── Search ────────────────────────────────────────────────────────────────────
async function runSearch() {
  const params = new URLSearchParams();
  const q      = $('q').value.trim();
  const symbol = $('filter-symbol').value.trim();
  const from   = $('filter-from').value;
  const to     = $('filter-to').value;
  const note   = $('filter-note').value.trim();

  if (q)      params.set('q', q);
  if (symbol) params.set('symbol', symbol);
  if (from)   params.set('from', from);
  if (to)     params.set('to', to);
  if (note)   params.set('note', note);

  if (!params.toString()) return;

  naContext = null;
  $('results-label').textContent = '';
  $('results-label').style.display = 'none';

  const list = $('results-list');
  list.innerHTML = '<div class="loading-msg">' + i18n('searching', 'Searching…') + '</div>';
  $('results-count').textContent = '';

  try {
    const res  = await fetch('/api/research/search?' + params.toString());
    const data = await res.json();
    renderResults(data);
  } catch (e) {
    list.innerHTML = '<div class="empty-msg">' + i18n('searchFailed', 'Search failed: __MSG__').replace('__MSG__', e.message) + '</div>';
  }
}

let _lastResultsData = null;
let _sortBy  = 'date';
let _sortDir = 'asc';

window.setResultsSort = setResultsSort;
function setResultsSort(field) {
  if (_sortBy === field) {
    _sortDir = _sortDir === 'asc' ? 'desc' : 'asc';
  } else {
    _sortBy  = field;
    _sortDir = 'asc';
  }
  const arrow = _sortDir === 'asc' ? '↑' : '↓';
  $('sort-btn-date').textContent   = 'Date'   + (_sortBy === 'date'   ? ' ' + arrow : '');
  $('sort-btn-amount').textContent = 'Amount' + (_sortBy === 'amount' ? ' ' + arrow : '');
  $('sort-btn-date').classList.toggle('active',   _sortBy === 'date');
  $('sort-btn-amount').classList.toggle('active', _sortBy === 'amount');
  if (_lastResultsData) renderResults(_lastResultsData);
}

function renderResults(data) {
  _lastResultsData = data;
  const list  = $('results-list');
  const count = $('results-count');
  const rows  = (data.rows ?? []).slice().sort((a, b) => {
    const symCmp = (a.asset_symbol ?? '').localeCompare(b.asset_symbol ?? '');
    if (symCmp !== 0) return symCmp;
    let cmp = 0;
    if (_sortBy === 'amount') {
      cmp = Math.abs(Number(a.amount ?? 0)) - Math.abs(Number(b.amount ?? 0));
    } else {
      cmp = (a.timestamp_utc ?? '').localeCompare(b.timestamp_utc ?? '');
    }
    return _sortDir === 'asc' ? cmp : -cmp;
  });
  count.textContent = rows.length > 0 ? String(rows.length) : '';

  if (!rows.length) {
    list.innerHTML = '<div class="empty-msg">' + i18n('noTransactionsFound', 'No transactions found.') + '</div>';
    $('results-sort-bar').style.display = 'none';
    return;
  }

  $('results-sort-bar').style.display = 'flex';

  let html = '';
  let lastSym = null;
  for (const t of rows) {
    if (t.asset_symbol !== lastSym) {
      html += `<div class="results-group-header">${escapeHtml(t.asset_symbol ?? '—')}</div>`;
      lastSym = t.asset_symbol;
    }
    const dir         = (t.direction ?? '').toLowerCase();
    const isTransfer  = dir === 'out' && t.category === 'own_wallet';
    const dirClass    = isTransfer ? 'transfer' : dir;
    const dirLabel    = isTransfer ? 'transfer' : dir;
    const matchStatus = t.match_status_as_out ?? t.match_status_as_in ?? null;
    const matchDir    = t.match_id_as_out ? '→' : '←';
    const matchBadge  = (t.match_id_as_out || t.match_id_as_in)
      ? `<span class="match-badge${matchStatus === 'suggested' ? ' suggested' : ''}">${matchDir} matched</span>`
      : '';
    const label = '';

    // For Crypto.com fiat→crypto buys, amount = USD fiat side; to_amount = crypto qty.
    // Use to_amount as the display quantity when to_currency matches asset_symbol.
    const qty = (t.to_currency && t.to_currency === t.asset_symbol && t.to_amount != null)
      ? t.to_amount
      : t.amount;
    const amtDisplay = dir === 'out'
      ? `−${fmt(Math.abs(qty ?? 0))}`
      : `+${fmt(qty ?? 0)}`;

    const srcLine      = `${escapeHtml(srcName(t.source))}${t.account_name ? ' · ' + escapeHtml(t.account_name) : ''}`;
    const hasAnnotation = !!(t.category || t.notes);
    const catLabel      = t.category ? `<span class="category-badge">${escapeHtml(t.category)}</span>` : '';
    const noteText      = t.notes    ? `<span class="tx-note-text">${escapeHtml(t.notes)}</span>` : '';

    html += `<div class="tx-card result-card dir-${dirClass}" data-id="${t.id}" data-sym="${t.asset_symbol}" data-dir="${dir}" data-ts="${t.timestamp_utc}" data-amount="${Math.abs(Number(t.amount))}" data-usd="${t.native_usd ?? ''}">
      <div class="tx-badge-col"><span class="tx-dir ${dirClass}">${dirLabel}</span></div>
      <div class="tx-body">
        <div class="tx-row-1">
          <span class="tx-sym">${escapeHtml(t.asset_symbol ?? '?')}</span>${matchBadge}
          <span class="tx-amt">${amtDisplay} ${escapeHtml(t.asset_symbol ?? '')}</span>
        </div>
        <div class="tx-row-2">
          <span class="tx-src">${srcLine}${label}</span>
          ${t.native_usd ? `<span class="tx-usd">${fmtUsd(t.native_usd)}</span>` : ''}
        </div>
        <div class="tx-row-3">
          <span class="tx-desc">${escapeHtml(t.description ?? '')}</span>
          <span class="tx-dt">${fmtDT(t.timestamp_utc)}</span>
        </div>
        ${hasAnnotation ? `<div style="margin-top:0.3rem">${catLabel}${noteText}</div>` : ''}
        <div class="card-actions">
          <button class="btn-annotate${hasAnnotation ? ' has-note' : ''}"
                  data-tx-id="${t.id}"
                  data-category="${t.category ?? ''}"
                  data-note="${(t.notes ?? '').replace(/"/g,'&quot;')}"
                  onclick="openResultAnnotateForm(event, this)">
            ${hasAnnotation ? i18n('editNote','Edit note') : i18n('addNote','Add note')}
          </button>
          <button class="btn-attach"
                  onclick="attachReceipt(event,'${t.id}')">
            ${i18n('attach','Attach')}
          </button>
        </div>
        <div class="att-panel" id="atp-${t.id}"></div>
        <div class="annotate-form" id="af-${t.id}" style="display:none"></div>
      </div>
    </div>`;
  }
  list.innerHTML = html;

  // Wire result card clicks → chain exploration (search opposite direction)
  list.querySelectorAll('.result-card').forEach(el => {
    el.addEventListener('click', () => {
      const sym = el.getAttribute('data-sym');
      const dir = el.getAttribute('data-dir') ?? el.querySelector('.tx-dir')?.textContent?.trim() ?? '';
      const ts  = el.getAttribute('data-ts');
      if (!sym) return;
      list.querySelectorAll('.result-card').forEach(c => c.classList.remove('selected'));
      el.classList.add('selected');
      const opposite = dir === 'out' ? 'in' : 'out';
      naContext = { sym, dir, opposite };
      setActiveChip(sym);
      $('filter-symbol').value = sym;
      runSearchNa(sym, opposite, ts);
    });
  });
}

// ── Button wiring ─────────────────────────────────────────────────────────────
function maybeAddressLookup() {
  const stripped = ($('q').value ?? '').replace(/\s+/g, '');
  if (ADDRESS_RE.test(stripped)) {
    checkAddress(stripped);
    return true;
  }
  return false;
}

$('btn-search').addEventListener('click', () => { if (!maybeAddressLookup()) runSearch(); });
$('q').addEventListener('keydown', e => { if (e.key === 'Enter') { if (!maybeAddressLookup()) runSearch(); } });

$('btn-resolve').addEventListener('click', async () => {
  const btn    = $('btn-resolve');
  const bar    = $('resolve-status-bar');
  const status = $('resolve-status');
  const setStatus = (msg, isError = false) => {
    status.textContent = msg;
    status.className = `resolve-status${isError ? ' resolve-status--error' : ' resolve-status--ok'}`;
    bar.style.display = 'block';
  };
  btn.disabled = true;
  bar.style.display = 'none';
  try {
    btn.textContent = i18n('matching', 'Matching…');
    const matchRes  = await fetch('/api/research/run-matching', { method: 'POST' });
    if (!matchRes.ok) throw new Error(`Matching failed (${matchRes.status})`);
    const matchData = await matchRes.json();

    btn.textContent = i18n('classifying', 'Classifying…');
    const classRes  = await fetch('/api/research/auto-classify', { method: 'POST' });
    if (!classRes.ok) throw new Error(`Classify failed (${classRes.status})`);
    const classData = await classRes.json();

    const matched    = matchData.matched    ?? 0;
    const skipped    = matchData.skipped    ?? 0;
    const classified = classData.classified ?? 0;
    const parts = [];
    if (matched > 0)    parts.push(matched + ' ' + i18n('matched', 'matched'));
    if (classified > 0) parts.push(classified + ' ' + i18n('classified', 'classified'));
    const summary = parts.length ? '✓ ' + parts.join(' · ') : i18n('nothingNewToResolve', '✓ Nothing new to resolve');
    const detail  = skipped > 0 ? ' (' + skipped + ' ' + i18n('scanned', 'scanned') + ')' : '';
    setStatus(summary + detail);
    btn.textContent = i18n('btnResolve', 'Resolve');
    btn.disabled = false;
    await loadNeedsAttention();
  } catch (err) {
    setStatus(`(err.message ?? i18n('failedTryAgain', 'Failed — try again'))`, true);
    btn.textContent = 'Resolve';
    btn.disabled = false;
  }
});

