  const noteInput  = document.getElementById('af-tnote-'   + txId);
  const statusEl   = document.getElementById('af-tstatus-' + txId);

  const destination = walletSel?.value.trim() || addrInput?.value.trim() || '';
  const extra       = noteInput?.value.trim() ?? '';
  const note        = [destination ? `To: ${destination}` : '', extra].filter(Boolean).join(' · ');

  if (statusEl) statusEl.textContent = i18n('saving','Saving…');

  try {
    const res = await fetch(`/api/research/annotate/${txId}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ category: 'own_wallet', note }),
    });
    if (!res.ok) throw new Error(await res.text());
    await loadNeedsAttention();
  } catch {
    if (statusEl) statusEl.textContent = i18n('saveFailed','Save failed');
  }
}

