async function runP2PClassify(disposition) {
  const bar    = $('resolve-status-bar');
  const status = $('resolve-status');
  const setStatus = (msg, isError = false) => {
    status.textContent = msg;
    status.className = `resolve-status${isError ? ' resolve-status--error' : ' resolve-status--ok'}`;
    bar.style.display = 'block';
  };
  $('p2p-panel').style.display = 'none';
  bar.style.display = 'none';
  try {
    const res  = await fetch('/api/research/classify-p2p', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ disposition }),
    });
    if (!res.ok) throw new Error(`Failed (${res.status})`);
    const data = await res.json();
    const classified = data.classified ?? 0;
    setStatus(classified > 0 ? i18n('p2pClassified', '✓ __N__ P2P transfers classified').replace('__N__', classified) : i18n('noP2p', '✓ No P2P transfers found'));
    if (classified > 0) await loadNeedsAttention();
  } catch (err) {
    setStatus(`${err.message ?? 'Failed — try again'}`, true);
  }
}

