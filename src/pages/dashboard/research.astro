<script is:inline>
// ── Error catcher: shows JS errors inside na-list instead of silent failure ───
window.__naErr = function(msg) {
  var el = document.getElementById('na-list');
  if (el) el.innerHTML = '<div class="loading-msg" style="color:var(--loss);font-size:0.85em;white-space:pre-wrap">JS Error:\n' + msg + '</div>';
};
window.addEventListener('error', function(e) {
  window.__naErr(e.message + '\n' + e.filename.split('/').pop() + ':' + e.lineno);
});
window.addEventListener('unhandledrejection', function(e) {
  window.__naErr('Unhandled: ' + String(e.reason));
});

// ── Synchronous SSR render — runs before any module script ────────────────────
// Renders NA data immediately so cold-start never shows "Loading…" even if the
// main module script fails to load. The module replaces this with interactive
// HTML (with buttons, event handlers) when it runs.
(function () {
  function escH(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  var SRC = { coinbase:'Coinbase', crypto_com:'Crypto.com', gemini:'Gemini',
    kraken:'Kraken', exodus:'Exodus', venmo:'Venmo', cashapp:'Cash App', robinhood:'Robinhood' };
  function srcN(s) { return SRC[s] || s || ''; }

  try {
    var ssrEl = document.getElementById('na-ssr-data');
    if (!ssrEl) return;
    var data = JSON.parse(ssrEl.textContent || '');
    if (!data || typeof data !== 'object') return;

    // Store parsed data for module to consume (avoids re-parsing)
    window.__naData = data;

    // Update count badge immediately
    var count = document.getElementById('na-count');
    if (count) {
      var total = data.total || 0;
      count.textContent = total > 0 ? (data.unmatchedCapped ? '300+' : String(total)) : '';
    }

    // Build list HTML (no interactive buttons — module replaces with full version)
    var list = document.getElementById('na-list');
    if (!list) return;
    var html = '';

    var suggested = data.suggested || [];
    if (suggested.length) {
      html += '<div class="section-label">Suggested matches</div>';
      for (var i = 0; i < suggested.length; i++) {
        var m = suggested[i];
        html += '<div class="suggest-item">' +
          '<div class="suggest-top"><span class="suggest-sym">' + escH(m.asset_symbol || '') + '</span>' +
          '<span class="suggest-score">confidence ' + escH(String(m.confidence_score || '')) + '</span></div>' +
          '<div class="suggest-flow">' + escH(srcN(String(m.out_source || ''))) + ' → ' + escH(srcN(String(m.in_source || ''))) + '</div>' +
          '<div class="suggest-dates">' + escH(String(m.out_ts || '').slice(0,10)) + ' → ' + escH(String(m.in_ts || '').slice(0,10)) + '</div>' +
          '</div>';
      }
    }

    var unmatched = data.unmatched || [];
    if (unmatched.length) {
      html += '<div class="section-label">Unresolved transactions</div>';
      for (var j = 0; j < unmatched.length; j++) {
        var t = unmatched[j];
        var dir = String(t.direction || '').toLowerCase();
        var isXfer = dir === 'out' && t.category === 'own_wallet';
        var dClass = isXfer ? 'transfer' : dir;
        var dLabel = isXfer ? 'transfer' : dir;
        var sym = escH(String(t.asset_symbol || ''));
        var absAmt = Math.abs(Number(t.amount || 0));
        var amtDisp = (dir === 'out' ? '−' : '+') + absAmt.toLocaleString(undefined,{maximumFractionDigits:8}) + ' ' + sym;
        var src = escH(srcN(String(t.source || '')));
        var usd = t.native_usd ? '<span class="tx-usd">$' + Number(t.native_usd).toLocaleString(undefined,{minimumFractionDigits:2,maximumFractionDigits:2}) + '</span>' : '';
        html += '<div class="tx-card na-item dir-' + dClass + '" data-sym="' + escH(String(t.asset_symbol||'')) + '" data-dir="' + dir + '" data-id="' + escH(String(t.id||'')) + '" data-ts="' + escH(String(t.timestamp_utc||'')) + '" data-src="' + src + '" data-amount="' + absAmt + '" data-usd="' + escH(String(t.native_usd||'')) + '">' +
          '<div class="tx-badge-col"><span class="tx-dir ' + dClass + '">' + dLabel + '</span></div>' +
          '<div class="tx-body">' +
          '<div class="tx-row-1"><span class="tx-sym">' + sym + '</span><span class="tx-amt">' + amtDisp + '</span></div>' +
          '<div class="tx-row-2"><span class="tx-src-badge">' + src + '</span>' + usd + '</div>' +
          '<div class="tx-row-3"><span class="tx-dt">' + escH(String(t.timestamp_utc||'').slice(0,16).replace('T',' ')) + '</span></div>' +
          '</div></div>';
      }
    }

    if (!html) html = '<div class="empty-msg">✓ Nothing to review.</div>';
    list.innerHTML = html;
  } catch(e) {
    if (window.__naErr) window.__naErr('inline: ' + e.message);
  }
})();
</script>

<script>
import { escapeHtml } from '../../lib/escapeHtml';
// ── i18n ─────────────────────────────────────────────────────────────────────
// Strings injected by the <script is:inline define:vars> island above.
// English fallbacks keep the script working if that block ever fails to run.
const I18N = (window as any).__researchI18n ?? {};
const i18n = (key: string, fallback: string) => (I18N[key] as string) ?? fallback;

// ── State ─────────────────────────────────────────────────────────────────────
let activeChip    = '';
let pendingMatch  = null;
let resolvedOpen  = false;
let naContext     = null;   // { sym, dir } when search was triggered from NA click

// ── Helpers ───────────────────────────────────────────────────────────────────
const $  = id => document.getElementById(id);
const fmt = n => n == null ? '—' : Number(n).toLocaleString(undefined, { maximumFractionDigits: 8 });
const fmtUsd = n => n == null ? '' : '$' + Number(n).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const fmtDT = s => {
  if (!s) return '';
  try {
    const d = new Date(s.replace(' UTC','Z').replace(' ','T'));
    const date = d.toLocaleDateString(undefined, { month:'short', day:'numeric', year:'numeric' });
    const time = d.toLocaleTimeString(undefined, { hour:'2-digit', minute:'2-digit' });
    return `${date} · ${time}`;
  } catch { return s.slice(0,16); }
};

const fmtDate = s => {
  if (!s) return '';
  try {
    return new Date(s.replace(' UTC','Z').replace(' ','T')).toLocaleDateString(undefined, { month:'short', day:'numeric', year:'numeric' });
  } catch { return s.slice(0,10); }
};

const srcName = s => ({
  coinbase:'Coinbase', crypto_com:'Crypto.com', gemini:'Gemini',
  kraken:'Kraken', exodus:'Exodus', venmo:'Venmo', cashapp:'Cash App', robinhood:'Robinhood',
})[s] ?? s;

// ── Load Needs Attention ──────────────────────────────────────────────────────
async function loadNeedsAttention(attempt = 1) {
  const MAX_ATTEMPTS = 4;
  const list = $('na-list');

  // On the very first call, use SSR-embedded data (already rendered inline by
  // the <script is:inline> block). window.__naData is set synchronously before
  // any module runs, so it's always available when this function first fires.
  if (attempt === 1) {
    const inlineData = (window as any).__naData as object | null | undefined;
    if (inlineData) {
      (window as any).__naData = null; // consume once
      try {
        renderNeedsAttention(inlineData);
        const badge = $('na-synced');
        if (badge) {
          const t = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
          badge.textContent = i18n('syncedAt', '· synced __T__').replace('__T__', t);
          badge.style.display = 'inline';
        }
        return;
      } catch (e) {
        console.error('[NA] renderNeedsAttention threw on inline data — falling back to fetch:', e);
      }
    }
    // Belt-and-suspenders: also check the DOM element (in case inline script skipped)
    const ssrEl = document.getElementById('na-ssr-data');
    if (ssrEl) {
      let embedded: object | null = null;
      try {
        const parsed = JSON.parse(ssrEl.textContent || '');
        if (parsed && typeof parsed === 'object') embedded = parsed;
      } catch (e) {
        console.warn('[NA] SSR DOM parse failed:', e);
      }
      if (embedded) {
        ssrEl.remove();
        try {
          renderNeedsAttention(embedded);
          const badge = $('na-synced');
          if (badge) {
            const t = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
            badge.textContent = i18n('syncedAt', '· synced __T__').replace('__T__', t);
            badge.style.display = 'inline';
          }
          return;
        } catch (e) {
          console.error('[NA] renderNeedsAttention threw on SSR DOM data — falling back to fetch:', e);
        }
      }
    }
  }

  list.innerHTML = '<div class="loading-msg">' + i18n('loading', 'Loading…') + '</div>';
  try {
    const ctrl = new AbortController();
    const tid  = setTimeout(() => ctrl.abort(), 28_000);
    const res  = await fetch('/api/research/needs-attention', { signal: ctrl.signal });
    clearTimeout(tid);
    const data = await res.json();
    if (data.error) {
      if (attempt < MAX_ATTEMPTS) {
        list.innerHTML = '<div class="loading-msg">' + i18n('retrying', 'Retrying…') + '</div>';
        setTimeout(() => loadNeedsAttention(attempt + 1), 5_000);
      } else {
        list.innerHTML = '<div class="empty-msg">' + i18n('stillWorking', 'Still working on it — check back in a moment.') + '</div>';
      }
      return;
    }
    renderNeedsAttention(data);
    const badge = $('na-synced');
    if (badge) {
      const t = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
      badge.textContent = i18n('syncedAt', '· synced __T__').replace('__T__', t);
      badge.style.display = 'inline';
    }
  } catch {
    if (attempt < MAX_ATTEMPTS) {
      list.innerHTML = '<div class="loading-msg">' + i18n('retrying', 'Retrying…') + '</div>';
      setTimeout(() => loadNeedsAttention(attempt + 1), 5_000);
    } else {
      list.innerHTML = '<div class="empty-msg">' + i18n('stillWorking', 'Still working on it — check back in a moment.') + '</div>';
    }
  }
}

const PHONE_RE = /(?:To|From)\s+\+\d{7,}/i;
const NON_EVM_ASSETS = new Set(['BTC','XBT','LTC','SOL','XRP','DOT','ADA','ATOM','ALGO']);

function naReasonTag(t, dir) {
  const desc = t.description ?? '';
  const sym  = (t.asset_symbol ?? '').toUpperCase();
  if (!t.native_usd)                      return { label: i18n('naReasonNeedsPrice','needs price'),   cls: 'price' };
  if (PHONE_RE.test(desc))                return { label: 'P2P',           cls: 'p2p' };
  if (t.kind === 'crypto_earn_deposit' ||
      t.kind === 'crypto_earn_withdraw')  return { label: 'Earn',          cls: 'earn' };
  if (NON_EVM_ASSETS.has(sym))            return { label: 'non-EVM',       cls: 'nonevm' };
  if (dir === 'out')                      return { label: 'unmatched send', cls: 'send' };
  return                                         { label: 'unmatched recv', cls: 'recv' };
}

function renderNeedsAttention(data) {
  naDataCache = data; // cache for AI triage
  const list  = $('na-list');
  const count = $('na-count');
  const total = data.total ?? 0;
  const countLabel = total > 0 ? (data.unmatchedCapped ? '300+' : String(total)) : '';
  count.textContent = countLabel;

  // Persist count for nav badge (other pages read from localStorage)
  try {
    localStorage.setItem('alms_na_count', String(total));
    const navBadge = document.getElementById('na-nav-badge');
    if (navBadge) {
      if (total > 0) {
        navBadge.textContent = total > 99 ? '99+' : String(total);
        navBadge.hidden = false;
      } else {
        navBadge.hidden = true;
      }
    }
  } catch { /* localStorage unavailable */ }

  let html = '';

  // ── Suggested matches ──────────────────────────────────────────────────────
  if (data.suggested?.length) {
    html += '<div class="section-label">' + i18n('suggestedMatches', 'Suggested matches') + '</div>';
    for (const m of data.suggested) {
      const safeM = JSON.stringify(m).replace(/'/g,"&#39;");
      html += `<div class="suggest-item" data-match-id="${m.match_id}" data-match='${safeM}'>
        <div class="suggest-top">
          <span class="suggest-sym">${escapeHtml(m.asset_symbol)}</span>
          <span class="suggest-score">confidence ${m.confidence_score}</span>
        </div>
        <div class="suggest-flow">${escapeHtml(srcName(m.out_source))}${m.out_account_name ? ' · ' + escapeHtml(m.out_account_name) : ''} → ${escapeHtml(srcName(m.in_source))}${m.in_account_name ? ' · ' + escapeHtml(m.in_account_name) : ''}</div>
        <div class="suggest-dates">${fmtDate(m.out_ts)} → ${fmtDate(m.in_ts)}</div>
        <div class="suggest-amt">Sent ${fmt(m.out_amount)} · Received ${fmt(m.in_amount)}${m.fee_amount ? ' · Fee ' + fmt(m.fee_amount) : ''}</div>
      </div>`;
    }
  }

  // ── Unresolved transactions ────────────────────────────────────────────────
  if (data.unmatched?.length) {
    html += '<div class="section-label">' + i18n('unresolvedTxs', 'Unresolved transactions') + '</div>';
    for (const t of data.unmatched) {
      const dir       = (t.direction ?? '').toLowerCase();
      const isTransfer = dir === 'out' && t.category === 'own_wallet';
      const dirClass  = isTransfer ? 'transfer' : dir;
      const dirLabel  = isTransfer ? 'transfer' : dir;
      const absAmt = Math.abs(Number(t.amount));
      const amt    = dir === 'out' ? `−${fmt(absAmt)}` : `+${fmt(absAmt)}`;
      const hint    = dir === 'out' ? i18n('clickToFindLanded', 'Click to find where this landed →') : i18n('clickToFindSource', 'Click to find where this came from →');
      const src     = `${escapeHtml(srcName(t.source))}${t.account_name ? ' · ' + escapeHtml(t.account_name) : ''}`;
      const catLabel = t.category ? `<span class="category-badge">${escapeHtml(t.category)}</span>` : '';
      const noteText = t.notes   ? `<span class="tx-note-text">${escapeHtml(t.notes)}</span>` : '';
      const hasAnnotation = !!(t.category || t.notes);
      const reasonTag = naReasonTag(t, dir);
      html += `<div class="tx-card na-item dir-${dirClass}" data-sym="${t.asset_symbol}" data-dir="${dir}" data-id="${t.id}" data-ts="${t.timestamp_utc}" data-src="${src}" data-amount="${Math.abs(Number(t.amount))}" data-usd="${t.native_usd ?? ''}">
        <div class="tx-badge-col">
          <span class="tx-dir ${dirClass}">${dirLabel}</span>
          <span class="na-reason na-reason--${reasonTag.cls}">${reasonTag.label}</span>
        </div>
        <div class="tx-body">
          <div class="tx-row-1">
            <span class="tx-sym">${escapeHtml(t.asset_symbol)}</span>
            <span class="tx-amt">${amt} ${escapeHtml(t.asset_symbol)}</span>
          </div>
          <div class="tx-row-2">
            <span class="tx-src-badge">${src}</span>
            ${t.native_usd ? `<span class="tx-usd">${fmtUsd(t.native_usd)}</span>` : ''}
          </div>
          <div class="tx-row-3">
            <span class="tx-hint">${hint}</span>
            <span class="tx-dt">${fmtDT(t.timestamp_utc)}</span>
          </div>
          ${hasAnnotation ? `<div class="tx-annotation-row">${catLabel}${noteText}</div>` : ''}
          <div class="card-actions">
            ${dir === 'out' ? `
            <button class="btn-dispose${hasAnnotation ? ' has-note' : ''}"
                    data-tx-id="${t.id}"
                    data-category="${t.category ?? ''}"
                    data-note="${(t.notes ?? '').replace(/"/g,'&quot;')}"
                    onclick="openDisposeForm(event, this)">
              ${hasAnnotation ? i18n('editDisposal', 'Edit disposal') : i18n('dispose', 'Dispose')}
            </button>
            ${t.category !== 'own_wallet' ? `
            <button class="btn-transfer"
                    data-tx-id="${t.id}"
                    onclick="openForwardForm(event, this)">
              ${i18n('forward', '↗ Forward')}
            </button>` : ''}
            ` : `
            <button class="btn-annotate${hasAnnotation ? ' has-note' : ''}"
                    data-tx-id="${t.id}"
                    data-category="${t.category ?? ''}"
                    data-note="${(t.notes ?? '').replace(/"/g,'&quot;')}"
                    onclick="openAnnotateForm(event, this)">
              ${hasAnnotation ? i18n('editNote', 'Edit note') : i18n('addNote', 'Add note')}
            </button>
            ${t.category !== 'legacy_exchange' ? `
            <button class="btn-legacy"
                    onclick="markLegacy(event, '${t.id}')">
              ${i18n('legacyExchange', 'Legacy exchange')}
            </button>` : ''}`}
            <button class="btn-attach"
                    onclick="attachReceipt(event,'${t.id}')">
              ${i18n('attach', 'Attach')}
            </button>
            <button class="btn-context-pill"
                    onclick="event.stopPropagation();openWizard()"
                    title="${i18n('aboutTxHistory', 'About my transaction history')}"></button>
            <button class="btn-help"
                    data-tx-id="${t.id}"
                    onclick="openHelpPanel(event,'${t.id}','${escapeHtml(t.kind??'')}','${dir}','${escapeHtml(t.asset_symbol)}','${escapeHtml((t.description??'').slice(0,80))}','${escapeHtml(srcName(t.source)??'')}')">
              ${i18n('helpBtn', '? Help')}
            </button>
          </div>
          <div class="att-panel" id="atp-${t.id}"></div>
          <div class="annotate-form" id="af-${t.id}" style="display:none"></div>
          <div class="help-panel" id="hp-${t.id}" style="display:none"></div>
        </div>
      </div>`;
    }
  }

  if (!html) {
    const emptyMessages = [
      { icon: '✓', text: i18n('nothingToReview', "You're all caught up — nothing to review.") },
      { icon: '✓', text: i18n('everythingMatched', "Everything's matched. Nothing left to review.") },
      { icon: '✓', text: i18n('cleanSlate', "Clean slate — no transactions need attention.") },
    ];
    const pick = emptyMessages[Math.floor(Math.random() * emptyMessages.length)];
    html = '<div class="empty-msg">' + pick.icon + ' ' + pick.text + '</div>';
  }

  list.innerHTML = html;

  // Wire NA item clicks → action panel + search
  list.querySelectorAll('.na-item').forEach(el => {
    el.addEventListener('click', () => {
      const sym  = el.getAttribute('data-sym');
      const dir  = el.getAttribute('data-dir');
      const ts   = el.getAttribute('data-ts');
      const txId = el.getAttribute('data-id');
      const src  = el.getAttribute('data-src') ?? '';
      const cat  = el.querySelector('[data-category]')?.getAttribute('data-category') ?? '';
      const note = el.querySelector('[data-note]')?.getAttribute('data-note') ?? '';
      if (!sym) return;
      list.querySelectorAll('.na-item').forEach(i => i.classList.remove('selected'));
      el.classList.add('selected');

      // Populate the right-panel action panel
      renderNaActionPanel({ txId, sym, dir, src, cat, note,
        amt: el.querySelector('.tx-amt')?.textContent ?? '' });

      // Search for potential matches on the opposite side
      const opposite = dir === 'out' ? 'in' : 'out';
      naContext = { sym, dir, opposite };
      setActiveChip(sym);
      $('filter-symbol').value = sym;
      runSearchNa(sym, opposite, ts);
    });
  });

  // Wire suggested match clicks → modal
  list.querySelectorAll('.suggest-item').forEach(el => {
    el.addEventListener('click', () => {
      const raw = el.getAttribute('data-match');
      if (!raw) return;
      openMatchModal(JSON.parse(raw.replace(/&#39;/g,"'")));
    });
  });

  // ── Resolved tin ──────────────────────────────────────────────────────────
  const resolved = data.resolved ?? [];
  const rHeader  = $('resolved-header');
  const rList    = $('resolved-list');
  const rCount   = $('resolved-count');

  if (resolved.length) {
    rCount.textContent = String(resolved.length);
    rHeader.style.display = 'flex';

    let rHtml = '';
    for (const r of resolved) {
      const autoLabel = r.status === 'auto' ? i18n('resolvedAuto', 'auto') : i18n('resolvedConfirmed', '✓ confirmed');
      rHtml += `<div class="resolved-item">
        <div class="resolved-top">
          <span class="resolved-sym">${r.asset_symbol}</span>
          <span class="resolved-badge">${autoLabel}</span>
        </div>
        <div class="resolved-flow">${srcName(r.out_source)}${r.out_account_name ? ' · ' + r.out_account_name : ''} → ${srcName(r.in_source)}${r.in_account_name ? ' · ' + r.in_account_name : ''}</div>
        <div class="resolved-meta">${fmtDate(r.out_ts)} → ${fmtDate(r.in_ts)} &nbsp;·&nbsp; ${fmt(r.out_amount)} → ${fmt(r.in_amount)}</div>
      </div>`;
    }
    rList.innerHTML = rHtml;

    // Honour current open/closed state
    rList.style.display = resolvedOpen ? 'block' : 'none';
    $('resolved-toggle').textContent = resolvedOpen ? '▴ hide' : '▾ show';
  } else {
    rHeader.style.display = 'none';
    rList.style.display   = 'none';
  }
}

// Toggle resolved list
