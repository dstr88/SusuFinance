// ── Receipt attachment & validation ──────────────────────────────────────────
function renderAttPanel(panel, attId, filename, validation, overrideNote) {
  if (!panel) return;
  const fname = escapeHtml(`${filename}`);
  if (!validation || validation.status === 'skipped') {
    panel.innerHTML = `<span class="att-badge">${fname}</span>`;
    return;
  }
  if (validation.status === 'matched') {
    panel.innerHTML = '<span class="att-badge att-badge--ok">' + i18n('receiptVerified','✓ Receipt verified · __F__').replace('__F__',fname) + '</span>';
    return;
  }
  if (validation.status === 'overridden') {
    const noteText = overrideNote ? ` · <em>${escapeHtml(overrideNote)}</em>` : '';
    panel.innerHTML = '<span class="att-badge att-badge--warn">' + i18n('overrideAccepted','Override accepted · __F__').replace('__F__',fname) + noteText + '</span>';
    return;
  }
  // rejected
  const missList = (validation.mismatches ?? []).map(m => `<li>${escapeHtml(m)}</li>`).join('');
  panel.innerHTML = `
    <div class="att-rejected">
      <span class="att-badge att-badge--err">${i18n('receiptMismatch','Receipt mismatch · __F__').replace('__F__',fname)}</span>
      ${missList ? `<ul class="att-mismatch-list">${missList}</ul>` : ''}
      <button class="btn-att-override" onclick="startOverride(event,'${attId}',this)">${i18n('overrideRejection','Override rejection')}</button>
      <div class="att-override-form" id="ovf-${attId}" style="display:none">
        <p class="att-override-confirm">${i18n('overrideConfirmPrompt',"Are you sure? This receipt doesn't match the transaction data. Provide a reason:")}</p>
        <textarea class="att-override-note" id="ovn-${attId}" placeholder="${i18n('overrideNotePlaceholder','e.g. Fee shown separately, minor rounding…')}" rows="2"></textarea>
        <div class="att-override-actions">
          <button class="btn-att-confirm-override" onclick="confirmOverride(event,'${attId}')">${i18n('yesKeepIt','Yes, keep it')}</button>
          <button class="btn-att-cancel-override" onclick="cancelOverride(event,'${attId}')">${i18n('cancel','Cancel')}</button>
        </div>
      </div>
    </div>`;
}

function attachReceipt(e, txId) {
  e.stopPropagation();
  const card  = e.target.closest('[data-id]');
  const asset = card?.dataset.sym   ?? '';
  const amt   = card?.dataset.amount ?? '0';
  const usd   = card?.dataset.usd   ?? '0';
  const ts    = card?.dataset.ts    ?? '';

  const input = document.createElement('input');
  input.type = 'file';
  input.accept = 'image/*,application/pdf';
  input.onchange = async () => {
    const file = input.files?.[0];
    if (!file) return;
    const panel = document.getElementById('atp-' + txId);
    if (panel) panel.innerHTML = '<span class="att-uploading">' + i18n('uploadValidating','Uploading & validating…') + '</span>';
    const fd = new FormData();
    fd.append('txId',           txId);
    fd.append('file',           file);
    fd.append('txAsset',        asset);
    fd.append('txCryptoAmount', amt);
    fd.append('txNativeUsd',    usd);
    fd.append('txTimestampUtc', ts);
    try {
      const res  = await fetch('/api/research/attachment', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.ok) {
        if (data.paywalled && panel) {
          panel.innerHTML = '<span class="att-badge">' + data.filename + '</span><a class="att-upgrade-hint" href="/dashboard/billing">' + i18n('upgradeToVerify','Upgrade to verify receipts automatically') + '</a>';
        } else {
          renderAttPanel(panel, data.id, data.filename, data.validation, null);
        }
      } else {
        if (panel) panel.innerHTML = `<span class="att-error">${data.error ?? 'Upload failed'}</span>`;
      }
    } catch {
      if (panel) panel.innerHTML = '<span class="att-error">' + i18n('uploadFailed','Upload failed — try again') + '</span>';
    }
  };
  input.click();
}

function startOverride(e, attId, btn) {
  e.stopPropagation();
  const form = document.getElementById('ovf-' + attId);
  if (form) { form.style.display = 'block'; btn.style.display = 'none'; }
}

function cancelOverride(e, attId) {
  e.stopPropagation();
  const form = document.getElementById('ovf-' + attId);
  if (form) {
    form.style.display = 'none';
    const btn = form.closest('.att-rejected')?.querySelector('.btn-att-override');
    if (btn) btn.style.display = '';
  }
}

async function confirmOverride(e, attId) {
  e.stopPropagation();
  const note = document.getElementById('ovn-' + attId)?.value?.trim() ?? '';
  const btn  = e.target;
  btn.disabled = true;
  btn.textContent = 'Saving…';
  try {
    const res  = await fetch('/api/research/attachment', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: attId, overrideNote: note }),
    });
    const data = await res.json();
    if (data.ok) {
      const panel = btn.closest('.att-panel');
      if (panel) renderAttPanel(panel, attId, panel.querySelector('.att-badge--err')?.textContent?.split('· ').pop() ?? '', { status: 'overridden' }, note);
    }
  } catch {
    btn.disabled = false;
    btn.textContent = i18n('yesKeepIt','Yes, keep it');
  }
}

