// ── AI Triage ─────────────────────────────────────────────────────────────────
const TRIAGE_LABELS = {
  annotated:          { label: i18n('triageLabelAnnotated',   'Already annotated'),      cls: 'triage-ok'   },
  obvious_purchase:   { label: i18n('triageLabelPurchase',    'Obvious purchase'),        cls: 'triage-info' },
  obvious_income:     { label: i18n('triageLabelIncome',      'Obvious income'),          cls: 'triage-info' },
  obvious_own_wallet: { label: i18n('triageLabelOwnWallet',   'Obvious own-wallet'),      cls: 'triage-info' },
  obvious_sale:       { label: i18n('triageLabelSale',        'Obvious sale/disposal'),   cls: 'triage-info' },
  needs_review:       { label: i18n('triageLabelNeedsReview', 'Needs manual review'),     cls: 'triage-warn' },
};

let naDataCache = null; // set by renderNeedsAttention

$('btn-ai-triage').addEventListener('click', async () => {
  const btn   = $('btn-ai-triage');
  const panel = $('triage-panel');
  if (!naDataCache?.unmatched?.length) {
    panel.style.display = 'block';
    panel.innerHTML = '<p class="triage-msg">' + i18n('loadNaFirst', 'Load Needs Attention first.') + '</p>';
    return;
  }
  btn.disabled = true;
  btn.textContent = i18n('triaging', 'Triaging…');
  panel.style.display = 'block';
  panel.innerHTML = '<p class="triage-msg">' + i18n('analysingTxs', 'Analysing __N__ transactions…').replace('__N__', naDataCache.unmatched.length) + '</p>';
  try {
    const res  = await fetch('/api/research/ai-triage', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ transactions: naDataCache.unmatched }),
    });
    const data = await res.json();
    if (res.status === 403) {
      panel.innerHTML = '<p class="triage-msg"><a href="/dashboard/billing" style="color:var(--accent)">' + i18n('upgradeForTriage', 'Upgrade to a paid plan to use AI Triage.') + '</a></p>';
      return;
    }
    if (!data.ok) throw new Error(data.error ?? 'Triage failed');

    // Reload NA list if anything was auto-resolved
    if (data.autoResolved > 0) await loadNeedsAttention();

    const groups = data.groups;
    const autoMsg = data.autoResolved > 0
      ? '<p class="triage-auto-note">' + i18n('triageAutoNote', '✓ __N__ item__S__ auto-resolved and removed from Needs Attention. Price backfills stay for your review.').replace('__N__', data.autoResolved).replace('__S__', data.autoResolved !== 1 ? 's' : '') + '</p>'
      : '';
    let html = `<div class="triage-results">${autoMsg}`;
    for (const [key, meta] of Object.entries(TRIAGE_LABELS)) {
      const rows = groups[key] ?? [];
      if (!rows.length) continue;
      html += `<div class="triage-group ${meta.cls}">
        <div class="triage-group-header">
          <span>${meta.label}</span>
          <span class="triage-count">${rows.length}</span>
        </div>
        <div class="triage-group-body">`;
      for (const r of rows) {
        const tx = naDataCache.unmatched.find(t => t.id === r.id);
        const sym  = tx?.asset_symbol ?? '?';
        const amt  = tx ? Math.abs(Number(tx.amount)).toFixed(4) : '';
        const date = tx?.timestamp_utc?.slice(0, 10) ?? '';
        html += `<div class="triage-row">
          <span class="triage-tx">${sym} ${amt} · ${date}</span>
          <span class="triage-reason">${r.reason}</span>
        </div>`;
      }
      html += `</div></div>`;
    }
    html += '<p class="triage-note">' + i18n('triageAdvisory', 'Triage is advisory — review before acting on AI suggestions.') + '</p></div>';
    panel.innerHTML = html;
    // Wire group headers to expand/collapse
    panel.querySelectorAll('.triage-group-header').forEach(hdr => {
      hdr.addEventListener('click', () => hdr.closest('.triage-group').classList.toggle('open'));
    });
  } catch (err) {
    panel.innerHTML = '<p class="triage-msg triage-err">' + i18n('triageFailed', 'Triage failed: __MSG__').replace('__MSG__', err.message) + '</p>';
  } finally {
    btn.disabled = false;
    btn.textContent = i18n('btnAiTriage', 'AI Triage');
  }
});

