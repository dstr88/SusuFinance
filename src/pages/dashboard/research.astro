function renderNaActionPanel({ txId, sym, dir, src, cat, note, amt }) {
  const panel = $('na-action-panel');
  panel.style.display = 'block';

  const walletItems = Array.from(document.querySelectorAll('.wallet-picker-item'));
  const walletOptions = walletItems.map(el => {
    const label = el.getAttribute('data-wallet-label') ?? '';
    const addr  = el.getAttribute('data-wallet-address') ?? '';
    return `<option value="${label}">${label}${addr ? '  (' + addr.slice(0,6) + '…' + addr.slice(-4) + ')' : ''}</option>`;
  }).join('');

  const disposeOptions = DISPOSAL_TYPES_ONLY.map(d =>
    `<option value="${d.value}"${d.value === cat ? ' selected' : ''}>${d.label}</option>`
  ).join('');

  panel.innerHTML = `
    <div class="nap-from">${i18n('fromLabel','From:')} ${escapeHtml(src)}</div>
    <div class="nap-tx">${dir === 'out' ? '↑' : '↓'} ${escapeHtml(amt)} &nbsp;·&nbsp; ${escapeHtml(sym)}</div>
    ${dir === 'out' ? `
    <div class="nap-actions">
      <button class="nap-btn-dispose" onclick="napShowDispose('${txId}')">${i18n('dispose','Dispose')}</button>
      <button class="nap-btn-forward" onclick="napShowForward('${txId}')">${i18n('forward','↗ Forward')}</button>
    </div>
    <div class="nap-form" id="nap-form-${txId}" style="display:none"></div>
    ` : `
    <div class="nap-actions">
      <button class="nap-btn-dispose" onclick="napShowDispose('${txId}')">${i18n('addNote','Add note')}</button>
      <button class="nap-btn-forward nap-btn-legacy-style" onclick="markLegacy(event,'${txId}')">${i18n('legacyExchange','Legacy exchange')}</button>
    </div>
    <div class="nap-form" id="nap-form-${txId}" style="display:none"></div>
    `}`;

  // store for use by napShow* functions
  panel._txId         = txId;
  panel._disposeOpts  = disposeOptions;
  panel._walletOpts   = walletOptions;
  panel._src          = src;
  panel._note         = note;
}

