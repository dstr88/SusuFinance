// ── Dataset Health Check ──────────────────────────────────────────────────────
async function loadHealthCheck() {
  try {
    const res  = await fetch('/api/research/diagnostics');
    const data = await res.json();
    if (data.ok) renderHealthCheck(data);
  } catch {}
}

function renderHealthCheck(d) {
  const grid = $('health-grid');
  if (!grid) return;

  const fmtV = n => n >= 1000 ? '$' + (n/1000).toFixed(0) + 'k' : '$' + n;

  const cards = [];

  // Import coverage
  const sources = d.coverage ?? [];
  if (sources.length) {
    const years = sources.map(r => {
      const e = String(r.earliest ?? '').slice(0, 4);
      const l = String(r.latest   ?? '').slice(0, 4);
      return `${escapeHtml(r.source)}: ${escapeHtml(e)}–${escapeHtml(l)}`;
    });
    cards.push({
      title:   i18n('hcImportCoverage','Import Coverage'),
      body:    i18n('hcSources','__N__ source__S__').replace('__N__',sources.length).replace('__S__',sources.length !== 1 ? 's' : ''),
      detail:  years.slice(0, 4).join('<br>') + (years.length > 4 ? '<br>+more' : ''),
      status:  'ok',
    });
  }

  // Pre-2019 gaps
  const pre = d.pre2019 ?? {};
  if (Number(pre.total) > 0) {
    const noHash = Number(pre.no_hash ?? 0);
    cards.push({
      title:  i18n('hcPre2019','Pre-2019 Records'),
      body:   i18n('hcTransactions','__N__ transactions').replace('__N__',pre.total),
      detail: i18n('hcNoHash','__N__ without tx hash').replace('__N__',noHash) + ' · ' + i18n('hcExposed','__V__ exposed').replace('__V__',fmtV(Number(pre.value_usd ?? 0))),
      status: noHash > 0 ? 'warn' : 'ok',
    });
  }

  // Non-EVM
  const nonEvm = (d.nonEvm ?? []).filter(r => Number(r.cnt) > 0);
  if (nonEvm.length) {
    const total = nonEvm.reduce((s, r) => s + Number(r.value_usd ?? 0), 0);
    const top   = nonEvm.slice(0, 3).map(r => `${escapeHtml(r.asset_symbol)} (${r.cnt})`).join(', ');
    cards.push({
      title:  i18n('hcNonEvm','Non-EVM Unresolved'),
      body:   i18n('hcAssets','__N__ asset__S__').replace('__N__',nonEvm.length).replace('__S__',nonEvm.length !== 1 ? 's' : ''),
      detail: top + (nonEvm.length > 3 ? ', ' + i18n('hcMore','+more') : '') + '<br>' + i18n('hcTotal','__V__ total').replace('__V__',fmtV(total)),
      status: total > 5000 ? 'warn' : 'info',
    });
  }

  // P2P
  if (Number(d.p2p?.cnt) > 0) {
    cards.push({
      title:  i18n('hcP2p','P2P Phone Transfers'),
      body:   i18n('hcTransactions','__N__ transactions').replace('__N__',d.p2p.cnt),
      detail: fmtV(Number(d.p2p.value_usd ?? 0)) + ' · ' + i18n('hcNeedManual','Need manual categorization'),
      status: 'info',
    });
  }

  // Price gaps
  const gaps = (d.priceGaps ?? []).filter(r => Number(r.cnt) > 0);
  if (gaps.length) {
    const total = gaps.reduce((s, r) => s + Number(r.cnt ?? 0), 0);
    cards.push({
      title:  i18n('hcMissingPrices','Missing Prices'),
      body:   i18n('hcTransactions','__N__ transactions').replace('__N__',total),
      detail: gaps.map(r => `${escapeHtml(r.source)}: ${r.cnt}`).slice(0, 4).join('<br>'),
      status: 'warn',
    });
  }

  // Orphaned INs
  const orphans = (d.orphanedIns ?? []).filter(r => Number(r.value_usd) >= 500);
  if (orphans.length) {
    const total = orphans.reduce((s, r) => s + Number(r.value_usd ?? 0), 0);
    cards.push({
      title:  i18n('hcOrphanedIns','Unexplained Receipts'),
      body:   i18n('hcAssets','__N__ asset__S__').replace('__N__',orphans.length).replace('__S__',orphans.length !== 1 ? 's' : '') + ' · ' + fmtV(total),
      detail: orphans.slice(0, 4).map(r => `${escapeHtml(r.asset_symbol)} ${fmtV(Number(r.value_usd))}`).join('<br>'),
      status: 'warn',
    });
  }

  // Failed exchanges
  if (d.failedExchanges?.length) {
    cards.push({
      title:  i18n('hcFailedExchange','Failed Exchange Data'),
      body:   d.failedExchanges.map(ex => escapeHtml(ex.name)).join(', '),
      detail: i18n('hcFailedExchangeDetail','Records imported from failed platforms — verify loss claims and write-offs'),
      status: 'warn',
    });
  }

  // Suspicious implied prices
  const suspPrices = (d.suspiciousPrices ?? []);
  if (suspPrices.length) {
    const sample = suspPrices.slice(0, 3).map(r => {
      const implied = Number(r.implied_price ?? 0);
      const max     = Number(r.max_price ?? 0);
      const ratio   = max > 0 ? Math.round(max / implied) : 0;
      return `${escapeHtml(r.asset_symbol)} · ${fmtUsd(r.native_usd)} (${ratio > 0 ? i18n('hcBelowMax','__R__× below max').replace('__R__',String(ratio)) : i18n('hcSuspect','suspect')})`;
    }).join('<br>');
    cards.push({
      title:  i18n('hcSuspectPrice','Suspect Price Data'),
      body:   i18n('hcTransactions','__N__ transactions').replace('__N__',suspPrices.length),
      detail: sample + '<br><span class="health-card-footnote">' + i18n('hcCostBasisUnderstated','Cost basis may be understated') + '</span>',
      status: 'warn',
    });
  }

  // Missing cost basis
  const missingBasis = (d.missingBasis ?? []).filter(r => r.snapValueUsd >= 50);
  if (missingBasis.length) {
    const totalExposed = missingBasis.reduce((s, r) => s + Number(r.snapValueUsd ?? 0), 0);
    const rows = missingBasis.slice(0, 6).map(r => {
      const val   = fmtUsd(r.snapValueUsd);
      const qty   = Number(r.snapQty ?? 0);
      let line = '<strong>' + escapeHtml(r.symbol) + '</strong> · ' + val + ' ' + i18n('hcCurrentBalance','current balance');
      if (r.estimatedPrice != null) {
        const estTotal = fmtUsd(r.estimatedTotal ?? r.estimatedPrice * qty);
        const estPer   = fmtUsd(r.estimatedPrice);
        const dateStr  = r.earliestDate ? r.earliestDate.slice(0, 10) : '';
        line += '<br><span class="health-card-footnote">' + i18n('hcEstCostBasis','Est. cost basis ~__T__ @ __P__/coin on __D__ — estimate only').replace('__T__',estTotal).replace('__P__',estPer).replace('__D__',dateStr) + '</span>';
      } else if (r.earliestDate) {
        line += '<br><span class="health-card-footnote">' + i18n('hcFirstSeen','First seen __D__ · no price available').replace('__D__',r.earliestDate.slice(0,10)) + '</span>';
      }
      return line;
    });
    if (missingBasis.length > 6) rows.push('<span class="health-card-footnote">' + i18n('hcAndMore','…and __N__ more').replace('__N__',missingBasis.length - 6) + '</span>');
    cards.push({
      title:  i18n('hcMissingBasis','Missing Cost Basis'),
      body:   i18n('hcInWallet','__N__ asset__S__ · __V__ in wallet').replace('__N__',missingBasis.length).replace('__S__',missingBasis.length !== 1 ? 's' : '').replace('__V__',fmtUsd(totalExposed)),
      detail: rows.join('<br>') + '<br><span class="health-card-footnote">' + i18n('hcImportMissing','Import missing exchange CSVs to establish cost basis') + '</span>',
      status: 'warn',
    });
  }

  // Fiat noise
  if (Number(d.fiatNoise) > 0) {
    cards.push({
      title:  i18n('hcFiatNoise','Fiat as Asset'),
      body:   i18n('hcTransactions','__N__ transactions').replace('__N__',d.fiatNoise),
      detail: i18n('hcFiatDetail','USD/EUR recorded as asset_symbol — likely noise from stablecoins or CSV quirks'),
      status: 'info',
    });
  }

  if (!cards.length) {
    grid.innerHTML = '<div class="health-empty">' + i18n('healthNoIssues','No issues found — dataset looks clean.') + '</div>';
    return;
  }

  grid.innerHTML = cards.map(c => `
    <div class="health-card health-card-${c.status}">
      <div class="health-card-title">${c.title}</div>
      <div class="health-card-body">${c.body}</div>
      <div class="health-card-detail">${c.detail}</div>
    </div>
  `).join('');

  // Top unresolved
  const top = d.topUnresolved ?? [];
  if (top.length) {
    const topHtml = top.map(t => {
      const dir = (t.direction ?? '').toLowerCase();
      const amt = dir === 'out' ? `−${fmt(Math.abs(Number(t.amount)))}` : `+${fmt(Number(t.amount))}`;
      return `<div class="health-tx-row">
        <span class="tx-dir ${dir}">${dir}</span>
        <span class="health-tx-sym">${escapeHtml(t.asset_symbol)}</span>
        <span class="health-tx-amt">${amt}</span>
        <span class="health-tx-usd">${t.native_usd ? fmtUsd(t.native_usd) : ''}</span>
        <span class="health-tx-src">${escapeHtml(srcName(t.source))}</span>
        <span class="health-tx-dt">${fmtDate(t.timestamp_utc)}</span>
      </div>`;
    }).join('');
    grid.insertAdjacentHTML('beforeend', `
      <div class="health-unresolved-block">
        <div class="health-unresolved-title">${i18n('healthTopUnresolved','Top unresolved by dollar value')}</div>
        ${topHtml}
      </div>
    `);
  }
}

