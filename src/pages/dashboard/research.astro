      { key: 'income_staking',  label: 'Staking rewards'          },
      { key: 'income_mining',   label: 'Mining'                   },
      { key: 'income_airdrops', label: 'Airdrops'                 },
      { key: 'income_salary',   label: 'Crypto salary / freelance'},
      { key: 'income_defi',     label: 'DeFi yields / LP rewards' },
    ],
  },
  {
    key: 'context',
    question: 'Any other context?',
    hint: 'Notes about unusual transactions help reconcile gaps that automated matching can\'t resolve.',
    type: 'textarea',
    placeholder: 'e.g. "Sent AVAX to my Ledger around March 2022", "Got 100 LUNA before the crash"',
  },
];

let wizardAnswers = {};
let wizardStep    = 0;

async function loadIntake() {
  try {
    const res  = await fetch('/api/research/intake');
    const data = await res.json();
    wizardAnswers = data.answers ?? {};
    updateCompletionBadge();
  } catch {}
}

function updateCompletionBadge() {
  const badge = $('intake-completion-badge');
  if (!badge) return;
  const answered = WIZARD_STEPS.filter(s => {
    if (s.type === 'checks') return s.checks.some(c => wizardAnswers[c.key]);
    if (s.type === 'textarea') return !!wizardAnswers[s.key]?.trim();
    return !!wizardAnswers[s.key];
  }).length;
  if (answered > 0) {
    badge.textContent = i18n('wizardAnswered','__A__/__T__ answered').replace('__A__',answered).replace('__T__',WIZARD_STEPS.length);
    badge.style.display = 'inline-block';
  } else {
    badge.style.display = 'none';
  }
}

function openWizard() {
  wizardStep = 0;
  renderWizardStep();
  $('intake-wizard-overlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeWizard() {
  $('intake-wizard-overlay').style.display = 'none';
  document.body.style.overflow = '';
}

function renderWizardStep() {
  const step  = WIZARD_STEPS[wizardStep];
  const total = WIZARD_STEPS.length;
  const prog  = $('intake-wizard-progress');
  const body  = $('intake-wizard-body');
  const back  = $('intake-wizard-back');
  const next  = $('intake-wizard-next');

  // Progress dots
  prog.innerHTML = Array.from({ length: total }, (_, i) =>
    `<span class="wizard-dot${i === wizardStep ? ' wizard-dot-active' : i < wizardStep ? ' wizard-dot-done' : ''}"></span>`
  ).join('') + `<span class="wizard-step-label">${wizardStep + 1} / ${total}</span>`;

  // Question body
  let html = `<p class="wizard-question">${step.question}</p>`;
  if (step.hint) html += `<p class="wizard-hint">${step.hint}</p>`;

  if (step.type === 'opts') {
    html += `<div class="wizard-opts">`;
    for (const opt of step.opts) {
      const active = wizardAnswers[step.key] === opt.value;
      html += `<button class="wizard-opt${active ? ' wizard-opt-active' : ''}" data-key="${step.key}" data-value="${opt.value}">${opt.label}</button>`;
    }
    html += `</div>`;
    if (step.detail) {
      const detailVal = wizardAnswers[step.detail.key] ?? '';
      html += `<input class="wizard-detail-text" data-key="${step.detail.key}" type="text" placeholder="${step.detail.placeholder}" value="${detailVal.replace(/"/g,'&quot;')}" />`;
    }
  } else if (step.type === 'checks') {
    html += `<div class="wizard-checks">`;
    for (const c of step.checks) {
      const checked = !!wizardAnswers[c.key];
      html += `<label class="wizard-check"><input type="checkbox" data-key="${c.key}"${checked ? ' checked' : ''} /> ${c.label}</label>`;
    }
    html += `</div>`;
  } else if (step.type === 'textarea') {
    const val = wizardAnswers[step.key] ?? '';
    html += `<textarea class="wizard-textarea" data-key="${step.key}" rows="4" placeholder="${step.placeholder}">${val}</textarea>`;
  }

  body.innerHTML = html;

  // Wire opt buttons
  body.querySelectorAll('.wizard-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      body.querySelectorAll('.wizard-opt').forEach(b => b.classList.remove('wizard-opt-active'));
      btn.classList.add('wizard-opt-active');
      wizardAnswers[btn.getAttribute('data-key')] = btn.getAttribute('data-value');
    });
  });

  // Wire checkboxes (live update)
  body.querySelectorAll('input[type="checkbox"][data-key]').forEach(cb => {
    cb.addEventListener('change', () => {
      wizardAnswers[cb.getAttribute('data-key')] = cb.checked || undefined;
      if (!cb.checked) delete wizardAnswers[cb.getAttribute('data-key')];
    });
  });

  // Wire detail input (live update)
  body.querySelectorAll('.wizard-detail-text').forEach(inp => {
    inp.addEventListener('input', () => {
      const v = inp.value.trim();
      if (v) wizardAnswers[inp.getAttribute('data-key')] = v;
      else   delete wizardAnswers[inp.getAttribute('data-key')];
    });
  });

  // Wire textarea (live update)
  body.querySelectorAll('.wizard-textarea').forEach(ta => {
    ta.addEventListener('input', () => {
      const v = ta.value.trim();
      if (v) wizardAnswers[ta.getAttribute('data-key')] = v;
      else   delete wizardAnswers[ta.getAttribute('data-key')];
    });
  });

  // Nav buttons
  back.style.visibility = wizardStep === 0 ? 'hidden' : 'visible';
  const isLast = wizardStep === total - 1;
  next.textContent = isLast ? i18n('wizardSave','✓ Save') : 'Next →';
}

async function saveWizardAnswers() {
  const next = $('intake-wizard-next');
  next.disabled = true;
  next.textContent = i18n('wizardSaving','Saving…');
  try {
    const res = await fetch('/api/research/intake', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(wizardAnswers),
    });
    if (!res.ok) throw new Error(await res.text());
    updateCompletionBadge();
    closeWizard();
  } catch (e) {
    next.textContent = '' + e.message;
    setTimeout(() => {
      next.textContent = i18n('wizardSave','✓ Save');
      next.disabled = false;
    }, 2500);
  }
}

$('intake-wizard-next')?.addEventListener('click', () => {
  if (wizardStep < WIZARD_STEPS.length - 1) {
    wizardStep++;
    renderWizardStep();
  } else {
    saveWizardAnswers();
  }
});

$('intake-wizard-back')?.addEventListener('click', () => {
  if (wizardStep > 0) { wizardStep--; renderWizardStep(); }
});

$('intake-wizard-close')?.addEventListener('click', closeWizard);

$('intake-wizard-overlay')?.addEventListener('click', e => {
  if (e.target === $('intake-wizard-overlay')) closeWizard();
});

$('btn-open-questionnaire')?.addEventListener('click', openWizard);

$('btn-run-health')?.addEventListener('click', async () => {
  const btn = $('btn-run-health');
  btn.disabled = true;
  btn.textContent = 'Running…';
  const grid = $('health-grid');
  if (grid) grid.innerHTML = '<div class="health-empty">' + i18n('healthRunning','Running diagnostics…') + '</div>';
  await loadHealthCheck();
  const now = new Date().toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
  const lr = $('health-last-run');
  if (lr) lr.textContent = i18n('healthLastRun','Last run: __T__').replace('__T__',now);
  btn.textContent = i18n('btnRunDiagnostics','Run diagnostics');
  btn.disabled = false;
});

// Expose to window so inline onclick="" attributes can find them
window.openAnnotateForm       = openAnnotateForm;
window.saveAnnotation         = saveAnnotation;
window.markLegacy             = markLegacy;
window.markOwnWallet          = markOwnWallet;
window.openDisposeForm        = openDisposeForm;
window.openForwardForm        = openForwardForm;
window.saveTransfer           = saveTransfer;
window.napShowDispose         = napShowDispose;
window.napShowForward         = napShowForward;
window.napSaveDispose         = napSaveDispose;
window.napSaveForward         = napSaveForward;
window.openResultAnnotateForm = openResultAnnotateForm;
window.saveResultAnnotation   = saveResultAnnotation;
window.openHelpPanel          = openHelpPanel;
window.helpQuickSave          = helpQuickSave;
window.helpSaveNote           = helpSaveNote;

// ── Address lookup ────────────────────────────────────────────────────────────
const ADDRESS_RE = /^(0x[0-9a-fA-F]{40,}|bc1[a-zA-HJ-NP-Z0-9]{25,}|[13][a-zA-HJ-NP-Z0-9]{25,}|0x[0-9a-fA-F]{60,}|ltc1[a-z0-9]{25,})$/i;

function detectNetwork(address) {
  const lower = address.toLowerCase();
  if (lower.startsWith('ltc1'))                          return { symbol: 'LTC', chains: ['litecoin'] };
  if (lower.startsWith('bc1') || /^[13]/.test(address)) return { symbol: 'BTC', chains: ['bitcoin'] };
  if (/^0x[a-f0-9]{64}$/.test(lower))                   return { symbol: 'SUI', chains: ['sui'] };
  if (/^0x[a-f0-9]{40}$/.test(lower))                   return { symbol: 'ETH', chains: ['ethereum', 'polygon', 'avalanche'] };
  return { symbol: '', chains: [] };
}

let addrDebounce = null;

$('q').addEventListener('input', () => {
  clearTimeout(addrDebounce);
  const raw      = $('q').value.trim();
  const stripped = raw.replace(/\s+/g, '');   // drop mid-string spaces from multi-line copy-paste
  if (ADDRESS_RE.test(stripped)) {
    addrDebounce = setTimeout(() => checkAddress(stripped), 400);
  } else {
    $('addr-panel').style.display = 'none';
  }
});

async function checkAddress(address) {
  const panel = $('addr-panel');
  const inner = $('addr-panel-inner');
  panel.style.display = 'block';
  inner.innerHTML = '<div class="addr-loading">' + i18n('addrLoading','Looking up __A__…').replace('__A__',address.slice(0,10)) + '</div>';

  try {
    const res  = await fetch('/api/research/address-lookup?address=' + encodeURIComponent(address));
    const data = await res.json();
    renderAddressPanel(data);
  } catch (e) {
    inner.innerHTML = '<div class="addr-loading">' + i18n('addrLookupFailed','Lookup failed: __MSG__').replace('__MSG__',e.message) + '</div>';
  }
}

// Store last lookup for the "Add wallet" flow
let lastLookupData = null;

function renderAddressPanel(data) {
  lastLookupData = data;
  const inner = $('addr-panel-inner');
  let html = '<div class="addr-panel-title">' + i18n('addrInfoTitle','Address info') + '</div>';

  // Resolve the best label for this address
  const resolvedLabel = data.addressLabel || data.globalLabel || data.knownExchange || null;
  const labelSource   = data.addressLabel  ? (data.addressLabelSource === 'user' ? 'you' : 'auto')
                      : data.globalLabel   ? 'community'
                      : data.knownExchange ? 'known'
                      : null;

  // Copy-button row: [□ address] [□ label] whenever we have a label
  html += `<div class="addr-copy-row">
    <button class="addr-copy-btn" onclick="navigator.clipboard.writeText('${data.address}')" title="Copy address">
      ⧉ <span class="addr-copy-text">${data.address.slice(0,10)}…${data.address.slice(-6)}</span>
    </button>`;
  if (resolvedLabel) {
    html += `<button class="addr-copy-btn" onclick="navigator.clipboard.writeText('${resolvedLabel.replace(/'/g,"\\'")}')" title="Copy label">
      ⧉ <span class="addr-copy-text">${resolvedLabel}</span>
    </button>`;
    if (labelSource === 'community') {
      html += '<span class="addr-community-badge">' + i18n('addrCommunityLabel','community label') + '</span>';
    }
  }
  html += `</div>`;

  // Chips row
  html += `<div class="addr-info-grid">`;
  if (data.ownWallet) {
    const lbl = data.ownWallet.label || data.ownWallet.address.slice(0,8) + '…';
    html += '<span class="addr-info-chip own">' + i18n('addrYourWallet','Your wallet: __L__').replace('__L__',lbl) + '</span>';
  }
  if (data.knownExchange) {
    html += `<span class="addr-info-chip exchange">${data.knownExchange}</span>`;
  }
  if (data.addressLabel && !data.ownWallet) {
    html += `<span class="addr-info-chip label">${data.addressLabel}</span>`;
  }
  if (data.globalLabel && !data.addressLabel && !data.ownWallet && !data.knownExchange) {
    html += `<span class="addr-info-chip label">${data.globalLabel}</span>`;
  }
  if (!data.ownWallet && !data.knownExchange && !data.addressLabel && !data.globalLabel) {
    html += '<span class="addr-info-chip unknown">' + i18n('addrUnknown','Unknown address') + '</span>';
  }
  html += `</div>`;

  // "Add as wallet" button — only when it's not already a registered wallet
  if (!data.ownWallet) {
    html += `
      <div id="add-wallet-area">
        <button class="btn-add-wallet" type="button" id="btn-show-add-wallet">${i18n('addrAddAsWallet','＋ Add as my wallet')}</button>
        <div id="add-wallet-form" style="display:none" class="add-wallet-form">
          <input id="add-wallet-label" type="text" placeholder="${i18n('addrWalletLabel','Wallet label (e.g. My LTC wallet)')}" class="add-wallet-input" />
          <input id="add-wallet-symbol" type="text" placeholder="${i18n('addrSymbolPlaceholder','Symbol (e.g. LTC, BTC, ETH)')}" class="add-wallet-input" style="margin-top:0.4rem" />
          <div class="add-wallet-row">
            <button class="btn-annotate-save" type="button" id="btn-confirm-add-wallet">Save</button>
            <button class="btn-annotate-cancel" type="button" id="btn-cancel-add-wallet">Cancel</button>
            <span id="add-wallet-status" style="font-size:0.8rem;opacity:0.6;margin-left:0.5rem"></span>
          </div>
        </div>
      </div>`;
  }

  // Recent transactions
  const txs = data.recentTxs ?? [];
  if (txs.length) {
    html += '<div class="addr-txs-label" style="margin-top:0.75rem">' + i18n('addrRecentTxs','Recent transactions') + '</div>';
    for (const t of txs) {
      const dir    = (t.direction ?? '').toLowerCase();
      const absAmt = Math.abs(Number(t.amount ?? 0));
      const amt    = dir === 'out' ? `−${fmt(absAmt)}` : `+${fmt(absAmt)}`;
      const sym    = t.asset_symbol ?? '?';
      html += `<div class="addr-tx-row">
        <span class="addr-tx-dir ${dir}">${dir}</span>
        <span class="addr-tx-sym">${sym}</span>
        <span class="addr-tx-amt">${amt} ${sym}</span>
        <span class="addr-tx-dt">${fmtDate(t.timestamp_utc)}</span>
      </div>`;
    }
  }

  inner.innerHTML = html;

  // Wire add-wallet buttons after innerHTML is set
  const btnShow = $('btn-show-add-wallet');
  const form    = $('add-wallet-form');
  if (btnShow && form) {
    btnShow.addEventListener('click', () => {
      form.style.display = 'block';
      btnShow.style.display = 'none';
      // Auto-fill symbol from address prefix
      const symbolInput = $('add-wallet-symbol');
      if (symbolInput && !symbolInput.value) {
        symbolInput.value = detectNetwork(data.address).symbol;
      }
      $('add-wallet-label').focus();
    });
    $('btn-cancel-add-wallet').addEventListener('click', () => {
      form.style.display = 'none';
      btnShow.style.display = '';
      $('add-wallet-status').textContent = '';
    });
    $('btn-confirm-add-wallet').addEventListener('click', () => saveNewWallet(data.address));
    $('add-wallet-label').addEventListener('keydown', e => { if (e.key === 'Enter') saveNewWallet(data.address); });
  }
}

function symbolToChains(symbol, address) {
  const s = symbol.trim().toUpperCase();
  const knownMap = {
    LTC: ['litecoin'], BTC: ['bitcoin'], ETH: ['ethereum', 'polygon', 'avalanche'],
    SOL: ['solana'], SUI: ['sui'], AVAX: ['avalanche'], MATIC: ['polygon'],
  };
  if (knownMap[s]) return knownMap[s];
  // Fall back to auto-detected chains if user left symbol blank or unknown
  if (!s) return detectNetwork(address).chains;
  return [s.toLowerCase()];
}

async function saveNewWallet(address) {
  const label  = $('add-wallet-label')?.value.trim() ?? '';
  const symbol = $('add-wallet-symbol')?.value ?? '';
  const status = $('add-wallet-status');
  const btn    = $('btn-confirm-add-wallet');
  if (!label) { if (status) status.textContent = i18n('addrLabelRequired','Label is required'); return; }

  const chains = symbolToChains(symbol, address);

  btn.disabled = true;
  if (status) status.textContent = 'Saving…';

  try {
    const res = await fetch('/api/wallets', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ address, label, chains }),
    });
    const data = await res.json();
    if (!res.ok) {
      if (status) status.textContent = data.message ?? i18n('addrFailedToSave','Failed to save');
      btn.disabled = false;
      return;
    }
    // Re-run the lookup so the panel now shows "Your wallet"
    await checkAddress(address);
  } catch (e) {
    if (status) status.textContent = 'Error: ' + e.message;
    btn.disabled = false;
  }
}

// ── Add Transaction wallet picker ─────────────────────────────────────────────
const btnAddTx     = $('btn-add-tx');
const walletPicker = $('wallet-picker');

btnAddTx?.addEventListener('click', (e) => {
  e.stopPropagation();
  const isOpen = walletPicker.style.display !== 'none';
  walletPicker.style.display = isOpen ? 'none' : 'block';
});

// Close picker when clicking outside
document.addEventListener('click', (e) => {
  if (walletPicker && !walletPicker.contains(e.target) && e.target !== btnAddTx) {
    walletPicker.style.display = 'none';
  }
});

// Wire wallet-picker items → open AddTransactionModal
walletPicker?.querySelectorAll('.wallet-picker-item').forEach(item => {
  item.addEventListener('click', () => {
    const walletId    = item.getAttribute('data-wallet-id');
    const walletLabel = item.getAttribute('data-wallet-label');
    walletPicker.style.display = 'none';
    document.dispatchEvent(new CustomEvent('open-add-tx', {
      detail: { walletId, walletLabel },
    }));
  });
});

// ── Boot ──────────────────────────────────────────────────────────────────────
loadNeedsAttention().catch(console.error);
loadIntake();
loadHealthCheck();
</script>

{isAdmin && (
<script>
// ── Admin activity log ────────────────────────────────────────────────────────
(function () {
  const pill    = document.getElementById('log-pill');
  const panel   = document.getElementById('log-panel');
  const closeBtn = document.getElementById('log-panel-close');
  const entries  = document.getElementById('log-entries');
  const filterRow = document.getElementById('log-filter-row');
  if (!pill || !panel) return;

  let loaded = false;
  let activeSource = 'all';
  let activeChain  = 'all';

  pill.addEventListener('click', () => {
    const isOpen = panel.classList.contains('open');
    panel.classList.toggle('open', !isOpen);
    panel.setAttribute('aria-hidden', String(isOpen));
    if (!isOpen && !loaded) fetchLog();
  });

  closeBtn?.addEventListener('click', () => {
    panel.classList.remove('open');
    panel.setAttribute('aria-hidden', 'true');
  });

  function fmtTime(iso) {
    const d = new Date(iso + (iso.endsWith('Z') ? '' : 'Z'));
    return d.toLocaleString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function applyFilters() {
    document.querySelectorAll('#log-entries .log-entry').forEach(el => {
      const src   = el.dataset.source ?? '';
      const chain = el.dataset.chain  ?? '';
      const srcOk   = activeSource === 'all' || src   === activeSource;
      const chainOk = activeChain  === 'all' || chain === activeChain;
      el.classList.toggle('hidden', !(srcOk && chainOk));
    });
  }

  function buildChips(sources, chains) {
    filterRow.innerHTML = '';
    const addChip = (label, val, group) => {
      const btn = document.createElement('button');
      btn.className = 'log-chip' + (val === 'all' ? ' log-chip-active' : '');
      btn.textContent = label;
      btn.dataset.filter = val;
      btn.dataset.group  = group;
      btn.addEventListener('click', () => {
        filterRow.querySelectorAll(`[data-group="${group}"]`).forEach(b => b.classList.remove('log-chip-active'));
        btn.classList.add('log-chip-active');
        if (group === 'source') activeSource = val;
        else activeChain = val;
        applyFilters();
      });
      filterRow.appendChild(btn);
    };

    addChip('All sources', 'all', 'source');
    sources.forEach(s => addChip(s.replace('_', '.'), s, 'source'));
    addChip('All chains', 'all', 'chain');
    chains.forEach(c => addChip(c, c, 'chain'));
  }

  async function fetchLog() {
    entries.innerHTML = '<div class="log-empty">Loading…</div>';
    try {
      const res  = await fetch('/api/admin/activity-log?limit=300');
      const data = await res.json();
      if (!data.ok) throw new Error('not ok');

      buildChips(data.sources ?? [], data.chains ?? []);

      if (!data.entries?.length) {
        entries.innerHTML = '<div class="log-empty">No activity recorded yet.</div>';
        loaded = true;
        return;
      }

      entries.innerHTML = data.entries.map(e => {
        const badgeClass = `log-badge log-badge-${e.event_type}`;
        const src   = e.source ?? '';
        const chain = e.chain  ?? '';
        return `<div class="log-entry" data-source="${src}" data-chain="${chain}">
          <span class="log-time">${fmtTime(e.created_at)}</span>
          <span class="log-summary">${e.summary}</span>
          <span class="${badgeClass}">${e.event_type.replace('_', ' ')}</span>
          <span class="log-tenant">${String(e.tenant_id).slice(0, 8)}… ${src ? '· ' + src.replace('_','.') : ''} ${chain ? '· ' + chain : ''}</span>
        </div>`;
      }).join('');

      loaded = true;
    } catch {
      entries.innerHTML = '<div class="log-empty">Failed to load log.</div>';
    }
  }
})();
</script>
)}

