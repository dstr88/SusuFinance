    }
    .tin-csv-btn:hover { background: rgba(255,255,255,0.13); }

    /* ── Section total ─────────────────────────────────────── */
    .tin-total {
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
      flex-wrap: wrap;
      padding: 0.5rem 0.75rem;
      background: rgba(255,255,255,0.04);
      border-radius: 8px;
      font-size: 0.9rem;
      margin-bottom: 0.75rem;
    }
    .tin-total strong { font-size: 1.05rem; }
    .tin-total__kind {
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      opacity: 0.55;
      margin-right: 0.15rem;
    }
    .tin-total__note {
      font-size: 0.75rem;
      opacity: 0.5;
      margin-left: auto;
      font-style: italic;
    }
    .tin-total--warn { background: rgba(239,68,68,0.08); }

    /* ── Row list ───────────────────────────────────────────── */
    .tin-rows {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      overflow-y: auto;
    }
    .tin-rows--income {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 0.4rem;
      overflow-y: visible;
    }

    .tin-row {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.4rem 0.75rem;
      padding: 0.45rem 0.7rem;
      border-radius: 7px;
      background: rgba(255,255,255,0.04);
      font-size: 0.85rem;
      transition: background 0.12s;
    }
    .tin-row:hover { background: rgba(255,255,255,0.08); }

    .tin-row--alert { border-left: 3px solid rgba(239,68,68,0.6); cursor: pointer; }
    .tin-row--alert:hover { background: rgba(239,68,68,0.08); }
    .tin-row__cta { margin-left: auto; font-size: 0.75rem; opacity: 0.45; font-weight: 600; letter-spacing: 0.04em; }
    .tin-row--alert:hover .tin-row__cta { opacity: 0.8; color: var(--loss); }
    .tin-row--income { border-left: 3px solid var(--accent-dim); }

    .tin-row__source-icon { width: 18px; height: 18px; border-radius: 4px; object-fit: contain; flex-shrink: 0; opacity: 0.85; margin-right: 0.1rem; vertical-align: middle; position: relative; top: -1px; }
    .tin-row__asset  { font-weight: 800; font-size: 0.95rem; letter-spacing: 0.04em; min-width: 3rem; max-width: 22ch; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .tin-row__qty    { font-variant-numeric: tabular-nums; opacity: 0.75; }
    .tin-row__date   { opacity: 0.55; font-size: 0.78rem; }
    .tin-row__dates  { display: flex; align-items: center; gap: 0.3rem; font-size: 0.78rem; opacity: 0.6; }
    .tin-row__arrow  { opacity: 0.4; }
    .tin-row__days   { opacity: 0.45; font-size: 0.72rem; }
    .tin-row__usd    { font-variant-numeric: tabular-nums; }
    .tin-row__gain   { font-weight: 700; font-size: 0.9rem; margin-left: auto; }
    .tin-row__note   { font-size: 0.75rem; opacity: 0.45; font-style: italic; }
    .tin-row__note--labeled { opacity: 1; font-style: normal; color: var(--accent-dim); font-weight: 600; }
    .tin-row__kind   { font-size: 0.75rem; opacity: 0.55; }
    .tin-row__term   { font-size: 0.72rem; font-weight: 700; padding: 0.1rem 0.4rem; border-radius: 4px; }

    /* ── Provenance trace line (audit trail — origin + basis source) ── */
    .tin-row__trace {
      flex-basis: 100%;
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.4rem 0.6rem;
      margin-top: 0.15rem;
      padding-top: 0.3rem;
      border-top: 1px dashed var(--border-subtle);
    }
    .basis-badge {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      padding: 0.08rem 0.4rem;
      border-radius: 4px;
      white-space: nowrap;
    }
    .basis-badge--recorded { color: var(--gain);    background: var(--gain-bg);    border: 1px solid var(--gain-border); }
    .basis-badge--est      { color: var(--warning); background: var(--warning-bg); border: 1px solid var(--warning-border); }
    .basis-badge--missing  { color: var(--loss);    background: var(--loss-bg);    border: 1px solid var(--loss-border); }
    .tin-row__origin {
      font-size: 0.72rem;
      opacity: 0.6;
      font-style: italic;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      max-width: 48ch;
    }
    .tin-trace-link {
      font-size: 0.72rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      margin-left: auto;
      white-space: nowrap;
      opacity: 0.85;
    }
    .tin-trace-link:hover { opacity: 1; text-decoration: underline; }
    .tin-hold-trace { font-size: 0.72rem; font-weight: 600; color: var(--accent); text-decoration: none; opacity: 0.75; white-space: nowrap; }
    .tin-hold-trace:hover { opacity: 1; text-decoration: underline; }

    /* ── DeFi rows grid (multi-column when wide) ────────────── */
    .tin-rows--defi {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 0.4rem;
      overflow-y: visible;
    }

    /* ── Row: aToken (Aave collateral deposit) ──────────────── */
    .tin-row--atoken {
      border-left: 3px solid rgba(6,182,212,0.55);
      background: rgba(6,182,212,0.05);
      color: #e0f7fa;
    }
    .tin-row--atoken:hover { background: rgba(6,182,212,0.1); }
    .tin-row--atoken .tin-row__asset { color: #67e8f9; }

    /* ── Row: Debt token (borrowed, still owed) ─────────────── */
    .tin-row--debt {
      border-left: 3px solid rgba(239,68,68,0.6);
      background: rgba(239,68,68,0.07);
      color: #fecaca;
    }
    .tin-row--debt:hover { background: rgba(239,68,68,0.13); }
    .tin-row--debt .tin-row__asset { color: #f87171; }

    /* ── Row: Stablecoin in regular wallet ──────────────────── */
    .tin-row--stable {
      border-left: 3px solid rgba(255,255,255,0.35);
      background: rgba(255,255,255,0.06);
      color: #f5f5f5;
    }
    .tin-row--stable:hover { background: rgba(255,255,255,0.1); }
    .tin-row--stable .tin-row__asset { color: #ffffff; }

    /* ── Asset type badges ──────────────────────────────────── */
    .asset-badge {
      display: inline-flex;
      align-items: center;
      font-size: 0.6rem;
      font-weight: 800;
      letter-spacing: 0.09em;
      padding: 0.1rem 0.35rem;
      border-radius: 4px;
      vertical-align: middle;
    }
    .asset-badge--stable {
      background: rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.7);
      border: 1px solid rgba(255,255,255,0.22);
    }
    .asset-badge--atoken {
      background: rgba(6,182,212,0.18);
      color: #67e8f9;
      border: 1px solid rgba(6,182,212,0.35);
    }
    .asset-badge--debt {
      background: rgba(239,68,68,0.18);
      color: #f87171;
      border: 1px solid rgba(239,68,68,0.35);
    }
    .asset-badge--scam {
      background: rgba(251,191,36,0.18);
      color: #fbbf24;
      border: 1px solid rgba(251,191,36,0.45);
      animation: scam-pulse 2s ease-in-out infinite;
    }
    .asset-badge--verify {
      background: rgba(251,191,36,0.08);
      color: rgba(251,191,36,0.7);
      border: 1px solid rgba(251,191,36,0.2);
    }
    .tin-row--scam {
      border-left: 3px solid rgba(251,191,36,0.6) !important;
    }
    @keyframes scam-pulse {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.55; }
    }

    /* ── Colour tokens ──────────────────────────────────────── */
    .gain-pos { color: var(--gain); }
    .gain-neg { color: var(--loss); }
    .term-long  { background: var(--gain-bg); color: var(--gain); }
    .term-short { background: rgba(245,158,11,0.12); color: #fbbf24; }

    /* ── Empty state ────────────────────────────────────────── */
    .tin-empty {
      font-size: 0.9rem;
      opacity: 0.5;
      padding: 1rem 0.5rem;
      margin: 0;
      font-style: italic;
    }


    /* ── "Confirmed held" checkbox ──────────────────────────── */
    .tin-row__confirm {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      margin-left: auto;
      cursor: pointer;
    }
    .confirm-check { accent-color: #3b82f6; cursor: pointer; }
    .confirm-label { font-size: 0.72rem; opacity: 0.45; }
    .tin-row__confirm:has(.confirm-check:checked) .confirm-label {
      opacity: 0.8;
      color: #86efac;
    }

    /* ── Responsive ─────────────────────────────────────────── */
    @media (max-width: 1080px) {
      .breakdown-grid,
      .year-bar {
        max-width: none;
        margin: 0 1.5rem;
      }
    }
    @media (max-width: 760px) {
      .breakdown-grid { grid-template-columns: 1fr; }
      .grid-cell--full { grid-column: 1; }
      .hero-bleed { height: 45vh; min-height: 320px; }
      .grid-cell { height: 50vh; max-height: none; }
      .grid-cell--full { height: 40vh; max-height: none; }
    }
  </style>

  <script>
    // ── Tax Readiness Bar ──────────────────────────────────────────────────────
    (async () => {
      const bar   = document.getElementById('readiness-bar');
      const fill  = document.getElementById('readiness-fill') as HTMLElement | null;
      const score = document.getElementById('readiness-score');
      const label = document.getElementById('readiness-label');
      if (!bar || !fill || !score || !label) return;

      const year = bar.dataset.year ?? String(new Date().getFullYear() - 1);

      function scoreColor(s: number) {
        if (s >= 90) return '#10b981'; // emerald
        if (s >= 70) return '#f59e0b'; // amber
        return '#ef4444';              // red
      }

      function buildLabel(data: {
        score: number;
        label: string;
        pillars: { status: string; label: string; detail: string; issueCount: number }[];
      }) {
        // Pull the most actionable issue across all pillars
        const issues: string[] = [];
        for (const p of data.pillars) {
          if (p.issueCount > 0) issues.push(p.detail);
        }
        return issues.length > 0
          ? `${data.label} — ${issues.slice(0, 2).join(' · ')}`
          : data.label;
      }

      try {
        const res  = await fetch(`/api/yearEnd/completeness?year=${year}`);
        if (!res.ok) return;
        const data = await res.json();
        if (!data.ok) return;

        const pct   = data.score as number;
        const color = scoreColor(pct);

        fill.style.width      = `${pct}%`;
        fill.style.background = color;
        score.textContent     = `${pct}%`;
        score.style.color     = color;
        label.textContent     = buildLabel(data);
      } catch {
        // silent — bar stays in loading state
      }
    })();
  </script>

  <script>
    // Persist "confirmed held" checkboxes across page loads via localStorage
    const KEY = 'held-confirmed';
    const stored: Record<string, boolean> = JSON.parse(localStorage.getItem(KEY) ?? '{}');

    document.querySelectorAll<HTMLInputElement>('.confirm-check').forEach((cb) => {
      const id = `${cb.dataset.asset}|${cb.dataset.date}`;
      if (stored[id]) cb.checked = true;
      cb.addEventListener('change', () => {
        if (cb.checked) stored[id] = true;
        else delete stored[id];
        localStorage.setItem(KEY, JSON.stringify(stored));
      });
    });
  </script>

  <script>
    // Open TransactionDrawer when a Needs Attention row is clicked
    document.addEventListener('click', (e: MouseEvent) => {
      const row = (e.target as Element).closest<HTMLElement>('.tin-row--alert');
      if (!row) return;

      const detail = {
        asset: row.dataset.asset ?? '',
        amount: parseFloat(row.dataset.amount ?? '0') || 0,
        sellDate: row.dataset.sellDate ?? '',
        proceedsUsd: row.dataset.proceeds ? parseFloat(row.dataset.proceeds) : null,
        sourceId: row.dataset.sourceId ?? '',
        groupId: row.dataset.groupId ?? '',
        txHash: row.dataset.txHash || null,
        transactionClass: row.dataset.txClass ?? '',
        sourceType: row.dataset.sourceType ?? '',
      };

      window.dispatchEvent(new CustomEvent('open-transaction-drawer', { detail }));
    });
  </script>

  <script>
    // ── Jurisdiction toggle ────────────────────────────────────────────────────
    // Fires a POST to /api/settings/jurisdiction and reloads so the SSR
    // profile is re-read.  Simple and predictable — no client-side state.
    document.querySelectorAll<HTMLButtonElement>('.jur-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const jur = btn.dataset.jur;
        if (!jur) return;
        try {
          const res = await fetch('/api/settings/jurisdiction', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ jurisdiction: jur }),
          });
          if (res.ok) window.location.reload();
        } catch {
          // silent — the button stays in its current visual state
        }
      });
    });
  </script>

  <script>
    // NFT manual cost basis — save on click, then show the value in place.
    document.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement)?.closest('.nft-cost-save');
      if (!btn) return;
      const wrap = btn.closest('.nft-cost-entry') as HTMLElement | null;
      const input = wrap?.querySelector('.nft-cost-input') as HTMLInputElement | null;
      if (!input) return;
      const costUsd = input.value.trim();
      if (costUsd === '') return;
      (btn as HTMLButtonElement).disabled = true;
      try {
        const res = await fetch('/api/tokens/nft-cost', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            chain: input.dataset.chain, contract: input.dataset.contract,
            tokenId: input.dataset.tokenid, costUsd,
          }),
        });
        if (!res.ok) throw new Error();
        const usd = Number(costUsd).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        if (wrap) wrap.outerHTML = '<span class="tin-row__usd">' + usd + '</span>';
      } catch {
        (btn as HTMLButtonElement).disabled = false;
        btn.textContent = 'retry';
      }
    });
  </script>
  <AiChat client:load />
</Layout>
