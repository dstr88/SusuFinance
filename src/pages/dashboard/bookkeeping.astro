        0 0 0 1px rgba(255,255,255,0.06) inset !important;
    }
    :global(.tin-section--defi::after) {
      border-color: rgba(6,182,212,0.55) !important;
    }

    /* Income: accent (Electric Mint) */
    :global(.tin-section--income .ornate-tin__label) {
      background: linear-gradient(180deg, rgba(45,212,168,0.85), rgba(45,212,168,0.6)) !important;
      color: var(--surface-bg) !important;
    }
    :global(.tin-section--income::before) {
      box-shadow:
        0 0 0 2px rgba(45,212,168,0.8) inset,
        0 0 0 8px rgba(45,212,168,0.08) inset,
