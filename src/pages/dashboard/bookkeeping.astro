---
import Layout from '../../layouts/Layout.astro';
import AiChat from '../../components/AiChat';
import NetWorthHero from '../../components/dashboard/NetWorthHero.astro';
import OrnateTin from '@/components/OrnatedTin.astro';
import DrawerHost from '../../components/bookkeeping/DrawerHost';
import ReconciliationTin from '../../components/bookkeeping/ReconciliationTin';
import JunkDrawer from '../../components/bookkeeping/JunkDrawer';
import { requireTenantSession } from '../../lib/requireTenantSession';
import { buildAnnualBreakdown, fmvSourceCategory, formatCostBasisMethod } from '../../lib/annualBreakdown';
import { classifyTokenName } from '../../lib/tokenClassification';
import { getTokenOverrides, lookupOverride, effectiveClass } from '../../lib/tokenOverrides';
import { getActivePlan } from '../../lib/subscriptions';
import { db } from '../../lib/db';
import { getJurisdictionProfile } from '../../lib/jurisdictionProfile';
import { tenantHasTaxAccess } from '../../lib/taxAuth';
import { getLang } from '@/lib/i18n/locale';
import { getBookkeeping } from '@/i18n/dashboard/bookkeeping';

const lang = getLang(Astro.request);
const t = getBookkeeping(lang);

const { tenantId } = await requireTenantSession(Astro.request);
const canTax = tenantHasTaxAccess(tenantId);

// Plan check for Year Summary PDF
const activePlan = await getActivePlan(tenantId);
const canDownloadPdf = activePlan.id === 'unlimited';

// Year selector — default to last year
const currentYear = new Date().getFullYear();
const defaultYear = currentYear - 1;
const yearParam   = Astro.url.searchParams.get('year');
const selectedYear = yearParam ? Number(yearParam) : defaultYear;

const bd      = await buildAnnualBreakdown(tenantId, selectedYear);

// Cost basis method actually applied — read from the breakdown so the label can
// never drift from the computation.
const costBasisMethod  = formatCostBasisMethod(bd.method);
// Non-taxable card rebates total (shown as a $0-tax line so the CPA can confirm it).
const cardRebatesTotal = bd.cardRebates.reduce((s, i) => s + (i.usdValue ?? 0), 0);

// Hide scam/spam airdrop tokens (Still in Wallet + Needs Attention) and any
// disposal dated before the 2025 bookkeeping start. The realized short/long-term
// tax sections, the FIFO cost-basis math, and the yearEnd/PDF exports are left
// untouched — this only cleans the two display lists below + their count/total.
const BOOKKEEPING_START = '2025-01-01';
// Spam filter, override-aware: a token the user marked "include" reappears here,
// one marked "junk" stays hidden. Symbol-level (bookkeeping rows have no contract).
const tokenOverrides = await getTokenOverrides(tenantId);
const notScam = (asset: string) =>
  effectiveClass(classifyTokenName({ symbol: asset }).class, lookupOverride(tokenOverrides, { symbol: asset })) !== 'spam';
const needsAttention = bd.needsAttention.filter(
  (i) => notScam(i.asset) && i.sellDate >= BOOKKEEPING_START,
);
const unsettledProceeds = needsAttention.reduce((s, i) => s + (i.proceedsUsd ?? 0), 0);
const profile = await getJurisdictionProfile(tenantId);

// ── Counterparty labels for Needs Attention items ────────────────────────────
// For each mystery transaction, look up the to_address in address_labels and
// global_address_labels so we can show a human name directly on the row.
const attentionLabels = new Map<string, string>();
{
  const sourceIds = needsAttention.map(i => i.sourceId).filter(Boolean);
  if (sourceIds.length > 0) {
    const placeholders = sourceIds.map(() => '?').join(', ');
    try {
      const result = await db.execute({
        sql: `SELECT t.id,
                     COALESCE(pal.label, gal.label) AS counterparty_label
              FROM transactions t
              LEFT JOIN address_labels pal
                ON pal.tenant_id = ?
                AND LOWER(pal.address) = LOWER(t.to_address)
              LEFT JOIN global_address_labels gal
                ON LOWER(gal.address) = LOWER(t.to_address)
              WHERE t.id IN (${placeholders})
                AND (pal.label IS NOT NULL OR gal.label IS NOT NULL)`,
        args: [tenantId, ...sourceIds],
      });
      for (const row of result.rows as { id: unknown; counterparty_label: unknown }[]) {
        if (row.counterparty_label && row.id) {
          attentionLabels.set(String(row.id), String(row.counterparty_label));
        }
      }
    } catch (e) {
      console.warn('[bookkeeping] counterparty label lookup failed', e);
    }
  }
}

// ── Source icon helper ───────────────────────────────────────────────────────
function sourceIcon(source: string | null | undefined): { url: string; alt: string } | null {
  if (!source) return null;
  const s = source.toLowerCase().trim();
  const map: { key: string; domain: string; alt: string }[] = [
    { key: 'exodus',     domain: 'exodus.com',     alt: 'Exodus'      },
    { key: 'crypto.com', domain: 'crypto.com',     alt: 'Crypto.com'  },
    { key: 'cdc',        domain: 'crypto.com',     alt: 'Crypto.com'  },
    { key: 'venmo',      domain: 'venmo.com',      alt: 'Venmo'       },
    { key: 'coinbase',   domain: 'coinbase.com',   alt: 'Coinbase'    },
    { key: 'kraken',     domain: 'kraken.com',     alt: 'Kraken'      },
    { key: 'binance',    domain: 'binance.com',    alt: 'Binance'     },
    { key: 'gemini',     domain: 'gemini.com',     alt: 'Gemini'      },
    { key: 'kucoin',     domain: 'kucoin.com',     alt: 'KuCoin'      },
    { key: 'robinhood',  domain: 'robinhood.com',  alt: 'Robinhood'   },
    { key: 'bybit',      domain: 'bybit.com',      alt: 'Bybit'       },
    { key: 'okx',        domain: 'okx.com',        alt: 'OKX'         },
    { key: 'bitfinex',   domain: 'bitfinex.com',   alt: 'Bitfinex'    },
    { key: 'ledger',     domain: 'ledger.com',     alt: 'Ledger'      },
    { key: 'metamask',   domain: 'metamask.io',    alt: 'MetaMask'    },
    { key: 'trust',      domain: 'trustwallet.com',alt: 'Trust Wallet'},
    { key: 'phantom',    domain: 'phantom.app',    alt: 'Phantom'     },
  ];
  for (const entry of map) {
    if (s.includes(entry.key)) {
      return { url: `https://www.google.com/s2/favicons?domain=${entry.domain}&sz=32`, alt: entry.alt };
    }
  }
  return null;
}

// ── Formatters ──────────────────────────────────────────────────────────────
const dateLocale = lang === 'es' ? 'es-ES' : lang === 'fr' ? 'fr-FR' : 'en-US';
const fDate = (iso: string | null) => {
  if (!iso) return '—';
  try {
    return new Date(iso).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', year: 'numeric' });
  } catch { return iso; }
};
const fQty = (v: number) =>
  Number.isFinite(v) ? v.toLocaleString(undefined, { maximumFractionDigits: 6 }) : '—';
const fUsd = (v: number | null) => {
  if (v == null || !Number.isFinite(v)) return '—';
  const sign = v < 0 ? '-' : '';
  return `${sign}$${Math.abs(v).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};
const fGain = (v: number | null) => {
  if (v == null || !Number.isFinite(v)) return { text: '—', cls: '' };
  const sign = v >= 0 ? '+' : '-';
  return {
    text: `${sign}$${Math.abs(v).toLocaleString(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`,
    cls: v >= 0 ? 'gain-pos' : 'gain-neg',
  };
};
const csvBase = (section: string) =>
  `/api/yearEnd/breakdown-csv?year=${selectedYear}&section=${section}`;

// Provenance badge for a disposal's cost basis — see SettledLot.basisSource.
const basisMeta = (s?: string): { label: string; cls: string } => {
  switch (s) {
    case 'manual':
    case 'estimated': return { label: 'estimated basis', cls: 'basis-badge--est' };
    case 'missing':   return { label: 'no recorded basis', cls: 'basis-badge--missing' };
    default:          return { label: 'recorded basis', cls: 'basis-badge--recorded' };
  }
};

const kindLabel = (kind: string) =>
  kind
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (c) => c.toUpperCase())
    .replace(/Crypto/g, 'Crypto')
    .trim();

// ── FMV (fair market value) provenance label for an income row ────────────────
const fmvTime = (iso: string) => {
  try {
    const d = new Date(iso);
    return `${String(d.getUTCHours()).padStart(2, '0')}:${String(d.getUTCMinutes()).padStart(2, '0')} UTC`;
  } catch { return ''; }
};
const fmvLabel = (item: { priceSource: string | null; priceAsof: string | null; usdValue: number | null }) => {
  const cat = fmvSourceCategory(item.priceSource, item.usdValue);
  const base = cat === 'source' ? t.fmvExchange
    : cat === 'stablecoin'      ? t.fmvStablecoin
    : cat === 'estimated'       ? t.fmvEstimated
    :                             t.fmvUnpriced;
  return (cat === 'estimated' && item.priceAsof)
    ? `${base} · ${t.fmvPricedAt(fmvTime(item.priceAsof))}`
    : base;
};

// ── Asset classifiers ────────────────────────────────────────────────────────
const STABLECOINS = new Set([
  'USDC','USDT','DAI','BUSD','FRAX','TUSD','USDP','GUSD','LUSD',
  'CRVUSD','USDE','PYUSD','USDS','FDUSD','SUSD','MUSD','ALUSD',
]);
const isAToken    = (s: string) => /^a[A-Z]/.test(s);   // aUSDC, aWETH, aPolUSDC…
const isDebtToken = (s: string) => /^(variableDebt|stableDebt)/i.test(s);
const isDefiAsset = (s: string) => isAToken(s) || isDebtToken(s);
const isStable    = (s: string) => STABLECOINS.has(s.replace(/^a/, '').toUpperCase());

// Split holdings into regular wallet vs DeFi protocol positions
const walletHoldings = bd.stillHolding.filter(p => !isDefiAsset(p.asset) && notScam(p.asset));
const defiHoldings   = bd.stillHolding.filter(p => isDefiAsset(p.asset));

const walletCostBasis = walletHoldings.reduce((s, p) => s + (p.costUsd ?? 0), 0);
const defiCostBasis   = defiHoldings.reduce((s, p)   => s + (p.costUsd ?? 0), 0);

// ── On-chain transaction-sync freshness (drives the "synced N ago" strip) ──────
// Reads wallet_sync_state.last_run_at — stamped after the EVM ledger is pulled
// (sync-wallets cron OR the in-app sync). If it's old, the bookkeeping data is
// behind, which is otherwise silent. Thresholds: ok ≤8d, warn ≤30d, else stale.
const syncFreshRow = await db.execute({
  sql: `SELECT MAX(last_run_at) AS last FROM wallet_sync_state WHERE tenant_id = ?`,
  args: [tenantId],
});
const lastSyncRaw = syncFreshRow.rows[0]?.last as string | null;
const lastSyncMs  = lastSyncRaw ? Date.parse(String(lastSyncRaw).replace(' ', 'T') + 'Z') : NaN;
const hasSync     = Number.isFinite(lastSyncMs);
const syncAgeDays = hasSync ? (Date.now() - lastSyncMs) / 86_400_000 : Infinity;
const syncLevel: 'ok' | 'warn' | 'stale' | 'never' =
  !hasSync ? 'never' : syncAgeDays <= 8 ? 'ok' : syncAgeDays <= 30 ? 'warn' : 'stale';
const syncRtf = new Intl.RelativeTimeFormat(lang, { numeric: 'auto' });
const syncRelative = !hasSync ? '' :
  syncAgeDays < 1   ? syncRtf.format(-Math.max(1, Math.round((Date.now() - lastSyncMs) / 3_600_000)), 'hour') :
  syncAgeDays < 45  ? syncRtf.format(-Math.round(syncAgeDays), 'day') :
  syncAgeDays < 365 ? syncRtf.format(-Math.round(syncAgeDays / 30), 'month') :
                      syncRtf.format(-Math.round(syncAgeDays / 365), 'year');
---

<Layout title={t.pageTitle} noindex={true}>
  <section class="bookkeeping-page">
    <div class="hero-bleed">
      <NetWorthHero title={t.heroTitle} subtitle={t.heroSubtitle} />
    </div>

    <!-- ══ Year Selector ════════════════════════════════════════════════════ -->
    <div class="year-bar">
      <span class="year-bar__label">{t.yearBarLabel}</span>
      <div class="year-bar__pills">
        {bd.availableYears.map((y) => (
          <a
            href={`/dashboard/bookkeeping?year=${y}`}
            class={`year-pill ${y === selectedYear ? 'year-pill--active' : ''}`}
          >
            {y}
          </a>
        ))}
      </div>
      <div class="year-bar__actions">
        <div class="jur-toggle" aria-label="View as">
          <button class={`jur-btn${profile.jurisdiction === 'us' ? ' jur-btn--active' : ''}`} data-jur="us">US</button>
          <button class={`jur-btn${profile.jurisdiction === 'intl' ? ' jur-btn--active' : ''}`} data-jur="intl">Intl</button>
        </div>
        {canDownloadPdf ? (
          <a
            href={`/api/year-summary/report?year=${selectedYear}`}
            download={`almstins-${selectedYear}-year-summary.pdf`}
            class="year-summary-btn"
            title={t.pdfDownloadTitle(selectedYear)}
          >
            {t.pdfBtnLabel}
          </a>
        ) : (
          <a
            href="/dashboard/billing"
            class="year-summary-btn year-summary-btn--locked"
            title={t.pdfLockedTitle}
          >
            {t.pdfLockedLabel}
            <span class="year-summary-badge">{t.pdfPremiumBadge}</span>
          </a>
        )}
      </div>
    </div>

    <!-- ══ On-chain transaction-sync freshness strip ═══════════════════════ -->
    <div class={`sync-strip sync-strip--${syncLevel}`}>
      <span class="sync-strip__status">
        {syncLevel === 'never' ? t.txSyncedNever : `${t.txSyncedPrefix} ${syncRelative}`}
      </span>
      {(syncLevel === 'warn' || syncLevel === 'stale' || syncLevel === 'never') && (
        <span class="sync-strip__note">{t.syncStaleNote}</span>
      )}
      <button type="button" class="sync-strip__btn" id="bk-sync-now">{t.syncNow}</button>
    </div>

    <style>
      .sync-strip { display: flex; align-items: center; gap: 0.5rem 0.9rem; flex-wrap: wrap; margin: 0.25rem 0 1rem; padding: 0.5rem 0.9rem; border-radius: 8px; font-size: 0.82rem; border: 1px solid var(--border-subtle); background: var(--surface-card); color: var(--text-secondary); }
      .sync-strip__status { font-weight: 600; }
      .sync-strip__note { color: var(--text-muted); }
      .sync-strip__btn { margin-left: auto; padding: 0.32rem 0.95rem; border-radius: 999px; border: 1px solid var(--border-bright); background: transparent; color: var(--text-primary); font-size: 0.78rem; cursor: pointer; transition: background 0.15s ease; }
      .sync-strip__btn:hover { background: var(--surface-hover); }
      .sync-strip__btn:disabled { opacity: 0.6; cursor: default; }
      .sync-strip--warn { border-color: var(--warning-border); background: var(--warning-bg); color: var(--warning); }
      .sync-strip--stale, .sync-strip--never { border-color: var(--loss-border); background: var(--loss-bg); color: var(--loss); }
    </style>

    <script is:inline define:vars={{ bkSyncI18n: { syncing: t.syncingLabel, err: t.syncErrLabel } }}>window.__bkSyncI18n = bkSyncI18n;</script>
    <script>
      (() => {
        const btn = document.getElementById('bk-sync-now');
        if (!btn) return;
        const I = (window as any).__bkSyncI18n || {};
        const original = btn.textContent;
        btn.addEventListener('click', async () => {
          (btn as HTMLButtonElement).disabled = true;
          btn.textContent = I.syncing ?? 'Syncing…';
          try {
            // 1. Pull the on-chain ledger (Etherscan/Snowtrace) into `transactions`.
            const sync = await fetch('/api/wallets/sync-all', { method: 'POST' });
            if (!sync.ok) throw new Error('sync ' + sync.status);
            // 2. Rebuild the lifecycle so the freshly-fetched txns — including Aave
            //    repays/deposits — get classified into the events bookkeeping reads.
            //    Without this, sync-all fetches the repay but never surfaces it.
            const rebuild = await fetch('/api/lifecycle/rebuild', { method: 'POST' });
            if (!rebuild.ok) throw new Error('rebuild ' + rebuild.status);
            location.reload();
          } catch {
            (btn as HTMLButtonElement).disabled = false;
            btn.textContent = I.err ?? 'Sync failed — please try again.';
            setTimeout(() => { btn.textContent = original; }, 4000);
          }
        });
      })();
    </script>

    <!-- ══ Tax Readiness Bar ════════════════════════════════════════════════ -->
    <div class="readiness-bar" id="readiness-bar" data-year={selectedYear}>
      <div class="readiness-bar__track">
        <div class="readiness-bar__fill" id="readiness-fill"></div>
      </div>
      <div class="readiness-bar__body">
        <span class="readiness-bar__score" id="readiness-score">—</span>
        <span class="readiness-bar__label" id="readiness-label">{t.readinessCalculating}</span>
        {canTax && (
          <a href="/dashboard/yearEnd" class="readiness-bar__link">{t.readinessLink}</a>
        )}
      </div>
    </div>

    <!-- ══ 2×2 Grid + Full-Width Income ═════════════════════════════════════ -->
    <div class="breakdown-grid">

      <!-- 1. Needs Attention -->
      <div class="grid-cell">
        <OrnateTin label={t.tinNeedsAttention} class="tin-section tin-section--alert">
          <div class="tin-toolbar">
            <span class="tin-toolbar__count">{t.countItems(needsAttention.length)}</span>
            <a href={csvBase('needsAttention')} download class="tin-csv-btn">↓ CSV</a>
          </div>
          <div class="tin-total tin-total--warn">
            {t.untracedProceeds} <strong>{fUsd(unsettledProceeds)}</strong>
          </div>
          {needsAttention.length === 0 ? (
            <p class="tin-empty">{t.noOrphanedSales(selectedYear)}</p>
          ) : (
            <div class="tin-rows">
              {needsAttention.map((item) => {
                // 'other' class = unrecognised transfer pattern → most common scam signal
                const isOther = item.transactionClass === 'other';
                // Round number + unrecognised = strong scam indicator (e.g. exactly 1,000 USDC)
                const isRound = item.amount >= 100 && item.amount === Math.floor(item.amount);
                const scamLikely = isOther && isRound;
                const scamPossible = isOther && !isRound;
                const counterpartyLabel = attentionLabels.get(item.sourceId) ?? null;
                return (
                  <div
                    class={`tin-row tin-row--alert${scamLikely ? ' tin-row--scam' : ''}`}
                    data-source-id={item.sourceId}
                    data-group-id={item.groupId}
                    data-tx-hash={item.txHash ?? ''}
                    data-asset={item.asset}
                    data-amount={String(item.amount)}
                    data-sell-date={item.sellDate}
                    data-proceeds={item.proceedsUsd != null ? String(item.proceedsUsd) : ''}
                    data-tx-class={item.transactionClass}
                    data-source-type={item.sourceType}
                  >
                    {(() => { const icon = sourceIcon(item.sourceType); return icon ? <img src={icon.url} alt={icon.alt} class="tin-row__source-icon" title={icon.alt} /> : null; })()}
                    <span class="tin-row__asset">{item.asset}</span>
                    {scamLikely && <span class="asset-badge asset-badge--scam">SCAM?</span>}
                    {scamPossible && <span class="asset-badge asset-badge--verify">VERIFY</span>}
                    <span class="tin-row__qty">{fQty(item.amount)}</span>
                    <span class="tin-row__date">{fDate(item.sellDate)}</span>
                    <span class="tin-row__usd">{fUsd(item.proceedsUsd)}</span>
                    {counterpartyLabel
                      ? <span class="tin-row__note tin-row__note--labeled">→ {counterpartyLabel}</span>
                      : <span class="tin-row__note">{scamLikely ? t.noteUnrecognisedRound : scamPossible ? t.noteUnrecognisedTransfer : t.noteNoPurchase}</span>
                    }
                    <span class="tin-row__cta">{t.detailsCta}</span>
                  </div>
                );
              })}
            </div>
          )}
        </OrnateTin>
      </div>

      <!-- 2. Still in Wallet -->
      <div class="grid-cell">
        <OrnateTin label={t.tinStillInWallet} class="tin-section tin-section--hold">
          <div class="tin-toolbar">
            <span class="tin-toolbar__count">{t.countPositions(walletHoldings.length)}</span>
            <a href={csvBase('stillHolding')} download class="tin-csv-btn">↓ CSV</a>
          </div>
          <div class="tin-total">
            <span class="tin-total__kind">{t.costBasisLabel}</span>
            <strong>{fUsd(walletCostBasis)}</strong>
            <span class="tin-total__note">{t.costBasisNote}</span>
          </div>
          {walletHoldings.length === 0 ? (
            <p class="tin-empty">{t.noOpenPositions}</p>
          ) : (
            <div class="tin-rows">
              {walletHoldings.map((pos) => (
                <div class={`tin-row${isStable(pos.asset) ? ' tin-row--stable' : ''}`}>
                  <span class="tin-row__asset">{pos.asset}</span>
                  {isStable(pos.asset) && <span class="asset-badge asset-badge--stable">STABLE</span>}
                  <span class="tin-row__qty">{fQty(pos.amount)}</span>
                  <span class="tin-row__date">{t.sinceDateLabel(fDate(pos.acquiredDate))}</span>
                  <span class="tin-row__usd">{fUsd(pos.costUsd)}</span>
                  <span class={`tin-row__term ${pos.daysHeld >= 365 ? 'term-long' : 'term-short'}`}>
                    {profile.splitByTerm
                      ? `${pos.daysHeld >= 365 ? t.termLong : t.termShort} · ${pos.daysHeld}d`
                      : `${pos.daysHeld}d`}
                  </span>
                  {(pos.costUsd == null || pos.costUsd > 5) && (
                    <a class="tin-hold-trace" href={`/dashboard/yearEnd/memory-lane?year=${selectedYear}&symbol=${encodeURIComponent(pos.asset)}`}>trace origin →</a>
                  )}
                  <label class="tin-row__confirm">
                    <input type="checkbox" class="confirm-check" data-asset={pos.asset} data-date={pos.acquiredDate} />
                    <span class="confirm-label">{t.confirmedLabel}</span>
                  </label>
                </div>
              ))}
            </div>
          )}

        </OrnateTin>
      </div>

      <!-- DeFi Positions — full width, only shown when present -->
      {defiHoldings.length > 0 && (
        <div class="grid-cell grid-cell--full">
          <OrnateTin label={t.tinDefiPositions} class="tin-section tin-section--defi">
            <div class="tin-toolbar">
              <span class="tin-toolbar__count">{t.countPositions(defiHoldings.length)}</span>
              <span class="tin-toolbar__note">{t.defiToolbarNote}</span>
            </div>
            <div class="tin-total">
              {t.protocolCostBasis} <strong>{fUsd(defiCostBasis)}</strong>
              <span class="tin-total__note">{t.protocolCostBasisNote}</span>
            </div>
            <div class="tin-rows tin-rows--defi">
              {defiHoldings.map((pos) => (
                <div class={`tin-row${isDebtToken(pos.asset) ? ' tin-row--debt' : ' tin-row--atoken'}`}>
                  <span class="tin-row__asset">{pos.asset}</span>
                  {isDebtToken(pos.asset)
                    ? <span class="asset-badge asset-badge--debt">DEBT</span>
                    : <span class="asset-badge asset-badge--atoken">AAVE</span>
                  }
                  <span class="tin-row__qty">{fQty(pos.amount)}</span>
                  <span class="tin-row__date">{t.sinceDateLabel(fDate(pos.acquiredDate))}</span>
                  <span class="tin-row__usd">{fUsd(pos.costUsd)}</span>
                  <span class={`tin-row__term ${pos.daysHeld >= 365 ? 'term-long' : 'term-short'}`}>
                    {profile.splitByTerm
                      ? `${pos.daysHeld >= 365 ? t.termLong : t.termShort} · ${pos.daysHeld}d`
                      : `${pos.daysHeld}d`}
                  </span>
                </div>
              ))}
            </div>
          </OrnateTin>
        </div>
      )}

      <!-- 3 & 4. Realized G/L — split into two tins (US) or one combined tin (Intl) -->
      {profile.splitByTerm ? (
        <>
          <!-- Short-Term G/L -->
          <div class="grid-cell">
            <OrnateTin label={profile.shortTermLabel} class="tin-section tin-section--short">
              <div class="tin-toolbar">
                <span class="tin-toolbar__count">{t.countLots(bd.shortTerm.length)}</span>
                <a href={csvBase('shortTerm')} download class="tin-csv-btn">↓ CSV</a>
              </div>
              {(() => {
                const g = fGain(bd.totals.shortTermGain);
                return (
                  <div class={`tin-total ${g.cls}`}>
                    {t.netShortTerm} <strong>{g.text}</strong>
                    {profile.showUsTaxNotes && (
                      <span class="tin-total__note">{t.taxedAsOrdinaryIncome}</span>
                    )}
                  </div>
                );
              })()}
              {bd.shortTerm.length === 0 ? (
                <p class="tin-empty">{t.noShortTermDisposals(selectedYear)}</p>
              ) : (
                <div class="tin-rows">
                  {bd.shortTerm.map((lot) => {
                    const g = fGain(lot.gainLossUsd);
                    const b = basisMeta(lot.basisSource);
                    return (
                      <div class="tin-row">
                        <span class="tin-row__asset">{lot.asset}</span>
                        <span class="tin-row__qty">{fQty(lot.amount)}</span>
                        <div class="tin-row__dates">
                          <span>{fDate(lot.buyDate)}</span>
                          <span class="tin-row__arrow">→</span>
                          <span>{fDate(lot.sellDate)}</span>
                          <span class="tin-row__days">{lot.daysHeld}d</span>
                        </div>
                        <span class="tin-row__usd">{fUsd(lot.costUsd)}</span>
                        <span class="tin-row__usd">{fUsd(lot.proceedsUsd)}</span>
                        <span class={`tin-row__gain ${g.cls}`}>{g.text}</span>
                        <div class="tin-row__trace">
                          <span class={`basis-badge ${b.cls}`}>{b.label}</span>
                          {lot.originNote && <span class="tin-row__origin" title={lot.originNote}>{lot.originNote}</span>}
                          <a class="tin-trace-link" href={`/dashboard/yearEnd/memory-lane?year=${selectedYear}&symbol=${encodeURIComponent(lot.asset)}`}>trace origin →</a>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </OrnateTin>
          </div>

          <!-- Long-Term G/L -->
          <div class="grid-cell">
            <OrnateTin label={profile.longTermLabel} class="tin-section tin-section--long">
              <div class="tin-toolbar">
                <span class="tin-toolbar__count">{t.countLots(bd.longTerm.length)}</span>
                <a href={csvBase('longTerm')} download class="tin-csv-btn">↓ CSV</a>
              </div>
              {(() => {
                const g = fGain(bd.totals.longTermGain);
                return (
                  <div class={`tin-total ${g.cls}`}>
                    {t.netLongTerm} <strong>{g.text}</strong>
                    {profile.showUsTaxNotes && (
                      <span class="tin-total__note">{t.preferentialRate}</span>
                    )}
                  </div>
                );
              })()}
              {bd.longTerm.length === 0 ? (
                <p class="tin-empty">{t.noLongTermDisposals(selectedYear)}</p>
              ) : (
                <div class="tin-rows">
                  {bd.longTerm.map((lot) => {
                    const g = fGain(lot.gainLossUsd);
                    const b = basisMeta(lot.basisSource);
                    return (
                      <div class="tin-row">
                        <span class="tin-row__asset">{lot.asset}</span>
                        <span class="tin-row__qty">{fQty(lot.amount)}</span>
                        <div class="tin-row__dates">
                          <span>{fDate(lot.buyDate)}</span>
                          <span class="tin-row__arrow">→</span>
                          <span>{fDate(lot.sellDate)}</span>
                          <span class="tin-row__days">{lot.daysHeld}d</span>
                        </div>
                        <span class="tin-row__usd">{fUsd(lot.costUsd)}</span>
                        <span class="tin-row__usd">{fUsd(lot.proceedsUsd)}</span>
                        <span class={`tin-row__gain ${g.cls}`}>{g.text}</span>
                        <div class="tin-row__trace">
                          <span class={`basis-badge ${b.cls}`}>{b.label}</span>
                          {lot.originNote && <span class="tin-row__origin" title={lot.originNote}>{lot.originNote}</span>}
                          <a class="tin-trace-link" href={`/dashboard/yearEnd/memory-lane?year=${selectedYear}&symbol=${encodeURIComponent(lot.asset)}`}>trace origin →</a>
                        </div>
                      </div>
                    );
                  })}
                </div>
              )}
            </OrnateTin>
          </div>
        </>
      ) : (
        /* International: single date-ordered Realized G/L tin */
        <div class="grid-cell grid-cell--full">
          <OrnateTin label={t.tinRealizedGL} class="tin-section tin-section--short">
            <div class="tin-toolbar">
              <span class="tin-toolbar__count">{t.countLots(bd.shortTerm.length + bd.longTerm.length)}</span>
              <a href={csvBase('shortTerm')} download class="tin-csv-btn">↓ CSV</a>
            </div>
            {(() => {
              const total = bd.totals.shortTermGain + bd.totals.longTermGain;
              const g = fGain(total);
              return (
                <div class={`tin-total ${g.cls}`}>
                  {t.netRealized} <strong>{g.text}</strong>
                </div>
              );
            })()}
            {(bd.shortTerm.length + bd.longTerm.length) === 0 ? (
              <p class="tin-empty">{t.noDisposals(selectedYear)}</p>
            ) : (
              <div class="tin-rows">
                {[...bd.shortTerm, ...bd.longTerm]
                  .sort((a, b) => a.sellDate.localeCompare(b.sellDate))
                  .map((lot) => {
                    const g = fGain(lot.gainLossUsd);
                    const b = basisMeta(lot.basisSource);
                    return (
                      <div class="tin-row">
                        <span class="tin-row__asset">{lot.asset}</span>
                        <span class="tin-row__qty">{fQty(lot.amount)}</span>
                        <div class="tin-row__dates">
                          <span>{fDate(lot.buyDate)}</span>
                          <span class="tin-row__arrow">→</span>
                          <span>{fDate(lot.sellDate)}</span>
                          <span class="tin-row__days">{lot.daysHeld}d</span>
                        </div>
                        <span class="tin-row__usd">{fUsd(lot.costUsd)}</span>
                        <span class="tin-row__usd">{fUsd(lot.proceedsUsd)}</span>
                        <span class={`tin-row__gain ${g.cls}`}>{g.text}</span>
                        <div class="tin-row__trace">
                          <span class={`basis-badge ${b.cls}`}>{b.label}</span>
                          {lot.originNote && <span class="tin-row__origin" title={lot.originNote}>{lot.originNote}</span>}
                          <a class="tin-trace-link" href={`/dashboard/yearEnd/memory-lane?year=${selectedYear}&symbol=${encodeURIComponent(lot.asset)}`}>trace origin →</a>
                        </div>
                      </div>
                    );
                  })}
              </div>
            )}
          </OrnateTin>
        </div>
      )}

      <!-- Cost basis method label — answers the CPA's "what method?" immediately -->
      <div class="grid-cell grid-cell--full">
        <p style="margin:0.25rem 0 0.75rem; font-size:0.85rem; color:var(--text-secondary);">
          {t.costMethodLabel}: <strong style="color:var(--text-primary);">{costBasisMethod}</strong>
          <span style="opacity:0.6;"> — {t.costMethodNote}</span>
        </p>
      </div>

      <!-- 5. Income & Fees — full width -->
      <div class="grid-cell grid-cell--full">
        <OrnateTin label={t.tinIncome} class="tin-section tin-section--income">
          <div class="tin-toolbar">
            <span class="tin-toolbar__count">{t.countItems(bd.income.length)}</span>
            <a href={csvBase('income')} download class="tin-csv-btn">↓ CSV</a>
          </div>
          <div class="tin-total">
            {t.totalOrdinaryIncome} <strong>{fUsd(bd.totals.totalIncome)}</strong>
          </div>
          {bd.income.length > 0 && (
            <p class="tin-empty" style="margin:0.15rem 0 0.55rem; opacity:0.6;">{t.fmvNote}</p>
          )}
          {bd.income.length === 0 ? (
            <p class="tin-empty">{t.noIncomeEvents(selectedYear)}</p>
          ) : (
            <div class="tin-rows tin-rows--income">
              {bd.income.map((item) => (
                <div class="tin-row tin-row--income">
                  <span class="tin-row__asset">{item.asset}</span>
                  <span class="tin-row__qty">{fQty(item.amount)}</span>
                  <span class="tin-row__date">{fDate(item.date)}</span>
                  <span class="tin-row__usd">{fUsd(item.usdValue)}</span>
                  <span class="tin-row__kind">{kindLabel(item.kind)}</span>
                  <span class="tin-row__note" title={t.fmvNote}>{fmvLabel(item)}</span>
                  {item.description && (
                    <span class="tin-row__note">{item.description}</span>
                  )}
                </div>
              ))}
            </div>
          )}

          {bd.cardRebates.length > 0 && (
            <div class="tin-rows tin-rows--income" style="margin-top:0.75rem;">
              <div class="tin-total">
                {t.cardRebatesLabel} <strong>{fUsd(cardRebatesTotal)}</strong>
                <span class="tin-total__note">{t.cardRebatesNote}</span>
              </div>
              {bd.cardRebates.map((item) => (
                <div class="tin-row tin-row--income">
                  <span class="tin-row__asset">{item.asset}</span>
                  <span class="tin-row__qty">{fQty(item.amount)}</span>
                  <span class="tin-row__date">{fDate(item.date)}</span>
                  <span class="tin-row__usd">{fUsd(item.usdValue)}</span>
                  <span class="tin-row__kind">{t.cardRebateTag}</span>
                </div>
              ))}
            </div>
          )}
        </OrnateTin>
      </div>

      <!-- 6. Transaction costs (fees) — full width -->
      <div class="grid-cell grid-cell--full">
        <OrnateTin label={t.tinTransactionCosts} class="tin-section tin-section--income">
          <div class="tin-toolbar">
            <span class="tin-toolbar__count">{t.countItems(bd.transactionCosts.length)}</span>
            <a href={csvBase('transactionCosts')} download class="tin-csv-btn">↓ CSV</a>
          </div>
          <div class="tin-total">
            {t.totalTransactionCosts} <strong>{fUsd(bd.totals.transactionCostsUsd)}</strong>
          </div>
          <p class="tin-empty" style="margin:0.15rem 0 0.6rem; opacity:0.6;">
            {t.feeTaxNote}
            {bd.feeCoverage.total > 0 && ` · ${t.feeCoverageNote(bd.feeCoverage.withFee, bd.feeCoverage.total)}`}
          </p>
          {bd.transactionCosts.length === 0 ? (
            <p class="tin-empty">{t.noTransactionCosts(selectedYear)}</p>
          ) : (
            <div class="tin-rows tin-rows--income">
              {bd.transactionCosts.map((item) => (
                <div class="tin-row tin-row--income">
                  <span class="tin-row__asset">{item.asset || '—'}</span>
                  <span class="tin-row__date">{fDate(item.date)}</span>
                  <span class="tin-row__usd">
                    {item.feeUsd != null
                      ? fUsd(item.feeUsd)
                      : item.feeNative != null
                        ? `${fQty(item.feeNative)} ${item.feeCurrency ?? ''}`.trim()
                        : '—'}
                  </span>
                  <span class="tin-row__kind">{kindLabel(item.source)}</span>
                  {item.description && (
                    <span class="tin-row__note">{item.description}</span>
                  )}
                </div>
              ))}
            </div>
          )}
          {bd.gasByChain.length > 0 && (
            <div class="tin-rows tin-rows--income" style="margin-top:0.75rem;">
              <div class="tin-total" style="margin-bottom:0.4rem;">{t.gasFeesHeading}</div>
              {bd.gasByChain.map((g) => (
                <div class="tin-row tin-row--income">
                  <span class="tin-row__asset">{g.nativeSymbol}</span>
                  <span class="tin-row__date">{g.chain}</span>
                  <span class="tin-row__usd">{fQty(g.totalNative)} {g.nativeSymbol}</span>
                  <span class="tin-row__kind">{t.countItems(g.txCount)}</span>
                </div>
              ))}
            </div>
          )}
        </OrnateTin>
      </div>

      <!-- 7. NFT Holdings — full width -->
      <div class="grid-cell grid-cell--full">
        <OrnateTin label={t.tinNftHoldings} class="tin-section tin-section--hold">
          <div class="tin-toolbar">
            <span class="tin-toolbar__count">{t.countItems(bd.nftHoldings.length)}</span>
          </div>
          {bd.nftHoldings.length === 0 ? (
            <p class="tin-empty">{t.noNfts}</p>
          ) : (
            <div class="tin-rows">
              {bd.nftHoldings.map((nft) => (
                <div class="tin-row">
                  <span class="tin-row__asset">{nft.name}</span>
                  <span class="tin-row__kind">{nft.chain}</span>
                  <span class="tin-row__note">#{nft.tokenId}</span>
                  {nft.costUsd != null && nft.costUsd > 1 ? (
                    <span class="tin-row__usd">{fUsd(nft.costUsd)}</span>
                  ) : (
                    <span class="nft-cost-entry" style="display:inline-flex; gap:0.3rem; align-items:center;">
                      <input class="nft-cost-input" type="number" step="0.01" min="0" placeholder="cost $"
                        data-chain={nft.chain} data-contract={nft.contract} data-tokenid={nft.tokenId}
                        style="width:78px; padding:0.15rem 0.35rem; font-size:0.78rem; border:1px solid var(--border-bright); border-radius:6px; background:transparent; color:var(--text-primary);" />
                      <button class="nft-cost-save" type="button"
                        style="padding:0.15rem 0.5rem; font-size:0.72rem; border:1px solid var(--accent-dim); border-radius:6px; background:var(--accent-soft); color:var(--accent); cursor:pointer;">save</button>
                    </span>
                  )}
                  {nft.url && (
                    <a class="tin-trace-link" href={nft.url} target="_blank" rel="noopener">view →</a>
                  )}
                </div>
              ))}
            </div>
          )}
          {bd.nftHoldings.length > 0 && (
            <p class="tin-empty" style="margin-top:0.5rem; opacity:0.6;">{t.nftCostNote}</p>
          )}
        </OrnateTin>
      </div>

    </div><!-- /breakdown-grid -->

    <!-- ══ Reconciliation ══════════════════════════════════════════════════ -->
    <div style="display:flex; justify-content:flex-end; margin:0.75rem 0 0.25rem;">
      <JunkDrawer client:load lang={lang} />
    </div>
    <div class="reconciliation-section">
      <ReconciliationTin client:load />
    </div>

  </section>

  <!-- Drawer mount point -->
  <div id="drawer-mount">
    <DrawerHost client:load />
  </div>

  <style>
    /* ── Tax Readiness Bar ──────────────────────────────────── */
    .readiness-bar {
      border-radius: 0.75rem;
      background: var(--surface-card-2);
      border: 1px solid var(--border-bright);
      overflow: hidden;
    }
    .readiness-bar__track {
      height: 4px;
      background: var(--border-bright);
      width: 100%;
    }
    .readiness-bar__fill {
      height: 4px;
      width: 0%;
      background: var(--accent);
      transition: width 0.9s cubic-bezier(0.4, 0, 0.2, 1), background 0.4s ease;
      border-radius: 0 2px 2px 0;
    }
    .readiness-bar__body {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.6rem 1rem;
    }
    .readiness-bar__score {
      font-size: 0.8rem;
      font-weight: 700;
      color: var(--text-secondary);
      min-width: 2.5rem;
      letter-spacing: 0.02em;
    }
    .readiness-bar__label {
      font-size: 0.8rem;
      color: var(--text-muted);
      flex: 1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .readiness-bar__link {
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .readiness-bar__link:hover { color: var(--accent); opacity: 0.8; }

    /* ── Page shell ─────────────────────────────────────────── */
    .bookkeeping-page {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding: 1rem 0 3rem;
      max-width: 1400px;
      width: 100%;
      margin: 0 auto;
      box-sizing: border-box;
    }

    .bookkeeping-page > :not(.hero-bleed) {
      padding-left: clamp(1rem, 3vw, 2.5rem);
      padding-right: clamp(1rem, 3vw, 2.5rem);
    }
    .reconciliation-section {
      padding: 0 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
      width: 100%;
    }

    .hero-bleed {
      height: 60vh;
      min-height: 420px;
      width: 100vw;
      margin-left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: stretch;
    }
    .hero-bleed :global(.hero) { width: 100%; }

    /* ── Year selector bar ─────────────────────────────────── */
    .year-bar {
      display: flex;
      align-items: center;
      gap: 1rem;
      max-width: calc(100% - 6rem);
      margin: 0 auto;
      flex-wrap: wrap;
    }
    .year-bar__label {
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      opacity: 0.55;
    }
    .year-bar__pills {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .year-pill {
      display: inline-block;
      padding: 0.35rem 0.9rem;
      border-radius: 20px;
      border: 1px solid var(--accent-dim);
