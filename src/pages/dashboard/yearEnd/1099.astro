---
/**
 * /dashboard/yearEnd/1099
 *
 * Upload a 1099-DA or 1099-B CSV from an exchange and reconcile it
 * against SusuFinance' computed gains.
 */
import Layout from '../../../layouts/Layout.astro';
import TaxNotice from '@/components/TaxNotice.astro';
import { requireTenantSession } from '@/lib/requireTenantSession';
import { hasTaxAccess } from '@/lib/taxAuth';
import { getLang } from '@/lib/i18n/locale';
import { get1099 } from '@/i18n/dashboard/yearEnd/1099';

if (!(await hasTaxAccess(Astro.request))) return Astro.redirect('/tax-login', 302);
const _authSess = await requireTenantSession(Astro.request);
if (!_authSess) return Astro.redirect('/login');

const lang = getLang(Astro.request);
const t = get1099(lang);
const dateLocale = lang === 'es' ? 'es-ES' : lang === 'fr' ? 'fr-FR' : 'en-US';

const currentYear = new Date().getFullYear();
const years = Array.from({ length: 6 }, (_, i) => currentYear - 1 - i);
---

<Layout title={t.pageTitle} noindex={true}>
  <div class="recon-page">

    <!-- Header -->
    <div class="recon-header">
      <a href="/year-summary" class="recon-back">{t.backLink}</a>
      <h1 class="recon-title">{t.heroTitle}</h1>
      <p class="recon-sub">{t.heroSub}</p>
    </div>

    <TaxNotice />

    <!-- Upload card -->
    <div class="recon-card">
      <h2 class="recon-card__title">{t.uploadCardTitle}</h2>

      <form id="upload-form" enctype="multipart/form-data">
        <div class="form-grid">

          <!-- Form type -->
          <div class="form-field">
            <label class="form-label">{t.labelFormType}</label>
            <select id="form-type" name="formType" class="form-select">
              <option value="1099-da">1099-DA (crypto)</option>
              <option value="1099-b">1099-B (brokerage)</option>
            </select>
          </div>

          <!-- Tax year -->
          <div class="form-field">
            <label class="form-label">{t.labelTaxYear}</label>
            <select id="tax-year" name="taxYear" class="form-select">
              {years.map(y => <option value={y} selected={y === currentYear - 1}>{y}</option>)}
            </select>
          </div>

          <!-- Exchange name -->
          <div class="form-field">
            <label class="form-label">{t.labelExchange} <span class="form-optional">{t.labelExchangeOptional}</span></label>
            <input type="text" id="exchange-name" name="exchangeName"
                   placeholder={t.exchangePlaceholder}
                   class="form-input" />
          </div>
        </div>

        <!-- File drop zone -->
        <div id="drop-zone" class="drop-zone">
          <input type="file" id="file-input" name="file" accept=".csv,text/csv,.pdf,application/pdf" style="display:none" required />
          <span class="drop-zone__icon">📄</span>
          <p class="drop-zone__primary">{t.dropPrimary}</p>
          <p class="drop-zone__secondary">{t.dropSecondary} <span id="browse-btn" class="drop-zone__browse">{t.dropBrowse}</span></p>
          <p id="file-name" class="drop-zone__filename" style="display:none"></p>
        </div>

        <div class="form-actions">
          <button type="submit" id="upload-btn" class="upload-btn">{t.uploadBtn}</button>
          <span id="upload-status" class="upload-status" style="display:none"></span>
        </div>
      </form>
    </div>

    <!-- Reconciliation results -->
    <div id="results-section" style="display:none">

      <!-- Summary banner -->
      <div id="results-banner" class="results-banner">
        <div>
          <p class="results-banner__title" id="results-title">{t.resultsTitle}</p>
          <p class="results-banner__sub" id="results-subtitle"></p>
        </div>
        <div class="results-banner__counts">
          <span class="count-pill count-pill--green">
            <span class="count-dot count-dot--green"></span>
            <span id="count-matched">{t.countMatched(0)}</span>
          </span>
          <span class="count-pill count-pill--amber">
            <span class="count-dot count-dot--amber"></span>
            <span id="count-diff">{t.countDiff(0)}</span>
          </span>
          <span class="count-pill count-pill--red">
            <span class="count-dot count-dot--red"></span>
            <span id="count-unmatched">{t.countUnmatched(0)}</span>
          </span>
        </div>
      </div>

      <!-- Results table -->
      <div class="recon-card" style="padding:0;overflow:hidden">
        <div class="table-scroll">
          <table class="recon-table">
            <thead>
              <tr>
                <th>{t.tableAsset}</th>
                <th class="text-right">{t.tableFormProceeds}</th>
                <th class="text-right">{t.tableFormBasis}</th>
                <th class="text-right">{t.tableSusuFinanceProceeds}</th>
                <th class="text-right">{t.tableSusuFinanceBasis}</th>
                <th class="text-right">{t.tableDeltaProceeds}</th>
                <th class="text-right">{t.tableDeltaBasis}</th>
                <th class="text-center">{t.tableStatus}</th>
              </tr>
            </thead>
            <tbody id="results-tbody"></tbody>
          </table>
        </div>
      </div>

      <!-- Guidance -->
      <div class="guidance-box">
        <p class="guidance-box__title">{t.guidanceTitle}</p>
        <ul class="guidance-box__list">
          <li set:html={t.guidanceMatched}></li>
          <li set:html={t.guidanceProceedsDiff}></li>
          <li set:html={t.guidanceBasisDiff}></li>
          <li set:html={t.guidanceUnmatched}></li>
        </ul>
      </div>
    </div>

    <!-- Past uploads -->
    <div class="recon-card">
      <h2 class="recon-card__title">{t.historyCardTitle}</h2>
      <div id="history-loading" class="history-placeholder">{t.historyLoading}</div>
      <div id="history-empty" class="history-placeholder" style="display:none">{t.historyEmpty}</div>
      <div id="history-list" style="display:none"></div>
    </div>

  </div>
</Layout>

<style>
  .recon-page {
    max-width: 1000px;
    margin: 0 auto;
    padding: 2rem 1.5rem 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    line-height: 1.7;
  }

  /* Header */
  .recon-back {
    display: inline-block;
    font-size: .8rem;
    color: #a5b4fc;
    text-decoration: none;
    margin-bottom: .5rem;
    transition: color .15s;
  }
  .recon-back:hover { color: #e2e8ff; }
  .recon-title {
    font-size: 1.75rem;
    font-weight: 700;
    color: #e2e8ff;
    margin: 0 0 .4rem;
  }
  .recon-sub {
    font-size: .9rem;
    color: #64748b;
    margin: 0;
    max-width: 680px;
  }

  /* Card */
  .recon-card {
    background: rgba(255,255,255,.03);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 14px;
    padding: 1.5rem;
  }
  .recon-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: #e2e8ff;
    margin: 0 0 1.25rem;
  }

  /* Form */
  .form-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 1.25rem;
  }
  .form-field { display: flex; flex-direction: column; gap: .35rem; }
  .form-label {
    font-size: .78rem;
    font-weight: 600;
    color: rgba(255,255,255,.5);
  }
  .form-optional { font-weight: 400; opacity: .6; }
  .form-select, .form-input {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 8px;
    color: #e2e8ff;
    font-size: .9rem;
    font-family: inherit;
    padding: .55rem .85rem;
    outline: none;
    transition: border-color .15s;
    width: 100%;
    box-sizing: border-box;
  }
  .form-select:focus, .form-input:focus { border-color: rgba(99,102,241,.6); }
  .form-select option { background: #1a1d2e; }
  .form-input::placeholder { color: rgba(255,255,255,.25); }

  /* Drop zone */
  .drop-zone {
    border: 2px dashed rgba(99,102,241,.35);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    background: rgba(99,102,241,.03);
    transition: background .15s, border-color .15s;
    margin-bottom: 1.25rem;
  }
  .drop-zone:hover, .drop-zone.dragover {
    background: rgba(99,102,241,.08);
    border-color: rgba(99,102,241,.6);
  }
  .drop-zone__icon { font-size: 2rem; display: block; margin-bottom: .5rem; }
  .drop-zone__primary { font-size: .95rem; font-weight: 600; color: rgba(255,255,255,.65); margin: 0 0 .25rem; }
  .drop-zone__secondary { font-size: .85rem; color: rgba(255,255,255,.35); margin: 0; }
  .drop-zone__browse { color: #a5b4fc; cursor: pointer; text-decoration: underline; }
  .drop-zone__filename { font-size: .85rem; color: #a5b4fc; margin: .5rem 0 0; font-weight: 600; }

  /* Form actions */
  .form-actions { display: flex; align-items: center; gap: 1rem; }
  .upload-btn {
    padding: .65rem 1.5rem;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    border: none;
    border-radius: 8px;
    color: #fff;
    font-size: .9rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity .15s;
  }
  .upload-btn:hover { opacity: .88; }
  .upload-btn:disabled { opacity: .45; cursor: not-allowed; }
  .upload-status { font-size: .85rem; color: #94a3b8; line-height: 1.7; }

  /* Results banner */
  .results-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem;
    border-radius: 12px;
    border: 1px solid rgba(52,211,153,.25);
    background: rgba(52,211,153,.06);
  }
  .results-banner--warn {
    border-color: rgba(251,191,36,.25);
    background: rgba(251,191,36,.06);
  }
  .results-banner__title { font-size: .95rem; font-weight: 700; color: #e2e8ff; margin: 0 0 .15rem; }
  .results-banner__sub { font-size: .82rem; color: #64748b; margin: 0; }
  .results-banner__counts { display: flex; gap: .75rem; flex-wrap: wrap; }
  .count-pill {
    display: flex; align-items: center; gap: .4rem;
    font-size: .8rem; color: rgba(255,255,255,.6);
  }
  .count-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .count-dot--green { background: #34d399; }
  .count-dot--amber { background: #fbbf24; }
  .count-dot--red   { background: #f87171; }

  /* Results table */
  .table-scroll { overflow-x: auto; }
  .recon-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .85rem;
  }
  .recon-table thead tr {
    background: rgba(255,255,255,.04);
    border-bottom: 1px solid rgba(255,255,255,.08);
  }
  .recon-table th {
    padding: .65rem 1rem;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #64748b;
    white-space: nowrap;
  }
  .recon-table td {
    padding: .6rem 1rem;
    color: rgba(255,255,255,.65);
    border-bottom: 1px solid rgba(255,255,255,.04);
    white-space: nowrap;
  }
  .recon-table tbody tr:hover td { background: rgba(255,255,255,.03); }
  .text-right { text-align: right; }
  .text-center { text-align: center; }

  /* Guidance box */
  .guidance-box {
    background: rgba(99,102,241,.07);
    border: 1px solid rgba(99,102,241,.2);
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  .guidance-box__title {
    font-size: .85rem;
    font-weight: 700;
    color: #a5b4fc;
    margin: 0 0 .5rem;
  }
  .guidance-box__list {
    margin: 0;
    padding-left: 1.25rem;
    font-size: .83rem;
    color: rgba(255,255,255,.5);
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .guidance-box__list strong { color: rgba(255,255,255,.75); }

  /* History */
  .history-placeholder { font-size: .88rem; color: #475569; line-height: 1.7; }

  @media (max-width: 640px) {
    .form-grid { grid-template-columns: 1fr; }
    .recon-page { padding: 1.5rem 1rem 3rem; }
  }
</style>

<script is:inline define:vars={{ i18n: {
  dateLocale,
  pleaseSelectFile:   t.pleaseSelectFile,
  uploading:          t.uploading,
  uploadFailed:       t.uploadFailed,
  networkError:       t.networkError,
  resultsTitle:       t.resultsTitle,
  /** String with literal "{n}" replaced by the count at runtime */
  tplCountMatched:    t.countMatched(0).replace('0', '{n}'),
  tplCountDiff:       t.countDiff(0).replace('0', '{n}'),
  tplCountUnmatched:  t.countUnmatched(0).replace('0', '{n}'),
  tplSubtitle:        t.resultsSubtitle(0).replace('0', '{n}'),
  /** "✅ N rows processed" — uses tpl "{n}" */
  tplRowsProcessed:   t.rowsProcessed(0).replace('0', '{n}'),
  statusMatched:      t.statusMatched,
  statusProceedsDiff: t.statusProceedsDiff,
  statusBasisDiff:    t.statusBasisDiff,
  statusUnmatched:    t.statusUnmatched,
  statusExtra:        t.statusExtra,
  uploaded:           t.uploaded,
  rows:               t.rows,
  historyViewLink:    t.historyViewLink,
} }}>window.__1099I18n = i18n;</script>

<script>
interface Locale1099 {
  dateLocale: string;
  pleaseSelectFile: string;
  uploading: string;
  uploadFailed: string;
  networkError: string;
  resultsTitle: string;
  tplCountMatched: string;
  tplCountDiff: string;
  tplCountUnmatched: string;
  tplSubtitle: string;
  tplRowsProcessed: string;
  statusMatched: string;
  statusProceedsDiff: string;
  statusBasisDiff: string;
  statusUnmatched: string;
  statusExtra: string;
  uploaded: string;
  rows: string;
  historyViewLink: string;
}
const I18N: Locale1099 = (window as unknown as { __1099I18n?: Locale1099 }).__1099I18n ?? {
  dateLocale: 'en-US',
  pleaseSelectFile: 'Please select a file.',
  uploading: '⏳ Uploading and reconciling…',
  uploadFailed: 'Upload failed',
  networkError: 'Network error',
  resultsTitle: 'Reconciliation Complete',
  tplCountMatched: '{n} matched',
  tplCountDiff: '{n} differences',
  tplCountUnmatched: '{n} unmatched',
  tplSubtitle: '{n} assets compared',
  tplRowsProcessed: '✅ {n} rows processed',
  statusMatched: '✓ Matched',
  statusProceedsDiff: 'Δ Proceeds',
  statusBasisDiff: 'Δ Basis',
  statusUnmatched: '! Unmatched',
  statusExtra: 'Extra',
  uploaded: 'Uploaded',
  rows: 'rows',
  historyViewLink: 'View →',
};

const fmt = (tpl: string, n: number) => tpl.replace('{n}', String(n));
function fmtMatched(n: number)   { return fmt(I18N.tplCountMatched, n); }
function fmtDiff(n: number)      { return fmt(I18N.tplCountDiff, n); }
function fmtUnmatched(n: number) { return fmt(I18N.tplCountUnmatched, n); }
function fmtSubtitle(n: number)  { return fmt(I18N.tplSubtitle, n); }

const USD = (n: number | null) => n != null
  ? new Intl.NumberFormat(I18N.dateLocale, { style: 'currency', currency: 'USD', minimumFractionDigits: 2 }).format(n)
  : '—';

const DELTA = (n: number | null) => {
  if (n == null) return '—';
  const abs = USD(Math.abs(n));
  return n >= 0 ? `+${abs}` : `(${abs})`;
};

// ── Drag-and-drop / file picker ────────────────────────────────────────────
const dropZone   = document.getElementById('drop-zone')!;
const fileInput  = document.getElementById('file-input') as HTMLInputElement;
const fileNameEl = document.getElementById('file-name')!;
const browseBtn  = document.getElementById('browse-btn')!;

function showFileName(name: string) {
  fileNameEl.textContent = `📎 ${name}`;
  fileNameEl.style.display = 'block';
}

browseBtn.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('click', (e) => {
  if ((e.target as HTMLElement).id !== 'browse-btn') fileInput.click();
});
fileInput.addEventListener('change', () => {
  if (fileInput.files?.[0]) showFileName(fileInput.files[0].name);
});
dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  const files = e.dataTransfer?.files;
  if (files?.[0]) {
    const dt = new DataTransfer();
    dt.items.add(files[0]);
    fileInput.files = dt.files;
    showFileName(files[0].name);
  }
});

// ── Upload form ────────────────────────────────────────────────────────────
document.getElementById('upload-form')?.addEventListener('submit', async (e) => {
  e.preventDefault();
  const uploadBtn = document.getElementById('upload-btn') as HTMLButtonElement;
  const statusEl  = document.getElementById('upload-status')!;

  if (!fileInput.files?.[0]) {
    statusEl.textContent = I18N.pleaseSelectFile;
    statusEl.style.display = 'inline';
    return;
  }

  uploadBtn.disabled = true;
  statusEl.textContent = I18N.uploading;
  statusEl.style.display = 'inline';

  const fd = new FormData(e.currentTarget as HTMLFormElement);

  try {
    const res = await fetch('/api/yearEnd/1099/upload', { method: 'POST', body: fd });
    const data = await res.json() as {
      ok: boolean; error?: string; uploadId?: string; rowCount?: number;
      reconciliation?: Array<{
        id: string; formAsset: string;
        formProceeds: number | null; formCostBasis: number | null;
        computedProceeds: number | null; computedBasis: number | null;
        matchStatus: string; deltaProceeds: number | null; deltaBasis: number | null;
      }>;
    };

    if (!data.ok) {
      statusEl.textContent = `❌ ${data.error ?? I18N.uploadFailed}`;
      uploadBtn.disabled = false;
      return;
    }

    statusEl.textContent = fmt(I18N.tplRowsProcessed, data.rowCount ?? 0);
    setTimeout(() => { statusEl.style.display = 'none'; }, 3000);
    uploadBtn.disabled = false;
    renderReconciliation(data.reconciliation ?? []);
    loadHistory();
  } catch (err) {
    console.error('[1099] upload error', err);
    statusEl.textContent = `❌ ${I18N.networkError}`;
    uploadBtn.disabled = false;
  }
});

// ── Render reconciliation table ────────────────────────────────────────────
function renderReconciliation(rows: Array<{
  formAsset: string;
  formProceeds: number | null; formCostBasis: number | null;
  computedProceeds: number | null; computedBasis: number | null;
  matchStatus: string; deltaProceeds: number | null; deltaBasis: number | null;
}>) {
  const section = document.getElementById('results-section')!;
  const tbody   = document.getElementById('results-tbody')!;
  tbody.innerHTML = '';

  const matched   = rows.filter(r => r.matchStatus === 'matched').length;
  const diffs     = rows.filter(r => ['proceeds_diff','basis_diff'].includes(r.matchStatus)).length;
  const unmatched = rows.filter(r => r.matchStatus === 'unmatched').length;

  document.getElementById('count-matched')!.textContent   = fmtMatched(matched);
  document.getElementById('count-diff')!.textContent      = fmtDiff(diffs);
  document.getElementById('count-unmatched')!.textContent = fmtUnmatched(unmatched);
  document.getElementById('results-subtitle')!.textContent = fmtSubtitle(rows.length);

  const banner = document.getElementById('results-banner')!;
  if (unmatched > 0 || diffs > 0) banner.classList.add('results-banner--warn');
  else banner.classList.remove('results-banner--warn');

  const pill = (color: string, bg: string, border: string, label: string) =>
    `<span style="padding:.15rem .55rem;border-radius:999px;font-size:.72rem;font-weight:700;background:${bg};color:${color};border:1px solid ${border}">${label}</span>`;
  const STATUS_BADGE: Record<string, string> = {
    matched:      pill('#34d399', 'rgba(52,211,153,.15)',  'rgba(52,211,153,.3)',  I18N.statusMatched),
    proceeds_diff:pill('#fbbf24', 'rgba(251,191,36,.15)',  'rgba(251,191,36,.3)',  I18N.statusProceedsDiff),
    basis_diff:   pill('#fbbf24', 'rgba(251,191,36,.15)',  'rgba(251,191,36,.3)',  I18N.statusBasisDiff),
    unmatched:    pill('#f87171', 'rgba(248,113,113,.15)', 'rgba(248,113,113,.3)', I18N.statusUnmatched),
    extra:        pill('#a5b4fc', 'rgba(99,102,241,.15)',  'rgba(99,102,241,.3)',  I18N.statusExtra),
  };

  for (const row of rows) {
    const badge  = STATUS_BADGE[row.matchStatus] ?? row.matchStatus;
    const dpCol  = row.deltaProceeds != null && Math.abs(row.deltaProceeds) > 1
      ? (row.deltaProceeds > 0 ? '#f87171' : '#34d399') : 'rgba(255,255,255,.35)';
    const dbCol  = row.deltaBasis != null && Math.abs(row.deltaBasis) > 1
      ? (row.deltaBasis > 0 ? '#f87171' : '#34d399') : 'rgba(255,255,255,.35)';

    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td style="font-weight:700;color:#e2e8ff">${row.formAsset}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums">${USD(row.formProceeds)}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums">${USD(row.formCostBasis)}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums;color:rgba(255,255,255,.4)">${USD(row.computedProceeds)}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums;color:rgba(255,255,255,.4)">${USD(row.computedBasis)}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:${dpCol}">${DELTA(row.deltaProceeds)}</td>
      <td style="text-align:right;font-variant-numeric:tabular-nums;font-weight:600;color:${dbCol}">${DELTA(row.deltaBasis)}</td>
      <td style="text-align:center">${badge}</td>
    `;
    tbody.appendChild(tr);
  }

  section.style.display = 'flex';
  section.style.flexDirection = 'column';
  section.style.gap = '1.25rem';
  section.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ── Past uploads history ───────────────────────────────────────────────────
async function loadHistory() {
  const loadingEl = document.getElementById('history-loading')!;
  const emptyEl   = document.getElementById('history-empty')!;
  const listEl    = document.getElementById('history-list')!;

  try {
    const res  = await fetch('/api/yearEnd/1099/list');
    const data = await res.json() as {
      ok: boolean;
      uploads: Array<{ id: string; formType: string; exchangeName: string | null; taxYear: number; filename: string; rowCount: number | null; createdAt: string }>;
    };

    loadingEl.style.display = 'none';

    if (!data.ok || !data.uploads.length) { emptyEl.style.display = 'block'; return; }

    listEl.innerHTML = '';
    for (const u of data.uploads) {
      const div = document.createElement('div');
      div.style.cssText = 'display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.75rem 1rem;border-radius:10px;border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.03);margin-bottom:.5rem';
      div.innerHTML = `
        <div style="min-width:0">
          <p style="font-size:.88rem;font-weight:600;color:#e2e8ff;margin:0 0 .15rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${u.filename}</p>
          <p style="font-size:.75rem;color:#475569;margin:0">
            ${u.formType.toUpperCase()} · ${u.taxYear}
            ${u.exchangeName ? ` · ${u.exchangeName}` : ''}
            · ${u.rowCount ?? '?'} ${I18N.rows}
            · ${I18N.uploaded} ${new Date(u.createdAt).toLocaleDateString(I18N.dateLocale)}
          </p>
        </div>
        <a href="/dashboard/yearEnd/1099?uploadId=${u.id}"
           style="font-size:.85rem;font-weight:600;color:#a5b4fc;text-decoration:none;white-space:nowrap;flex-shrink:0">
          ${I18N.historyViewLink}
        </a>
      `;
      listEl.appendChild(div);
    }
    listEl.style.display = 'block';
  } catch (err) {
    console.error('[1099] history error', err);
    loadingEl.style.display = 'none';
    emptyEl.style.display = 'block';
  }
}

// Load history on page load; also handle ?uploadId deep-link
(async () => {
  await loadHistory();
  const params   = new URLSearchParams(window.location.search);
  const uploadId = params.get('uploadId');
  if (uploadId) {
    try {
      const res  = await fetch(`/api/yearEnd/1099/reconciliation?uploadId=${uploadId}`);
      const data = await res.json();
      if (data.ok) renderReconciliation(data.reconciliation ?? []);
    } catch {}
  }
})();
</script>
