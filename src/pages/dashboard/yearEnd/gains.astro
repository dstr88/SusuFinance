																						: 'bg-amber-100 text-amber-700'
																				}`}>
																					{lot.term === 'long' ? t.termLong : t.termShort}
																				</span>
																			</td>
																		</tr>
																	))}
																</tbody>
																<!-- Sub-total row -->
																<tfoot>
																	<tr class="bg-indigo-50 font-semibold border-t border-indigo-200">
																		<td class="px-6 py-2 text-indigo-700">{t.lotSubtotal}</td>
																		<td class="px-4 py-2"></td>
																		<td class="px-4 py-2"></td>
																		<td class="px-4 py-2"></td>
																		<td class="px-4 py-2 text-right tabular-nums text-indigo-700">
																			{fmt(lots.reduce((s, l) => s + (l.proceedsUsd ?? 0), 0))}
																		</td>
																		<td class="px-4 py-2 text-right tabular-nums text-indigo-700">
																			{fmt(lots.reduce((s, l) => s + (l.costUsd ?? 0), 0))}
																		</td>
																		<td class={`px-4 py-2 text-right tabular-nums ${row.netGain < 0 ? 'text-red-600' : 'text-green-700'}`}>
																			{fmtGain(row.netGain)}
																		</td>
																		<td class="px-4 py-2"></td>
																	</tr>
																</tfoot>
															</table>
														</div>
														<div class="h-3"></div>
													</td>
												</tr>
											)}
										</>
									);
								})}
								<!-- Totals row -->
								<tr class="bg-gray-50 font-semibold border-t-2 border-gray-200">
									<td class="px-4 py-3"></td>
									<td class="px-5 py-3 text-gray-700">{t.colTotal}</td>
									<td class={`px-5 py-3 text-right tabular-nums ${(payload.gains?.shortTermGain ?? 0) < 0 ? 'text-red-600' : 'text-green-700'}`}>
										{fmtGain(payload.gains?.shortTermGain ?? 0)}
									</td>
									<td class="px-5 py-3 text-right text-gray-500">{payload.gains?.shortTermCount}</td>
									<td class={`px-5 py-3 text-right tabular-nums ${(payload.gains?.longTermGain ?? 0) < 0 ? 'text-red-600' : 'text-green-700'}`}>
										{fmtGain(payload.gains?.longTermGain ?? 0)}
									</td>
									<td class="px-5 py-3 text-right text-gray-500">{payload.gains?.longTermCount}</td>
									<td class={`px-5 py-3 text-right tabular-nums ${(payload.gains?.netGain ?? 0) < 0 ? 'text-red-600' : 'text-green-700'}`}>
										{fmtGain(payload.gains?.netGain ?? 0)}
									</td>
								</tr>
							</tbody>
						</table>
					</div>
				)}

				<!-- Tax-loss harvesting -->
				{(payload.harvestLosses?.length ?? 0) > 0 && (
					<div class="rounded-xl border border-amber-200 bg-amber-50 shadow-sm overflow-hidden">
						<div class="px-5 py-3 border-b border-amber-200 flex items-center justify-between">
							<div>
								<h2 class="text-sm font-semibold text-amber-900">{t.harvestHeading}</h2>
								<p class="text-xs text-amber-700 mt-0.5">{t.harvestSub}</p>
							</div>
							<span class="text-xs text-amber-600 font-medium">{t.harvestCount(payload.harvestLosses!.length)}</span>
						</div>
						<table class="min-w-full text-sm">
							<thead class="bg-amber-100">
								<tr>
									<th class="px-5 py-2.5 text-left   text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColAsset}</th>
									<th class="px-5 py-2.5 text-right  text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColQty}</th>
									<th class="px-5 py-2.5 text-right  text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColCost}</th>
									<th class="px-5 py-2.5 text-right  text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColValue}</th>
									<th class="px-5 py-2.5 text-right  text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColLoss}</th>
									<th class="px-5 py-2.5 text-center text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColTerm}</th>
									<th class="px-5 py-2.5 text-right  text-xs font-medium text-amber-800 uppercase tracking-wide">{t.harvestColDaysToLt}</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-amber-100 bg-white">
								{payload.harvestLosses!.map((row) => {
									const termLabel = row.longTermQty > 0 && row.shortTermQty > 0
										? t.termMixed
										: row.longTermQty > 0 ? 'Long' : 'Short';
									const termColor = termLabel === 'Long'
										? 'text-green-700 bg-green-50'
										: termLabel === 'Short'
											? 'text-amber-700 bg-amber-50'
											: 'text-purple-700 bg-purple-50';
									return (
										<tr class="hover:bg-amber-50">
											<td class="px-5 py-3 font-mono font-semibold text-gray-800">{row.asset}</td>
											<td class="px-5 py-3 text-right text-gray-600 tabular-nums">
												{row.totalQty.toLocaleString(dateLocale, { maximumFractionDigits: 6 })}
											</td>
											<td class="px-5 py-3 text-right text-gray-700 tabular-nums">{fmt(row.totalCost)}</td>
											<td class="px-5 py-3 text-right text-gray-700 tabular-nums">
												{row.currentValue !== null ? fmt(row.currentValue) : <span class="text-gray-300">—</span>}
											</td>
											<td class="px-5 py-3 text-right font-semibold text-red-600 tabular-nums">
												{row.unrealizedGainLoss !== null ? fmtGain(row.unrealizedGainLoss) : <span class="text-gray-300">—</span>}
											</td>
											<td class="px-5 py-3 text-center">
												<span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${termColor}`}>
													{termLabel}
												</span>
											</td>
											<td class="px-5 py-3 text-right text-gray-500 tabular-nums">
												{termLabel === 'Long'
													? <span class="text-green-600 font-medium">{t.harvestLtCheck}</span>
													: row.soonestLotDaysToLT !== null
														? `${row.soonestLotDaysToLT}d`
														: '—'
												}
											</td>
										</tr>
									);
								})}
							</tbody>
						</table>
						<div class="px-5 py-3 border-t border-amber-200 bg-amber-50">
							<p class="text-xs text-amber-700">
								{t.harvestNote}
							</p>
						</div>
					</div>
				)}

				<!-- Missing cost basis report -->
				{(payload.missingBasis?.length ?? 0) > 0 && (
					<div class="rounded-xl border border-red-200 bg-red-50 shadow-sm overflow-hidden">
						<div class="px-5 py-3 border-b border-red-200 flex items-center justify-between">
							<div>
								<h2 class="text-sm font-semibold text-red-900">{t.missingBasisHeading}</h2>
								<p class="text-xs text-red-700 mt-0.5">{t.missingBasisSub}</p>
							</div>
							<span class="text-xs text-red-600 font-semibold bg-red-100 px-2 py-0.5 rounded-full">
								{t.missingBasisCount(payload.missingBasis!.length)}
							</span>
						</div>
						<table class="min-w-full text-sm">
							<thead class="bg-red-100">
								<tr>
									<th class="px-5 py-2.5 text-left  text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColAsset}</th>
									<th class="px-5 py-2.5 text-left  text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColDisposed}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColQty}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColProceeds}</th>
									<th class="px-5 py-2.5 text-left  text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColTerm}</th>
									<th class="px-5 py-2.5 text-left  text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColProblem}</th>
									<th class="px-5 py-2.5 text-left  text-xs font-medium text-red-800 uppercase tracking-wide">{t.missingColFix}</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-red-100 bg-white">
								{payload.missingBasis!.map((row) => {
									const isOrphan = row.issue === 'no_matching_buy';
									return (
										<tr class="hover:bg-red-50">
											<td class="px-5 py-3 font-mono font-semibold text-gray-800">{row.asset}</td>
											<td class="px-5 py-3 text-gray-600">{fmtDate(row.date)}</td>
											<td class="px-5 py-3 text-right text-gray-600 tabular-nums">
												{row.qty.toLocaleString(dateLocale, { maximumFractionDigits: 6 })}
											</td>
											<td class="px-5 py-3 text-right tabular-nums text-gray-700">
												{row.proceeds !== null ? fmt(row.proceeds) : <span class="text-gray-300">—</span>}
											</td>
											<td class="px-5 py-3">
												{row.term
													? <span class={`inline-block px-2 py-0.5 rounded-full text-xs font-medium ${row.term === 'long' ? 'text-green-700 bg-green-50' : 'text-amber-700 bg-amber-50'}`}>
														{row.term === 'long' ? t.termLong : t.termShort}
													</span>
													: <span class="text-gray-300 text-xs">{t.termUnknown}</span>
												}
											</td>
											<td class="px-5 py-3">
												{isOrphan
													? <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium text-red-700 bg-red-100">{t.issueNoMatchingBuy}</span>
													: <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium text-orange-700 bg-orange-50">{t.issueBuyNoPrice}</span>
												}
											</td>
											<td class="px-5 py-3 text-xs text-gray-500">
												{isOrphan
													? <a href="/dashboard/bookkeeping" class="underline text-blue-600 hover:text-blue-800">{t.fixFindBookkeeping}</a>
													: <a href="/dashboard/bookkeeping" class="underline text-blue-600 hover:text-blue-800">{t.fixEnterCost}</a>
												}
											</td>
										</tr>
									);
								})}
							</tbody>
						</table>
						<div class="px-5 py-3 border-t border-red-200 bg-red-50">
							<p class="text-xs text-red-700">
								{t.missingImpact}
							</p>
						</div>
					</div>
				)}

