																			<td class="px-4 py-2 text-right font-mono text-gray-700 whitespace-nowrap">
																				{lot.amount.toLocaleString(dateLocale, { maximumFractionDigits: 8 })}
																			</td>
																			<td class="px-4 py-2 text-gray-500 whitespace-nowrap">{fmtDate(lot.buyDate)}</td>
																			<td class="px-4 py-2 text-right text-gray-500 whitespace-nowrap">{lot.daysHeld}d</td>
																			<td class="px-4 py-2 text-right tabular-nums text-gray-700 whitespace-nowrap">
																				{lot.proceedsUsd != null ? fmt(lot.proceedsUsd) : <span class="text-gray-300">—</span>}
																			</td>
																			<td class="px-4 py-2 text-right tabular-nums text-gray-700 whitespace-nowrap">
																				{lot.costUsd != null ? fmt(lot.costUsd) : <span class="text-gray-300">—</span>}
																			</td>
																			<td class={`px-4 py-2 text-right tabular-nums font-medium whitespace-nowrap ${
																				lot.gainLossUsd == null ? 'text-gray-300' :
