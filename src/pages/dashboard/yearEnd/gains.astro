							to confirm or override each transaction.
						</div>
					</div>
				)}

				<!-- Year-over-year chart -->
				{(payload.yoyRows?.length ?? 0) > 1 && (() => {
					const rows = payload.yoyRows!;
					const maxAbs = Math.max(...rows.map(r => Math.abs(r.netGain)), 1);
					const BAR_H = 28;
					const LABEL_W = 48;
					const VALUE_W = 88;
					const CHART_W = 400;
					const SVG_W = LABEL_W + CHART_W + VALUE_W;
					const SVG_H = rows.length * (BAR_H + 6) + 24;
					const midX = LABEL_W + CHART_W / 2;

					return (
						<div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
							<div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
								<h2 class="text-sm font-semibold text-gray-700">Year-over-Year Realized Gains</h2>
								<span class="text-xs text-gray-400">ST + LT net · FIFO</span>
							</div>
							<div class="px-5 py-4 overflow-x-auto">
								<svg
									width={SVG_W}
									height={SVG_H}
									viewBox={`0 0 ${SVG_W} ${SVG_H}`}
									style="font-family: system-ui, sans-serif; display:block; max-width:100%;"
								>
									{/* centre line */}
									<line x1={midX} y1={0} x2={midX} y2={SVG_H - 16} stroke="#e5e7eb" stroke-width="1" />

									{rows.map((r, i) => {
										const y = i * (BAR_H + 6) + 4;
										const isGain = r.netGain >= 0;
										const barW = Math.max(2, (Math.abs(r.netGain) / maxAbs) * (CHART_W / 2 - 4));
										const barX = isGain ? midX : midX - barW;
										const fill = isGain ? '#15803d' : '#b91c1c';
										const valStr = r.netGain === 0 ? '$0'
											: r.netGain > 0
												? `+$${(r.netGain / 1000).toFixed(1)}k`
												: `($${(Math.abs(r.netGain) / 1000).toFixed(1)}k)`;

										return (
											<g key={r.year}>
												{/* year label */}
												<text x={LABEL_W - 6} y={y + BAR_H / 2 + 5} text-anchor="end" font-size="12" fill="#6b7280">{r.year}</text>
												{/* bar */}
												<rect x={barX} y={y} width={barW} height={BAR_H} rx="3" fill={fill} opacity="0.85" />
												{/* value */}
												<text
													x={isGain ? midX + barW + 6 : midX - barW - 6}
													y={y + BAR_H / 2 + 5}
													text-anchor={isGain ? 'start' : 'end'}
													font-size="12"
													font-weight="600"
													fill={fill}
												>{valStr}</text>
											</g>
										);
									})}

									{/* axis label */}
									<text x={midX} y={SVG_H - 2} text-anchor="middle" font-size="10" fill="#9ca3af">{t.yoyAxisLabel}</text>
								</svg>
							</div>
						</div>
					);
				})()}

				<!-- Form 8949 CTA -->
				<div class="rounded-xl border border-blue-100 bg-blue-50 p-5 flex items-center justify-between flex-wrap gap-4">
					<div>
						<p class="font-semibold text-blue-900">{t.exportCtaHeading}</p>
						<p class="text-sm text-blue-700 mt-0.5">
							{t.exportCtaBody}
						</p>
					</div>
					<a
						href="/dashboard/transactions"
						class="inline-flex items-center gap-2 rounded-lg bg-blue-600 hover:bg-blue-700
						       text-white text-sm font-medium px-4 py-2 transition-colors"
					>
						{t.exportCtaBtn}
					</a>
				</div>
			</>
		)}

	</div>
</Layout>

<script is:inline define:vars={{ pipelineI18n: {
	running: t.pipelineBtnRunning,
	done: t.pipelineBtnDone,
	rerun: t.pipelineBtnRerun,
	networkError: t.pipelineNetworkError,
} }}>window.__gainsI18n = pipelineI18n;</script>

<script>
// ── 2024 / 2025 IRS Tax Brackets ─────────────────────────────────────────────
// Ordinary income brackets [threshold, rate]  (marginal, single top of range)
const ORDINARY: Record<string, [number, number][]> = {
  single: [
    [11600,  0.10], [47150,  0.12], [100525, 0.22],
    [191950, 0.24], [243725, 0.32], [609350, 0.35], [Infinity, 0.37],
  ],
  mfj: [
    [23200,  0.10], [94300,  0.12], [201050, 0.22],
    [383900, 0.24], [487450, 0.32], [731200, 0.35], [Infinity, 0.37],
  ],
  mfs: [
    [11600,  0.10], [47150,  0.12], [100525, 0.22],
    [191950, 0.24], [243725, 0.32], [365600, 0.35], [Infinity, 0.37],
  ],
  hoh: [
    [16550,  0.10], [63100,  0.12], [100500, 0.22],
    [191950, 0.24], [243700, 0.32], [609350, 0.35], [Infinity, 0.37],
  ],
};

// Long-term capital gains rate thresholds [threshold, rate]
const LT_RATES: Record<string, [number, number][]> = {
  single: [[47025, 0.00], [518900, 0.15], [Infinity, 0.20]],
  mfj:    [[94050, 0.00], [583750, 0.15], [Infinity, 0.20]],
  mfs:    [[47025, 0.00], [291850, 0.15], [Infinity, 0.20]],
  hoh:    [[63000, 0.00], [551350, 0.15], [Infinity, 0.20]],
};

// State income tax — top marginal rate applied to all crypto income and gains.
// Most states tax LT capital gains as ordinary income (no preferential rate).
// Rates current as of 2024-2025; WA rate applies only to LT gains above $262K.
const STATE_RATES: Record<string, number> = {
  none: 0,
  AL: 0.050, AK: 0,     AZ: 0.025, AR: 0.044, CA: 0.133,
  CO: 0.044, CT: 0.0699,DE: 0.066, FL: 0,     GA: 0.0549,
  HI: 0.110, ID: 0.058, IL: 0.0495,IN: 0.0305,IA: 0.057,
  KS: 0.057, KY: 0.045, LA: 0.060, ME: 0.0715,MD: 0.0575,
  MA: 0.050, MI: 0.0425,MN: 0.0985,MS: 0.050, MO: 0.048,
  MT: 0.0675,NE: 0.0664,NV: 0,     NH: 0,     NJ: 0.1075,
  NM: 0.059, NY: 0.109, NC: 0.0475,ND: 0.029, OH: 0.035,
  OK: 0.0475,OR: 0.099, PA: 0.0307,RI: 0.0599,SC: 0.064,
  SD: 0,     TN: 0,     TX: 0,     UT: 0.0465,VT: 0.0875,
  VA: 0.0575,WA: 0.07,  WV: 0.065, WI: 0.0765,WY: 0,
  DC: 0.1075,
};

// Net Investment Income Tax — 3.8% on NII above MAGI threshold
// NII includes crypto gains (ST + LT) and staking/interest income
const NIIT_RATE = 0.038;
const NIIT_THRESHOLD: Record<string, number> = {
  single: 200_000,
  mfj:    250_000,
  mfs:    125_000,
  hoh:    200_000,
};

function marginalRate(income: number, brackets: [number, number][]): number {
  for (const [top, rate] of brackets) {
    if (income <= top) return rate;
  }
  return brackets[brackets.length - 1][1];
}

// Compute tax owed on `amount` stacked on top of `base` income using marginal brackets.
// Returns { tax, effectiveRate }.
function taxOnAmount(base: number, amount: number, brackets: [number, number][]): { tax: number; rate: number } {
  if (amount <= 0) return { tax: 0, rate: 0 };
  let tax = 0;
  let prev = 0;
  let remaining = amount;
  const totalTop = base + amount;

  for (const [top, rate] of brackets) {
    const sliceTop = Math.min(top, totalTop);
    if (sliceTop <= base) { prev = sliceTop; continue; }
    const sliceBottom = Math.max(prev, base);
    const slice = Math.min(sliceTop - sliceBottom, remaining);
    if (slice <= 0) { prev = sliceTop; continue; }
    tax += slice * rate;
    remaining -= slice;
    prev = sliceTop;
    if (remaining <= 0) break;
  }
  return { tax, rate: tax / amount };
}

function fmtUsd(n: number): string {
  return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
}
function fmtPct(r: number): string {
  return (r * 100).toFixed(1) + '%';
}

function recalculate() {
  const el = document.getElementById('tax-estimator');
  if (!el) return;

  const stGain        = parseFloat(el.dataset.stGain  ?? '0') || 0;
  const ltGain        = parseFloat(el.dataset.ltGain  ?? '0') || 0;
  const cryptoIncome  = parseFloat(el.dataset.ordinaryIncome ?? '0') || 0;

  const filingEl = document.getElementById('est-filing-status') as HTMLSelectElement | null;
  const otherEl  = document.getElementById('est-other-income')  as HTMLInputElement  | null;
  const stateEl  = document.getElementById('est-state')         as HTMLSelectElement | null;

  const filing      = (filingEl?.value ?? 'single') as keyof typeof ORDINARY;
  const otherIncome = Math.max(0, parseFloat(otherEl?.value ?? '0') || 0);
  const stateKey    = stateEl?.value ?? 'none';
  const stateRate   = STATE_RATES[stateKey] ?? 0;

  const ordBrackets = ORDINARY[filing] ?? ORDINARY.single;
  const ltBrackets  = LT_RATES[filing]  ?? LT_RATES.single;

  // Base = other income
  // ST gains stacked on top of base (ordinary income treatment)
  // Crypto income stacked on top of base + ST gains
  const stResult     = taxOnAmount(otherIncome,                          Math.max(0, stGain),       ordBrackets);
  const incomeResult = taxOnAmount(otherIncome + Math.max(0, stGain),    Math.max(0, cryptoIncome), ordBrackets);

  // LT gains: rate determined by total ordinary income stacked base
  const ltOrdinaryBase = otherIncome + Math.max(0, stGain) + Math.max(0, cryptoIncome);
  const ltRate = marginalRate(ltOrdinaryBase, ltBrackets);
  const ltTax  = Math.max(0, ltGain) * ltRate;

  // If gains are negative, they offset — show $0
  const stTax     = stGain       < 0 ? 0 : stResult.tax;
  const incomeTax = cryptoIncome < 0 ? 0 : incomeResult.tax;

  // ── NIIT ────────────────────────────────────────────────────────────────
  // MAGI approximation = other income + crypto gains + crypto income
  const magi          = otherIncome + Math.max(0, stGain) + Math.max(0, ltGain) + Math.max(0, cryptoIncome);
  const niitThreshold = NIIT_THRESHOLD[filing] ?? NIIT_THRESHOLD.single;
  const niitApplies   = magi > niitThreshold;
  // NIIT base = net investment income (gains + crypto income), capped at the
  // amount that exceeds the threshold
  const nii           = Math.max(0, stGain) + Math.max(0, ltGain) + Math.max(0, cryptoIncome);
  const niitBase      = niitApplies ? Math.min(nii, magi - niitThreshold) : 0;
  const niitTax       = niitBase * NIIT_RATE;

  // ── State tax ────────────────────────────────────────────────────────────
  // States generally tax LT gains as ordinary income (no preferential rate).
  // Apply the top marginal rate to all crypto gains + income combined.
  const cryptoTaxableState = Math.max(0, stGain) + Math.max(0, ltGain) + Math.max(0, cryptoIncome);
  const stateTax = cryptoTaxableState * stateRate;

  const totalTax = stTax + incomeTax + ltTax + niitTax + stateTax;

  const setText = (id: string, val: string) => {
    const node = document.getElementById(id);
    if (node) node.textContent = val;
  };
  const setHidden = (id: string, hidden: boolean) => {
    const node = document.getElementById(id);
    if (node) node.classList.toggle('hidden', hidden);
  };

  setText('est-st-tax',     stGain       <= 0 ? '—' : fmtUsd(stTax));
  setText('est-st-rate',    stGain       <= 0 ? 'no ST gain this year'  : `${fmtPct(stResult.rate)} effective rate`);
  setText('est-lt-tax',     ltGain       <= 0 ? '—' : fmtUsd(ltTax));
  setText('est-lt-rate',    ltGain       <= 0 ? 'no LT gain this year'  : `${fmtPct(ltRate)} capital gains rate`);
  setText('est-income-tax', cryptoIncome <= 0 ? '—' : fmtUsd(incomeTax));
  setText('est-niit-tax',   fmtUsd(niitTax));
  setText('est-state-tax',  stateRate === 0 ? '—' : fmtUsd(stateTax));
  setText('est-state-rate', stateRate === 0 ? 'no state income tax' : `${fmtPct(stateRate)} flat applied`);
  setText('est-total-tax',  totalTax     <= 0 ? '$0' : fmtUsd(totalTax));

  // Show NIIT cell + banner only when it applies
  setHidden('est-niit-cell',   !niitApplies);
  setHidden('est-niit-banner', !niitApplies);
}

document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('est-filing-status')?.addEventListener('change', recalculate);
  document.getElementById('est-other-income')?.addEventListener('input', recalculate);
  document.getElementById('est-state')?.addEventListener('change', recalculate);
  recalculate();
});

// ── Per-asset lot drill-down ──────────────────────────────────────────────────
// Clicking an asset summary row toggles the hidden detail row below it.
// The CSV export button serialises that asset's lots to a downloadable file.

(function () {
  // Expand / collapse
  document.querySelectorAll<HTMLTableRowElement>('.asset-summary-row[data-target]').forEach((summaryRow) => {
    const targetId = summaryRow.dataset.target!;
    const detailRow = document.getElementById(targetId);
    if (!detailRow) return;

    summaryRow.addEventListener('click', () => {
      const isOpen = !detailRow.classList.contains('hidden');
      detailRow.classList.toggle('hidden', isOpen);
      const chevron = summaryRow.querySelector<HTMLSpanElement>('.expand-chevron');
      if (chevron) {
        chevron.style.transform = isOpen ? '' : 'rotate(90deg)';
      }
    });
  });

  // CSV export per asset
  document.querySelectorAll<HTMLButtonElement>('.csv-export-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation(); // don't collapse the row
      const asset = btn.dataset.asset ?? 'asset';
      const detailRow = btn.closest<HTMLTableRowElement>('.lot-detail-row');
      if (!detailRow) return;

      const rows = detailRow.querySelectorAll<HTMLTableRowElement>('tbody tr');
      const lines: string[] = [
        'Asset,Sold Date,Qty,Acquired Date,Days Held,Proceeds USD,Cost Basis USD,Gain/Loss USD,Term',
      ];
      rows.forEach((tr) => {
        const cells = Array.from(tr.querySelectorAll('td')).map((td) => {
          const text = td.textContent?.trim().replace(/,/g, '') ?? '';
          return `"${text}"`;
        });
        // cells: [sold, qty, acquired, held, proceeds, cost, gain, term]
        if (cells.length >= 8) {
          lines.push(`"${asset}",${cells.join(',')}`);
        }
      });

      const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
      const url  = URL.createObjectURL(blob);
      const a    = document.createElement('a');
      a.href     = url;
      a.download = `${asset}-lots-${new URLSearchParams(window.location.search).get('year') ?? 'year'}.csv`;
      a.click();
      URL.revokeObjectURL(url);
    });
  });
})();

// ── Pipeline re-run button handler ────────────────────────────────────────────
// All three buttons (.pipeline-run-btn) share this handler.
// POST /api/yearEnd/classify → wait → show result → reload page.

(function () {
  const ENDPOINT = '/api/yearEnd/classify';
  interface GainsI18n { running: string; done: string; rerun: string; networkError: string; }
  const GAPI18N: GainsI18n = (window as unknown as { __gainsI18n?: GainsI18n }).__gainsI18n ?? {
    running: '⏳ Running…', done: '✓ Done — reloading…',
    rerun: 'Re-run Pipeline', networkError: 'Network error — could not reach the server. Please try again.',
  };

  function setAllBtns(disabled: boolean, label: string) {
    document.querySelectorAll<HTMLButtonElement>('.pipeline-run-btn').forEach((btn) => {
      btn.disabled = disabled;
      btn.textContent = label;
    });
  }

  async function runPipeline() {
    setAllBtns(true, GAPI18N.running);

    try {
      const res  = await fetch(ENDPOINT, { method: 'POST' });
      const data = await res.json() as { ok: boolean; stats?: Record<string, unknown>; error?: string };

      if (data.ok) {
        setAllBtns(true, GAPI18N.done);
        // Brief pause so the user sees the success state, then reload with fresh data
        setTimeout(() => window.location.reload(), 1200);
      } else {
        const msg = data.error ?? 'Pipeline failed.';
        setAllBtns(false, GAPI18N.rerun);
        // Show error inline near whichever button was clicked
        document.querySelectorAll<HTMLButtonElement>('.pipeline-run-btn').forEach((btn) => {
          const err = document.createElement('span');
          err.className = 'text-xs text-red-600 ml-2';
          err.textContent = `❌ ${msg}`;
          btn.insertAdjacentElement('afterend', err);
          setTimeout(() => err.remove(), 6000);
        });
      }
    } catch {
      setAllBtns(false, GAPI18N.rerun);
      alert(GAPI18N.networkError);
    }
  }

  document.querySelectorAll<HTMLButtonElement>('.pipeline-run-btn').forEach((btn) => {
    btn.addEventListener('click', runPipeline);
  });
})();
</script>
