					data-lt-gain={payload.gains?.longTermGain ?? 0}
					data-ordinary-income={payload.ordinaryIncome?.total ?? 0}
					data-year={year}
				>
					<div class="px-5 py-3 border-b border-indigo-100 flex items-center justify-between">
						<div>
							<h2 class="text-sm font-semibold text-indigo-900">{t.estimatorHeading}</h2>
							<p class="text-xs text-indigo-600 mt-0.5">
								{t.estimatorSub(year, method.toUpperCase())}
							</p>
						</div>
						<span class="text-xs text-indigo-400 font-medium">{t.estimatorDisclaimer}</span>
					</div>

					<!-- Inputs -->
					<div class="px-5 py-4 border-b border-gray-100 grid grid-cols-1 sm:grid-cols-3 gap-4 bg-gray-50">
						<div>
							<label class="block text-xs font-semibold text-gray-600 mb-1">{t.labelFilingStatus}</label>
							<select id="est-filing-status" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
								<option value="single">{t.optSingle}</option>
								<option value="mfj">{t.optMfj}</option>
								<option value="mfs">{t.optMfs}</option>
								<option value="hoh">{t.optHoh}</option>
							</select>
						</div>
						<div>
							<label class="block text-xs font-semibold text-gray-600 mb-1">
								{t.labelOtherIncome}
							</label>
							<div class="relative">
								<span class="absolute left-3 top-2 text-gray-400 text-sm">$</span>
								<input
									id="est-other-income"
									type="number"
									min="0"
									step="1000"
									value="0"
									class="w-full border border-gray-300 rounded-lg pl-7 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400"
								/>
							</div>
						</div>
						<div>
							<label class="block text-xs font-semibold text-gray-600 mb-1">{t.labelState}</label>
							<select id="est-state" class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400">
								<option value="none">No state income tax</option>
