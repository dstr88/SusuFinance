							</thead>
							<tbody class="divide-y divide-gray-100">
								{payload.defiEvents!.byType.map((row) => (
									<tr class="hover:bg-gray-50">
										<td class="px-5 py-3 font-medium text-gray-800">{row.label}</td>
										<td class="px-5 py-3 text-right text-gray-500">{row.count}</td>
										<td class="px-5 py-3 text-right font-semibold text-gray-900">
											{row.totalUsd > 0 ? fmt(row.totalUsd) : '—'}
										</td>
										<td class="px-5 py-3 text-xs text-gray-500">
											{row.type === 'lp-deposit'    && t.defiLpDeposit}
											{row.type === 'lp-withdrawal' && t.defiLpWithdrawal}
											{row.type === 'rebase-income' && t.defiRebaseIncome}
											{row.type === 'wrapped-swap'  && t.defiWrappedSwap}
