---
/**
 * /dashboard/yearEnd — Schedule D tax summary
 *
 * Shows a high-level breakdown of:
 *   • Ordinary income   (Aave interest, rebasing rewards — Form 1040 Schedule 1)
 *   • Disposal proceeds (capital events — Form 8949 / Schedule D)
 *   • Forced liquidations
 *   • Unpriced warning  (transactions that still need historical pricing)
 *
 * Exact FIFO per-lot gain/loss is computed client-side on the transactions page
 * and downloaded from there as a Form 8949 CSV.  This page gives the tax-season
 * overview at a glance.
 */

import Layout from '../../../layouts/Layout.astro';
import { hasTaxAccess } from '@/lib/taxAuth';
import CompletenessScore from '@/components/yearEnd/CompletenessScore.astro';
import { getLang } from '@/lib/i18n/locale';
import { getGains } from '@/i18n/dashboard/yearEnd/gains';

const lang = getLang(Astro.request);
const t = getGains(lang);

// ── Types ──────────────────────────────────────────────────────────────────
type AssetIncome = { symbol: string; amount: number; count: number };

type IncomeCategoryRow = {
	type:    string;
	label:   string;
	irsLine: string;
	count:   number;
	total:   number;
};

type WashSaleItem = {
	asset:             string;
	disposedAt:        string;
	lossAmount:        number;
	triggerAcquiredAt: string;
	disallowedLoss:    number;
};

type DefiTypeRow = { type: string; label: string; count: number; totalUsd: number };

type TaxPayload = {
	ok: boolean;
	error?: string;
	year?: number;
	availableYears?: number[];
	ordinaryIncome?: {
		total: number;
		count: number;
		byAsset: AssetIncome[];
		byCategory?: IncomeCategoryRow[];
		incomeSource?: 'pipeline' | 'lifecycle';
	};
	disposals?: {
		totalProceeds:    number;
		count:            number;
		unpricedCount:    number;
		liquidationCount: number;
	};
	unpricedOnchain?: number;
	gains?: {
		shortTermGain:  number;
		longTermGain:   number;
		netGain:        number;
		shortTermCount: number;
		longTermCount:  number;
		dataSource?:    'pipeline' | 'lifecycle';
	};
	byAssetGains?: {
		asset:   string;
		stGain:  number;
		stLots:  number;
		ltGain:  number;
		ltLots:  number;
		netGain: number;
	}[];
	lotDetails?: Record<string, Array<{
		amount:      number;
		buyDate:     string;
		sellDate:    string;
		costUsd:     number | null;
		proceedsUsd: number | null;
		gainLossUsd: number | null;
		daysHeld:    number;
		term:        'short' | 'long';
	}>>;
	harvestLosses?: {
		asset:              string;
		totalQty:           number;
		totalCost:          number;
		currentPrice:       number | null;
		currentValue:       number | null;
		unrealizedGainLoss: number | null;
		shortTermQty:       number;
		longTermQty:        number;
		soonestLotDaysToLT: number | null;
	}[];
	missingBasis?: {
		asset:    string;
		date:     string;
		qty:      number;
		proceeds: number | null;
		issue:    'no_cost_basis' | 'no_matching_buy';
		daysHeld: number | null;
		term:     'short' | 'long' | null;
	}[];
	carryLedger?: {
		year:           number;
		netGainLoss:    number;
		deducted:       number;
		absorbedByGain: number;
		endingBalance:  number;
	}[];
	carryforwardAvailable?: number;
	yoyRows?: { year: number; stGain: number; ltGain: number; netGain: number }[];
	method?: 'fifo' | 'hifo' | 'lifo' | 'spec_id';
	gainCrossCheck?: {
		pipelineStGain:  number | null;
		pipelineLtGain:  number | null;
		pipelineNet:     number | null;
		displayedStGain: number;
		displayedLtGain: number;
		displayedNet:    number;
		/** Deprecated alias kept for backwards compat — same as displayedNet */
		inMemoryNet?:    number;
		netDiff:         number | null;
		withinTolerance: boolean | null;
		disposalCount:   number | null;
		/** True when both sides read from the pipeline — check is an identity (always passes). */
		sameSource?:     boolean;
	};
	washSaleShadow?: { totalDisallowed: number; items: WashSaleItem[] };
	defiEvents?: { count: number; byType: DefiTypeRow[] };
	incomeCrossCheck?: {
		pipelineTotal:   number | null;
		displayedTotal:  number;
		/** Deprecated alias kept for backwards compat — same as displayedTotal */
		inMemoryTotal?:  number;
		diff:            number | null;
		withinTolerance: boolean | null;
		/** True when both sides read from the pipeline — check is an identity (always passes). */
		sameSource?:     boolean;
	};
	lastPipelineRun?: {
		startedAt:       string;
		completedAt:     string | null;
		status:          string;
		errorMsg:        string | null;
		totalClassified: number | null;
		totalUnknown:    number | null;
	} | null;
	pipelineStale?: {
		stale:           boolean;
		lastRunAt:       string | null;
		latestImportAt:  string | null;
		staleSinceMs:    number | null;
	} | null;
};

// ── Fetch data ─────────────────────────────────────────────────────────────

if (!(await hasTaxAccess(Astro.request))) return Astro.redirect('/tax-login', 302);
const defaultYear = new Date().getFullYear() - 1; // prior tax year
const yearParam   = Astro.url.searchParams.get('year');
const year        = yearParam ? Number(yearParam) : defaultYear;
const methodParam = Astro.url.searchParams.get('method');
const method =
	methodParam === 'hifo'    ? 'hifo'    :
	methodParam === 'lifo'    ? 'lifo'    :
	methodParam === 'spec_id' ? 'spec_id' : 'fifo';

const apiUrl = new URL(`/api/yearEnd/summary?year=${year}&method=${method}`, Astro.request.url);
const apiRes = await fetch(apiUrl);
const data: TaxPayload = apiRes.ok ? await apiRes.json() : { ok: false };

const payload        = data.ok ? data : null;
const availableYears = payload?.availableYears ?? [];

// ── Helpers ────────────────────────────────────────────────────────────────
const dateLocale = lang === 'es' ? 'es-ES' : lang === 'fr' ? 'fr-FR' : 'en-US';

const fmt = (n: number) =>
	n.toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });

const fmtDate = (iso: string) => {
	try { return new Date(iso).toLocaleDateString(dateLocale, { month: 'short', day: 'numeric', year: 'numeric' }); }
	catch { return iso; }
};

// Accounting notation: losses in parentheses, gains with + prefix
const fmtGain = (n: number) => {
	const abs = Math.abs(n).toLocaleString('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 2 });
	if (n < 0) return `(${abs})`;
	if (n > 0) return `+${abs}`;
	return abs;
};
---

<Layout title={t.pageTitle} noindex={true}>
	<div class="max-w-4xl mx-auto px-4 py-8 space-y-8">

		<!-- Header + year picker -->
		<div class="flex items-center justify-between flex-wrap gap-4">
			<div>
				<a href="/dashboard/yearEnd" class="text-xs text-indigo-500 hover:text-indigo-700 font-medium mb-1 inline-block">{t.backLink}</a>
				<h1 class="text-2xl font-bold">{t.heroTitle}</h1>
				<p class="text-sm text-gray-500 mt-1">
					{t.heroSub(year)}
					{t.heroSubDetail}
					<a href="/dashboard/transactions" class="underline text-blue-600 hover:text-blue-800">
						{t.heroSubLinkLabel}
					</a>.
				</p>
			</div>

			<div class="flex items-center flex-wrap gap-3">
				<!-- Cost basis method toggle -->
				<div class="flex rounded-lg border border-gray-300 overflow-hidden text-sm font-medium">
					<a
						href={`?year=${year}&method=fifo`}
						class={`px-3 py-1.5 transition-colors ${method === 'fifo' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
						title={t.fifoTitle}
					>FIFO</a>
					<a
						href={`?year=${year}&method=hifo`}
						class={`px-3 py-1.5 border-l border-gray-300 transition-colors ${method === 'hifo' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
						title={t.hifoTitle}
					>HIFO</a>
					<a
						href={`?year=${year}&method=lifo`}
						class={`px-3 py-1.5 border-l border-gray-300 transition-colors ${method === 'lifo' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
						title={t.lifoTitle}
					>LIFO</a>
					<a
						href={`/dashboard/yearEnd/lots?year=${year}&method=${method}`}
						class={`px-3 py-1.5 border-l border-gray-300 transition-colors ${method === 'spec_id' ? 'bg-indigo-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
						title={t.specIdTitle}
					>Spec ID</a>
				</div>

				{(method === 'hifo' || method === 'lifo' || method === 'spec_id') && (
					<span class="text-xs text-indigo-600 font-medium bg-indigo-50 border border-indigo-200 rounded-full px-2 py-0.5">
						{method === 'hifo' ? t.hifoActive :
						 method === 'lifo' ? t.lifoActive :
						 t.specIdActive}
					</span>
				)}

				{availableYears.length > 0 && (
					<form id="gains-year-filter" method="get" class="flex items-center gap-2">
						<input type="hidden" name="method" value={method} />
						<label for="year-select" class="text-sm font-medium text-gray-700">{t.yearLabel}</label>
						<select
							id="year-select"
							name="year"
							onchange="this.form.submit()"
							class="border border-gray-300 rounded-md px-3 py-1.5 text-sm shadow-sm
							       focus:outline-none focus:ring-2 focus:ring-indigo-500"
						>
							{availableYears.map((y) => (
								<option value={y} selected={y === year}>{y}</option>
							))}
						</select>
					</form>
				)}
			</div>
		</div>

		<!-- Completeness compact banner -->
		<CompletenessScore year={year} compact={true} />

		<!-- API / data error -->
		{!payload && (
			<div class="rounded-lg border border-red-200 bg-red-50 p-4 text-sm text-red-700">
				{t.loadError(year)}
			</div>
		)}

		{payload && (
			<>
				<!-- Unpriced transactions warning -->
				{(payload.unpricedOnchain ?? 0) > 0 && (
					<div class="flex items-start gap-3 rounded-lg border border-amber-200 bg-amber-50 p-4">
						<span class="text-amber-500 text-xl leading-none mt-0.5">⚠</span>
						<div class="text-sm">
							<p class="font-semibold text-amber-800">
								{t.unpricedHeading(payload.unpricedOnchain!)}
							</p>
							<p class="text-amber-700 mt-1">
								{t.unpricedBody}
								<a href="/dashboard/wallets" class="underline">{t.unpricedWalletsLink}</a>.
							</p>
						</div>
					</div>
				)}

				<!-- ST / LT gain cards -->
				{payload.gains && (
					<div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
						<div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between flex-wrap gap-2">
							<div>
								<h2 class="text-sm font-semibold text-gray-700">{t.capitalGainsHeading}</h2>
								<p class="text-xs text-gray-400 mt-0.5">
									{t.capitalGainsSub(method === 'fifo' ? 'FIFO' : method === 'hifo' ? 'HIFO' : method === 'lifo' ? 'LIFO' : 'Spec ID')}
								</p>
							</div>
							<!-- Data source badge: shows whether gains came from the pipeline or
							     were re-computed in-memory from lifecycle events -->
							{payload.gains.dataSource === 'pipeline'
								? <span class="inline-flex items-center gap-1.5 rounded-full bg-indigo-50 border border-indigo-200 text-indigo-700 text-xs font-medium px-2.5 py-1">
										<span class="w-1.5 h-1.5 rounded-full bg-indigo-500 inline-block"></span>
										{t.pipelineBadge}
									</span>
								: <span class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 border border-gray-200 text-gray-500 text-xs font-medium px-2.5 py-1">
										<span class="w-1.5 h-1.5 rounded-full bg-gray-400 inline-block"></span>
										{t.inMemoryBadge}
									</span>
							}
						</div>
						<div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">

							<!-- Short-term -->
							<div class="p-5 space-y-1">
								<p class="text-xs font-semibold uppercase tracking-wide text-gray-400">
									{t.shortTermLabel} &nbsp;<span class="normal-case font-normal text-gray-400">{t.shortTermNote}</span>
								</p>
								<p class={`text-2xl font-bold ${
									(payload.gains.shortTermGain ?? 0) >= 0 ? 'text-green-700' : 'text-red-600'
								}`}>
									{fmtGain(payload.gains.shortTermGain)}
								</p>
								<p class="text-xs text-gray-500">
									{t.lotCount(payload.gains.shortTermCount)}
									&nbsp;·&nbsp;{t.shortTermSub}
								</p>
							</div>

							<!-- Long-term -->
							<div class="p-5 space-y-1">
								<p class="text-xs font-semibold uppercase tracking-wide text-gray-400">
									{t.longTermLabel} &nbsp;<span class="normal-case font-normal text-gray-400">{t.longTermNote}</span>
								</p>
								<p class={`text-2xl font-bold ${
									(payload.gains.longTermGain ?? 0) >= 0 ? 'text-green-700' : 'text-red-600'
								}`}>
									{fmtGain(payload.gains.longTermGain)}
								</p>
								<p class="text-xs text-gray-500">
									{t.lotCount(payload.gains.longTermCount)}
									&nbsp;·&nbsp;{t.longTermSub}
								</p>
							</div>

							<!-- Net -->
							<div class="p-5 space-y-1">
								<p class="text-xs font-semibold uppercase tracking-wide text-gray-400">
									{t.netRealizedLabel}
								</p>
								<p class={`text-2xl font-bold ${
									(payload.gains.netGain ?? 0) >= 0 ? 'text-green-700' : 'text-red-600'
								}`}>
									{fmtGain(payload.gains.netGain)}
								</p>
								<p class="text-xs text-gray-500">
									{t.netRealizedSub}
								</p>
							</div>

						</div>
					</div>
				)}

				<!-- Gain/loss cross-check warning (only shown when sources are different AND diverge) -->
				{payload.gainCrossCheck?.withinTolerance === false && !payload.gainCrossCheck?.sameSource && (
					<div class="rounded-xl border border-orange-300 bg-orange-50 shadow-sm p-4 flex gap-3">
						<span class="text-orange-500 text-xl leading-none mt-0.5">⚠</span>
						<div class="space-y-1">
							<p class="text-sm font-semibold text-orange-900">
								{t.gainDivergeHeading}
							</p>
							<p class="text-xs text-orange-700">
								{t.gainDivergeSub(
									fmtGain(payload.gainCrossCheck.pipelineNet ?? 0),
									fmtGain(payload.gainCrossCheck.displayedNet ?? payload.gainCrossCheck.inMemoryNet ?? 0),
									fmtGain(payload.gainCrossCheck.netDiff ?? 0)
								)}
							</p>
						</div>
					</div>
				)}

				<!-- Income cross-check warning (only shown when sources differ AND diverge) -->
				{payload.incomeCrossCheck?.withinTolerance === false && !payload.incomeCrossCheck?.sameSource && (
					<div class="rounded-xl border border-orange-300 bg-orange-50 shadow-sm p-4 flex gap-3">
						<span class="text-orange-500 text-xl leading-none mt-0.5">⚠</span>
						<div class="space-y-1">
							<p class="text-sm font-semibold text-orange-900">
								{t.incomeDivergeHeading}
							</p>
							<p class="text-xs text-orange-700">
								{t.incomeDivergeSub(
									fmt(payload.incomeCrossCheck.pipelineTotal ?? 0),
									fmt(payload.incomeCrossCheck.displayedTotal ?? payload.incomeCrossCheck.inMemoryTotal ?? 0),
									fmt(Math.abs(payload.incomeCrossCheck.diff ?? 0))
								)}
							</p>
						</div>
					</div>
				)}

				<!-- Pipeline run status bar -->
				{payload.lastPipelineRun && (
					<div class={`rounded-xl border shadow-sm p-3 flex items-center justify-between gap-3 text-xs ${
						payload.lastPipelineRun.status === 'failed'
							? 'border-red-300 bg-red-50 text-red-700'
							: 'border-gray-200 bg-gray-50 text-gray-500'
					}`}>
						<div class="flex items-center gap-2 min-w-0">
							{payload.lastPipelineRun.status === 'success' && <span class="text-green-600 font-bold">✓</span>}
							{payload.lastPipelineRun.status === 'failed'  && <span class="text-red-500 font-bold">✗</span>}
							{payload.lastPipelineRun.status === 'running' && <span class="text-yellow-500 font-bold">↻</span>}
							<span>
								{t.pipelineStatus(payload.lastPipelineRun.status)}&nbsp;·&nbsp;
								{payload.lastPipelineRun.completedAt
									? new Date(payload.lastPipelineRun.completedAt).toLocaleString(dateLocale)
									: t.inProgress}
								{payload.lastPipelineRun.totalClassified != null && (
									<span class="ml-2 text-gray-400">
										{t.classified(payload.lastPipelineRun.totalClassified)}
										{(payload.lastPipelineRun.totalUnknown ?? 0) > 0 && ` · ${t.unknown(payload.lastPipelineRun.totalUnknown!)}`}
									</span>
								)}
							</span>
							{payload.lastPipelineRun.status === 'failed' && payload.lastPipelineRun.errorMsg && (
								<span class="text-red-600 font-mono truncate max-w-xs" title={payload.lastPipelineRun.errorMsg}>
									{payload.lastPipelineRun.errorMsg.slice(0, 80)}
								</span>
							)}
						</div>
						<button id="run-pipeline-btn-bar"
						        class="pipeline-run-btn shrink-0 rounded border border-gray-300 hover:border-indigo-400
						               hover:text-indigo-600 disabled:opacity-50 text-gray-500 text-xs font-medium
						               px-2.5 py-1 transition-colors bg-white">
							{t.rerunBtn}
						</button>
					</div>
				)}

				<!-- First-run prompt: pipeline has never run -->
				{!payload.lastPipelineRun && payload.gains?.dataSource === 'lifecycle' && (
					<div class="rounded-xl border border-indigo-200 bg-indigo-50 shadow-sm p-4 flex items-center justify-between gap-4">
						<div>
							<p class="text-sm font-semibold text-indigo-900">{t.firstRunHeading}</p>
							<p class="text-xs text-indigo-700 mt-0.5">
								{t.firstRunSub}
							</p>
						</div>
						<button id="run-pipeline-btn-first"
						        class="pipeline-run-btn shrink-0 rounded-lg bg-indigo-600 hover:bg-indigo-700 disabled:opacity-60
						               text-white text-sm font-semibold px-4 py-2 transition-colors">
							{t.runPipelineBtn}
						</button>
					</div>
				)}

				<!-- Stale pipeline warning -->
				<!-- Only shown when: pipeline has run (we're serving its data) AND
				     new import data has arrived since the last successful run.      -->
				{payload.pipelineStale?.stale && payload.gains?.dataSource === 'pipeline' && (
					<div class="rounded-xl border border-amber-300 bg-amber-50 shadow-sm p-4 flex items-start gap-3">
						<span class="text-amber-500 text-xl leading-none mt-0.5">⚠</span>
						<div class="space-y-1 flex-1 min-w-0">
							<p class="text-sm font-semibold text-amber-900">
								{t.stalePipelineHeading}
							</p>
							<p class="text-xs text-amber-700">
								{t.stalePipelineBody}
								{payload.pipelineStale.staleSinceMs != null && (() => {
									const ms   = payload.pipelineStale!.staleSinceMs!;
									const days = Math.floor(ms / 86_400_000);
									const hrs  = Math.floor(ms / 3_600_000);
									return days >= 2 ? t.staleDays(days)
									     : hrs  >= 1 ? t.staleHours(hrs)
									     : t.staleRecent;
								})()}
								{t.staleAfterPipeline}
							</p>
							{payload.pipelineStale.lastRunAt && (
								<p class="text-xs text-amber-600">
									{t.staleLastRun} {new Date(payload.pipelineStale.lastRunAt).toLocaleString(dateLocale)}
									{payload.pipelineStale.latestImportAt && (
										<> {t.staleLatestImport} {new Date(payload.pipelineStale.latestImportAt).toLocaleString(dateLocale)}</>
									)}
								</p>
							)}
						</div>
						<button id="run-pipeline-btn-stale"
						        class="pipeline-run-btn shrink-0 rounded-lg bg-amber-600 hover:bg-amber-700 disabled:opacity-60
						               text-white text-xs font-semibold px-3 py-2 transition-colors">
							{t.rerunPipelineBtn}
						</button>
					</div>
				)}

				<!-- Capital Loss Carryforward -->
				{(payload.carryforwardAvailable ?? 0) > 0 && (
					<div class="rounded-xl border border-emerald-200 bg-emerald-50 shadow-sm overflow-hidden">
						<div class="px-5 py-3 border-b border-emerald-200 flex items-center justify-between">
							<div>
								<h2 class="text-sm font-semibold text-emerald-900">{t.carryforwardHeading}</h2>
								<p class="text-xs text-emerald-700 mt-0.5">{t.carryforwardSub(year)}</p>
							</div>
							<div class="text-right">
								<p class="text-xl font-bold text-emerald-800">{fmtGain(-(payload.carryforwardAvailable ?? 0))}</p>
								<p class="text-xs text-emerald-600">{t.availableToApply}</p>
							</div>
						</div>

						{(payload.carryLedger?.length ?? 0) > 0 && (
							<table class="min-w-full text-sm">
								<thead class="bg-emerald-100">
									<tr>
										<th class="px-5 py-2.5 text-left  text-xs font-medium text-emerald-800 uppercase tracking-wide">{t.carryColYear}</th>
										<th class="px-5 py-2.5 text-right text-xs font-medium text-emerald-800 uppercase tracking-wide">{t.carryColNetGain}</th>
										<th class="px-5 py-2.5 text-right text-xs font-medium text-emerald-800 uppercase tracking-wide">{t.carryColDeducted}</th>
										<th class="px-5 py-2.5 text-right text-xs font-medium text-emerald-800 uppercase tracking-wide">{t.carryColAbsorbed}</th>
										<th class="px-5 py-2.5 text-right text-xs font-medium text-emerald-800 uppercase tracking-wide">{t.carryColEnding}</th>
									</tr>
								</thead>
								<tbody class="divide-y divide-emerald-100 bg-white">
									{payload.carryLedger!.filter(r => r.netGainLoss < 0 || r.absorbedByGain > 0 || r.deducted > 0).map((row) => (
										<tr class="hover:bg-emerald-50">
											<td class="px-5 py-3 font-semibold text-gray-700">{row.year}</td>
											<td class={`px-5 py-3 text-right font-medium tabular-nums ${row.netGainLoss < 0 ? 'text-red-600' : 'text-green-700'}`}>
												{fmtGain(row.netGainLoss)}
											</td>
											<td class="px-5 py-3 text-right tabular-nums text-gray-600">
												{row.deducted > 0 ? fmtGain(-row.deducted) : <span class="text-gray-300">—</span>}
											</td>
											<td class="px-5 py-3 text-right tabular-nums text-gray-600">
												{row.absorbedByGain > 0 ? fmtGain(-row.absorbedByGain) : <span class="text-gray-300">—</span>}
											</td>
											<td class={`px-5 py-3 text-right font-semibold tabular-nums ${row.endingBalance > 0 ? 'text-emerald-700' : 'text-gray-400'}`}>
												{row.endingBalance > 0 ? fmtGain(-row.endingBalance) : '$0'}
											</td>
										</tr>
									))}
								</tbody>
							</table>
						)}

						<div class="px-5 py-3 border-t border-emerald-200 bg-emerald-50">
							<p class="text-xs text-emerald-700">
								<strong>{t.carryHowTo(year)}</strong>
							</p>
						</div>
					</div>
				)}

				<!-- No carryforward — small note if there were prior loss years -->
				{(payload.carryforwardAvailable ?? 0) === 0 && (payload.carryLedger?.some(r => r.netGainLoss < 0) ?? false) && (
					<div class="rounded-lg border border-gray-200 bg-gray-50 px-5 py-3 flex items-center gap-3">
						<span class="text-gray-400 text-lg">✓</span>
						<p class="text-xs text-gray-500">
							{t.noCarryforward(year)}
						</p>
					</div>
				)}

				<!-- Per-asset breakdown (expandable drill-down) -->
				{(payload.byAssetGains?.length ?? 0) > 0 && (
					<div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
						<div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
							<div>
								<h2 class="text-sm font-semibold text-gray-700">{t.byAssetHeading}</h2>
								<p class="text-xs text-gray-400 mt-0.5">{t.byAssetSub}</p>
							</div>
						</div>
						<table class="min-w-full text-sm">
							<thead class="bg-gray-50">
								<tr>
									<th class="px-5 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide w-8"></th>
									<th class="px-5 py-2.5 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colAsset}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colStGain}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colStLots}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colLtGain}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colLtLots}</th>
									<th class="px-5 py-2.5 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">{t.colNet}</th>
								</tr>
							</thead>
							<tbody class="divide-y divide-gray-100">
								{payload.byAssetGains!.map((row) => {
									const lots = payload.lotDetails?.[row.asset] ?? [];
									const hasLots = lots.length > 0;
									const rowId = `lots-${row.asset.replace(/[^a-zA-Z0-9]/g, '_')}`;
									return (
										<>
											<!-- Summary row — clickable when lots exist -->
											<tr class={`asset-summary-row ${hasLots ? 'cursor-pointer hover:bg-indigo-50' : 'hover:bg-gray-50'}`}
											    data-target={rowId}
											    data-asset={row.asset}>
												<td class="px-4 py-3 text-center w-8">
													{hasLots && (
														<span class="expand-chevron text-gray-400 text-xs select-none transition-transform inline-block">▶</span>
													)}
												</td>
												<td class="px-5 py-3 font-mono font-semibold text-gray-800">{row.asset}</td>
												<td class={`px-5 py-3 text-right font-medium tabular-nums ${row.stGain < 0 ? 'text-red-600' : row.stGain > 0 ? 'text-green-700' : 'text-gray-400'}`}>
													{row.stLots > 0 ? fmtGain(row.stGain) : <span class="text-gray-300">—</span>}
												</td>
												<td class="px-5 py-3 text-right text-gray-500 tabular-nums">
													{row.stLots > 0 ? row.stLots : <span class="text-gray-300">—</span>}
												</td>
												<td class={`px-5 py-3 text-right font-medium tabular-nums ${row.ltGain < 0 ? 'text-red-600' : row.ltGain > 0 ? 'text-green-700' : 'text-gray-400'}`}>
													{row.ltLots > 0 ? fmtGain(row.ltGain) : <span class="text-gray-300">—</span>}
												</td>
												<td class="px-5 py-3 text-right text-gray-500 tabular-nums">
													{row.ltLots > 0 ? row.ltLots : <span class="text-gray-300">—</span>}
												</td>
												<td class={`px-5 py-3 text-right font-semibold tabular-nums ${row.netGain < 0 ? 'text-red-600' : row.netGain > 0 ? 'text-green-700' : 'text-gray-400'}`}>
													{fmtGain(row.netGain)}
												</td>
											</tr>

											<!-- Drill-down row (hidden by default) -->
											{hasLots && (
												<tr id={rowId} class="lot-detail-row hidden bg-indigo-50/40">
													<td colspan={7} class="px-0 py-0">
														<!-- Sub-table header + CSV export -->
														<div class="flex items-center justify-between px-6 pt-3 pb-1.5">
															<span class="text-xs font-semibold text-indigo-700 uppercase tracking-wide">
																{t.assetDisposals(row.asset, lots.length)}
															</span>
															<button class="csv-export-btn text-xs text-indigo-500 hover:text-indigo-700 font-medium
															               border border-indigo-200 hover:border-indigo-400 rounded px-2 py-0.5
															               transition-colors"
															        data-asset={row.asset}>
																{t.csvBtn}
															</button>
														</div>
														<!-- Individual lot table -->
														<div class="overflow-x-auto">
															<table class="min-w-full text-xs border-t border-indigo-100">
																<thead>
																	<tr class="bg-indigo-50 text-indigo-600">
																		<th class="px-6 py-2 text-left font-medium uppercase tracking-wide">{t.lotColSold}</th>
																		<th class="px-4 py-2 text-right font-medium uppercase tracking-wide">{t.lotColQty}</th>
																		<th class="px-4 py-2 text-left font-medium uppercase tracking-wide">{t.lotColAcquired}</th>
																		<th class="px-4 py-2 text-right font-medium uppercase tracking-wide">{t.lotColHeld}</th>
																		<th class="px-4 py-2 text-right font-medium uppercase tracking-wide">{t.lotColProceeds}</th>
																		<th class="px-4 py-2 text-right font-medium uppercase tracking-wide">{t.lotColCostBasis}</th>
																		<th class="px-4 py-2 text-right font-medium uppercase tracking-wide">{t.lotColGainLoss}</th>
																		<th class="px-4 py-2 text-center font-medium uppercase tracking-wide">{t.lotColTerm}</th>
																	</tr>
																</thead>
																<tbody class="divide-y divide-indigo-100/60">
																	{lots.map((lot) => (
																		<tr class="hover:bg-indigo-50/60">
