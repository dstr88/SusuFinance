	ctxNone:                 t.ctxNone,
	diagPipelineNotRunStrong: t.diagPipelineNotRunStrong,
	diagPipelineNotRunText:  t.diagPipelineNotRunText,
	diagNoBuyStrong:         t.diagNoBuyStrong,
	diagNoBuyConnector:      t.diagNoBuyConnector,
	diagNoBuyTail:           t.diagNoBuyTail,
