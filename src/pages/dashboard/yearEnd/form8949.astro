	ctxCoinPlural:           t.ctxCoinPlural,
	ctxHasSingular:          t.ctxHasSingular,
	ctxHavePlural:           t.ctxHavePlural,
	ctxTxSingular:           t.ctxTxSingular,
	ctxTxPlural:             t.ctxTxPlural,
