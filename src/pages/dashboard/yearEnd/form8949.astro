	diagNoFoundStrong: 'No transactions found for {year}',
	diagNoFoundTail: ' — nothing has been imported for this year yet',
	importBtnLabel: '📥 Import Transactions — add data for {year}',
	pipelineAfterImport: '⚙️ Run Pipeline — after importing',
	pipelineClassify: '⚙️ Run Pipeline — classify transactions for {year}',
	pipelineRerunMissing: '⚙️ Re-run Pipeline — after adding missing records',
	pipelineRerunPrices: '⚙️ Re-run Pipeline — after fixing missing prices',
	reviewNoBuy: '🔍 Review Queue — find the missing buys for {n} sell{s}',
	reviewNoBasis: '🔍 Review Queue — enter purchase prices for {n} lot{s}',
	rowCountSingular: 'transaction', rowCountPlural: 'transactions · See Schedule D for totals',
	chipNoBuy: '⚠ no purchase record', chipNoPrice: '⚠ missing price',
	irsHeaderBadge: 'Informational summary — not for filing',
	irsHeaderTitle: 'Capital Gains Summary',
	irsHeaderDesc: 'Realized gains and losses, formatted to mirror IRS Form 8949 for reference',
	irsHeaderDisclaimer: 'Not a tax filing or tax advice — confirm with your tax professional',
	irsHeaderTaxYear: 'Tax Year:', irsHeaderMethod: 'Method:',
	irsHeaderPreparedBy: 'Prepared by Almstins — not an IRS-issued form',
	boxNoteTemplate: 'Note: Crypto transactions are reported in Box {box} ("all other") because exchanges were not required to issue 1099-B for these transactions.',
	totalsPrefix: 'Totals (Box {box})',
};

const USD = (n: number) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2 }).format(n);
const fmtGain = (n: number) => { const abs = USD(Math.abs(n)); return n < 0 ? `(${abs})` : n > 0 ? `+${abs}` : abs; };

interface Form8949Row {
	description: string;
	dateAcquired: string;
	dateSold: string;
	proceeds: number;
	costBasis: number;
	codes: string;
	adjustment: number;
	gainLoss: number;
	daysHeld: number;
}
interface Form8949Box {
	box: string;
	label: string;
	part: 'I' | 'II';
	term: string;
	rows: Form8949Row[];
	totals: { proceeds: number; basis: number; gainLoss: number };
}

let currentData: { year: number; method: string; boxes: Record<string, Form8949Box>; totals: { proceeds: number; basis: number; gainLoss: number } } | null = null;

async function loadForm8949() {
	const yearSel   = (document.getElementById('year-sel')   as HTMLSelectElement).value;
	const methodSel = (document.getElementById('method-sel') as HTMLSelectElement).value;

	const stLoading = document.getElementById('state-loading')!;
	const stError   = document.getElementById('state-error')!;
	const stEmpty   = document.getElementById('state-empty')!;
	const formOut   = document.getElementById('form-output')!;

	stLoading.classList.remove('hidden');
	stError.classList.add('hidden');
	stEmpty.classList.add('hidden');
	formOut.classList.add('hidden');

	// Update URL without reload
	const url = new URL(window.location.href);
	url.searchParams.set('year', yearSel);
	url.searchParams.set('method', methodSel);
	history.replaceState(null, '', url);

	try {
		const res = await fetch(`/api/yearEnd/form8949?year=${yearSel}&method=${methodSel}`);
		if (!res.ok) throw new Error(`HTTP ${res.status}`);
		const data = await res.json() as { ok: boolean; error?: string; year: number; method: string; boxes: Record<string, Form8949Box>; totals: { proceeds: number; basis: number; gainLoss: number } };

		stLoading.classList.add('hidden');

		if (!data.ok) {
			stError.textContent = data.error ?? I18N.errLoadFailed;
			stError.classList.remove('hidden');
			return;
		}

		// Check ALL boxes (A-F), not just C and F
		const totalRows = Object.values(data.boxes ?? {}).reduce((sum, b) => sum + (b.rows?.length ?? 0), 0);
		const hasData = totalRows > 0;

		if (!hasData) {
			stEmpty.classList.remove('hidden');
			await populateDiagnostics(yearSel, methodSel, data.totals);
			return;
		}

		currentData = data;
		renderForm(data);
		formOut.classList.remove('hidden');
		document.getElementById('btn-csv')!.classList.remove('hidden');
		document.getElementById('btn-turbotax')!.classList.remove('hidden');
		document.getElementById('btn-print')!.classList.remove('hidden');

	} catch (err) {
		stLoading.classList.add('hidden');
		stError.textContent = I18N.errNetwork;
		stError.classList.remove('hidden');
	}
}

function renderForm(data: NonNullable<typeof currentData>) {
	// Summary
	(document.getElementById('sum-proceeds') as HTMLElement).textContent = USD(data.totals.proceeds);
	(document.getElementById('sum-basis')    as HTMLElement).textContent = USD(data.totals.basis);
	const gainEl = document.getElementById('sum-gain')!;
	gainEl.textContent  = fmtGain(data.totals.gainLoss);
	gainEl.className    = `f8-card__value ${data.totals.gainLoss >= 0 ? 'f8-gain--positive' : 'f8-gain--negative'}`;

	// BO warning — check all boxes
	const allRows = Object.values(data.boxes ?? {}).flatMap(b => b.rows ?? []);
	const hasBO = allRows.some(r => r.codes.includes('B') || r.codes.includes('BO'));
	if (hasBO) document.getElementById('bo-warning')!.classList.remove('hidden');

	// Render form pages — one page per Part (I = short-term, II = long-term)
	const pagesEl = document.getElementById('form-pages')!;
	pagesEl.innerHTML = '';

	// Build parts from whichever boxes actually have rows
	const shortTermBoxes = ['A', 'B', 'C'].filter(b => (data.boxes[b]?.rows?.length ?? 0) > 0);
	const longTermBoxes  = ['D', 'E', 'F'].filter(b => (data.boxes[b]?.rows?.length ?? 0) > 0);

	// Merge rows and totals across all populated boxes within each part
	function mergeBoxes(boxes: string[]) {
		const rows: Form8949Row[] = boxes.flatMap(b => data.boxes[b]?.rows ?? []);
		const totals = boxes.reduce((acc, b) => {
			const t = data.boxes[b]?.totals ?? { proceeds: 0, basis: 0, gainLoss: 0 };
			return { proceeds: acc.proceeds + t.proceeds, basis: acc.basis + t.basis, gainLoss: acc.gainLoss + t.gainLoss };
		}, { proceeds: 0, basis: 0, gainLoss: 0 });
		// Use the highest box letter as the "active" box label
		const activeBox = boxes[boxes.length - 1] ?? '';
		return { rows, totals, activeBox };
	}

	const parts: Array<{ part: 'I' | 'II'; label: string; activeBox: string; allBoxes: string[]; rows: Form8949Row[]; totals: { proceeds: number; basis: number; gainLoss: number } }> = [
		{
			part: 'I', label: 'Part I — Short-Term Capital Gains and Losses',
			allBoxes: ['A', 'B', 'C'],
			...mergeBoxes(shortTermBoxes.length > 0 ? shortTermBoxes : ['C']),
		},
		{
			part: 'II', label: 'Part II — Long-Term Capital Gains and Losses',
			allBoxes: ['D', 'E', 'F'],
			...mergeBoxes(longTermBoxes.length > 0 ? longTermBoxes : ['F']),
		},
	];

	const boxDescriptions: Record<string, string> = {
		A: '(A) Basis reported to IRS on 1099-B',
		B: '(B) Basis NOT reported to IRS on 1099-B',
		C: '(C) Not reported to you on 1099-B or Form 1099-B not received',
		D: '(D) Basis reported to IRS on 1099-B',
		E: '(E) Basis NOT reported to IRS on 1099-B',
		F: '(F) Not reported to you on 1099-B or Form 1099-B not received',
	};

	for (const p of parts) {
		if (p.rows.length === 0) continue;

		const page = document.createElement('div');
		page.className = 'form-page';

		// IRS header
		const header = document.createElement('div');
		header.className = 'irs-header';
		header.innerHTML = `
			<div style="display:flex; justify-content:space-between; align-items:flex-start; gap:1.5rem;">
				<div>
					<p style="font-size:0.7rem; font-weight:600; letter-spacing:0.07em; text-transform:uppercase; color:#9ca3af; margin:0 0 4px;">${I18N.irsHeaderBadge}</p>
					<p style="font-size:1.25rem; font-weight:800; color:#111827; margin:0 0 2px;">${I18N.irsHeaderTitle}</p>
					<p style="font-size:0.8rem; color:#374151; margin:0 0 2px;">${I18N.irsHeaderDesc}</p>
					<p style="font-size:0.75rem; color:#6b7280; margin:0;">${I18N.irsHeaderDisclaimer}</p>
				</div>
				<div style="text-align:right; font-size:0.8rem; color:#374151; white-space:nowrap;">
					<p style="margin:0 0 3px;"><strong>${I18N.irsHeaderTaxYear}</strong> ${data.year}</p>
					<p style="margin:0 0 6px;"><strong>${I18N.irsHeaderMethod}</strong> ${data.method.toUpperCase()}</p>
					<p style="margin:0; font-size:0.7rem; color:#9ca3af;">${I18N.irsHeaderPreparedBy}</p>
				</div>
			</div>
		`;
		page.appendChild(header);

		// Part label
		const partLabel = document.createElement('p');
		partLabel.className = 'part-label';
		partLabel.textContent = p.label;
		page.appendChild(partLabel);

		// Box checkboxes
		const boxRow = document.createElement('div');
		boxRow.className = 'box-row';
		for (const b of p.allBoxes) {
			const checked = b === p.activeBox;
			boxRow.innerHTML += `
				<label>
					<span class="checkbox ${checked ? 'checked' : ''}">${checked ? '✓' : ''}</span>
					${boxDescriptions[b]}
				</label>
			`;
		}
		page.appendChild(boxRow);

		// Note about Box C/F for crypto
		const note = document.createElement('p');
		note.style.cssText = 'font-size:0.75rem; color:#6b7280; line-height:1.6; margin:0 0 1.5rem; padding:0.6rem 0.875rem; background:#f9fafb; border-left:3px solid #d1d5db; border-radius:0 4px 4px 0;';
		note.textContent = I18N.boxNoteTemplate.replace('{box}', p.activeBox);
		page.appendChild(note);

		// Table
		const table = document.createElement('table');
		table.innerHTML = `
			<thead>
				<tr>
					<th style="width:18%">(a) Description</th>
					<th style="width:9%">(b) Date Acquired</th>
					<th style="width:9%">(c) Date Sold</th>
					<th style="width:10%; text-align:right">(d) Proceeds</th>
					<th style="width:10%; text-align:right">(e) Cost Basis</th>
					<th style="width:5%; text-align:center">(f) Codes</th>
					<th style="width:8%; text-align:right">(g) Adjustment</th>
					<th style="width:11%; text-align:right">(h) Gain / (Loss)</th>
				</tr>
			</thead>
			<tbody id="tbody-${p.part}"></tbody>
			<tfoot>
				<tr class="totals-row">
					<td colspan="3" style="font-weight:700">${I18N.totalsPrefix.replace('{box}', p.activeBox)}</td>
					<td style="text-align:right">${USD(p.totals.proceeds)}</td>
					<td style="text-align:right">${USD(p.totals.basis)}</td>
					<td></td>
					<td></td>
					<td style="text-align:right">${fmtGain(p.totals.gainLoss)}</td>
				</tr>
			</tfoot>
		`;
		page.appendChild(table);

		const tbody = table.querySelector(`#tbody-${p.part}`)!;
		for (const row of p.rows) {
			const tr = document.createElement('tr');
			const gainClass = row.gainLoss < 0 ? 'color:#dc2626' : row.gainLoss > 0 ? 'color:#059669' : '';
			tr.innerHTML = `
				<td>${row.description}</td>
				<td>${row.dateAcquired}</td>
				<td>${row.dateSold}</td>
				<td style="text-align:right; font-variant-numeric:tabular-nums">${USD(row.proceeds)}</td>
				<td style="text-align:right; font-variant-numeric:tabular-nums">${USD(row.costBasis)}</td>
				<td style="text-align:center; color:#92400e">${row.codes || ''}</td>
				<td style="text-align:right">${row.adjustment !== 0 ? USD(row.adjustment) : '—'}</td>
				<td style="text-align:right; font-variant-numeric:tabular-nums; font-weight:500; ${gainClass}">${fmtGain(row.gainLoss)}</td>
			`;
			tbody.appendChild(tr);
		}

		// Row count note
		const countNote = document.createElement('p');
		countNote.style.cssText = 'font-size:0.75rem; color:#9ca3af; margin:10px 0 0; text-align:right; letter-spacing:0.01em;';
		countNote.textContent = `${p.rows.length.toLocaleString()} ${p.rows.length !== 1 ? I18N.rowCountPlural : I18N.rowCountSingular}`;
		page.appendChild(countNote);

		pagesEl.appendChild(page);
	}
}

// ── Diagnostic enrichment for empty state ────────────────────────────────────
async function populateDiagnostics(year: string, method: string, _totals: { proceeds: number; basis: number; gainLoss: number }) {
	const ctxEl         = document.getElementById('empty-context')!;
	const diagPipeline  = document.getElementById('diag-pipeline')!;
	const diagMissingBuy = document.getElementById('diag-missing-buy')!;
	const diagNoData    = document.getElementById('diag-no-data')!;
	const emptyTokens   = document.getElementById('empty-tokens')!;
	const tokensList    = document.getElementById('empty-tokens-list')!;
	const actionsEl     = document.querySelector('.empty-state__actions')!;

	try {
		const res = await fetch(`/api/yearEnd/summary?year=${year}&method=${method}`);
		if (!res.ok) return;
		const summary = await res.json() as {
			ok: boolean;
			gains?: { dataSource?: string };
			disposals?: { count?: number };
			lastPipelineRun?: { status?: string; completedAt?: string | null } | null;
			missingBasis?: Array<{ asset: string; date: string; qty: number; proceeds: number | null; issue: 'no_cost_basis' | 'no_matching_buy' }>;
		};
		if (!summary.ok) return;

		const missingBasis   = summary.missingBasis   ?? [];
		const disposalCount  = summary.disposals?.count ?? 0;
		const dataSource     = summary.gains?.dataSource ?? 'lifecycle';
		const lastRun        = summary.lastPipelineRun ?? null;

		const pipelineRan  = lastRun !== null && dataSource === 'pipeline';
		const hasNoImports = disposalCount === 0 && missingBasis.length === 0;

		// ── Group issues by asset ────────────────────────────────────────────
		const assetIssues = new Map<string, { noBuy: number; noBasis: number }>();
		for (const item of missingBasis) {
			if (!assetIssues.has(item.asset)) assetIssues.set(item.asset, { noBuy: 0, noBasis: 0 });
			const entry = assetIssues.get(item.asset)!;
			if (item.issue === 'no_matching_buy') entry.noBuy++;
			else entry.noBasis++;
		}
		const affectedAssets = Array.from(assetIssues.keys());
		const totalMissing   = missingBasis.length;
		const totalNoBuy     = missingBasis.filter(m => m.issue === 'no_matching_buy').length;
		const totalNoBasis   = missingBasis.filter(m => m.issue === 'no_cost_basis').length;

		// ── Update headline context ──────────────────────────────────────────
		if (hasNoImports) {
			ctxEl.textContent = I18N.ctxNoImports.replace('{year}', year);
		} else if (!pipelineRan) {
			ctxEl.textContent = I18N.ctxPipelineNotRun.replace('{year}', year);
		} else if (affectedAssets.length > 0) {
			const named = affectedAssets.slice(0, 4).join(', ') + (affectedAssets.length > 4 ? ` +${affectedAssets.length - 4} more` : '');
			const coinWord  = affectedAssets.length === 1 ? I18N.ctxCoinSingular : I18N.ctxCoinPlural;
			const haveWord  = affectedAssets.length === 1 ? I18N.ctxHasSingular  : I18N.ctxHavePlural;
			const txWord    = totalMissing   === 1 ? I18N.ctxTxSingular    : I18N.ctxTxPlural;
			ctxEl.textContent = `${affectedAssets.length}${coinWord} (${named}) ${haveWord} ${totalMissing} ${txWord}. ${I18N.ctxMustFix}`;
		} else {
			ctxEl.textContent = I18N.ctxNone.replace('{year}', year);
		}

		// ── Highlight the relevant diagnostic bullet, dim the others ────────
		const dim  = (el: HTMLElement) => { el.style.opacity = '0.38'; el.style.textDecoration = 'none'; };
		const show = (el: HTMLElement) => { el.style.opacity = '1'; };

		if (hasNoImports) {
			dim(diagPipeline); dim(diagMissingBuy); show(diagNoData);
			diagNoData.innerHTML = `<strong>${I18N.diagNoFoundStrong.replace('{year}', year)}</strong>${I18N.diagNoFoundTail}`;
		} else if (!pipelineRan) {
			show(diagPipeline); dim(diagMissingBuy); dim(diagNoData);
			diagPipeline.innerHTML = `<strong>${I18N.diagPipelineNotRunStrong}</strong>${I18N.diagPipelineNotRunText.replace('{year}', year)}`;
		} else if (totalNoBuy > 0) {
			dim(diagPipeline); show(diagMissingBuy); dim(diagNoData);
			const coinList = affectedAssets.filter(a => (assetIssues.get(a)?.noBuy ?? 0) > 0).slice(0, 3).join(', ');
			const strong = I18N.diagNoBuyStrong.replace('{n}', String(totalNoBuy)).replace('{s}', totalNoBuy === 1 ? '' : 's');
			diagMissingBuy.innerHTML = `<strong>${strong}</strong>${I18N.diagNoBuyConnector}${coinList}${I18N.diagNoBuyTail}`;
		} else if (totalNoBasis > 0) {
			dim(diagPipeline); show(diagMissingBuy); dim(diagNoData);
			const coinList = affectedAssets.slice(0, 3).join(', ');
			const strong = I18N.diagNoBasisStrong.replace('{n}', String(totalNoBasis)).replace('{s}', totalNoBasis === 1 ? '' : 's');
			diagMissingBuy.innerHTML = `<strong>${strong}</strong>${I18N.diagNoBasisConnector}${coinList}${I18N.diagNoBasisTail}`;
		} else {
			dim(diagPipeline); dim(diagMissingBuy); show(diagNoData);
			diagNoData.innerHTML = `<strong>${I18N.diagNoDisposalsStrong.replace('{year}', year)}</strong>${I18N.diagNoDisposalsTail}`;
		}

		// ── Coin chips ───────────────────────────────────────────────────────
		if (affectedAssets.length > 0) {
			tokensList.innerHTML = '';
			for (const asset of affectedAssets) {
				const info     = assetIssues.get(asset)!;
				const hasNoBuy = info.noBuy > 0;
				const count    = info.noBuy + info.noBasis;
				const chip     = document.createElement('span');
				chip.className = `asset-chip asset-chip--${hasNoBuy ? 'no-buy' : 'no-basis'}`;
				chip.innerHTML =
					`<strong>${asset}</strong>` +
					`<span class="chip-badge">${hasNoBuy ? I18N.chipNoBuy : I18N.chipNoPrice}</span>` +
					(count > 1 ? `<span class="chip-count">×${count}</span>` : '');
				tokensList.appendChild(chip);
			}
			emptyTokens.classList.remove('hidden');
		}

		// ── Action buttons — reorder and relabel based on what's actually wrong ─
		const buttons  = Array.from(actionsEl.querySelectorAll<HTMLAnchorElement>('.es-btn'));
		const [reviewBtn, importBtn, pipelineBtn] = buttons;

		if (hasNoImports) {
			if (importBtn)   { importBtn.innerHTML   = I18N.importBtnLabel.replace('{year}', year); importBtn.className   = 'es-btn es-btn--primary'; }
			if (reviewBtn)   { reviewBtn.className   = 'es-btn es-btn--secondary'; }
			if (pipelineBtn) { pipelineBtn.innerHTML = I18N.pipelineAfterImport; pipelineBtn.className = 'es-btn es-btn--secondary'; }
		} else if (!pipelineRan) {
			if (pipelineBtn) { pipelineBtn.innerHTML = I18N.pipelineClassify.replace('{year}', year); pipelineBtn.className = 'es-btn es-btn--primary'; }
			if (reviewBtn)   { reviewBtn.className   = 'es-btn es-btn--secondary'; }
			if (importBtn)   { importBtn.className   = 'es-btn es-btn--secondary'; }
		} else if (totalNoBuy > 0) {
			if (reviewBtn)   { reviewBtn.innerHTML   = I18N.reviewNoBuy.replace('{n}', String(totalNoBuy)).replace('{s}', totalNoBuy === 1 ? '' : 's'); reviewBtn.className = 'es-btn es-btn--primary'; }
			if (pipelineBtn) { pipelineBtn.innerHTML = I18N.pipelineRerunMissing; pipelineBtn.className = 'es-btn es-btn--secondary'; }
			if (importBtn)   { importBtn.className   = 'es-btn es-btn--secondary'; }
		} else if (totalNoBasis > 0) {
			if (reviewBtn)   { reviewBtn.innerHTML   = I18N.reviewNoBasis.replace('{n}', String(totalNoBasis)).replace('{s}', totalNoBasis === 1 ? '' : 's'); reviewBtn.className = 'es-btn es-btn--primary'; }
			if (pipelineBtn) { pipelineBtn.innerHTML = I18N.pipelineRerunPrices; pipelineBtn.className = 'es-btn es-btn--secondary'; }
			if (importBtn)   { importBtn.className   = 'es-btn es-btn--secondary'; }
		}

	} catch (e) {
		console.warn('[form8949] populateDiagnostics failed:', e);
	}
}

// ── CSV export ────────────────────────────────────────────────────────────────
document.getElementById('btn-csv')?.addEventListener('click', () => {
	if (!currentData) return;
	const allRows: Array<{ box: string } & Form8949Row> = [];
	for (const [box, b] of Object.entries(currentData.boxes)) {
		for (const r of b.rows) allRows.push({ box, ...r });
	}
	const header = ['Box','Description','Date Acquired','Date Sold','Proceeds','Cost Basis','Codes','Adjustment','Gain/(Loss)','Days Held'];
	const lines = [
		header.join(','),
		...allRows.map(r => [
			r.box,
			`"${r.description}"`,
			r.dateAcquired,
			r.dateSold,
			r.proceeds.toFixed(2),
			r.costBasis.toFixed(2),
			r.codes,
			r.adjustment.toFixed(2),
			r.gainLoss.toFixed(2),
			r.daysHeld,
		].join(',')),
	];
	const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
	const a = document.createElement('a');
	a.href = URL.createObjectURL(blob);
	a.download = `form8949_${currentData.year}_${currentData.method}.csv`;
	a.click();
});

// ── TurboTax CSV export ───────────────────────────────────────────────────────
document.getElementById('btn-turbotax')?.addEventListener('click', () => {
	if (!currentData) return;
	const year = (document.getElementById('year-sel') as HTMLSelectElement).value;
	const a = document.createElement('a');
	a.href = `/api/yearEnd/breakdown-csv?section=turbotax&year=${year}`;
	a.download = `turbotax-form8949-${year}.csv`;
	a.click();
});

// ── Print ─────────────────────────────────────────────────────────────────────
document.getElementById('btn-print')?.addEventListener('click', () => window.print());

// ── Load on demand ────────────────────────────────────────────────────────────
document.getElementById('btn-load')?.addEventListener('click', loadForm8949);
document.getElementById('year-sel')?.addEventListener('change', loadForm8949);
document.getElementById('method-sel')?.addEventListener('change', loadForm8949);

// Keep "Open Review Queue" link in sync with the selected year
function syncReviewLink() {
	const year = (document.getElementById('year-sel') as HTMLSelectElement)?.value;
	const link = document.getElementById('btn-review-queue') as HTMLAnchorElement | null;
	if (link && year) link.href = `/dashboard/yearEnd/review?year=${year}`;
}
document.getElementById('year-sel')?.addEventListener('change', syncReviewLink);
syncReviewLink();

// Auto-load on page open
loadForm8949();
</script>
