---
/**
 * /dashboard/yearEnd/form8949
 *
 * Printable IRS Form 8949 — Sales and Other Dispositions of Capital Assets.
 * Data is fetched client-side so the page can render immediately and the
 * user can switch year/method without a full page reload.
 *
 * Print button opens browser print dialog. CSS @media print hides all chrome.
 */
import Layout from '../../../layouts/Layout.astro';
import TaxNotice from '@/components/TaxNotice.astro';
import { requireTenantSession } from '@/lib/requireTenantSession';
import { getLang } from '@/lib/i18n/locale';
import { getForm8949 } from '@/i18n/dashboard/yearEnd/form8949';

import { hasTaxAccess } from '@/lib/taxAuth';
import { isOwner } from '@/lib/owner';

if (!(await hasTaxAccess(Astro.request))) return Astro.redirect('/tax-login', 302);

const lang = getLang(Astro.request);
const t = getForm8949(lang);

const _authSess = await requireTenantSession(Astro.request);
if (!_authSess) return Astro.redirect('/login');
const showTurboTax = isOwner(_authSess.tenantId);

const currentYear = new Date().getFullYear();
const defaultYear = currentYear - 1;
const yearParam   = Astro.url.searchParams.get('year');
const initialYear = yearParam ? Number(yearParam) : defaultYear;
const methodParam = Astro.url.searchParams.get('method') ?? 'fifo';
---

<Layout title={t.pageTitle} noindex={true}>
	<div id="app">

		<!-- Screen-only header -->
		<div class="f8-header">
			<div class="f8-header__left">
				<a href="/dashboard/yearEnd" class="f8-back">{t.backLink}</a>
				<h1 class="f8-title">{t.heroTitle}</h1>
				<p class="f8-subtitle">{t.heroSubtitle}</p>
			</div>
			<div class="f8-controls">
				<!-- Year + method selectors -->
				<select id="year-sel" class="f8-select">
					{Array.from({ length: 8 }, (_, i) => currentYear - 1 - i).map(y => (
						<option value={y} selected={y === initialYear}>{y}</option>
					))}
				</select>
				<select id="method-sel" class="f8-select">
					<option value="fifo"    selected={methodParam === 'fifo'}>FIFO</option>
					<option value="hifo"    selected={methodParam === 'hifo'}>HIFO</option>
					<option value="lifo"    selected={methodParam === 'lifo'}>LIFO</option>
					<option value="spec_id" selected={methodParam === 'spec_id'}>Spec ID</option>
				</select>
				<button id="btn-load" class="f8-btn f8-btn--primary">{t.btnLoad}</button>
				<button id="btn-csv"  class="f8-btn f8-btn--ghost hidden">{t.btnCsv}</button>
				{showTurboTax && <button id="btn-turbotax" class="f8-btn f8-btn--turbotax hidden">↓ TurboTax</button>}
				<button id="btn-print" class="f8-btn f8-btn--dark hidden">{t.btnPrint}</button>
			</div>
		</div>

		<TaxNotice />

		<!-- Loading/error/empty states -->
		<div id="state-loading" class="f8-state-loading">
			<div class="f8-spinner"></div>
			<p>{t.stateLoading}</p>
		</div>
		<div id="state-error" class="f8-state-error hidden"></div>
		<div id="state-empty" class="hidden empty-state">
			<div class="empty-state__header">
				<span class="empty-state__icon">⚠️</span>
				<div>
					<p class="empty-state__title">{t.emptyTitle}</p>
					<p class="empty-state__context" id="empty-context">{t.emptyContext}</p>
				</div>
			</div>

			<div class="empty-state__section">
				<p class="empty-state__label">{t.emptyWhatLabel}</p>
				<ul class="empty-state__list">
					<li id="diag-pipeline"><strong>{t.diagPipelineStrong}</strong>{t.diagPipelineText}</li>
					<li id="diag-missing-buy">{t.diagMissingBuyText}</li>
					<li id="diag-no-data">{t.diagNoDataText}</li>
				</ul>
			</div>

			<div id="empty-tokens" class="empty-state__section hidden">
				<p class="empty-state__label">{t.emptyTokensLabel}</p>
				<div id="empty-tokens-list" class="empty-state__chips"></div>
			</div>

			<div class="empty-state__actions" id="empty-actions">
				<a href="/dashboard/yearEnd/review" class="es-btn es-btn--primary" id="btn-review-queue">{t.btnReviewQueue}</a>
				<a href="/dashboard/bookkeeping" class="es-btn es-btn--secondary">{t.btnImport}</a>
				<a href="/dashboard/yearEnd" class="es-btn es-btn--secondary" id="btn-pipeline">{t.btnPipeline}</a>
			</div>
		</div>

		<!-- Form output — screen summary cards + printable pages -->
		<div id="form-output" class="hidden f8-form-output">

			<!-- Screen-only summary -->
			<div id="summary-cards" class="f8-summary-cards">
				<div class="f8-card">
					<p class="f8-card__label">{t.cardProceeds}</p>
					<p id="sum-proceeds" class="f8-card__value"></p>
				</div>
				<div class="f8-card">
					<p class="f8-card__label">{t.cardBasis}</p>
					<p id="sum-basis" class="f8-card__value"></p>
				</div>
				<div class="f8-card">
					<p class="f8-card__label">{t.cardNetGain}</p>
					<p id="sum-gain" class="f8-card__value"></p>
				</div>
			</div>

			<!-- BO warning -->
			<div id="bo-warning" class="f8-bo-warning hidden">
				{t.boWarningText} <a href="/dashboard/yearEnd/review" class="f8-link">{t.boWarningLinkText}</a>{t.boWarningTail}
			</div>

			<!-- Form pages container — one page per part -->
			<div id="form-pages"></div>

		</div>

	</div>
</Layout>

<style>
/* ── Global safety nets ────────────────────────────────────────────────────── */
.hidden { display: none !important; }

/* ── Page layout ───────────────────────────────────────────────────────────── */
#app {
	width: 100%;
	max-width: 72rem;
	margin: 0 auto;
	padding: 2rem 2.5rem;
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

@media (max-width: 640px) {
	#app { padding: 1.5rem 1rem; }
}

@media print {
	#app { max-width: none; padding: 0; }
}

/* ── Screen-only header ────────────────────────────────────────────────────── */
.f8-header {
	display: flex;
	align-items: flex-start;
	justify-content: space-between;
	flex-wrap: wrap;
	gap: 1rem;
}
@media print { .f8-header { display: none; } }

.f8-back {
	display: inline-block;
	font-size: .75rem;
	font-weight: 500;
	color: #6366f1;
	text-decoration: none;
	margin-bottom: .3rem;
}
.f8-back:hover { color: #818cf8; }

.f8-title { font-size: 1.5rem; font-weight: 700; color: #fff; margin: 0; }
.f8-subtitle { font-size: .875rem; color: #9ca3af; margin: .25rem 0 0; }

.f8-controls {
	display: flex;
	align-items: center;
	gap: .6rem;
	flex-wrap: wrap;
}

.f8-select {
	background: rgba(255,255,255,.05);
	border: 1px solid rgba(255,255,255,.12);
	border-radius: 8px;
	color: #e5e7eb;
	font-size: .875rem;
	padding: .45rem .75rem;
	outline: none;
	cursor: pointer;
	transition: border-color .15s;
}
.f8-select:focus { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,.2); }
.f8-select option { background: #1a1f2e; color: #e5e7eb; }

.f8-btn {
	border-radius: 8px;
	font-size: .875rem;
	font-weight: 500;
	padding: .45rem 1rem;
	cursor: pointer;
	border: 1px solid transparent;
	transition: background .15s;
	white-space: nowrap;
}
.f8-btn--primary { background: #4f46e5; color: #fff; }
.f8-btn--primary:hover { background: #4338ca; }
.f8-btn--ghost { background: rgba(255,255,255,.05); color: #d1d5db; border-color: rgba(255,255,255,.1); }
.f8-btn--ghost:hover { background: rgba(255,255,255,.09); }
.f8-btn--dark { background: #1f2937; color: #fff; }
.f8-btn--dark:hover { background: #111827; }
.f8-btn--turbotax { background: #0077b6; color: #fff; border-color: #0077b6; }
.f8-btn--turbotax:hover { background: #005f94; }

/* ── Loading state ─────────────────────────────────────────────────────────── */
.f8-state-loading {
	text-align: center;
	padding: 4rem 0;
	color: #6b7280;
	font-size: .875rem;
}
@media print { .f8-state-loading { display: none; } }

.f8-spinner {
	display: block;
	width: 1.5rem;
	height: 1.5rem;
	border: 2px solid rgba(255,255,255,.1);
	border-top-color: #6366f1;
	border-radius: 50%;
	animation: f8spin .7s linear infinite;
	margin: 0 auto .75rem;
}
@keyframes f8spin { to { transform: rotate(360deg); } }

/* ── Error state ───────────────────────────────────────────────────────────── */
.f8-state-error {
	border: 1px solid rgba(239,68,68,.25);
	background: rgba(239,68,68,.07);
	border-radius: 12px;
	padding: 1.25rem 1.5rem;
	color: #fca5a5;
	font-size: .875rem;
}
@media print { .f8-state-error { display: none; } }

/* ── Summary cards ─────────────────────────────────────────────────────────── */
.f8-form-output {
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}
.f8-summary-cards {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 1rem;
}
@media (max-width: 640px) { .f8-summary-cards { grid-template-columns: 1fr; } }
@media print { .f8-summary-cards { display: none; } }

.f8-card {
	background: #161b27;
	border: 1px solid rgba(255,255,255,.07);
	border-radius: 12px;
	padding: 1rem 1.25rem;
}
.f8-card__label {
	font-size: .7rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: .07em;
	color: #6b7280;
	margin: 0 0 .3rem;
}
.f8-card__value {
	font-size: 1.25rem;
	font-weight: 700;
	color: #fff;
	margin: 0;
}
.f8-gain--positive { color: #34d399 !important; }
.f8-gain--negative { color: #f87171 !important; }

/* ── BO warning ────────────────────────────────────────────────────────────── */
.f8-bo-warning {
	border: 1px solid rgba(251,191,36,.2);
	background: rgba(251,191,36,.07);
	border-radius: 10px;
	padding: 1rem 1.25rem;
	font-size: .875rem;
	color: #fde68a;
	line-height: 1.6;
}
@media print { .f8-bo-warning { display: none; } }
.f8-link { color: #818cf8; text-decoration: underline; }
.f8-link:hover { color: #a5b4fc; }

/* ── Empty / diagnostic state ──────────────────────────────────────────────── */
.empty-state {
	border: 1px solid rgba(251,191,36,.35);
	border-left: 4px solid #f59e0b;
	background: rgba(251,191,36,.07);
	border-radius: 12px;
	padding: 1.5rem;
	display: flex;
	flex-direction: column;
	gap: 1.25rem;
}

.empty-state__header {
	display: flex;
	align-items: flex-start;
	gap: .75rem;
}

.empty-state__icon { font-size: 1.4rem; flex-shrink: 0; margin-top: .1rem; }

.empty-state__title {
	font-size: 1rem;
	font-weight: 700;
	color: #fde68a;
	margin: 0 0 .35rem;
}

.empty-state__context {
	font-size: .875rem;
	color: rgba(255,255,255,.65);
	margin: 0;
	line-height: 1.6;
}

.empty-state__section {
	border-top: 1px solid rgba(251,191,36,.2);
	padding-top: 1rem;
}

.empty-state__label {
	font-size: .7rem;
	font-weight: 700;
	text-transform: uppercase;
	letter-spacing: .08em;
	color: #fbbf24;
	margin: 0 0 .6rem;
}

.empty-state__list {
	font-size: .875rem;
	color: rgba(255,255,255,.7);
	margin: 0;
	padding-left: 1.4rem;
	line-height: 2;
}

.empty-state__list strong { color: #fef3c7; }

.empty-state__chips {
	display: flex;
	flex-wrap: wrap;
	gap: .5rem;
}

.asset-chip {
	display: inline-flex;
	align-items: center;
	gap: .35rem;
	padding: .28rem .65rem;
	border-radius: 6px;
	font-size: .8rem;
	font-weight: 500;
	border: 1px solid;
	line-height: 1.4;
}
.asset-chip--no-buy {
	background: rgba(239,68,68,.12);
	border-color: rgba(239,68,68,.3);
	color: #fca5a5;
}
.asset-chip--no-basis {
	background: rgba(251,191,36,.12);
	border-color: rgba(251,191,36,.3);
	color: #fde68a;
}
.asset-chip strong { color: #fff; }
.chip-badge { font-size: .7rem; font-weight: 400; opacity: .8; }
.chip-count { font-size: .7rem; opacity: .65; }

.empty-state__actions {
	border-top: 1px solid rgba(251,191,36,.2);
	padding-top: 1rem;
	display: flex;
	flex-wrap: wrap;
	gap: .6rem;
}

.es-btn {
	display: inline-flex;
	align-items: center;
	gap: .4rem;
	padding: .5rem 1.1rem;
	border-radius: 8px;
	font-size: .85rem;
	font-weight: 600;
	text-decoration: none;
	transition: background .15s, border-color .15s;
	white-space: nowrap;
}

.es-btn--primary {
	background: #f59e0b;
	color: #1c1007;
	border: none;
}

.es-btn--primary:hover { background: #fbbf24; }

.es-btn--secondary {
	background: rgba(251,191,36,.1);
	color: #fde68a;
	border: 1px solid rgba(251,191,36,.3);
}

.es-btn--secondary:hover {
	background: rgba(251,191,36,.2);
	border-color: rgba(251,191,36,.5);
}

/* ── Print styles ──────────────────────────────────────────────────────────── */
@media print {
	body { margin: 0; font-family: Arial, sans-serif; font-size: 9pt; }
	.form-page {
		page-break-after: always;
		padding: 0.4in 0.4in 0.3in;
		width: 100%;
		box-sizing: border-box;
	}
	.form-page:last-child { page-break-after: avoid; }
	table { border-collapse: collapse; width: 100%; }
	th, td { border: 1px solid #000; padding: 2px 4px; font-size: 8pt; }
	th { background: #e8e8e8 !important; -webkit-print-color-adjust: exact; }
	.irs-header { border: 2px solid #000; padding: 6px; margin-bottom: 6px; }
	.part-label { font-size: 11pt; font-weight: bold; margin: 6px 0 4px; }
	.box-row { display: flex; gap: 16px; align-items: center; margin: 4px 0; }
	.checkbox { width: 12px; height: 12px; border: 1px solid #000; display: inline-flex; align-items: center; justify-content: center; margin-right: 4px; font-weight: bold; font-size: 9pt; }
	.totals-row td { font-weight: bold; background: #f0f0f0 !important; -webkit-print-color-adjust: exact; }
}

/* ── Screen preview styles ─────────────────────────────────────────────────── */
@media screen {
	.form-page {
		background: #fff;
		border: 1px solid #d1d5db;
		border-radius: 0.75rem;
		padding: 2rem 2.5rem;
		box-shadow: 0 2px 8px rgba(0,0,0,0.08);
		overflow-x: auto;
	}
	.irs-header {
		border: 2px solid #d1d5db;
		border-radius: 0.5rem;
		padding: 1rem 1.25rem;
		margin-bottom: 1.75rem;
		background: #f9fafb;
		line-height: 1.6;
	}
	table { border-collapse: collapse; width: 100%; font-size: 0.8rem; }
	th {
		background: #f3f4f6;
		font-weight: 600;
		text-align: left;
		padding: 9px 12px;
		border: 1px solid #d1d5db;
		font-size: 0.75rem;
		letter-spacing: 0.01em;
	}
	td { padding: 7px 12px; border: 1px solid #e5e7eb; line-height: 1.4; }
	tr:hover td { background: #f9fafb; }
	.part-label { font-size: 1rem; font-weight: 700; color: #111827; margin: 0 0 1rem; }
	.box-row {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		align-items: center;
		margin: 0.75rem 0 1.25rem;
		font-size: 0.85rem;
		color: #374151;
		line-height: 1.6;
	}
	.box-row label { display: flex; align-items: center; gap: 6px; cursor: default; }
	.checkbox {
		width: 16px;
		height: 16px;
		flex-shrink: 0;
		border: 1.5px solid #9ca3af;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-weight: bold;
		border-radius: 3px;
	}
	.checked { background: #1e40af; border-color: #1e40af; color: #fff; }
	.totals-row td { font-weight: 700; background: #f3f4f6; }
}
</style>

<script is:inline define:vars={{ f8i18n: {
	errLoadFailed:           t.errLoadFailed,
	errNetwork:              t.errNetwork,
