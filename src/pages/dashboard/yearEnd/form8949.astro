	errLoadFailed: string; errNetwork: string;
	ctxNoImports: string; ctxPipelineNotRun: string;
	ctxCoinSingular: string; ctxCoinPlural: string;
	ctxHasSingular: string; ctxHavePlural: string;
	ctxTxSingular: string; ctxTxPlural: string;
