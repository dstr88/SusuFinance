---
/**
 * /dashboard/portfolio
 *
 * Premium portfolio performance page — Titanium Hut design language.
 * Single accent: Electric Mint #2dd4a8 (matches brand SalmonTin color).
 * All colors are expressed via CSS custom properties in portfolio.css —
 * nothing is hard-coded in this template.
 *
 * Data is fetched client-side so prices are always live.
 */
import './portfolio.css';
import Layout from '../../layouts/Layout.astro';
import { requireTenantSession } from '@/lib/requireTenantSession';
import ReconciliationTransactions from '@/components/dashboard/ReconciliationTransactions';
import ReconciliationSnapshot from '@/components/dashboard/ReconciliationSnapshot';
import PortfolioTour from '../../components/tours/PortfolioTour.astro';
import { getLang } from '@/lib/i18n/locale';
import { getPortfolio } from '@/i18n/dashboard/portfolio';

const lang = getLang(Astro.request);
const t = getPortfolio(lang);
// Split heroCostBasis into prefix/suffix around the amount placeholder for static HTML use.
const _cbParts = t.heroCostBasis('\x00').split('\x00');
const heroCostBasisPrefix = _cbParts[0] ?? 'vs. ';
const heroCostBasisSuffix = _cbParts[1] ?? ' cost basis';

const _authSess = await requireTenantSession(Astro.request);
if (!_authSess) return Astro.redirect('/login');
---

<Layout title={t.pageTitle} noindex={true}>
<div class="portfolio-page">

	<!-- ── Loading ──────────────────────────────────────────────────────── -->
	<div id="pf-loading" class="pf-loading">
		<div class="pf-spinner"></div>
		<span class="pf-loading__label">{t.loadingLabel}</span>
	</div>

	<!-- ── Error state ──────────────────────────────────────────────────── -->
	<div id="pf-error" class="pf-state pf-state--error" hidden>
		<div class="pf-state__icon"></div>
		<p class="pf-state__title">{t.errorTitle}</p>
		<p class="pf-state__sub">{t.errorSub}</p>
	</div>

	<!-- ── Empty state ──────────────────────────────────────────────────── -->
	<div id="pf-empty" class="pf-state" hidden>
		<div class="pf-state__icon"></div>
		<p class="pf-state__title">{t.emptyTitle}</p>
		<p class="pf-state__sub">{t.emptySub}</p>
	</div>

	<!-- ── Main content (hidden until data loads) ───────────────────────── -->
	<div id="pf-content" hidden>

		<!-- Hero band ──────────────────────────────────────────────────── -->
		<section class="pf-hero">
			<div class="pf-hero__inner">
				<div class="pf-hero__eyebrow">
					<span class="pf-hero__eyebrow-dot"></span>
					{t.heroEyebrow}
					<PortfolioTour />
				</div>

				<div class="pf-hero__value-block">
					<span class="pf-hero__value-label">{t.heroValueLabel}</span>
					<div class="pf-hero__value" id="hero-value">—</div>
				</div>

				<div class="pf-hero__pnl-row">
					<span class="pf-hero__pnl pf-hero__pnl--neutral" id="hero-pnl">—</span>
					<span class="pf-hero__sep">·</span>
					<span class="pf-hero__pct pf-hero__pct--neutral" id="hero-pct">—</span>
					<span class="pf-hero__sep">·</span>
					<span class="pf-hero__meta" id="hero-vs" style="margin-bottom:0">{heroCostBasisPrefix}<strong id="hero-invested">—</strong>{heroCostBasisSuffix}</span>
				</div>
				<div class="pf-hero__unpriced-note" id="hero-unpriced-note" hidden>
					<span id="hero-unpriced-text"></span>
				</div>

				<p class="pf-hero__meta" id="hero-updated"></p>
			</div>

			<!-- Allocation bar lives at the very bottom of the hero -->
			<div class="pf-alloc-bar" id="alloc-bar"></div>
		</section>

		<!-- Metric cards ───────────────────────────────────────────────── -->
		<div class="pf-metrics">
			<div class="pf-metric">
				<span class="pf-metric__label">{t.metricCostBasis}</span>
				<span class="pf-metric__value" id="card-cost">—</span>
			</div>
			<div class="pf-metric">
				<span class="pf-metric__label">{t.metricCurrentValue}</span>
				<span class="pf-metric__value" id="card-value">—</span>
			</div>
			<div class="pf-metric">
				<span class="pf-metric__label">{t.metricUnrealizedPnl}</span>
				<span class="pf-metric__value" id="card-pnl">—</span>
			</div>
			<div class="pf-metric">
				<span class="pf-metric__label">{t.metricTotalReturn}</span>
				<span class="pf-metric__value" id="card-pct">—</span>
			</div>
		</div>

		<!-- Per-asset table ────────────────────────────────────────────── -->
		<section class="pf-positions">
			<div class="pf-positions__header">
				<span class="pf-positions__title">{t.positionsTitle}</span>
				<span class="pf-positions__ts" id="updated-at"></span>
			</div>

			<div class="pf-table-wrap">
				<table class="pf-table">
					<thead>
						<tr>
							<th>{t.colAsset}</th>
							<th class="pf-col--holdings">{t.colHoldings}</th>
							<th class="pf-col--avg-cost">{t.colAvgCost}</th>
							<th>{t.colCostBasis}</th>
							<th class="pf-col--price-now">{t.colPriceNow}</th>
							<th>{t.colMarketValue}</th>
							<th>{t.colUnrealizedPnl}</th>
							<th>{t.colReturn}</th>
						</tr>
					</thead>
					<tbody id="asset-tbody"></tbody>
					<tfoot id="asset-tfoot"></tfoot>
				</table>
			</div>

			<p id="no-price-note" class="pf-note" hidden>
				{t.noPriceNote}
			</p>
		</section>
	</div><!-- /pf-content -->

	<!-- ── Reconciliation ───────────────────────────────────────────────── -->
	<section class="recon-section">
		<div class="recon-section-divider">
			<span class="recon-section-divider__label">{t.reconDivider}</span>
			<span class="recon-section-divider__line"></span>
		</div>
		<div class="recon-grid">
			<ReconciliationTransactions client:only="react" threshold={50} />
			<ReconciliationSnapshot     client:only="react" threshold={50} />
		</div>
	</section>

</div><!-- /portfolio-page -->
</Layout>

<script is:inline define:vars={{ pfI18n: {
	lang:           lang,
	heroUpdated:    t.heroUpdated('__T__'),
	heroUnpriced:   t.heroUnpriced('__A__'),
	tableTotal:     t.tableTotal,
	lastAcquired:   t.lastAcquired('__D__'),
	aaveCollateral: t.aaveCollateral,
} }}>window.__pfI18n = pfI18n;</script>

<script>
import { escapeHtml } from '../../lib/escapeHtml';
// ── Formatters ──────────────────────────────────────────────────────────── //
const USD = new Intl.NumberFormat('en-US', {
	style: 'currency', currency: 'USD',
	minimumFractionDigits: 2, maximumFractionDigits: 2,
});
const PCT = (n: number) => `${n >= 0 ? '+' : ''}${n.toFixed(2)}%`;
const QTY = (n: number) => {
	if (n >= 1000) return n.toLocaleString('en-US', { maximumFractionDigits: 4 });
	if (n >= 1)    return n.toLocaleString('en-US', { maximumFractionDigits: 6 });
	return n.toLocaleString('en-US', { maximumFractionDigits: 8 });
};

function pillClass(n: number | null): string {
	if (n == null) return 'pf-pill pf-pill--neutral';
	return n >= 0  ? 'pf-pill pf-pill--gain' : 'pf-pill pf-pill--loss';
}

function fmtPnl(n: number | null): string {
	if (n == null) return '—';
	const abs = USD.format(Math.abs(n));
	return n >= 0 ? `+${abs}` : `(${abs})`;
}

function heroClass(suffix: 'pnl' | 'pct', n: number | null): string {
	const base = suffix === 'pnl' ? 'pf-hero__pnl' : 'pf-hero__pct';
	if (n == null) return `${base} ${base}--neutral`;
	return n >= 0  ? `${base} ${base}--gain` : `${base} ${base}--loss`;
}

function metricClass(n: number | null): string {
	const base = 'pf-metric__value';
	if (n == null) return base;
	return n >= 0  ? `${base} pf-metric__value--gain` : `${base} pf-metric__value--loss`;
}

// Ticker badge: up to 4 chars, clipped sensibly
function tickerLabel(sym: string): string {
	return sym.slice(0, 4).toUpperCase();
}

// ── i18n strings (injected by inline define:vars script above) ─────────── //
interface PfI18n {
	lang:           string;
	heroUpdated:    string;
	heroUnpriced:   string;
	tableTotal:     string;
	lastAcquired:   string;
	aaveCollateral: string;
}
const I18N: PfI18n = (window as unknown as { __pfI18n?: PfI18n }).__pfI18n ?? {
	lang:           'en',
	heroUpdated:    'Prices as of __T__',
	heroUnpriced:   '+ __A__ in assets with no live price',
	tableTotal:     'Total',
	lastAcquired:   'Last acq. __D__',
	aaveCollateral: 'Aave Collateral',
};
const lang = I18N.lang;
/** Replace a single __PLACEHOLDER__ in a template string. */
function interpolate(tmpl: string, value: string): string {
	return tmpl.replace(/__[A-Z_]+__/, value);
}

// ── Allocation bar ──────────────────────────────────────────────────────── //
// Renders each asset as a proportional segment in the hero bar.
// Gainers → mint-to-green gradient, losers → red, no-price → dim gray.
function buildAllocBar(
	assets: Array<{
		symbol: string;
		currentValue: number | null;
		totalCostBasis: number;
		unrealizedPnl: number | null;
	}>,
) {
	const bar = document.getElementById('alloc-bar');
	if (!bar) return;

	// Use current value if available, otherwise cost basis as proxy
	const total = assets.reduce((s, a) => s + (a.currentValue ?? a.totalCostBasis), 0);
	if (total <= 0) return;

	// Sort: gainers first, then no-price, then losers
	const sorted = [...assets].sort((a, b) => {
		const aP = a.unrealizedPnl ?? 0;
		const bP = b.unrealizedPnl ?? 0;
		if (a.currentValue == null && b.currentValue != null) return 1;
		if (b.currentValue == null && a.currentValue != null) return -1;
		return bP - aP;
	});

	bar.innerHTML = '';

	// Mint shades for top gainers, desaturated for flat/unknown, red for losers
	const gainColors  = ['#2dd4a8', '#28c49a', '#24b58c', '#1fa67e', '#1a9770'];
	let gainIdx = 0;

	for (const asset of sorted) {
		const val   = asset.currentValue ?? asset.totalCostBasis;
		const share = val / total;
		const pnl   = asset.unrealizedPnl;

		let color: string;
		if (asset.currentValue == null) {
			color = 'rgba(255,255,255,.12)';          // no price — dim
		} else if (pnl != null && pnl < 0) {
			color = 'rgba(248,113,113,.65)';           // loss — muted red
		} else {
			color = gainColors[gainIdx % gainColors.length];
			gainIdx++;
		}

		const seg = document.createElement('div');
		seg.className = 'pf-alloc-bar__seg';
		seg.style.flexGrow = String(share * 100);
		seg.style.background = color;
		seg.title = `${asset.symbol}: ${USD.format(val)}`;
		bar.appendChild(seg);
	}
}

// ── Main load ───────────────────────────────────────────────────────────── //
async function loadPortfolio() {
	const elLoading  = document.getElementById('pf-loading')!;
	const elError    = document.getElementById('pf-error')!;
	const elEmpty    = document.getElementById('pf-empty')!;
	const elContent  = document.getElementById('pf-content')!;

	try {
		const res = await fetch('/api/portfolio/performance');
		if (!res.ok) throw new Error(`HTTP ${res.status}`);

		const data = await res.json() as {
			ok: boolean;
			updatedAt: string;
			summary: {
				totalCostBasis:       number;   // cost of ALL assets (including unpriced)
				pricedCostBasis:      number;   // cost of priced assets only — matches P&L base
				totalCurrentValue:    number;
				totalUnrealizedPnl:   number;
				pnlPercent:           number | null;
			};
			assets: Array<{
				symbol:           string;
				quantity:         number;
				weightedAvgCost:  number;
				totalCostBasis:   number;
				currentPrice:     number | null;
				currentValue:     number | null;
				unrealizedPnl:    number | null;
				pnlPercent:       number | null;
				lastAcquiredAt:   string | null;
				priceSource:      string;
				isCollateral:     boolean;
			}>;
		};

		elLoading.hidden = true;

		if (!data.ok) throw new Error('API returned ok:false');
		if (!data.assets || data.assets.length === 0) {
			elEmpty.hidden = false;
			return;
		}

		// ── Hero ─────────────────────────────────────────────────────── //
		const s = data.summary;
		const hasPrices = s.totalCurrentValue > 0;
		const pnlVal    = hasPrices ? s.totalUnrealizedPnl : null;

		const heroValue = document.getElementById('hero-value')!;
		heroValue.textContent = hasPrices ? USD.format(s.totalCurrentValue) : '—';
		if (pnlVal != null && pnlVal >= 0) heroValue.classList.add('pf-hero__value--gain');

		const heroPnl = document.getElementById('hero-pnl')!;
		heroPnl.textContent = fmtPnl(pnlVal);
		heroPnl.className   = heroClass('pnl', pnlVal);

		const heroPct = document.getElementById('hero-pct')!;
		heroPct.textContent = s.pnlPercent != null ? PCT(s.pnlPercent) : '—';
		heroPct.className   = heroClass('pct', s.pnlPercent);

		// Use pricedCostBasis so "vs. X cost basis" reconciles with P&L and Current Value.
		// (totalCostBasis includes unpriced assets that have no matching current value.)
		(document.getElementById('hero-invested')!).textContent = USD.format(s.pricedCostBasis);

		// If there are unpriced assets, show a note so the user understands the difference.
		const unpricedCost = s.totalCostBasis - s.pricedCostBasis;
		if (unpricedCost > 0.005) {
			const noteEl = document.getElementById('hero-unpriced-note')!;
			const textEl = document.getElementById('hero-unpriced-text')!;
			textEl.textContent = interpolate(I18N.heroUnpriced, USD.format(unpricedCost));
			noteEl.hidden = false;
		}

		try {
			const locale = lang === 'es' ? 'es-ES' : lang === 'fr' ? 'fr-FR' : 'en-US';
			const ts = new Date(data.updatedAt).toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit' });
			const updatedStr = interpolate(I18N.heroUpdated, ts);
			(document.getElementById('hero-updated')!).textContent = updatedStr;
			(document.getElementById('updated-at')!).textContent   = updatedStr;
		} catch {}

		// ── Metric cards ──────────────────────────────────────────────── //
		const cardCost  = document.getElementById('card-cost')!;
		const cardValue = document.getElementById('card-value')!;
		const cardPnl   = document.getElementById('card-pnl')!;
		const cardPct   = document.getElementById('card-pct')!;

		// Show priced cost basis so Total Invested reconciles with P&L and Current Value.
		cardCost.textContent  = USD.format(s.pricedCostBasis);
		cardValue.textContent = hasPrices ? USD.format(s.totalCurrentValue) : '—';

		cardPnl.textContent = fmtPnl(pnlVal);
		cardPnl.className   = metricClass(pnlVal);

		cardPct.textContent = s.pnlPercent != null ? PCT(s.pnlPercent) : '—';
		cardPct.className   = metricClass(s.pnlPercent);

		// ── Asset rows ────────────────────────────────────────────────── //
		const tbody = document.getElementById('asset-tbody')!;
		let   hasNoPricedAssets = false;

		for (const a of data.assets) {
			const hasPrice = a.currentPrice != null;
			if (!hasPrice) hasNoPricedAssets = true;

			const tr = document.createElement('tr');

			tr.innerHTML = `
				<td>
					<div class="pf-ticker">
						<div class="pf-ticker__badge">${tickerLabel(a.symbol)}</div>
						<div class="pf-ticker__info">
							<div class="pf-ticker__name">${escapeHtml(a.symbol)}</div>
							${a.lastAcquiredAt
								? `<div class="pf-ticker__sub">${interpolate(I18N.lastAcquired, escapeHtml(a.lastAcquiredAt))}</div>`
								: ''}
							${a.isCollateral
								? `<span class="pf-collateral-badge">${I18N.aaveCollateral}</span>`
								: ''}
						</div>
					</div>
				</td>
				<td class="pf-col--holdings">${QTY(a.quantity)}</td>
				<td class="pf-col--avg-cost">${a.weightedAvgCost > 0 ? USD.format(a.weightedAvgCost) : '—'}</td>
				<td>${USD.format(a.totalCostBasis)}</td>
				<td class="pf-col--price-now">${hasPrice ? USD.format(a.currentPrice!) : '<span style="color:var(--pf-text-2)">—*</span>'}</td>
				<td>${a.currentValue != null ? USD.format(a.currentValue) : '<span style="color:var(--pf-text-2)">—</span>'}</td>
				<td><span class="${pillClass(a.unrealizedPnl)}">${fmtPnl(a.unrealizedPnl)}</span></td>
				<td><span class="${pillClass(a.pnlPercent)}">${a.pnlPercent != null ? PCT(a.pnlPercent) : '—'}</span></td>
			`;
			tbody.appendChild(tr);
		}

		// ── Footer totals ─────────────────────────────────────────────── //
		const tfoot       = document.getElementById('asset-tfoot')!;
		const priced      = data.assets.filter(a => a.currentValue != null);

		if (priced.length > 0) {
			const footPricedCost = priced.reduce((sum, a) => sum + a.totalCostBasis, 0);
			const footCurVal     = priced.reduce((sum, a) => sum + a.currentValue!, 0);
			const footPnl        = footCurVal - footPricedCost;

			// Cost Basis total uses priced-only so it reconciles: Cost + P&L = Market Value.
			// Unpriced assets are excluded here (they have no matching current value to sum against).
			tfoot.innerHTML = `
				<tr>
					<td>${I18N.tableTotal}</td>
					<td class="pf-col--holdings"></td>
					<td class="pf-col--avg-cost"></td>
					<td>${USD.format(footPricedCost)}</td>
					<td class="pf-col--price-now"></td>
					<td>${USD.format(footCurVal)}</td>
					<td><span class="${pillClass(footPnl)}">${fmtPnl(footPnl)}</span></td>
					<td><span class="${pillClass(s.pnlPercent)}">${s.pnlPercent != null ? PCT(s.pnlPercent) : '—'}</span></td>
				</tr>
			`;
		}

		if (hasNoPricedAssets) {
			(document.getElementById('no-price-note')!).hidden = false;
		}

		// ── Allocation bar ────────────────────────────────────────────── //
		buildAllocBar(data.assets);

		// Reveal everything
		elContent.hidden = false;

	} catch (err) {
		console.error('[portfolio] load error', err);
		elLoading.hidden = true;
		elError.hidden   = false;
	}
}

loadPortfolio();
</script>
