---
// /dashboard/lobby — the way in for everyone who is NOT an admin.
//
// ── Who sees this ────────────────────────────────────────────────────────────
//
// Revised Jul 16: admins no longer pass through the lobby. An admin (owner/co-owner)
// logs straight into her panel — and the "admin" door was deleted with that change,
// because there is no door to click when you are already inside. A demo session
// showcases the operator panel, so it goes there too.
//
// So the lobby is now the landing for a signed-in NON-admin — a member, or a person
// who has signed in but is not yet in any programme (non-members can now sign in;
// the two-founder gate returns null instead of throwing). Her way in is "invited by"
// — the member/join path (still being built).
//
// ── Layout ───────────────────────────────────────────────────────────────────
//
// LoginLayout, not Layout: Layout renders the Almstins dashboard nav (Bookkeeping,
// Vault, Portfolio, Scam Checker) — dead scaffolding awaiting the feature strip,
// and no way to put a full-bleed splash underneath it.
//
// ── The image ────────────────────────────────────────────────────────────────
//
// bank-lobby.png is 1.9 MB at 1376×768. It goes through Astro's pipeline to webp
// because the audience is market women on data bundles — the member view is already
// specced to respect that, and a background is the easiest place to spend someone's
// money without noticing.
import LoginLayout from '../../layouts/LoginLayout.astro';
import { getImage } from 'astro:assets';
import bankLobby from '../../assets/bank-lobby.png';
import MemberAccount from '../../components/circles/MemberAccount';
import { getAuthSession } from '@/lib/authSession';
import { isDemoRequest } from '@/lib/demo';
import { db } from '@/lib/db';
import { getCirclesLocale } from '@/i18n/dashboard/circles';
import { getMemberAccount } from '@/lib/circles/memberAccount';
import { langFromCookieHeader } from '@/lib/i18n/locale';

// "Are you signed in?" — NOT "which programme are you in?". The lobby is a door-
// chooser; it needs neither a tenant nor a role. requireTenantSession would throw
// 403 for a signed-in user who is in no programme yet (the invitee, between
// sign-in and redeeming her link) — and the swallowed throw would bounce her to
// /login, where she would sign in, and bounce again. A door you cannot reach
// without already being through it.
const auth = await getAuthSession(Astro.request).catch(() => null);
const isDemo = isDemoRequest(Astro.request);
const userId = auth?.user?.id ? String(auth.user.id) : '';
const signedIn = Boolean(userId) || isDemo;
if (!signedIn) return Astro.redirect('/login?next=/dashboard/lobby');

// Admins log straight into their panel — they never see the lobby, and the "admin"
// door was deleted with this change. The demo showcases the operator panel, so it
// goes there too. Everyone still here is a non-admin (a member, or a signed-in
// non-member not yet in any programme).
if (isDemo) return Astro.redirect('/dashboard/circles');
if (userId) {
  const roleRes = await db.execute({
    sql: `SELECT role FROM tenant_memberships WHERE user_id = ? LIMIT 1`,
    args: [userId],
  });
  const role = roleRes.rows[0] ? String((roleRes.rows[0] as any).role ?? '') : '';
  if (role === 'owner' || role === 'admin') return Astro.redirect('/dashboard/circles');
}

const lang = langFromCookieHeader(Astro.request.headers.get('cookie'));
const t = getCirclesLocale(lang);

// Her account modal is server-seeded here — her circles and every vote open in them
// (vouches, proposals, expulsions) — so it paints without a spinner on a slow bundle.
// null = this login is not a member (an operator would have been redirected above; a
// signed-in non-member has not joined yet), and the modal renders nothing for them.
// This replaces the old standalone "someone is waiting for your vouch" link: vouching
// now lives inside the modal alongside everything else the group is deciding.
const memberAccount = userId ? await getMemberAccount(userId).catch(() => null) : null;

// Two widths: phones get a 900px webp, desktops 1800. Same picture, a quarter of
// the bytes on the device most likely to be paying per megabyte.
const [bgSmall, bgLarge] = await Promise.all([
  getImage({ src: bankLobby, format: 'webp', width: 900, quality: 62 }),
  getImage({ src: bankLobby, format: 'webp', width: 1800, quality: 68 }),
]);
---

<LoginLayout title={t.lobby.welcome} noindex={true} lang={lang}>
  <section
    class="lobby"
    style={`--bg-small: url(${bgSmall.src}); --bg-large: url(${bgLarge.src});`}
  >
    <!-- Scrim: the photograph is bright marble and gold, so the text needs ground to
         stand on. Built from --surface-bg and `transparent` so it stays inside the
         token rule — no rgba() anywhere. -->
    <div class="lobby__scrim" aria-hidden="true"></div>

    {/* Her account modal — top-left. Only mounts for a member; the island itself
        returns nothing when `member` is null, so an operator/non-member sees no pill.
        `lang`, not `t`: island props are JSON, and the locale's functions would drop. */}
    {memberAccount && (
      <MemberAccount
        client:load
        lang={lang}
        initial={{ member: { displayName: memberAccount.displayName, payoutAddress: memberAccount.payoutAddress, addressVerified: memberAccount.addressVerified }, circles: memberAccount.circles }}
      />
    )}

    <nav class="lobby__doors" aria-label="Your way in">
      {/* The "admin" door was deleted Jul 16 — admins land straight in their panel.
          "Invited by" is the member's way in: the self-serve join form, where she
          names her group and sponsor. (A seeded member instead gets a claim link.) */}
      <a class="lobby__door lobby__door--right" href="/join">{t.lobby.invitedBy}</a>
    </nav>

    <h1 class="lobby__welcome">{t.lobby.welcome}</h1>
  </section>
</LoginLayout>

<style>
  .lobby {
    position: relative;
    width: 100%;
    /* svh, not vh: on a phone, 100vh sits under the browser chrome and the welcome
       line lands off-screen. svh is the small viewport — what she can actually see. */
    min-height: 100svh;
    display: flex;
    /* Column so a vouch prompt can stack above the welcome line; both stay bottom-
       anchored and centered. */
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
    background-image: var(--bg-small);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: var(--surface-bg);
  }
  @media (min-width: 901px) {
    .lobby { background-image: var(--bg-large); }
  }
  /* Older browsers without svh support still get a full screen. */
  @supports not (min-height: 100svh) {
    .lobby { min-height: 100vh; }
  }

  .lobby__scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to bottom, var(--surface-bg), transparent 22%, transparent 55%, var(--surface-bg)),
      linear-gradient(to bottom, transparent 70%, var(--surface-bg));
    opacity: 0.92;
  }

  .lobby__doors {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    /* One door now (the admin door was removed) — keep it top-right where it was. */
    justify-content: flex-end;
    padding: 1.25rem 1.25rem 0;
    z-index: 1;
  }
  .lobby__door {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    background: var(--surface-card);
    transition: color 120ms ease, border-color 120ms ease, background 120ms ease;
  }
  .lobby__door:hover {
    color: var(--accent);
    border-color: var(--accent-soft);
    background: var(--surface-card-2);
  }
  .lobby__door:focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

  .lobby__welcome {
    position: relative;
    z-index: 1;
    margin: 0 0 clamp(2rem, 8vh, 4.5rem);
    padding: 0 1.25rem;
    text-align: center;
    font-size: clamp(1.75rem, 6vw, 3.25rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    text-wrap: balance;
  }

  @media (min-width: 768px) {
    .lobby__doors { padding: 1.75rem 2rem 0; }
    .lobby__door { font-size: 0.9rem; }
  }
</style>
