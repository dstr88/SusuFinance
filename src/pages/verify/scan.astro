---
// Public customer-scan — confirm a merchant's address is a verified SusuFinance
// destination and screen it for scams, no account required. /verify/* is public
// (isPublicPath), and a QR badge deep-links here with ?address=.
import '@/styles/tokens.css';
import VerifyScan from '@/components/verify/VerifyScan';
const initialAddress = Astro.url.searchParams.get('address') ?? '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Verify before you pay — SusuFinance</title>
  <meta name="description" content="Scan or paste a crypto address to confirm it's a verified SusuFinance destination and screen it for scams — no account needed." />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" href="/favicon-verify.png" />
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: var(--surface-bg); color: var(--text-primary); min-height: 100vh;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; }
  </style>
</head>
<body>
  <VerifyScan client:load initialAddress={initialAddress} />
</body>
</html>
