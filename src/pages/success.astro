---
import Layout from '@/layouts/Layout.astro';
import { getLang } from '@/lib/i18n/locale';
import { getSuccess } from '@/i18n/success';

const lang = getLang(Astro.request);
const t = getSuccess(lang);

// Serialise JS runtime strings for the inline script to consume.
const jsStrings = JSON.stringify({
  unavailable: t.jsUnavailable,
  noSession: t.jsNoSession,
  stillProcessing: t.jsStillProcessing,
  notePrefix: lang === 'es' ? 'Nota: ' : lang === 'fr' ? 'Remarque : ' : 'Note: ',
  fulfilled: t.jsFulfilled,
  inProgress: t.jsInProgress,
  fetchError: t.jsFetchError,
});
---

<Layout showHero={false} title={t.pageTitle} noindex={true}>
  {/* Hidden element carrying localised JS strings — read synchronously by the inline script below */}
  <div id="i18n-success" data-strings={jsStrings} style="display:none" aria-hidden="true"></div>

  <main class="status-page">
    <section class="status-card" aria-live="polite">
      <h1>{t.heading}</h1>
      <p id="statusMessage">{t.initialMessage}</p>
      <p class="status-domain">
        {t.domainLabel} <span id="domainValue">{t.domainLoading}</span>
      </p>
      <p class="status-note" id="statusNote"></p>
      <a class="status-link" href="/">{t.backHome}</a>
    </section>
  </main>

  <style>
    .status-page {
      min-height: 60vh;
      display: grid;
      place-items: center;
      padding: clamp(1.5rem, 4vw, 3rem);
    }

    .status-card {
      width: min(680px, 92vw);
      padding: clamp(1.5rem, 3vw, 2.25rem);
      border-radius: 20px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(10px);
      text-align: center;
    }

    .status-card h1 {
      margin: 0 0 0.75rem;
      font-size: clamp(1.6rem, 3vw, 2.2rem);
    }

    .status-domain {
      margin: 0.75rem 0 0.25rem;
      font-weight: 700;
    }

    .status-note {
      min-height: 1.2rem;
      opacity: 0.9;
    }

    .status-link {
      display: inline-block;
      margin-top: 1.25rem;
      font-weight: 700;
      text-decoration: none;
      border-bottom: 2px solid currentColor;
    }
  </style>

  <script>
    (function () {
      // Read localised strings embedded by the server.
      var i18nEl = document.getElementById("i18n-success");
      var s = i18nEl
        ? JSON.parse(i18nEl.dataset.strings || "{}")
        : {};
      var unavailable   = s.unavailable   || "Unavailable";
      var noSession     = s.noSession     || "We could not find your checkout session. Contact support if needed.";
      var stillProc     = s.stillProcessing || "We are still processing your order. Please check back soon.";
      var notePrefix    = s.notePrefix    || "Note: ";
      var fulfilled     = s.fulfilled     || "Your domain is registered.";
      var inProgress    = s.inProgress    || "Your order is confirmed and in progress.";
      var fetchError    = s.fetchError    || "We could not verify your order right now.";

      var statusMessage = document.getElementById("statusMessage");
      var statusNote    = document.getElementById("statusNote");
      var domainValue   = document.getElementById("domainValue");

      var params    = new URLSearchParams(window.location.search);
      var sessionId = params.get("session_id");

      if (!sessionId) {
        domainValue.textContent   = unavailable;
        statusMessage.textContent = noSession;
        return;
      }

      fetch("/api/pay/status.php?session_id=" + encodeURIComponent(sessionId))
        .then(function (res) { return res.json(); })
        .then(function (data) {
          if (!data || !data.ok) {
            domainValue.textContent   = unavailable;
            statusMessage.textContent = stillProc;
            statusNote.textContent    = data && data.error ? notePrefix + data.error : "";
            return;
          }

          domainValue.textContent   = data.domain || unavailable;
          statusMessage.textContent =
            data.status === "fulfilled" ? fulfilled : inProgress;
          statusNote.textContent    = data.message || "";
        })
        .catch(function () {
          domainValue.textContent   = unavailable;
          statusMessage.textContent = fetchError;
        });
    })();
  </script>
</Layout>
