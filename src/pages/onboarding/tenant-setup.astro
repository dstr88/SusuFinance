---
import Layout from '@/layouts/LoginLayout.astro';
---

<Layout title="Tenant Setup">
	<main class="tenant-setup">
		<section class="tenant-setup__card">
			<h1>Setting up your workspace</h1>
			<p>
				Your account is signed in, but onboarding is not complete yet.
				Finish setup to unlock your dashboard.
			</p>
			<div class="tenant-setup__actions">
				<form id="onboarding-finish-setup" method="POST" action="/api/onboarding/complete">
					<button type="submit" name="finish-setup" class="tenant-setup__button">Finish setup</button>
				</form>
				<a class="tenant-setup__button tenant-setup__button--ghost" href="/api/logout">Sign out</a>
			</div>
		</section>
	</main>
</Layout>

<style>
	.tenant-setup {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 2rem;
		background: linear-gradient(135deg, #0b1320, #111827);
	}

	.tenant-setup__card {
		width: min(560px, 100%);
		background: rgba(10, 15, 26, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.15);
		border-radius: 16px;
		padding: 2rem;
		color: #f7f2eb;
	}

	.tenant-setup__card h1 {
		margin: 0 0 0.75rem;
		font-size: 1.6rem;
	}

	.tenant-setup__card p {
		margin: 0 0 1rem;
		line-height: 1.5;
	}

	.tenant-setup__actions {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.tenant-setup__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 600;
		background: #f8b45d;
		color: #121212;
		border: none;
		cursor: pointer;
	}

	.tenant-setup__button--ghost {
		background: transparent;
		color: #f7f2eb;
		border: 1px solid rgba(255, 255, 255, 0.25);
	}
</style>
