---
// Legal chrome for PetroTins (Terms, Privacy). A thin wrapper around
// PetroTinsLayout that adds the legal hero (eyebrow / title / date / back) and
// the dark prose styles (.notice / h2 / h3 / lists). Now fully dark-themed and
// sharing the one PetroTins token set. PetroTins is English-only by design.
import PetroTinsLayout from './PetroTinsLayout.astro';
import SiteFooter from '../components/petro-tins/SiteFooter.astro';

export interface Props {
  title: string;
  description?: string;
  effectiveDate?: string;
}
const { title, description = '', effectiveDate = 'June 15, 2026' } = Astro.props;
---
<PetroTinsLayout title={`${title} · PetroTins`} description={description}>
  <header class="pt-legal-hero">
    <div class="pt-legal-hero__wrap">
      <div class="pt-legal-hero__eyebrow">PetroTins</div>
      <h1 class="pt-legal-hero__title">{title}</h1>
      <div class="pt-legal-hero__date">Effective date: {effectiveDate}</div>
      <a class="pt-legal-hero__back" href="/petro-tins">← Back to PetroTins</a>
    </div>
  </header>
  <main class="pt-legal">
    <slot />
    <SiteFooter />
  </main>
</PetroTinsLayout>

<!-- Global (not scoped): the prose lives in the slotted page, so .pt-legal
     descendant selectors must reach it. Namespaced under .pt-legal to contain it. -->
<style is:global>
  .pt-legal-hero { background: linear-gradient(135deg, #1c1407 0%, #0f0a03 100%); border-bottom: 3px solid var(--pt); padding: 48px 0 34px; margin-bottom: 32px; }
  .pt-legal-hero__wrap { max-width: 820px; margin: 0 auto; padding: 0 20px; }
  .pt-legal-hero__eyebrow { color: var(--pt); font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; font-size: 0.78em; }
  .pt-legal-hero__title { font-size: 2em; margin: 6px 0 8px; color: var(--text); }
  .pt-legal-hero__date { font-size: 0.9em; color: var(--muted); }
  .pt-legal-hero__back { color: var(--pt); text-decoration: none; font-size: 0.9em; display: inline-block; margin-top: 14px; }
  .pt-legal-hero__back:hover { text-decoration: underline; }

  .pt-legal { max-width: 820px; margin: 0 auto; padding: 0 20px 60px; font-size: 15px; line-height: 1.65; color: var(--sub); }
  .pt-legal h2 { font-size: 1.2em; color: var(--pt); margin: 28px 0 10px; }
  .pt-legal h3 { font-size: 1.02em; color: var(--text); margin: 18px 0 6px; }
  .pt-legal p { margin-bottom: 14px; }
  .pt-legal ul { margin: 12px 0 14px 26px; }
  .pt-legal li { margin-bottom: 7px; }
  .pt-legal strong { color: var(--text); }
  .pt-legal a { color: var(--pt); }
  .pt-legal .notice { background: var(--pt-soft); border: 1px solid var(--pt-glow); border-left: 4px solid var(--pt); border-radius: 8px; padding: 14px 18px; margin: 18px 0; color: var(--sub); }
  .pt-legal .xmark { color: var(--loss); font-weight: bold; }
  .pt-legal .checkmark { color: var(--gain); font-weight: bold; }
</style>
