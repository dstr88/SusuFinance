---
import './Layout.css';
import '../styles/dashboard.css';
import Footer from "@/components/Footer.astro";
import DemoBanner from "@/components/DemoBanner.astro";
import { getAuthSession } from '@/lib/authSession';
import { db } from '@/lib/db';
import { isDemoRequest } from '@/lib/demo';
import { getActivePlan } from '@/lib/subscriptions';
import kingSolomon from '@/assets/KingSolomon.png';

import minerva from '@/assets/Minerva.png';
import { getLang, isLang } from '@/lib/i18n/locale';
import { getDashboardCommon } from '@/i18n/dashboard/common';
import { getCirclesLocale } from '@/i18n/dashboard/circles';
const GA_ID = import.meta.env.PUBLIC_GA_ID;

const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path;

// Dashboard language follows the almstins-lang cookie (Phase-3 i18n).
const cookieLang = getLang(Astro.request);

const session = await getAuthSession(Astro.request).catch(() => null);
const user = session?.user ?? null;

// Real auth session always wins — never show the demo banner to a signed-in user
const isDemo = !user?.id && isDemoRequest(Astro.request);
const tenantId = session?.tenantId ?? null;

// Tax section (Summary + yearEnd/*) is owner-gated — hide its nav entry from
// everyone else so the demo has no dead-end links into /tax-login.

// Avatar: use OAuth profile image if available, otherwise pick a random default
const defaultAvatars = [kingSolomon, minerva];
const defaultAvatar = defaultAvatars[Math.floor(Math.random() * defaultAvatars.length)];

// Pull last_login, email, and member-since from DB for the account dropdown
let memberSinceIso: string | null = null;
let dbEmail: string | null = null;
// Two queries, run independently. They used to share a Promise.all and select
// last_login + alert_email — columns that do not exist on auth_users here. The
// whole thing threw, the catch swallowed it, and "member since" (from the OTHER
// query) silently vanished with it. A try/catch around a Promise.all makes one
// missing column erase every result beside it.
if (user?.id) {
  try {
    const userRow = await db.execute({ sql: 'SELECT email FROM auth_users WHERE id = ? LIMIT 1', args: [user.id] });
    dbEmail = userRow.rows[0] ? String((userRow.rows[0] as any).email ?? '') || null : null;
  } catch { /* non-fatal */ }
  try {
    const memberRow = await db.execute({ sql: 'SELECT created_at FROM tenant_memberships WHERE user_id = ? ORDER BY created_at ASC LIMIT 1', args: [user.id] });
    memberSinceIso = memberRow.rows[0] ? String((memberRow.rows[0] as any).created_at ?? '') || null : null;
  } catch { /* non-fatal */ }
}

// Prefer session email, fall back to DB email
const displayEmail = user?.email || dbEmail;

// Admin check — tenant ID is checked first (always in JWT, no email dependency).
// Fall back to email match as a secondary check.
const _adminTenantIdsRaw =
  (process.env as any).ADMIN_TENANT_IDS ??
  (process.env as any).ADMIN_TENANT_ID ??
  '';
const ADMIN_TENANT_IDS = new Set(
  _adminTenantIdsRaw.split(',').map((id: string) => id.trim().toLowerCase()).filter(Boolean)
);
const _adminEmailsRaw =
  (process.env as any).ADMIN_EMAILS ??
  (process.env as any).ADMIN_EMAIL ??
  import.meta.env.ADMIN_EMAILS ??
  import.meta.env.ADMIN_EMAIL ??
  '';
const ADMIN_EMAILS = new Set(
  _adminEmailsRaw.split(',').map((e: string) => e.trim().toLowerCase()).filter(Boolean)
);
const isAdmin =
  (tenantId ? ADMIN_TENANT_IDS.has(String(tenantId).toLowerCase()) : false) ||
  Boolean(displayEmail && ADMIN_EMAILS.has(displayEmail.toLowerCase()));

// ── The veil ──────────────────────────────────────────────────────────────────
//
// A temporary grey-out over the dashboard while the programme is still being
// furnished, so the second founder does not sign in to an empty room. The LOBBY is
// not veiled — it uses LoginLayout — so he still arrives somewhere finished, and
// only the door marked "admin" is papered over.
//
// ADMIN_EMAILS sees through it: the person furnishing the room can see what he is
// doing while everyone else sees grey.
//
// COSMETIC, NOT A PERMISSION. The page renders underneath, the APIs still answer,
// and devtools removes it in one click. It says "not ready yet"; it does not keep
// anyone out. Never put anything behind this that must not be seen — the real
// boundaries are tenant scoping and the endpoint gates.
//
// Lift it by unsetting DASHBOARD_VEIL in Render. No deploy, no code change.
const _veilRaw = ((process.env as any).DASHBOARD_VEIL ?? import.meta.env.DASHBOARD_VEIL ?? '')
  .toString().trim().toLowerCase();
const veilEnabled = _veilRaw === '1' || _veilRaw === 'true' || _veilRaw === 'on';
const showVeil = veilEnabled && !isAdmin;

// Support unread count — only fetched for admin sessions (one cheap query)
let adminSupportUnread = 0;
if (isAdmin) {
  try {
    const unreadRow = await db.execute(
      `SELECT COUNT(*) AS cnt FROM support_messages WHERE from_admin = 0 AND read_at IS NULL`
    );
    adminSupportUnread = Number((unreadRow.rows[0] as any)?.cnt ?? 0);
  } catch { /* non-fatal */ }
}

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
  /** Override where the Log out button redirects. Defaults to /login. */
  logoutRedirect?: string;
  /** HTML lang attribute — set to "es" for Spanish pages. Defaults to "en". */
  lang?: string;
}

const {
  title = 'SusuFinance — Crypto Portfolio Tracker & Bookkeeping Tool',
  description = 'Track your crypto wallets, DeFi positions, and exchange accounts in one place. Calculate realized gains, download your Year Summary, and stay on top of your net worth.',
  canonical = Astro.url.href,
  image = 'https://susufinance.com/og-default.png',
  noindex = false,
  logoutRedirect,
  lang = cookieLang,
} = Astro.props;

const navLang = isLang(lang) ? lang : 'en';
const tNav = getDashboardCommon(navLang);
// The operator nav reuses the circles locale's own strings (Circles / Programme),
// already trilingual — no new nav vocabulary, and it can't drift from the pages.
const tCircles = getCirclesLocale(navLang);

const isTradfiDomain = ['tradifitins.com', 'www.tradifitins.com'].includes(
  Astro.request.headers.get('x-forwarded-host') ?? Astro.url.hostname
);

// ── Promo expiry banner ───────────────────────────────────────────────────────
const PROMO_EXPIRY_SENTINEL = '9999-12-31T23:59:59Z';
let promoDaysLeft: number | null = null;
let promoExpiryDisplay: string | null = null;
if (tenantId) {
  try {
    const plan = await getActivePlan(tenantId);
    const expiresAt = (plan as any).promoExpiresAt as string | undefined;
    if (expiresAt && expiresAt !== PROMO_EXPIRY_SENTINEL) {
      const msLeft = new Date(expiresAt).getTime() - Date.now();
      const days = Math.ceil(msLeft / (1000 * 60 * 60 * 24));
      if (days <= 30 && days > 0) {
        promoDaysLeft = days;
        const dateLocale = navLang === 'es' ? 'es-ES' : navLang === 'fr' ? 'fr-FR' : 'en-US';
        promoExpiryDisplay = new Intl.DateTimeFormat(dateLocale, {
          month: 'long', day: 'numeric', year: 'numeric'
        }).format(new Date(expiresAt));
      }
    }
  } catch { /* non-fatal */ }
}

const memberSinceDisplay = memberSinceIso
  ? new Intl.DateTimeFormat(navLang === 'es' ? 'es-ES' : navLang === 'fr' ? 'fr-FR' : 'en-US', { month: 'short', day: 'numeric', year: 'numeric' }).format(new Date(memberSinceIso))
  : null;
---

<!doctype html>
<html lang={navLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="SusuFinance" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />

		<!-- Favicon -->
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<link rel="icon" href="/favicon.ico" sizes="any" />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

		<!-- Google Analytics -->
	<script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
<script is:inline define:vars={{ GA_ID, isDemo }}>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', GA_ID, isDemo ? { page_path: '/demo' + window.location.pathname } : {});
  if (isDemo) {
    gtag('set', 'user_properties', { demo_user: 'true' });
    gtag('event', 'demo_page_view', {
      event_category: 'demo',
      event_label: window.location.pathname,
    });
  }
</script>
	</head>
	<body>
		{/* The veil — greys the dashboard while the programme is being furnished.
		    Fixed-position, so its place in the DOM does not matter visually; it sits
		    here so it paints immediately rather than after the nav.
		    COSMETIC ONLY — see the note in the frontmatter. It is not a boundary. */}
		{showVeil && (
			<div class="veil" role="status" aria-live="polite">
				<div class="veil__note">
					<p class="veil__title">
						{navLang === 'fr' ? 'Bientôt prêt' : navLang === 'es' ? 'Casi listo' : 'Almost ready'}
					</p>
					<p class="veil__body">
						{navLang === 'fr'
							? 'Cet espace est en cours de préparation. Il ouvrira très bientôt.'
							: navLang === 'es'
								? 'Este espacio se está preparando. Se abrirá muy pronto.'
								: 'This space is still being set up. It will open shortly.'}
					</p>
				</div>
			</div>
		)}

		{isDemo && <DemoBanner />}
		{promoDaysLeft !== null && (
			<div class="promo-expiry-banner">
				<span class="promo-expiry-banner__icon">⏳</span>
				<span class="promo-expiry-banner__text">
					<strong>{tNav.chrome.promoDays(promoDaysLeft!)}</strong>
					{promoExpiryDisplay ? ` (${promoExpiryDisplay})` : ''}.
					{tNav.chrome.promoKeep}
				</span>
				<a href="/dashboard/billing" class="promo-expiry-banner__btn">
					{tNav.chrome.promoViewPlans}
				</a>
			</div>
		)}
		<div class="chrome">
			<header class="chrome__header" id="chrome-header">
				<div>
					<p class="brand">Titanium Hut</p>
					{isAdmin
					? <a class="dashboard-link" href="/admin">{tNav.chrome.adminDashboard}</a>
					: <a class="dashboard-link" href="/dashboard/circles">{tCircles.page.title}</a>
				}
				</div>
				<button id="nav-toggle" class="nav-toggle" aria-label={tNav.chrome.ariaOpenMenu} aria-expanded="false" aria-controls="nav-drawer">☰</button>
				<nav id="nav-drawer">
				{isTradfiDomain ? (
					<!-- TradfiTins-only nav -->
					<>
						<a href="/dashboard/petro-tins" class={`nav-link ${isActive('/dashboard/petro-tins') ? 'active' : ''}`}>Dashboard</a>
						<a href="/petro-tins/docs" class={`nav-link ${isActive('/petro-tins/docs') ? 'active' : ''}`}>Docs</a>
						<a href="/dashboard/petro-tins/upgrade" class={`nav-link ${isActive('/dashboard/petro-tins/upgrade') ? 'active' : ''}`}>Upgrade</a>
					</>
				) : (
					<!-- SusuFinance operator nav — Circles (the vault) and the aggregate
					     Programme view. The Almstins crypto strip (Vault/Portfolio/
					     Bookkeeping/Addresses/Memory Lane/Alerts) was removed here. -->
					<>
						<a href="/dashboard/circles" class={`nav-link ${currentPath.startsWith('/dashboard/circles') && !currentPath.startsWith('/dashboard/circles/stats') ? 'active' : ''}`}>{tCircles.page.title}</a>
						<a href="/dashboard/circles/stats" class={`nav-link ${isActive('/dashboard/circles/stats') ? 'active' : ''}`}>{tCircles.stats.title}</a>
					</>
				)}
				{!isTradfiDomain && isAdmin && (
					<>
						<a href="/admin" class={`nav-link nav-link--admin ${isActive('/admin') ? 'active' : ''}`}>Admin</a>
						<a href="/admin/support" class={`nav-link nav-link--admin ${isActive('/admin/support') ? 'active' : ''}`}>
							Support{adminSupportUnread > 0 ? ` (${adminSupportUnread})` : ''}
						</a>
					</>
				)}

					<!-- Language switcher -->
					<div class="lang-switch" role="group" aria-label="Language">
						<button type="button" class={`lang-opt ${navLang === 'en' ? 'active' : ''}`} data-setlang="en">EN</button>
						<button type="button" class={`lang-opt ${navLang === 'es' ? 'active' : ''}`} data-setlang="es">ES</button>
						<button type="button" class={`lang-opt ${navLang === 'fr' ? 'active' : ''}`} data-setlang="fr">FR</button>
					</div>

					<!-- Account dropdown -->
					<details class="account-menu">
						<summary class="account-trigger">
							{user?.image ? (
								<img class="account-avatar" src={user.image} alt={user.name ?? 'Account'} referrerpolicy="no-referrer" />
							) : (
								<img class="account-avatar account-avatar--default" src={defaultAvatar.src} alt="Account" />
							)}
							<span class="account-label">{tNav.chrome.account}</span>
							<span class="account-caret" aria-hidden="true">▾</span>
						</summary>

						<div class="account-dropdown">
							<!-- Identity -->
							<div class="account-identity">
								{user?.image ? (
									<img class="account-avatar account-avatar--lg" src={user.image} alt={user.name ?? ''} referrerpolicy="no-referrer" />
								) : (
									<img class="account-avatar account-avatar--lg account-avatar--default" src={defaultAvatar.src} alt="Account" />
								)}
								<div class="account-info">
									{user?.name && <p class="account-name">{user.name}</p>}
									<p class="account-email">{displayEmail ?? '—'}</p>
								</div>
							</div>

							<hr class="account-divider" />

							<!-- Meta: email, tenant ID, last login, member since -->
							<div class="account-meta-block">
								<div class="account-meta-row">
									<span class="account-meta-label">{tNav.chrome.accountEmail}</span>
									<span class="account-meta-value account-meta-email">{displayEmail ?? '—'}</span>
								</div>
								{user?.id && (
									<div class="account-meta-row">
										{/* The HUMAN's UUID (auth_users.id → token.sub), not the
										    programme's. Email already says which human, but this is
										    the id every support conversation and access log turns on. */}
										<span class="account-meta-label">{tNav.chrome.uuid}</span>
										<span class="account-meta-value">
											<code>{user.id.slice(0, 8)}&hellip;</code>
											<button
												class="copy-btn"
												type="button"
												data-copy={user.id}
												aria-label={tNav.chrome.ariaCopyUuid}
												title={tNav.chrome.ariaCopyUuid}
											>
												<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
											</button>
										</span>
									</div>
								)}
								{memberSinceDisplay && (
									<div class="account-meta-row">
										<span class="account-meta-label">{tNav.chrome.memberSince}</span>
										<span class="account-meta-value">{memberSinceDisplay}</span>
									</div>
								)}
							</div>

							<hr class="account-divider" />

							<!-- Export stats — the programme report. Aggregates only; no member
							     row leaves this programme (the endpoint aggregates in SQL). -->
							<a class="account-action" href="/api/circles/stats" download="programme-report.json">
								{tNav.chrome.exportStats}
							</a>

							<!-- Invite an admin. There is no email configured, so this mints a
							     LINK he sends however he likes. The token IS the credential:
							     single-use, 7 days. Owner-gated server-side — this button is
							     shown to everyone with an account, and the API decides. -->
							<div class="account-invite">
								<button id="invite-admin-btn" class="account-action" type="button">{tNav.chrome.inviteAdmin}</button>
								<div id="invite-result" class="account-invite__result" hidden>
									<input id="invite-url" class="account-invite__url" type="text" readonly />
									<button id="invite-copy" class="account-invite__copy" type="button">{tNav.chrome.inviteCopy}</button>
									<p class="account-invite__hint">{tNav.chrome.inviteHint}</p>
								</div>
							</div>

							<hr class="account-divider" />

							<!-- Delete account -->
							<div class="account-delete-wrap">
								<button id="delete-account-btn" class="account-delete" type="button">{tNav.chrome.deleteAccount}</button>
							</div>

							<hr class="account-divider" />

							<!-- Logout -->
							<form id="logout" method={logoutRedirect ? 'get' : 'post'} action={logoutRedirect ? `/api/logout?next=${encodeURIComponent(logoutRedirect)}` : '/api/logout'}>
								<button class="account-logout" type="submit">{tNav.chrome.logOut}</button>
							</form>
						</div>
					</details>
					{isDemo && (
						<div class="nav-demo-links">
							<a href="/" class="nav-link nav-demo-signup">{tNav.chrome.demoSignup}</a>
							<a href="/api/demo/end" class="nav-link nav-demo-exit">{tNav.chrome.demoExit}</a>
						</div>
					)}
				</nav>
			</header>
			<main>
				<slot />
			</main>
			<Footer lang={navLang} />
		</div>

		{user && (
			<>
				<!-- ── Help pill ──────────────────────────────────────────────────── -->
				<button id="help-pill" class="help-pill" aria-label={tNav.chrome.helpTitle} title={tNav.chrome.helpTitle}>
					{tNav.chrome.helpPill}
					<span id="help-pill-badge" class="help-pill__badge" hidden>0</span>
				</button>

				<!-- ── Help drawer ───────────────────────────────────────────────── -->
				<div id="help-drawer" class="help-drawer" role="dialog" aria-modal="true" aria-label="Support chat" hidden>
					<div class="help-drawer__header">
						<span class="help-drawer__title">{tNav.chrome.helpTitle}</span>
						<button id="help-drawer-close" class="help-drawer__close" aria-label={tNav.ui.close}>✕</button>
					</div>
					<div class="help-drawer__messages" id="help-messages">
						<p class="help-drawer__loading">{tNav.chrome.helpLoading}</p>
					</div>
					<div class="help-drawer__compose">
						<textarea
							id="help-input"
							class="help-drawer__input"
							placeholder={tNav.chrome.helpPlaceholder}
							maxlength="500"
							rows="3"
						></textarea>
						<div class="help-drawer__footer">
							<span id="help-char-count" class="help-drawer__count">0 / 500</span>
							<button id="help-send" class="help-drawer__send">{tNav.chrome.helpSend}</button>
						</div>
					</div>
				</div>
			</>
		)}
	</body>
</html>

{user && (
<script is:inline define:vars={{ chromeI18n: {
  helpLoading:       tNav.chrome.helpLoading,
  helpEmpty:         tNav.chrome.helpEmpty,
  helpSupportPrefix: tNav.chrome.helpSupportPrefix,
  helpYouPrefix:     tNav.chrome.helpYouPrefix,
  helpLoadError:     tNav.chrome.helpLoadError,
  helpSending:       tNav.chrome.helpSending,
  helpSend:          tNav.chrome.helpSend,
  helpSendError:     tNav.chrome.helpSendError,
  dateLocale:        navLang === 'es' ? 'es-ES' : navLang === 'fr' ? 'fr-FR' : 'en-US',
  inviteGenerating:  tNav.chrome.inviteGenerating,
  inviteCopy:        tNav.chrome.inviteCopy,
  inviteCopied:      tNav.chrome.inviteCopied,
  inviteFailed:      tNav.chrome.inviteFailed,
} }}>
window.__chromeI18n = chromeI18n;
</script>
)}

{user && (

<script>
// ── Mobile nav hamburger toggle ──────────────────────────────────────────
(function () {
	var toggle = document.getElementById('nav-toggle');
	var header = document.getElementById('chrome-header');
	if (!toggle || !header) return;

	function close() {
		header.classList.remove('nav-open');
		toggle.textContent = '☰';
		toggle.setAttribute('aria-expanded', 'false');
	}

	toggle.addEventListener('click', function (e) {
		e.stopPropagation();
		var open = header.classList.toggle('nav-open');
		toggle.textContent = open ? '✕' : '☰';
		toggle.setAttribute('aria-expanded', String(open));
	});

	// Close when clicking outside
	document.addEventListener('click', function (e) {
		if (!header.contains(e.target)) close();
	});

	// Close on nav link click (navigating away)
	document.getElementById('nav-drawer')?.querySelectorAll('a').forEach(function (a) {
		a.addEventListener('click', close);
	});
})();


(function () {
	const pill    = document.getElementById('help-pill');
	const drawer  = document.getElementById('help-drawer');
	const closeBtn= document.getElementById('help-drawer-close');
	const messages= document.getElementById('help-messages');
	const input   = document.getElementById('help-input') as HTMLTextAreaElement | null;
	const sendBtn = document.getElementById('help-send') as HTMLButtonElement | null;
	const counter = document.getElementById('help-char-count');
	const badge   = document.getElementById('help-pill-badge');
	if (!pill || !drawer || !messages || !input || !sendBtn || !counter || !badge) return;

	const LIMIT = 500;

	const fmtDate = (iso: string) => {
		try {
			const _loc = (window as any).__chromeI18n?.dateLocale || 'en-US';
			return new Intl.DateTimeFormat(_loc, {
				month: 'short', day: 'numeric',
				hour: 'numeric', minute: '2-digit',
			}).format(new Date(iso));
		} catch { return ''; }
	};

	function renderMessages(msgs: any[]) {
		messages!.innerHTML = '';
		if (!msgs.length) {
			const p = document.createElement('p');
			p.className = 'help-drawer__empty';
			p.textContent = ((window as any).__chromeI18n?.helpEmpty) || 'No messages yet.\nDescribe your issue below and we\'ll get back to you.';
			messages!.appendChild(p);
			return;
		}
		for (const msg of msgs) {
			const isAdmin = Number(msg.from_admin) === 1;
			const wrap    = document.createElement('div');
			wrap.className = `help-msg ${isAdmin ? 'help-msg--admin' : 'help-msg--user'}`;

			const text = document.createElement('div');
			text.className = 'help-msg__text';
			text.textContent = msg.body;

			const time = document.createElement('div');
			time.className = 'help-msg__time';
			const _i18n = (window as any).__chromeI18n || {};
			time.textContent = (isAdmin ? (_i18n.helpSupportPrefix || 'Support · ') : (_i18n.helpYouPrefix || 'You · ')) + fmtDate(msg.created_at);

			wrap.appendChild(text);
			wrap.appendChild(time);
			messages!.appendChild(wrap);
		}
		messages!.scrollTop = messages!.scrollHeight;
	}

	async function loadThread() {
		messages!.innerHTML = `<p class="help-drawer__loading">${((window as any).__chromeI18n?.helpLoading) || 'Loading…'}</p>`;
		try {
			const res  = await fetch('/api/support');
			const data = await res.json();
			renderMessages(Array.isArray(data.messages) ? data.messages : []);
			badge!.hidden = true; // cleared on read
		} catch {
			messages!.innerHTML = `<p class="help-drawer__empty">${((window as any).__chromeI18n?.helpLoadError) || 'Could not load messages.'}</p>`;
		}
	}

	// Badge: check unread on page load
	fetch('/api/support/unread')
		.then((r) => r.json())
		.then((d) => {
			const n = Number(d.unread ?? 0);
			if (n > 0) {
				badge!.textContent = String(n);
				badge!.hidden = false;
			}
		})
		.catch(() => {});

	let drawerOpen = false;

	pill.addEventListener('click', () => {
		drawerOpen = !drawerOpen;
		drawer!.hidden = !drawerOpen;
		if (drawerOpen) {
			loadThread();
			setTimeout(() => input!.focus(), 60);
		}
	});

	closeBtn!.addEventListener('click', () => {
		drawerOpen = false;
		drawer!.hidden = true;
	});

	// Close on Escape
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape' && drawerOpen) {
			drawerOpen = false;
			drawer!.hidden = true;
		}
	});

	// Character counter
	input.addEventListener('input', () => {
		const len = input!.value.length;
		counter!.textContent = `${len} / ${LIMIT}`;
		counter!.className = 'help-drawer__count' +
			(len >= LIMIT ? ' at-limit' : len >= LIMIT * 0.85 ? ' near-limit' : '');
	});

	// Send
	sendBtn.addEventListener('click', async () => {
		const text = input!.value.trim();
		if (!text) return;
		sendBtn!.disabled = true;
		sendBtn!.textContent = ((window as any).__chromeI18n?.helpSending) || 'Sending…';
		try {
			const res  = await fetch('/api/support', {
				method:  'POST',
				headers: { 'Content-Type': 'application/json' },
				body:    JSON.stringify({ body: text }),
			});
			const data = await res.json();
			if (!data.ok) throw new Error(data.error ?? 'Failed to send.');
			input!.value = '';
			counter!.textContent = `0 / ${LIMIT}`;
			counter!.className = 'help-drawer__count';
			await loadThread();
		} catch (err: any) {
			alert(err?.message ?? ((window as any).__chromeI18n?.helpSendError || 'Could not send message. Please try again.'));
		} finally {
			sendBtn!.disabled = false;
			sendBtn!.textContent = ((window as any).__chromeI18n?.helpSend) || 'Send';
		}
	});

	// Cmd/Ctrl+Enter to send
	input.addEventListener('keydown', (e) => {
		if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') sendBtn!.click();
	});
})();
</script>
)}


<script>
	// Copy-to-clipboard for tenant ID button
	// Attach directly to each button so the click is treated as a user gesture
	// (document-level delegation can lose transient activation in strict Chrome contexts).
	function initCopyBtn(btn: HTMLButtonElement) {
		btn.addEventListener('click', (e) => {
			e.stopPropagation(); // prevent details from toggling
			const text = btn.dataset.copy ?? '';
			if (!text) return;

			const checkmark = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;

			const showFeedback = () => {
				const prev = btn.innerHTML;
				const origTitle = btn.title;
				btn.classList.add('copied');
				btn.title = 'Copied!';
				btn.innerHTML = checkmark;
				setTimeout(() => {
					btn.classList.remove('copied');
					btn.title = origTitle;
					btn.innerHTML = prev;
				}, 2000);
			};

			if (navigator.clipboard?.writeText) {
				navigator.clipboard.writeText(text).then(showFeedback).catch(() => {
					// fallback
					const ta = document.createElement('textarea');
					ta.value = text;
					ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
					document.body.appendChild(ta);
					ta.select();
					document.execCommand('copy');
					document.body.removeChild(ta);
					showFeedback();
				});
			} else {
				const ta = document.createElement('textarea');
				ta.value = text;
				ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
				showFeedback();
			}
		});
	}

	document.querySelectorAll<HTMLButtonElement>('.copy-btn[data-copy]').forEach(initCopyBtn);

	// ── Invite an admin ───────────────────────────────────────────────────────
	// Mints a single-use link. The button is visible to anyone with an account;
	// the API refuses anyone who is not an owner of this programme. Client-side
	// hiding is decoration — the server is the gate.
	(() => {
		const btn    = document.getElementById('invite-admin-btn') as HTMLButtonElement | null;
		const result = document.getElementById('invite-result')    as HTMLElement       | null;
		const urlEl  = document.getElementById('invite-url')       as HTMLInputElement  | null;
		const copyEl = document.getElementById('invite-copy')      as HTMLButtonElement | null;
		if (!btn || !result || !urlEl || !copyEl) return;

		const i18n = (window as any).__chromeI18n ?? {};
		btn.addEventListener('click', async () => {
			const original = btn.textContent;
			btn.disabled = true;
			btn.textContent = i18n.inviteGenerating || 'Making a link…';
			try {
				const res = await fetch('/api/admin/invite', { method: 'POST' });
				const data = await res.json();
				if (!res.ok || !data.ok) throw new Error(data.error || String(res.status));
				urlEl.value = data.url;
				result.hidden = false;
				btn.hidden = true;
			} catch {
				btn.textContent = i18n.inviteFailed || 'Could not make a link';
				btn.disabled = false;
				setTimeout(() => { btn.textContent = original; }, 2500);
			}
		});

		copyEl.addEventListener('click', async () => {
			urlEl.select();
			try {
				await navigator.clipboard.writeText(urlEl.value);
			} catch {
				document.execCommand('copy');
			}
			const was = copyEl.textContent;
			copyEl.textContent = i18n.inviteCopied || 'Copied';
			setTimeout(() => { copyEl.textContent = was; }, 1500);
		});
	})();

</script>

<script>
	// Delete account
	document.getElementById('delete-account-btn')?.addEventListener('click', async () => {
		const confirmed = confirm('Are you sure? This will permanently delete everything you have stored. This cannot be undone.');
		if (!confirmed) return;
		const confirmed2 = confirm('Last chance — all your tins, entries, and subscription data will be permanently and irreversibly deleted. Continue?');
		if (!confirmed2) return;
		try {
			const res = await fetch('/api/account/delete', { method: 'POST' });
			if (res.ok) {
				window.location.href = '/login';
			} else {
				const d = await res.json().catch(() => ({}));
				alert(d.error ?? 'Could not delete account. Please try again.');
			}
		} catch {
			alert('Could not delete account. Please try again.');
		}
	});
</script>

<script>
	// Dashboard language switcher — set the almstins-lang cookie and reload.
	document.querySelectorAll('[data-setlang]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const l = btn.getAttribute('data-setlang');
			if (!l) return;
			document.cookie = 'almstins-lang=' + l + '; path=/; max-age=31536000; samesite=lax';
			// Persist to the account so emails (digests, alerts, receipts) match the chosen language.
			try { fetch('/api/account/lang', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ lang: l }), keepalive: true }); } catch (e) {}
			location.reload();
		});
	});
</script>

