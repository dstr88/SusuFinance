---
import type { SignupLocale } from '@/i18n/signup';

interface Props {
	t: SignupLocale;
	error?: string | null;
}

const { t, error } = Astro.props;

const message =
	error === 'email'             ? t.errors.email :
	error === 'email_domain'      ? t.errors.email_domain :
	error === 'password'          ? t.errors.password :
	error === 'exists'            ? t.errors.exists :
	error === 'terms_not_accepted'? t.terms.error : '';

// Sign-in link points at the matching-language login/marketing surface
// (/, /es, /fr are one trilingual page after the homepage merge).
const loginHref = t.lang === 'es' ? '/es' : t.lang === 'fr' ? '/fr' : '/login';
---

<!doctype html>
<html lang={t.lang}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{t.meta.title}</title>
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<style>
			:root {
				color-scheme: dark;
				font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
				background: radial-gradient(circle at top, #141630, #070910 65%);
				min-height: 100vh;
				color: #f5f8ff;
			}

			body {
				margin: 0;
				min-height: 100vh;
				display: flex;
				align-items: center;
				justify-content: center;
			}

			main {
				width: min(460px, calc(100% - 2rem));
				background: rgba(255, 255, 255, 0.04);
				border: 1px solid rgba(255, 255, 255, 0.08);
				border-radius: 20px;
				padding: 2rem;
				box-shadow: 0 25px 60px rgba(0, 0, 0, 0.45);
			}

			h1 {
				margin-top: 0;
				margin-bottom: 0.5rem;
				font-size: 1.45rem;
				font-weight: 600;
			}

			p {
				margin-top: 0;
				margin-bottom: 1.5rem;
				color: rgba(255, 255, 255, 0.75);
				font-size: 0.95rem;
			}

			form {
				display: flex;
				flex-direction: column;
				gap: 1rem;
			}

			label {
				display: flex;
				flex-direction: column;
				gap: 0.45rem;
				color: rgba(255, 255, 255, 0.85);
				font-weight: 500;
			}

			input {
				border-radius: 12px;
				border: 1px solid rgba(255, 255, 255, 0.18);
				background: rgba(255, 255, 255, 0.08);
				backdrop-filter: blur(4px);
				color: #fff;
				padding: 0.75rem 1rem;
				font-size: 1rem;
			}

			input:focus {
				outline: 2px solid rgba(84, 144, 255, 0.9);
				outline-offset: 1px;
			}

			button {
				border-radius: 12px;
				padding: 0.85rem 1rem;
				border: none;
				background: linear-gradient(135deg, #5767ff, #934dff);
				color: #fff;
				font-size: 1rem;
				font-weight: 600;
				cursor: pointer;
				transition: opacity 0.2s ease;
			}

			button:hover {
				opacity: 0.92;
			}

			.notice {
				background: rgba(255, 107, 107, 0.12);
				border: 1px solid rgba(255, 107, 107, 0.35);
				color: #ffb5b5;
				padding: 0.75rem 1rem;
				border-radius: 12px;
				font-size: 0.9rem;
			}

			.helper {
				margin: 0.5rem 0 0;
				font-size: 0.9rem;
				color: rgba(255, 255, 255, 0.7);
			}

			.helper a {
				color: #c7d2ff;
				text-decoration: none;
			}

			.value-reminder {
				background: rgba(99, 102, 241, 0.1);
				border: 1px solid rgba(99, 102, 241, 0.25);
				border-radius: 10px;
				padding: 0.65rem 0.9rem;
				color: rgba(199, 210, 255, 0.9);
				font-size: 0.9rem;
				margin-bottom: 1rem;
			}

			/* Language switcher (EN / ES / FR) — colors match this page's pre-token palette */
			.lang-switch {
				position: fixed;
				top: 1.25rem;
				right: 1.25rem;
				z-index: 10;
				display: inline-flex;
				align-items: center;
				gap: 0.15rem;
				padding: 0.25rem 0.3rem;
				border-radius: 999px;
				border: 1px solid rgba(255, 255, 255, 0.18);
				background: rgba(255, 255, 255, 0.04);
			}

			.lang-switch a {
				padding: 0.2rem 0.55rem;
				border-radius: 999px;
				color: rgba(255, 255, 255, 0.6);
				font-size: 0.75rem;
				font-weight: 700;
				letter-spacing: 0.05em;
				text-decoration: none;
				transition: color 0.15s, background 0.15s;
			}

			.lang-switch a:hover {
				color: #fff;
			}

			.lang-switch a[aria-current='true'] {
				background: rgba(99, 102, 241, 0.25);
				color: #fff;
			}

			.terms-row {
				display: flex;
				align-items: flex-start;
				gap: 0.6rem;
				font-size: 0.88rem;
				color: rgba(255, 255, 255, 0.75);
				line-height: 1.5;
			}

			.terms-row input[type="checkbox"] {
				margin-top: 0.18rem;
				flex-shrink: 0;
				width: 1rem;
				height: 1rem;
				accent-color: #5767ff;
				cursor: pointer;
				padding: 0;
				border-radius: 3px;
			}

			.terms-row a {
				color: #c7d2ff;
				text-decoration: underline;
				text-underline-offset: 2px;
			}

			button:disabled {
				opacity: 0.45;
				cursor: not-allowed;
			}
		</style>
	</head>
	<body>
		<nav class="lang-switch" aria-label="Language">
			<a href="/signup" aria-current={t.lang === 'en' ? 'true' : undefined}>EN</a>
			<a href="/signup/es" aria-current={t.lang === 'es' ? 'true' : undefined}>ES</a>
			<a href="/signup/fr" aria-current={t.lang === 'fr' ? 'true' : undefined}>FR</a>
		</nav>
		<main>
			<h1>{t.heading}</h1>
			<p class="value-reminder">{t.valueReminder}</p>
			<p>{t.subhead}</p>

			{message && <p class="notice">{message}</p>}

			<form id="signup-new-account" method="POST" action="/api/signup">
				<input type="hidden" name="lang" value={t.lang} />
				<label>
					<span>{t.labels.email}</span>
					<input type="email" name="email" placeholder={t.placeholders.email} required />
				</label>
				<label>
					<span>{t.labels.password}</span>
					<input type="password" name="password" minlength="10" required />
				</label>

				<label class="terms-row">
					<input type="checkbox" name="terms_accepted" id="terms-checkbox" />
					<span set:html={t.terms.label} />
				</label>

				<button type="submit" id="signup-submit" disabled>{t.submit}</button>
			</form>

			<p class="helper">
				{t.haveAccount} <a href={loginHref}>{t.signIn}</a>
			</p>
		</main>
		<script is:inline>
			var cb = document.getElementById('terms-checkbox');
			var btn = document.getElementById('signup-submit');
			if (cb && btn) {
				cb.addEventListener('change', function() {
					btn.disabled = !cb.checked;
				});
			}
		</script>
	</body>
</html>
