---
import './ProfileCard.css';
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  name?: string;
  photoSrc: ImageMetadata;
  xHandle?: string;
  linkedinHandle?: string;
  telegramHandle?: string;
}

const { name, photoSrc, xHandle, linkedinHandle, telegramHandle } =
  Astro.props as Props;

const xUrl = xHandle ? `https://x.com/${xHandle.replace(/^@/, "")}` : null;
const linkedinUrl = linkedinHandle
  ? `https://www.linkedin.com/in/${linkedinHandle.replace(/^@/, "")}`
  : null;
const telegramUrl = telegramHandle
  ? `https://t.me/${telegramHandle.replace(/^@/, "")}`
  : null;
---

<div class="profile-card">
  <div class="photo-wrap">
    <Image
      src={photoSrc}
      alt=""
      aria-hidden="true"
      class="profile-photo"
      width={150}
      height={150}
      loading="eager"
    />
  </div>

  {name && <h2>{name}</h2>}

  {(xUrl || linkedinUrl || telegramUrl) && (
    <div class="social-links">
      {xUrl && (
        <a href={xUrl} target="_blank" rel="noreferrer" aria-label="X/Twitter">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M17.2 3h3.6l-7.9 9 9.3 9h-6.9l-5.4-6.6-5.9 6.6H0l8.4-9.4L0 3h7.1l4.9 5.9L17.2 3Zm-1.3 16h2l-11-13h-2l11 13Z"
            />
          </svg>
        </a>
      )}
      {linkedinUrl && (
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="LinkedIn"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M20.5 3h-17A2.5 2.5 0 0 0 1 5.5v13A2.5 2.5 0 0 0 3.5 21h17a2.5 2.5 0 0 0 2.5-2.5v-13A2.5 2.5 0 0 0 20.5 3ZM8.3 18.3H5.6V9h2.7v9.3Zm-1.4-10.6a1.6 1.6 0 1 1 0-3.2 1.6 1.6 0 0 1 0 3.2Zm11.4 10.6h-2.7v-4.6c0-1.1 0-2.5-1.6-2.5-1.6 0-1.8 1.2-1.8 2.4v4.7H9.6V9h2.6v1.3h.1c.4-.7 1.4-1.5 2.9-1.5 3.1 0 3.7 2 3.7 4.7v4.8Z"
            />
          </svg>
        </a>
      )}
      {telegramUrl && (
        <a
          href={telegramUrl}
          target="_blank"
          rel="noreferrer"
          aria-label="Telegram"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              fill="currentColor"
              d="M21.8 4.2a1.6 1.6 0 0 0-1.7-.3L3.2 10.2a1.6 1.6 0 0 0 .1 3l4.4 1.4 1.7 5.1a1.6 1.6 0 0 0 2.8.4l2.4-3.1 4.6 3.3a1.6 1.6 0 0 0 2.5-1L22.3 6a1.6 1.6 0 0 0-.5-1.8Zm-3.3 14.2-4.4-3.1a1 1 0 0 0-1.4.2l-1.8 2.4-1.3-4a1 1 0 0 0-.6-.6l-3.8-1.2L19.9 6.5l-1.4 11.9Z"
            />
          </svg>
        </a>
      )}
    </div>
  )}
</div>

