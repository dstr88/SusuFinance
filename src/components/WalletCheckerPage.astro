---
import type { WalletCheckerLocale } from '../i18n/walletChecker';
import LoginLayout from '../layouts/LoginLayout.astro';
import WalletChecker from './WalletChecker';

interface Props {
  t: WalletCheckerLocale;
  prefilledAddress: string;
  isLoggedIn?: boolean;
  isPaid?: boolean;
}

const { t, prefilledAddress, isLoggedIn = false, isPaid = false } = Astro.props;
---

<LoginLayout title={t.meta.title} description={t.meta.description} noindex={false}>

  <!-- JSON-LD: WebApplication -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": t.jsonld.appName,
    "url": t.jsonld.appUrl,
    "description": t.jsonld.appDescription,
    "applicationCategory": "FinanceApplication",
    "operatingSystem": "Any",
    "browserRequirements": "Requires JavaScript",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "creator": { "@type": "Organization", "name": "Almstins", "url": "https://almstins.com" },
    "featureList": t.jsonld.featureList,
  })} />

  <!-- JSON-LD: FAQPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": t.faq.items.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a },
    })),
  })} />

  <!-- i18n runtime strings for the client script -->
  <script id="wc-i18n" type="application/json" set:html={JSON.stringify(t.js)} />

  <!-- Top nav -->
  <nav class="topnav" aria-label={t.nav.ariaLabel}>
    <a class="topnav__brand" href="/" aria-label={t.nav.brandAriaLabel}>
      <span class="topnav__wordmark">Almstins</span>
      <span class="topnav__tagline">{t.nav.tagline}</span>
    </a>
    <div class="topnav__actions">
      <div class="topnav__langs" aria-label="Language">
        <a class="topnav__lang" href="/wallet-checker" aria-current={t.lang === 'en' ? 'true' : undefined}>EN</a>
        <a class="topnav__lang" href="/wallet-checker/es" aria-current={t.lang === 'es' ? 'true' : undefined}>ES</a>
        <a class="topnav__lang" href="/wallet-checker/fr" aria-current={t.lang === 'fr' ? 'true' : undefined}>FR</a>
      </div>
      <a class="topnav__login" href="/login">{t.nav.login}</a>
      <a class="topnav__signup" href="/login">{t.nav.signup}</a>
    </div>
  </nav>

  <div class="page">

    <!-- Hero -->
    <header class="hero">
      <div class="hero__eyebrow">{t.hero.eyebrow}</div>
      <h1 class="hero__title">{t.hero.title}</h1>
      <p class="hero__sub">{t.hero.sub}</p>

      <!-- Primary action: scan a QR (opens the camera in the wallet island), plus the
           account entry point. Scanning stays free and login-optional. -->
      <div class="qr-top-bar">
        <button type="button" id="qr-top-btn" class="qr-top-btn" aria-label={t.checker.scanAria}>
          {t.checker.scanQr}
        </button>
        <a class="qr-top-login" href="/login">{t.hero.loginCta}</a>
        <p class="qr-top-note">{t.hero.loginNote}</p>
      </div>

      <p class="hero__or">{t.hero.orPaste}</p>

      <div class="threat-grid">

        <!-- Card 1: site/dApp -->
        <div class="threat-card">
          <button class="threat-card__top" data-modal="modal-phishing" aria-haspopup="dialog">
            <span class="threat-card__icon">🌐</span>
            <span class="threat-card__title">{t.cards.site.title}</span>
            <span class="threat-card__cta">{t.cards.site.cta}</span>
          </button>
          <div class="threat-card__divider"></div>
          <div class="threat-card__checker">
            <input class="threat-card__input" type="text" placeholder={t.cards.site.placeholder} autocomplete="off" spellcheck="false" data-checker="dapp" />
            <button class="threat-card__check-btn" data-checker="dapp">{t.cards.site.button}</button>
          </div>
        </div>

        <!-- Card 2: wallet -->
        <div class="threat-card">
          <button class="threat-card__top" data-modal="modal-scam" aria-haspopup="dialog">
            <span class="threat-card__icon">💀</span>
            <span class="threat-card__title">{t.cards.wallet.title}</span>
            <span class="threat-card__cta">{t.cards.wallet.cta}</span>
          </button>
          <div class="threat-card__divider"></div>
          <div class="threat-card__checker">
            <input class="threat-card__input" type="text" placeholder={t.cards.wallet.placeholder} autocomplete="off" spellcheck="false" data-checker="wallet" />
            <button class="threat-card__check-btn" data-checker="wallet">{t.cards.wallet.button}</button>
          </div>
        </div>

        <!-- Card 3: approval -->
        <div class="threat-card">
          <button class="threat-card__top" data-modal="modal-approval" aria-haspopup="dialog">
            <span class="threat-card__icon">🔓</span>
            <span class="threat-card__title">{t.cards.approval.title}</span>
            <span class="threat-card__cta">{t.cards.approval.cta}</span>
          </button>
          <div class="threat-card__divider"></div>
          <div class="threat-card__approval-links">
            <p class="threat-card__approval-desc">{t.cards.approval.desc}</p>
            <a href="https://revoke.cash" target="_blank" rel="noopener noreferrer" class="threat-card__approval-link">
              <span class="approval-link__name">revoke.cash</span>
              <span class="approval-link__arrow">↗</span>
            </a>
            <a href="https://etherscan.io/tokenapprovalchecker" target="_blank" rel="noopener noreferrer" class="threat-card__approval-link">
              <span class="approval-link__name">etherscan.io</span>
              <span class="approval-link__arrow">↗</span>
            </a>
          </div>
        </div>

      </div>
    </header>

    <!-- Modal: phishing -->
    <div id="modal-phishing" class="threat-modal" role="dialog" aria-modal="true" aria-labelledby="modal-phishing-title">
      <div class="threat-modal__box">
        <button class="threat-modal__close" aria-label={t.modal.close}>&times;</button>
        <div class="threat-modal__icon">🌐</div>
        <h2 class="threat-modal__title" id="modal-phishing-title">{t.modals.phishing.title}</h2>
        <p class="threat-modal__subtitle">{t.modals.phishing.subtitle}</p>
        <div class="threat-modal__body">
          <p set:html={t.modals.phishing.p1}></p>
          <div class="threat-modal__example" set:html={t.modals.phishing.example}></div>
          <p>{t.modals.phishing.p2}</p>
          <div class="threat-modal__tip" set:html={t.modals.phishing.tip}></div>
        </div>
      </div>
    </div>

    <!-- Modal: scam -->
    <div id="modal-scam" class="threat-modal" role="dialog" aria-modal="true" aria-labelledby="modal-scam-title">
      <div class="threat-modal__box">
        <button class="threat-modal__close" aria-label={t.modal.close}>&times;</button>
        <div class="threat-modal__icon">💀</div>
        <h2 class="threat-modal__title" id="modal-scam-title">{t.modals.scam.title}</h2>
        <p class="threat-modal__subtitle">{t.modals.scam.subtitle}</p>
        <div class="threat-modal__body">
          <p set:html={t.modals.scam.p1}></p>
          <div class="threat-modal__example" set:html={t.modals.scam.example}></div>
          <p>{t.modals.scam.p2}</p>
          <div class="threat-modal__tip" set:html={t.modals.scam.tip}></div>
        </div>
      </div>
    </div>

    <!-- Modal: approval -->
    <div id="modal-approval" class="threat-modal" role="dialog" aria-modal="true" aria-labelledby="modal-approval-title">
      <div class="threat-modal__box">
        <button class="threat-modal__close" aria-label={t.modal.close}>&times;</button>
        <div class="threat-modal__icon">🔓</div>
        <h2 class="threat-modal__title" id="modal-approval-title">{t.modals.approval.title}</h2>
        <p class="threat-modal__subtitle">{t.modals.approval.subtitle}</p>
        <div class="threat-modal__body">
          <p set:html={t.modals.approval.p1}></p>
          <div class="threat-modal__example" set:html={t.modals.approval.example}></div>
          <p>{t.modals.approval.p2}</p>
          <div class="threat-modal__tip" set:html={t.modals.approval.tip}></div>
        </div>
      </div>
    </div>

    <!-- Tab switcher -->
    <div class="checker-tabs" role="tablist" aria-label={t.tabs.ariaLabel}>
      <button class="checker-tab active" id="tab-btn-wallet" role="tab" aria-selected="true" aria-controls="panel-wallet" data-tab="wallet">
        {t.tabs.wallet}
      </button>
      <button class="checker-tab" id="tab-btn-dapp" role="tab" aria-selected="false" aria-controls="panel-dapp" data-tab="dapp">
        {t.tabs.dapp}
      </button>
    </div>

    <!-- Wallet checker panel -->
    <div id="panel-wallet" class="checker-wrap" role="tabpanel" aria-labelledby="tab-btn-wallet">
      <WalletChecker client:load prefilledAddress={prefilledAddress} c={t.checker} />
    </div>

    <!-- dApp checker panel -->
    <div id="panel-dapp" class="dapp-panel" role="tabpanel" aria-labelledby="tab-btn-dapp" hidden>
      <div class="dapp-input-row">
        <input id="dapp-url-input" type="text" placeholder={t.dappPanel.placeholder} autocomplete="off" spellcheck="false" />
        <button id="dapp-check-btn" type="button">{t.dappPanel.button}</button>
      </div>

      <div id="dapp-result" class="dapp-result" hidden>
        <div class="verdict-banner" id="verdict-banner">
          <span class="verdict-icon" id="verdict-icon"></span>
          <div>
            <p class="verdict-label" id="verdict-label"></p>
            <p class="verdict-url" id="verdict-url"></p>
          </div>
        </div>
        <ul class="source-list" id="source-list"></ul>
        <div class="safety-tip" id="safety-tip"></div>
      </div>

      <div id="dapp-loading" class="dapp-loading" hidden>
        <span class="spinner"></span> {t.dappPanel.loading}
      </div>

      <div id="dapp-status" class="dapp-status" hidden></div>

      <div id="dapp-error" class="dapp-error" hidden></div>
    </div>

    <!-- Community ratings panel (appears after a check result) -->
    <div id="cr-session" style="display:none"
      data-logged-in={isLoggedIn ? '1' : '0'}
      data-paid={isPaid ? '1' : '0'}
    ></div>
    <div id="cr-panel" class="cr-panel" hidden></div>

    <!-- Example results section -->
    <section class="examples-section" aria-labelledby="examples-heading">
      <h2 id="examples-heading" class="examples__title">What a check looks like</h2>
      <p class="examples__sub">Three real result types — run any address or URL to see yours.</p>

      <div class="examples__grid">

        <!-- Clean -->
        <div class="ex-card ex-card--clean">
          <div class="ex-card__header">
            <span class="ex-card__chain-pill">Ethereum</span>
            <span class="ex-card__addr">0x71C7656EC7ab88b098defB751B7401B5f6d8976F</span>
          </div>
          <div class="ex-card__meter">
            <div class="ex-card__score-row">
              <span class="ex-card__score" style="color:#22c55e">2</span>
              <div class="ex-card__verdict">
                <span class="ex-card__verdict-label" style="color:#22c55e">✓ No threats detected</span>
                <span class="ex-card__verdict-sub">Score out of 100 — lower is safer</span>
              </div>
            </div>
            <div class="ex-card__bar-track">
              <div class="ex-card__bar-fill" style="width:2%;background:#22c55e"></div>
            </div>
          </div>
          <ul class="ex-card__flags">
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>Not on any blacklist</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>No sanctions match</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>No mixer activity</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>Active wallet — 4 years old</li>
          </ul>
          <p class="ex-card__footnote">GoPlus · OFAC · ChainAbuse ran</p>
        </div>

        <!-- Caution -->
        <div class="ex-card ex-card--caution">
          <div class="ex-card__header">
            <span class="ex-card__chain-pill">Ethereum</span>
            <span class="ex-card__addr">0x3fC91A3afd70395Cd496C647d5a6CC9D4B2b7FAD</span>
          </div>
          <div class="ex-card__meter">
            <div class="ex-card__score-row">
              <span class="ex-card__score" style="color:#f59e0b">45</span>
              <div class="ex-card__verdict">
                <span class="ex-card__verdict-label" style="color:#f59e0b">⚠ Proceed with caution</span>
                <span class="ex-card__verdict-sub">Score out of 100 — lower is safer</span>
              </div>
            </div>
            <div class="ex-card__bar-track">
              <div class="ex-card__bar-fill" style="width:45%;background:#f59e0b"></div>
            </div>
          </div>
          <div class="ex-card__flag-banner" style="background:rgba(245,158,11,0.08);border-color:rgba(245,158,11,0.25);color:#fcd34d">
            Flagged for: wallet age under 30 days
          </div>
          <ul class="ex-card__flags">
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>Not on any blacklist</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>No sanctions match</li>
            <li class="ex-flag ex-flag--warn"><span class="ex-flag__dot"></span>Wallet created 12 days ago</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>No mixer activity</li>
          </ul>
          <p class="ex-card__footnote">GoPlus · OFAC · ChainAbuse ran</p>
        </div>

        <!-- Danger -->
        <div class="ex-card ex-card--danger">
          <div class="ex-card__header">
            <span class="ex-card__chain-pill">Ethereum</span>
            <span class="ex-card__addr">0x8589427373D6D84E98730D7795D8f6f8731FDA16</span>
          </div>
          <div class="ex-card__meter">
            <div class="ex-card__score-row">
              <span class="ex-card__score" style="color:#ef4444">92</span>
              <div class="ex-card__verdict">
                <span class="ex-card__verdict-label" style="color:#ef4444">✕ High risk — do not send</span>
                <span class="ex-card__verdict-sub">Score out of 100 — lower is safer</span>
              </div>
            </div>
            <div class="ex-card__bar-track">
              <div class="ex-card__bar-fill" style="width:92%;background:#ef4444"></div>
            </div>
          </div>
          <div class="ex-card__flag-banner" style="background:rgba(239,68,68,0.08);border-color:rgba(239,68,68,0.22);color:#fca5a5">
            Flagged for: on global blacklist, OFAC sanctioned
          </div>
          <ul class="ex-card__flags">
            <li class="ex-flag ex-flag--danger"><span class="ex-flag__dot"></span>On GoPlus global blacklist</li>
            <li class="ex-flag ex-flag--danger"><span class="ex-flag__dot"></span>OFAC sanctions match</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>No mixer activity</li>
            <li class="ex-flag ex-flag--ok"><span class="ex-flag__dot"></span>Wallet established (2019)</li>
          </ul>
          <p class="ex-card__footnote">GoPlus · OFAC · ChainAbuse ran</p>
        </div>

      </div>
    </section>

    <!-- Almstins CTA -->
    <section class="cta-banner" aria-label={t.cta.ariaLabel}>
      <div class="cta-banner__icon" aria-hidden="true">📊</div>
      <div class="cta-banner__body">
        <p class="cta-banner__headline">{t.cta.headline}</p>
        <p class="cta-banner__sub">{t.cta.sub}</p>
      </div>
      <a class="cta-banner__btn" href="/login">{t.cta.button}</a>
    </section>

    <!-- What we check -->
    <section class="signals" aria-labelledby="signals-heading">
      <h2 id="signals-heading" class="signals__title">{t.signals.title}</h2>

      <p class="signals__sub">{t.signals.walletSub}</p>
      <div class="signals__grid">
        {t.signals.walletCards.map(s => (
          <div class="signal-card">
            <span class="signal-card__icon">{s.icon}</span>
            <h3 class="signal-card__label">{s.label}</h3>
            <p class="signal-card__body">{s.body}</p>
          </div>
        ))}
      </div>

      <p class="signals__sub" style="margin-top:2rem">{t.signals.dappSub}</p>
      <div class="signals__grid">
        {t.signals.dappCards.map(s => (
          <div class="signal-card">
            <span class="signal-card__icon">{s.icon}</span>
            <h3 class="signal-card__label">{s.label}</h3>
            <p class="signal-card__body">{s.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Wallet approvals section -->
    <section class="approvals-section" aria-labelledby="approvals-heading">
      <h2 id="approvals-heading" class="approvals__title">{t.approvals.title}</h2>
      <p class="approvals__intro">{t.approvals.intro}</p>

      <div class="approvals__cards">
        <div class="approvals__card approvals__card--what">
          <h3 set:html={t.approvals.whatTitle}></h3>
          <p set:html={t.approvals.whatP1}></p>
          <p>{t.approvals.whatP2}</p>
        </div>

        <div class="approvals__card approvals__card--how">
          <h3>{t.approvals.howTitle}</h3>
          <p>{t.approvals.howIntro}</p>
          <ul class="approvals__tools">
            <li>
              <a href="https://revoke.cash" target="_blank" rel="noopener noreferrer" class="tool-link">
                <span class="tool-link__name">revoke.cash</span>
                {t.approvals.tools[0].badge && <span class="tool-link__badge">{t.approvals.tools[0].badge}</span>}
              </a>
              <span class="tool-link__desc">{t.approvals.tools[0].desc}</span>
            </li>
            <li>
              <a href="https://etherscan.io/tokenapprovalchecker" target="_blank" rel="noopener noreferrer" class="tool-link">
                <span class="tool-link__name">etherscan.io/tokenapprovalchecker</span>
              </a>
              <span class="tool-link__desc">{t.approvals.tools[1].desc}</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="approvals__tips">
        <h3 class="approvals__tips-title">{t.approvals.tipsTitle}</h3>
        <div class="approvals__tips-grid">
          {t.approvals.tips.map(tip => (
            <div class="approvals__tip">
              <span class="tip-icon">{tip.icon}</span>
              <div>
                <strong>{tip.title}</strong>
                <p>{tip.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="faq__title">{t.faq.title}</h2>
      <div class="faq__list">
        {t.faq.items.map(item => (
          <details class="faq__item">
            <summary class="faq__q">
              <span>{item.q}</span>
              <span class="faq__chevron" aria-hidden="true">›</span>
            </summary>
            <p class="faq__a">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- Disclaimer -->
    <p class="disclaimer">
      {t.disclaimer.text}
      <br />
      <a class="disclaimer__link" href="/">{t.disclaimer.link}</a>
    </p>

  </div>
</LoginLayout>

<style>
  /* ── Wallet approvals section ── */
  .approvals-section {
    max-width: 860px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }
  .approvals__title {
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 800; letter-spacing: -0.01em;
    margin: 0 0 0.85rem; color: #f5f8ff;
  }
  .approvals__intro {
    font-size: 0.97rem; color: rgba(255,255,255,0.55);
    line-height: 1.75; margin: 0 0 1.75rem;
    max-width: 740px;
  }

  .approvals__cards {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    margin-bottom: 1.75rem;
  }
  @media (max-width: 680px) { .approvals__cards { grid-template-columns: 1fr; } }

  .approvals__card {
    border-radius: 14px; padding: 1.5rem;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
  }
  .approvals__card--what { border-color: rgba(248,113,113,0.2); background: rgba(248,113,113,0.04); }
  .approvals__card--how  { border-color: rgba(99,102,241,0.2);  background: rgba(99,102,241,0.04); }

  .approvals__card h3 {
    font-size: 0.95rem; font-weight: 700; margin: 0 0 0.75rem; color: #f5f8ff;
  }
  .approvals__card p {
    font-size: 0.85rem; color: rgba(255,255,255,0.55); line-height: 1.7; margin: 0 0 0.65rem;
  }
  .approvals__card p:last-child { margin-bottom: 0; }
  .approvals__card em  { color: rgba(255,255,255,0.75); font-style: normal; }
  .approvals__card strong { color: rgba(255,255,255,0.9); }

  .approvals__tools {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 0.85rem;
  }
  .approvals__tools li { display: flex; flex-direction: column; gap: 0.2rem; }
  .tool-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    text-decoration: none; color: #a5b4fc; font-weight: 700; font-size: 0.9rem;
    transition: color 0.15s;
  }
  .tool-link:hover { color: #c7d2fe; }
  .tool-link__name { text-decoration: underline; text-underline-offset: 3px; }
  .tool-link__badge {
    font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    background: rgba(74,222,128,0.15); color: #4ade80;
    border: 1px solid rgba(74,222,128,0.25); border-radius: 99px;
    padding: 0.1rem 0.45rem;
  }
  .tool-link__desc { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.5; }

  .approvals__tips {
    background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.07);
    border-radius: 14px; padding: 1.5rem;
  }
  .approvals__tips-title {
    font-size: 0.9rem; font-weight: 700; color: rgba(255,255,255,0.6);
    text-transform: uppercase; letter-spacing: 0.07em;
    margin: 0 0 1.1rem;
  }
  .approvals__tips-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }
  @media (max-width: 560px) { .approvals__tips-grid { grid-template-columns: 1fr; } }

  .approvals__tip {
    display: flex; align-items: flex-start; gap: 0.7rem;
  }
  .tip-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 0.1rem; }
  .approvals__tip strong { display: block; font-size: 0.85rem; color: #f5f8ff; margin-bottom: 0.25rem; }
  .approvals__tip p { font-size: 0.78rem; color: rgba(255,255,255,0.4); line-height: 1.6; margin: 0; }

  /* ── Top nav ── */
  .topnav {
    position: sticky; top: 0; z-index: 50;
    width: 100%; box-sizing: border-box;
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.85rem 1.25rem;
    background: rgba(5, 7, 15, 0.88);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.07);
  }
  .topnav__brand { display: flex; align-items: baseline; gap: 0.6rem; text-decoration: none; }
  .topnav__wordmark {
    font-size: 1.05rem; font-weight: 800;
    background: linear-gradient(135deg, #f5f8ff 30%, #a5b4fc);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    letter-spacing: -0.02em;
  }
  .topnav__tagline { font-size: 0.75rem; color: rgba(255, 255, 255, 0.35); display: none; }
  @media (min-width: 560px) { .topnav__tagline { display: inline; } }
  .topnav__actions { display: flex; align-items: center; gap: 0.6rem; }
  .topnav__lang {
    font-size: 0.875rem; font-weight: 500; color: rgba(255, 255, 255, 0.5);
    text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 999px;
    transition: color 0.15s ease; margin-right: 0.25rem;
  }
  .topnav__lang:hover { color: #f5f8ff; }
  .topnav__langs { display: inline-flex; align-items: center; gap: 0.1rem; }
  .topnav__lang[aria-current="true"] { color: #f5f8ff; font-weight: 700; }

  /* Prominent top-of-page QR scan button */
  /* Prominent, centered so it is impossible to miss on desktop too
     (full-width on phones, a wide centered pill on wider screens). */
  .qr-top-bar { display: flex; flex-direction: column; align-items: center; gap: 0.65rem; margin: 0 auto 1.25rem; }
  .qr-top-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
    width: 100%; max-width: 440px;
    background: linear-gradient(135deg, #5767ff, #934dff); color: #fff;
    border: none; border-radius: 999px; cursor: pointer;
    font-family: inherit; font-size: 1.05rem; font-weight: 700;
    padding: 0.9rem 1.5rem;
    box-shadow: 0 6px 20px rgba(87,103,255,0.40);
    transition: filter 0.15s ease, transform 0.15s ease;
  }
  .qr-top-btn:hover { filter: brightness(1.12); transform: translateY(-1px); }
  .qr-top-login {
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.95rem; font-weight: 600; color: #a5b4fc; text-decoration: none;
    border: 1px solid rgba(165,180,252,0.45); border-radius: 999px;
    padding: 0.6rem 1.4rem; transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .qr-top-login:hover { color: #fff; background: rgba(165,180,252,0.12); border-color: rgba(165,180,252,0.7); }
  .qr-top-note { font-size: 0.8rem; color: rgba(255,255,255,0.4); margin: 0.1rem 0 0; text-align: center; max-width: 360px; line-height: 1.5; }
  .hero__or {
    font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em;
    color: rgba(255,255,255,0.35); margin: 0 0 1.5rem;
  }
  .topnav__login {
    font-size: 0.875rem; font-weight: 500; color: rgba(255, 255, 255, 0.6);
    text-decoration: none; padding: 0.4rem 0.75rem; border-radius: 999px;
    transition: color 0.15s ease;
  }
  .topnav__login:hover { color: #f5f8ff; }
  .topnav__signup {
    font-size: 0.875rem; font-weight: 600; color: #fff; text-decoration: none;
    padding: 0.45rem 1.1rem; border-radius: 999px;
    background: linear-gradient(135deg, #5767ff, #934dff);
    transition: filter 0.15s ease, transform 0.15s ease; white-space: nowrap;
  }
  .topnav__signup:hover { filter: brightness(1.12); transform: translateY(-1px); }

  /* ── Page ── */
  .page {
    width: 100%; box-sizing: border-box;
    max-width: 860px; margin: 0 auto;
    padding: 3rem 1.25rem 6rem;
    color: #f5f8ff; font-family: 'Inter', system-ui, sans-serif;
  }
  @media (max-width: 480px) {
    .page { padding: 2rem 1rem 4rem; }
    .topnav { padding: 0.75rem 1rem; }
    .topnav__login { display: none; }
  }

  /* Hero */
  .hero { text-align: center; padding: 2rem 0 2.5rem; border-bottom: 1px solid rgba(255,255,255,0.07); margin-bottom: 2.5rem; }
  .hero__eyebrow {
    display: inline-block; font-size: 0.75rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.12em; color: #a5b4fc;
    background: rgba(87,103,255,0.12); border: 1px solid rgba(87,103,255,0.25);
    padding: 0.3rem 0.9rem; border-radius: 999px; margin-bottom: 1.25rem;
  }
  .hero__title {
    font-size: clamp(2.2rem, 5vw, 3.6rem); font-weight: 800; line-height: 1.2; margin: 0 0 1.1rem;
    background: linear-gradient(135deg, #f5f8ff 30%, #a5b4fc);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  }
  .hero__sub { font-size: 1.2rem; color: rgba(255,255,255,0.6); line-height: 1.9; max-width: 640px; margin: 0 auto 2rem; }

  /* Threat grid */
  .threat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 980px; margin: 0 auto 2.5rem; }
  .threat-card {
    display: flex; flex-direction: column;
    background: rgba(255,255,255,0.04); border: 2px solid rgba(165,180,252,0.4);
    border-radius: 16px; overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .threat-card:hover { border-color: rgba(165,180,252,0.75); box-shadow: 0 0 0 3px rgba(165,180,252,0.1); }
  .threat-card__top {
    display: flex; flex-direction: column; align-items: center; gap: 0.75rem;
    padding: 1.75rem 1.5rem 1.5rem; background: none; border: none; color: inherit;
    font-family: inherit; text-align: center; cursor: pointer; width: 100%; transition: background 0.15s;
  }
  .threat-card__top:hover { background: rgba(165,180,252,0.08); }
  .threat-card__icon { font-size: 2.8rem; line-height: 1; }
  .threat-card__title { font-size: 1.1rem; font-weight: 700; color: #e2e8ff; line-height: 1.4; }
  .threat-card__cta { font-size: 0.85rem; color: #a5b4fc; }
  .threat-card__divider { height: 1px; background: rgba(165,180,252,0.25); margin: 0; }
  .threat-card__checker { display: flex; flex-direction: column; gap: 0.6rem; padding: 1.25rem 1.25rem 1.5rem; background: rgba(0,0,0,0.15); }
  .threat-card__input {
    width: 100%; padding: 0.6rem 0.85rem;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px; color: #e2e8ff; font-size: 0.9rem; font-family: inherit;
    outline: none; transition: border-color 0.15s; box-sizing: border-box;
  }
  .threat-card__input::placeholder { color: rgba(255,255,255,0.3); }
  .threat-card__input:focus { border-color: rgba(165,180,252,0.6); background: rgba(255,255,255,0.09); }
  .threat-card__check-btn {
    width: 100%; padding: 0.65rem 1rem;
    background: rgba(87,103,255,0.7); border: 1px solid rgba(165,180,252,0.4);
    border-radius: 8px; color: #fff; font-size: 0.95rem; font-weight: 600;
    font-family: inherit; cursor: pointer; transition: background 0.15s;
  }
  .threat-card__check-btn:hover { background: rgba(87,103,255,0.9); }
  .threat-card__approval-links { display: flex; flex-direction: column; padding: 1.1rem 1.25rem 1.4rem; background: rgba(0,0,0,0.15); gap: 0; }
  .threat-card__approval-desc { font-size: 0.85rem; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0 0 0.85rem; }
  .threat-card__approval-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.7rem 0.85rem; border-radius: 8px; text-decoration: none;
    transition: background 0.15s; margin-bottom: 0.3rem; border: 1px solid transparent;
  }
  .threat-card__approval-link:last-child { margin-bottom: 0; }
  .threat-card__approval-link:hover { background: rgba(165,180,252,0.1); border-color: rgba(165,180,252,0.25); }
  .approval-link__name { font-size: 1rem; font-weight: 600; color: #a5b4fc; }
  .approval-link__arrow { font-size: 0.9rem; color: rgba(165,180,252,0.6); }

  /* Threat modals */
  .threat-modal { display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.65); backdrop-filter: blur(4px); }
  .threat-modal.open { display: flex; }
  .threat-modal__box { background: #1a1d2e; border: 1px solid rgba(165,180,252,0.2); border-radius: 16px; padding: 2rem; max-width: 560px; width: 100%; max-height: 90vh; overflow-y: auto; position: relative; box-shadow: 0 24px 64px rgba(0,0,0,0.6); }
  .threat-modal__close { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: rgba(255,255,255,0.45); font-size: 1.4rem; cursor: pointer; line-height: 1; padding: 0.2rem 0.5rem; border-radius: 6px; transition: color 0.15s, background 0.15s; }
  .threat-modal__close:hover { color: #fff; background: rgba(255,255,255,0.08); }
  .threat-modal__icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .threat-modal__title { font-size: 1.25rem; font-weight: 700; color: #e2e8ff; margin: 0 0 0.5rem; }
  .threat-modal__subtitle { font-size: 0.85rem; color: #f87171; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; margin: 0 0 1.25rem; }
  .threat-modal__body { font-size: 0.95rem; color: rgba(255,255,255,0.7); line-height: 1.75; }
  .threat-modal__body p { margin: 0 0 0.9rem; }
  .threat-modal__body p:last-child { margin-bottom: 0; }
  .threat-modal__example { background: rgba(248,113,113,0.08); border-left: 3px solid #f87171; border-radius: 4px; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.88rem; color: rgba(255,255,255,0.65); }
  .threat-modal__tip { background: rgba(52,211,153,0.08); border-left: 3px solid #34d399; border-radius: 4px; padding: 0.75rem 1rem; margin: 1rem 0; font-size: 0.88rem; color: rgba(255,255,255,0.65); }

  @media (max-width: 640px) { .threat-grid { grid-template-columns: 1fr; } }

  .checker-wrap { margin-bottom: 2.5rem; }

  /* ── CTA banner ── */
  /* ── Example result tiles ── */
  .examples-section { margin-bottom: 4rem; }
  .examples__title { font-size: 1.3rem; font-weight: 700; margin: 0 0 0.5rem; color: rgba(255,255,255,0.85); }
  .examples__sub { font-size: 0.875rem; color: rgba(255,255,255,0.45); margin: 0 0 1.75rem; }
  .examples__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
  .ex-card { background: var(--surface-card); border-radius: 14px; padding: 1.25rem; display: flex; flex-direction: column; gap: 1rem; }
  .ex-card--clean  { border: 1px solid rgba(52,211,153,0.25); }
  .ex-card--caution{ border: 1px solid rgba(245,158,11,0.30); }
  .ex-card--danger { border: 1px solid rgba(239,68,68,0.30); }
  .ex-card__header { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .ex-card__chain-pill { font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.55rem; border-radius: 999px; background: rgba(255,255,255,0.07); color: rgba(255,255,255,0.55); white-space: nowrap; }
  .ex-card__addr { font-family: ui-monospace, monospace; font-size: 0.7rem; color: rgba(255,255,255,0.35); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0; }
  .ex-card__meter { display: flex; flex-direction: column; gap: 0.5rem; }
  .ex-card__score-row { display: flex; align-items: center; gap: 0.75rem; }
  .ex-card__score { font-size: 2rem; font-weight: 700; line-height: 1; min-width: 2.5rem; text-align: center; }
  .ex-card__verdict { display: flex; flex-direction: column; gap: 0.15rem; }
  .ex-card__verdict-label { font-size: 0.9rem; font-weight: 700; }
  .ex-card__verdict-sub { font-size: 0.72rem; color: rgba(255,255,255,0.35); }
  .ex-card__bar-track { height: 6px; background: rgba(255,255,255,0.07); border-radius: 999px; overflow: hidden; }
  .ex-card__bar-fill { height: 100%; border-radius: 999px; transition: width 0.3s ease; }
  .ex-card__flag-banner { font-size: 0.8rem; padding: 0.55rem 0.75rem; border-radius: 8px; border: 1px solid; }
  .ex-card__flags { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.45rem; }
  .ex-flag { display: flex; align-items: center; gap: 0.5rem; font-size: 0.8rem; color: rgba(255,255,255,0.6); }
  .ex-flag__dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
  .ex-flag--ok   .ex-flag__dot { background: rgba(52,211,153,0.7); }
  .ex-flag--warn .ex-flag__dot { background: #f59e0b; }
  .ex-flag--danger .ex-flag__dot { background: #ef4444; }
  .ex-flag--warn  { color: rgba(252,211,77,0.9); }
  .ex-flag--danger{ color: rgba(252,165,165,0.9); }
  .ex-card__footnote { font-size: 0.7rem; color: rgba(255,255,255,0.25); margin: 0; padding-top: 0.25rem; border-top: 1px solid rgba(255,255,255,0.06); }

  .cta-banner { display: flex; align-items: center; gap: 1.25rem; background: linear-gradient(135deg, rgba(87,103,255,0.12), rgba(147,77,255,0.1)); border: 1px solid rgba(87,103,255,0.28); border-radius: 16px; padding: 1.4rem 1.6rem; margin-bottom: 4rem; flex-wrap: wrap; }
  .cta-banner__icon { font-size: 2rem; flex-shrink: 0; line-height: 1; }
  .cta-banner__body { flex: 1; min-width: 200px; }
  .cta-banner__headline { margin: 0 0 0.3rem; font-size: 1rem; font-weight: 700; color: #f5f8ff; }
  .cta-banner__sub { margin: 0; font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.6; }
  .cta-banner__btn { flex-shrink: 0; display: inline-block; padding: 0.65rem 1.3rem; border-radius: 999px; background: linear-gradient(135deg, #5767ff, #934dff); color: #fff; font-size: 0.9rem; font-weight: 600; text-decoration: none; white-space: nowrap; transition: filter 0.15s ease, transform 0.15s ease; }
  .cta-banner__btn:hover { filter: brightness(1.12); transform: translateY(-1px); }

  /* What we check */
  .signals { margin-bottom: 4rem; }
  .signals__title { font-size: 1.3rem; font-weight: 700; margin-bottom: 1rem; color: rgba(255,255,255,0.85); }
  .signals__sub { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.4); margin: 0 0 0.85rem; }
  .signals__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; }
  .signal-card { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; padding: 1.1rem 1.25rem; }
  .signal-card__icon { font-size: 1.3rem; display: block; margin-bottom: 0.5rem; }
  .signal-card__label { font-size: 0.875rem; font-weight: 700; color: rgba(255,255,255,0.85); margin: 0 0 0.4rem; }
  .signal-card__body { font-size: 0.8rem; color: rgba(255,255,255,0.4); line-height: 1.65; margin: 0; }

  /* FAQ */
  .faq { margin-bottom: 3rem; }
  .faq__title { font-size: 1.3rem; font-weight: 700; margin-bottom: 1rem; color: rgba(255,255,255,0.85); }
  .faq__item { border-bottom: 1px solid rgba(255,255,255,0.07); padding: 0.25rem 0; }
  .faq__item[open] { padding-bottom: 0.75rem; }
  .faq__q { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 0.9rem 0.25rem; font-size: 0.95rem; font-weight: 600; color: rgba(255,255,255,0.8); cursor: pointer; list-style: none; user-select: none; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q::marker { display: none; }
  .faq__chevron { font-size: 1.3rem; opacity: 0.4; transition: transform 0.2s ease; flex-shrink: 0; }
  .faq__item[open] .faq__chevron { transform: rotate(90deg); }
  .faq__a { font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.75; margin: 0 0 0 0.25rem; padding-right: 2rem; }

  /* ── Community ratings panel ── */
  .cr-panel {
    margin: 0 0 2.5rem;
    background: var(--surface-card);
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    padding: 1.25rem 1.4rem;
  }
  .cr-title {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-muted); margin: 0 0 1rem;
  }
  .cr-counts {
    display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem;
  }
  .cr-count {
    display: flex; align-items: center; gap: 0.4rem;
    background: var(--surface-card-2); border: 1px solid var(--border-subtle);
    border-radius: 99px; padding: 0.3rem 0.75rem;
    font-size: 0.82rem;
  }
  .cr-count--safe       { border-color: var(--gain-border); }
  .cr-count--suspicious { border-color: rgba(245,158,11,0.3); }
  .cr-count--scam       { border-color: var(--loss-border); }
  .cr-count-n { font-weight: 700; color: var(--text-primary); }
  .cr-count-label--safe       { color: var(--gain); }
  .cr-count-label--suspicious { color: #f59e0b; }
  .cr-count-label--scam       { color: var(--loss); }
  .cr-notes { margin-bottom: 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .cr-note {
    font-size: 0.82rem; color: var(--text-secondary); line-height: 1.5;
    padding: 0.5rem 0.75rem;
    background: var(--surface-card-2); border-radius: 8px;
    border-left: 3px solid var(--border-bright);
  }
  .cr-note--safe       { border-left-color: var(--gain-border); }
  .cr-note--suspicious { border-left-color: rgba(245,158,11,0.4); }
  .cr-note--scam       { border-left-color: var(--loss-border); }
  .cr-note-meta { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.25rem; }
  .cr-action { margin-top: 0.75rem; }
  .cr-rate-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
  .cr-rate-btn {
    font-size: 0.82rem; font-weight: 600; padding: 0.35rem 0.85rem;
    border-radius: 8px; cursor: pointer; border: 1px solid var(--border-bright);
    background: var(--surface-card-2); color: var(--text-secondary);
    font-family: inherit; transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .cr-rate-btn:hover           { background: var(--surface-hover); color: var(--text-primary); }
  .cr-rate-btn--safe:hover     { border-color: var(--gain-border); color: var(--gain); }
  .cr-rate-btn--suspicious:hover { border-color: rgba(245,158,11,0.4); color: #f59e0b; }
  .cr-rate-btn--scam:hover     { border-color: var(--loss-border); color: var(--loss); }
  .cr-rate-btn--active-safe       { border-color: var(--gain-border); color: var(--gain); background: var(--gain-bg); }
  .cr-rate-btn--active-suspicious { border-color: rgba(245,158,11,0.4); color: #f59e0b; background: rgba(245,158,11,0.08); }
  .cr-rate-btn--active-scam       { border-color: var(--loss-border); color: var(--loss); background: var(--loss-bg); }
  .cr-note-input {
    margin-top: 0.65rem; width: 100%; box-sizing: border-box;
    background: var(--surface-card-2); border: 1px solid var(--border-bright);
    border-radius: 8px; color: var(--text-primary); font-size: 0.82rem;
    padding: 0.45rem 0.65rem; font-family: inherit; outline: none; resize: vertical;
  }
  .cr-note-input:focus { border-color: var(--accent); }
  .cr-submit-row { display: flex; gap: 0.5rem; margin-top: 0.5rem; align-items: center; }
  .cr-submit-btn {
    background: var(--accent); color: var(--surface-bg); border: none;
    border-radius: 8px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 600;
    cursor: pointer; font-family: inherit;
  }
  .cr-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .cr-remove-btn {
    font-size: 0.78rem; color: var(--text-muted); background: none; border: none;
    cursor: pointer; font-family: inherit; padding: 0.4rem 0;
    text-decoration: underline; text-underline-offset: 2px;
  }
  .cr-remove-btn:hover { color: var(--loss); }
  .cr-cta {
    font-size: 0.82rem; color: var(--text-muted);
  }
  .cr-cta a { color: var(--accent); text-decoration: none; }
  .cr-cta a:hover { text-decoration: underline; }
  .cr-saved { font-size: 0.8rem; color: var(--gain); }

  /* Disclaimer */
  .disclaimer { font-size: 0.75rem; color: rgba(255,255,255,0.25); line-height: 1.7; text-align: center; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 2rem; }
  .disclaimer__link { color: rgba(165,180,252,0.5); text-decoration: none; display: inline-block; margin-top: 0.4rem; transition: color 0.15s ease; }
  .disclaimer__link:hover { color: #a5b4fc; }

  /* ── Checker tabs ── */
  .checker-tabs { display: flex; gap: 0.5rem; margin-bottom: 1.25rem; border-bottom: 1px solid rgba(255,255,255,0.08); padding-bottom: 0; }
  .checker-tab { padding: 0.65rem 1.2rem; font-size: 0.9rem; font-weight: 600; color: rgba(255,255,255,0.45); background: none; border: none; border-bottom: 2px solid transparent; cursor: pointer; transition: color 0.15s, border-color 0.15s; margin-bottom: -1px; }
  .checker-tab:hover { color: rgba(255,255,255,0.75); }
  .checker-tab.active { color: #a5b4fc; border-bottom-color: #a5b4fc; }

  /* ── dApp panel ── */
  .dapp-panel { margin-bottom: 2.5rem; }
  .dapp-input-row { display: flex; gap: 0.65rem; margin-bottom: 1rem; }
  .dapp-input-row input { flex: 1; padding: 0.8rem 1rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.15); background: rgba(255,255,255,0.06); color: #f5f8ff; font-size: 0.95rem; font-family: inherit; outline: none; transition: border-color 0.15s; }
  .dapp-input-row input:focus { border-color: rgba(165,180,252,0.6); }
  .dapp-input-row input::placeholder { color: rgba(255,255,255,0.3); }
  .dapp-input-row button { padding: 0.8rem 1.4rem; border-radius: 12px; border: none; background: linear-gradient(135deg, #5767ff, #934dff); color: #fff; font-size: 0.9rem; font-weight: 700; cursor: pointer; white-space: nowrap; transition: filter 0.15s, transform 0.15s; }
  .dapp-input-row button:hover { filter: brightness(1.12); transform: translateY(-1px); }
  .dapp-input-row button:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  [hidden] { display: none !important; }

  .dapp-loading { display: flex; align-items: center; gap: 0.75rem; padding: 1rem; font-size: 0.9rem; color: rgba(255,255,255,0.5); }
  .spinner { display: inline-block; width: 18px; height: 18px; border: 2px solid rgba(165,180,252,0.25); border-top-color: #a5b4fc; border-radius: 50%; animation: spin 0.7s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .dapp-error { padding: 0.85rem 1rem; border-radius: 12px; background: rgba(255,107,107,0.08); border: 1px solid rgba(255,107,107,0.3); color: #ff9b9b; font-size: 0.9rem; }
  .dapp-status { padding: 0.85rem 1rem; border-radius: 12px; background: rgba(165,180,252,0.07); border: 1px solid rgba(165,180,252,0.22); color: rgba(165,180,252,0.8); font-size: 0.875rem; line-height: 1.5; }

  /* ── Verdict banner ── */
  .verdict-banner { display: flex; align-items: center; gap: 1rem; padding: 1.2rem 1.4rem; border-radius: 16px; margin-bottom: 1rem; }
  .verdict-banner.red    { background: rgba(255,59,59,0.12);  border: 1px solid rgba(255,59,59,0.35); }
  .verdict-banner.yellow { background: rgba(255,193,7,0.1);   border: 1px solid rgba(255,193,7,0.3);  }
  .verdict-banner.green  { background: rgba(52,211,153,0.1);  border: 1px solid rgba(52,211,153,0.3); }
  .verdict-icon { font-size: 2.2rem; line-height: 1; }
  .verdict-label { margin: 0 0 0.25rem; font-size: 1.1rem; font-weight: 800; }
  .verdict-banner.red    .verdict-label { color: #ff6b6b; }
  .verdict-banner.yellow .verdict-label { color: #ffc107; }
  .verdict-banner.green  .verdict-label { color: #34d399; }
  .verdict-url { margin: 0; font-size: 0.8rem; color: rgba(255,255,255,0.4); word-break: break-all; }

  /* ── Source list ── */
  .source-list { list-style: none; padding: 0; margin: 0 0 1rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .source-item { display: flex; align-items: flex-start; gap: 0.75rem; padding: 0.75rem 1rem; border-radius: 12px; background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); font-size: 0.875rem; }
  .source-item.flagged { border-color: rgba(255,59,59,0.35); background: rgba(255,59,59,0.07); }
  .source-item.clean   { border-color: rgba(52,211,153,0.2); }
  .source-item.yellow  { border-color: rgba(255,193,7,0.25); background: rgba(255,193,7,0.05); }
  .source-badge { font-size: 1rem; flex-shrink: 0; line-height: 1.4; }
  .source-name { font-weight: 700; color: rgba(255,255,255,0.85); margin: 0 0 0.15rem; }
  .source-detail { margin: 0; color: rgba(255,255,255,0.45); font-size: 0.8rem; line-height: 1.5; }
  .source-verdict-dot { margin-left: auto; flex-shrink: 0; width: 10px; height: 10px; border-radius: 50%; align-self: center; }
  .dot-red    { background: #ff4d4d; box-shadow: 0 0 8px rgba(255,77,77,0.6); }
  .dot-green  { background: #34d399; box-shadow: 0 0 8px rgba(52,211,153,0.4); }
  .dot-yellow { background: #ffc107; box-shadow: 0 0 8px rgba(255,193,7,0.4); }
  .dot-gray   { background: rgba(255,255,255,0.2); }

  .safety-tip { padding: 0.9rem 1.1rem; border-radius: 12px; font-size: 0.85rem; line-height: 1.65; color: rgba(255,255,255,0.55); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); }

  @media (max-width: 600px) {
    .signals__grid { grid-template-columns: 1fr; }
    .hero__title { -webkit-text-fill-color: #f5f8ff; }
    .cta-banner { flex-direction: column; text-align: center; }
    .cta-banner__icon { align-self: center; }
    .cta-banner__btn { align-self: stretch; text-align: center; }
    .dapp-input-row { flex-direction: column; }
  }
</style>

<script>
  // Read i18n runtime strings embedded in the page
  const _i18nEl = document.getElementById('wc-i18n');
  const _i18n = _i18nEl ? JSON.parse(_i18nEl.textContent ?? '{}') : {};

  // Switch to the dApp / website tab, fill the URL, and run the check. Shared by the
  // hero "site" card and by a scanned QR that decoded to a website URL.
  function activateDappCheck(value: string) {
    const dappTab   = document.getElementById('tab-btn-dapp')   as HTMLButtonElement | null;
    const walletTab = document.getElementById('tab-btn-wallet') as HTMLButtonElement | null;
    const dappPanel   = document.getElementById('panel-dapp')   as HTMLElement | null;
    const walletPanel = document.getElementById('panel-wallet') as HTMLElement | null;
    const urlInput  = document.getElementById('dapp-url-input') as HTMLInputElement | null;
    const checkBtn  = document.getElementById('dapp-check-btn') as HTMLButtonElement | null;
    if (!(dappTab && walletTab && dappPanel && walletPanel && urlInput && checkBtn)) return;
    walletTab.classList.remove('active'); walletTab.setAttribute('aria-selected', 'false');
    dappTab.classList.add('active');      dappTab.setAttribute('aria-selected', 'true');
    walletPanel.hidden = true;
    dappPanel.hidden   = false;
    urlInput.value = value;
    dappPanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
    setTimeout(() => checkBtn.click(), 350);
  }

  // ── Threat modals ─────────────────────────────────────────────────────────
  function openModal(id: string) {
    const modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    modal.querySelector<HTMLButtonElement>('.threat-modal__close')?.focus();
  }
  function closeModal(modal: HTMLElement) {
    modal.classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.threat-card__top').forEach((btn) => {
    btn.addEventListener('click', () => { const id = btn.dataset.modal; if (id) openModal(id); });
  });

  document.querySelectorAll<HTMLButtonElement>('.threat-card__check-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const type  = btn.dataset.checker;
      const input = btn.closest('.threat-card__checker')?.querySelector<HTMLInputElement>('.threat-card__input');
      const value = input?.value.trim() ?? '';
      if (!value) { input?.focus(); return; }

      if (type === 'dapp') {
        activateDappCheck(value);
      } else if (type === 'wallet') {
        const url = new URL(window.location.href);
        url.searchParams.set('address', value);
        url.hash = 'panel-wallet';
        window.location.href = url.toString();
      } else if (type === 'approval') {
        window.open(`https://revoke.cash/address/${encodeURIComponent(value)}`, '_blank', 'noopener,noreferrer');
      }
    });
  });

  document.querySelectorAll<HTMLInputElement>('.threat-card__input').forEach((inp) => {
    inp.addEventListener('click', (e) => e.stopPropagation());
    inp.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        inp.closest('.threat-card__checker')?.querySelector<HTMLButtonElement>('.threat-card__check-btn')?.click();
      }
    });
  });

  document.querySelectorAll<HTMLElement>('.threat-modal').forEach((modal) => {
    modal.querySelector('.threat-modal__close')?.addEventListener('click', () => closeModal(modal));
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(modal); });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') document.querySelectorAll<HTMLElement>('.threat-modal.open').forEach(closeModal);
  });

  // ── Tab switching ─────────────────────────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.checker-tab');
  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      tabs.forEach((t) => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const target = btn.dataset.tab!;
      (document.getElementById('panel-wallet') as HTMLElement).hidden = target !== 'wallet';
      (document.getElementById('panel-dapp')   as HTMLElement).hidden = target !== 'dapp';
    });
  });

  // ── dApp checker ──────────────────────────────────────────────────────────
  const input    = document.getElementById('dapp-url-input')  as HTMLInputElement;
  const btn      = document.getElementById('dapp-check-btn')  as HTMLButtonElement;
  const result   = document.getElementById('dapp-result')     as HTMLElement;
  const loading  = document.getElementById('dapp-loading')    as HTMLElement;
  const statusEl = document.getElementById('dapp-status')     as HTMLElement;
  const errBox   = document.getElementById('dapp-error')      as HTMLElement;

  function verdictDot(v: string): string {
    if (v === 'flagged') return 'dot-red';
    if (v === 'clean' || v === 'whitelisted') return 'dot-green';
    if (v === 'unscanned') return 'dot-yellow';
    return 'dot-gray';
  }
  function sourceClass(v: string): string {
    if (v === 'flagged') return 'flagged';
    if (v === 'unscanned') return 'yellow';
    return 'clean';
  }

  async function runCheck() {
    const raw = input.value.trim();
    if (!raw) { input.focus(); return; }

    btn.disabled    = true;
    loading.hidden  = false;
    result.hidden   = true;
    errBox.hidden   = true;
    statusEl.hidden = true;
    statusEl.textContent = '';

    const warmupTimer = setTimeout(() => {
      statusEl.textContent = _i18n.warmupHint ?? '';
      statusEl.hidden = false;
    }, 8_000);

    let timedOut = false;
    const qs = new URLSearchParams({ url: raw });

    try {
      const res = await Promise.race([
        fetch(`/api/dapp-check?${qs}`),
        new Promise<never>((_, reject) =>
          setTimeout(() => { timedOut = true; reject(new Error('timeout')); }, 30_000),
        ),
      ]);

      const data = await res.json();
      if (!res.ok || data.error) throw new Error(data.message ?? `HTTP ${res.status}`);

      const banner = document.getElementById('verdict-banner')!;
      banner.className = `verdict-banner ${data.verdict}`;
      document.getElementById('verdict-icon')!.textContent =
        data.verdict === 'red' ? '🚨' : data.verdict === 'yellow' ? '⚠️' : '✅';
      document.getElementById('verdict-label')!.textContent =
        data.verdict === 'red'    ? (_i18n.verdictDanger  ?? 'DANGER')  :
        data.verdict === 'yellow' ? (_i18n.verdictCaution ?? 'CAUTION') :
                                    (_i18n.verdictSafe    ?? 'SAFE');
      document.getElementById('verdict-url')!.textContent = data.domain;

      const VERDICT_RANK: Record<string, number> = { flagged: 0, error: 1, unscanned: 1, clean: 2, whitelisted: 2, skipped: 3 };
      const sortedSources = ([...data.sources] as any[]).sort(
        (a, b) => (VERDICT_RANK[a.verdict] ?? 2) - (VERDICT_RANK[b.verdict] ?? 2),
      );
      document.getElementById('source-list')!.innerHTML = sortedSources.map((s) => `
        <li class="source-item ${sourceClass(s.verdict)}">
          <span class="source-badge">${escapeHtml(String(s.icon ?? ''))}</span>
          <div>
            <p class="source-name">${escapeHtml(String(s.name ?? ''))}</p>
            <p class="source-detail">${escapeHtml(String(s.detail ?? ''))}</p>
          </div>
          <span class="source-verdict-dot ${verdictDot(s.verdict)}"></span>
        </li>`).join('');

      document.getElementById('safety-tip')!.textContent =
        data.verdict === 'red'    ? (_i18n.tipRed    ?? '') :
        data.verdict === 'yellow' ? (_i18n.tipYellow ?? '') :
                                    (_i18n.tipGreen  ?? '');

      result.hidden = false;
      if (typeof (window as any).gtag === 'function') {
        (window as any).gtag('event', 'dapp_check_submitted', { event_category: 'interactive_tool', event_label: data.verdict ?? 'unknown' });
      }

    } catch (e: any) {
      if (timedOut || e?.message === 'timeout') {
        errBox.textContent = _i18n.warmupRetry ?? '';
        errBox.hidden = false;
        setTimeout(() => runCheck(), 5_000);
        return;
      }
      const msg = e instanceof Error ? e.message : 'Unknown error';
      errBox.textContent = `${_i18n.checkFailed ?? 'Check failed'}: ${msg}. ${_i18n.tryAgain ?? 'Try again.'}`;
      errBox.hidden = false;
    } finally {
      clearTimeout(warmupTimer);
      loading.hidden  = true;
      statusEl.hidden = true;
      btn.disabled    = false;
    }
  }

  btn.addEventListener('click', runCheck);
  input.addEventListener('keydown', (e) => { if (e.key === 'Enter') runCheck(); });

  // Top quick-scan button → switch to the wallet tab, then open the QR scanner in the React island
  document.getElementById('qr-top-btn')?.addEventListener('click', () => {
    (document.getElementById('tab-btn-wallet') as HTMLButtonElement | null)?.click();
    window.dispatchEvent(new CustomEvent('almstins:open-qr'));
  });

  // A scanned QR that decoded to a website / dApp URL → run the dApp checker.
  // (Addresses are handled inside the wallet island; URLs are handed off here.)
  window.addEventListener('almstins:scanned-url', (e) => {
    const url = (e as CustomEvent).detail?.url as string | undefined;
    if (url) activateDappCheck(url);
  });

  // ── Community ratings ──────────────────────────────────────────────────────

  function escapeHtml(s: string): string {
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  }

  const crPanel     = document.getElementById('cr-panel') as HTMLElement;
  const crSessionEl = document.getElementById('cr-session') as HTMLElement;
  const crIsLoggedIn = crSessionEl?.dataset.loggedIn === '1';
  const crIsPaid     = crSessionEl?.dataset.paid === '1';

  let crCurrentKind    = 'wallet';
  let crCurrentSubject = '';
  let crPendingRating  = '';
  let crOwnRating      = '';

  function crRatingLabel(r: string): string {
    return r === 'safe' ? '✅ Safe' : r === 'suspicious' ? '⚠️ Suspicious' : '🚨 Scam';
  }

  async function loadCommunityRatings(kind: string, subject: string) {
    if (!subject) return;
    crCurrentKind    = kind;
    crCurrentSubject = subject;
    crPendingRating  = '';

    crPanel.hidden = false;
    crPanel.innerHTML = `<p class="cr-title">Community ratings</p><p style="font-size:0.82rem;color:var(--text-muted)">Loading…</p>`;

    try {
      const qs  = new URLSearchParams({ kind, subject });
      const res = await fetch(`/api/community-rating?${qs}`);
      const data = await res.json();

      if (!data.ok) { crPanel.hidden = true; return; }

      const { counts, notes, total } = data as {
        counts: Record<string, number>;
        notes: Array<{ rating: string; note: string; date: string }>;
        total: number;
      };

      const countsHtml = `
        <div class="cr-counts">
          <div class="cr-count cr-count--safe">
            <span class="cr-count-n">${counts.safe}</span>
            <span class="cr-count-label--safe">safe</span>
          </div>
          <div class="cr-count cr-count--suspicious">
            <span class="cr-count-n">${counts.suspicious}</span>
            <span class="cr-count-label--suspicious">suspicious</span>
          </div>
          <div class="cr-count cr-count--scam">
            <span class="cr-count-n">${counts.scam}</span>
            <span class="cr-count-label--scam">scam</span>
          </div>
          ${total === 0 ? '<span style="font-size:0.78rem;color:var(--text-muted)">No community ratings yet.</span>' : ''}
        </div>`;

      const notesHtml = notes.length > 0
        ? `<div class="cr-notes">${notes.map(n => `
            <div class="cr-note cr-note--${n.rating}">
              ${escapeHtml(n.note)}
              <div class="cr-note-meta">${crRatingLabel(n.rating)} · ${n.date}</div>
            </div>`).join('')}</div>`
        : '';

      let actionHtml = '';
      if (!crIsLoggedIn) {
        actionHtml = `<p class="cr-cta">Have experience with this address? <a href="/login">Sign in</a> to rate it (paid plans).</p>`;
      } else if (!crIsPaid) {
        actionHtml = `<p class="cr-cta">Ratings are available on paid plans. <a href="/dashboard/billing">Upgrade</a> to contribute.</p>`;
      } else {
        actionHtml = `
          <div class="cr-action" id="cr-action">
            <div class="cr-rate-row">
              <span style="font-size:0.8rem;color:var(--text-muted);margin-right:0.25rem">Rate:</span>
              <button class="cr-rate-btn cr-rate-btn--safe"       data-r="safe">✅ Safe</button>
              <button class="cr-rate-btn cr-rate-btn--suspicious" data-r="suspicious">⚠️ Suspicious</button>
              <button class="cr-rate-btn cr-rate-btn--scam"       data-r="scam">🚨 Scam</button>
            </div>
            <textarea id="cr-note-input" class="cr-note-input" rows="2" maxlength="280" placeholder="Optional note (280 chars)" hidden></textarea>
            <div class="cr-submit-row" id="cr-submit-row" hidden>
              <button class="cr-submit-btn" id="cr-submit-btn">Submit</button>
              <button class="cr-remove-btn" id="cr-remove-btn">Remove my rating</button>
              <span class="cr-saved" id="cr-saved" hidden>Saved</span>
            </div>
          </div>`;
      }

      crPanel.innerHTML = `<p class="cr-title">Community ratings</p>${countsHtml}${notesHtml}${actionHtml}`;

      // Wire up rating buttons
      if (crIsPaid) {
        crPanel.querySelectorAll<HTMLButtonElement>('.cr-rate-btn').forEach(btn => {
          btn.addEventListener('click', () => {
            crPendingRating = btn.dataset.r ?? '';
            crPanel.querySelectorAll('.cr-rate-btn').forEach(b => {
              b.className = b.className.replace(/\s*cr-rate-btn--active-\w+/, '');
            });
            btn.className += ` cr-rate-btn--active-${crPendingRating}`;
            const noteInput  = document.getElementById('cr-note-input')  as HTMLTextAreaElement;
            const submitRow  = document.getElementById('cr-submit-row');
            if (noteInput)  noteInput.hidden  = false;
            if (submitRow)  submitRow.hidden  = false;
          });
        });

        document.getElementById('cr-submit-btn')?.addEventListener('click', async () => {
          const note = (document.getElementById('cr-note-input') as HTMLTextAreaElement)?.value ?? '';
          const btn  = document.getElementById('cr-submit-btn') as HTMLButtonElement;
          const saved = document.getElementById('cr-saved');
          if (!crPendingRating) return;
          btn.disabled = true;
          try {
            await fetch('/api/community-rating', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ kind: crCurrentKind, subject: crCurrentSubject, rating: crPendingRating, note }),
            });
            crOwnRating = crPendingRating;
            if (saved) { saved.hidden = false; setTimeout(() => { if (saved) saved.hidden = true; }, 2500); }
            // Reload fresh counts
            await loadCommunityRatings(crCurrentKind, crCurrentSubject);
          } finally {
            btn.disabled = false;
          }
        });

        document.getElementById('cr-remove-btn')?.addEventListener('click', async () => {
          const qs = new URLSearchParams({ kind: crCurrentKind, subject: crCurrentSubject });
          await fetch(`/api/community-rating?${qs}`, { method: 'DELETE' });
          crOwnRating = '';
          await loadCommunityRatings(crCurrentKind, crCurrentSubject);
        });
      }
    } catch {
      crPanel.hidden = true;
    }
  }

  // Triggered by WalletChecker.tsx after a result renders
  window.addEventListener('almstins:wallet-checked', (e) => {
    const addr = (e as CustomEvent).detail?.address as string | undefined;
    if (addr) loadCommunityRatings('wallet', addr);
  });

  // Triggered after a dApp check completes — patch into the existing runCheck closure
  const _origRunCheck = (window as any).__dappRunCheck;
  // Attach to the existing result render: watch for verdict-banner appearing
  const dappObserver = new MutationObserver(() => {
    const urlEl = document.getElementById('verdict-url');
    const domain = urlEl?.textContent?.trim();
    if (domain && !document.getElementById('dapp-result')?.hidden) {
      dappObserver.disconnect();
      loadCommunityRatings('dapp', domain);
      // Reconnect when result is hidden again (new check)
      const resultEl = document.getElementById('dapp-result');
      if (resultEl) {
        new MutationObserver(() => {
          if (resultEl.hidden) loadCommunityRatings('dapp', '');
        }).observe(resultEl, { attributes: true, attributeFilter: ['hidden'] });
      }
    }
  });
  const dappResultEl = document.getElementById('dapp-result');
  if (dappResultEl) dappObserver.observe(dappResultEl, { attributes: true, attributeFilter: ['hidden'] });
</script>
