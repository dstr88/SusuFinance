---
import type { LoginPageLocale } from '../i18n/loginPage';
import LoginLayout from '../layouts/LoginLayout.astro';
import Logo from '../assets/logo-scene.png';

interface Props {
  t: LoginPageLocale;
  safeCallbackUrl: string;
  csrfToken: string;
  message: string;      // localized error string, "" or "LOCKED_OUT"
  notice: string;       // localized notice string or ""
  hasAlert: boolean;
  isLoggedIn: boolean;
  /** Optional canonical URL override (e.g. point /login at the / homepage). */
  canonical?: string;
}

const { t, safeCallbackUrl, csrfToken, message, notice, hasAlert, isLoggedIn, canonical } = Astro.props;
const isLockedOut = message === 'LOCKED_OUT';
---

<LoginLayout title={t.meta.title} description={t.meta.description} noindex={false} canonical={canonical} lang={t.lang}>

  <nav class="lang-switch" aria-label="Language">
    <a class="lang-switch__lang" href="/" aria-current={t.lang === 'en' ? 'true' : undefined}>EN</a>
    <a class="lang-switch__lang" href="/es" aria-current={t.lang === 'es' ? 'true' : undefined}>ES</a>
    <a class="lang-switch__lang" href="/fr" aria-current={t.lang === 'fr' ? 'true' : undefined}>FR</a>
  </nav>

  <!-- ── Fixed sign-in pill — top-right ─────────────────────────────────
       Ships `disabled` on purpose: the dropdown it opens is pure client JS, so
       before that script runs the button can do nothing, and a button that looks
       alive but is not is worse than one that plainly is not. The toggle script
       enables it as its last act — see "Sign-in pill toggle" below. Do not remove
       `disabled` here without moving that guarantee somewhere else: the pair is the
       promise that the pill is only clickable once clicking it works. -->
  <div class="signin-pill-wrap" id="signinPillWrap">
    <button
      class="signin-pill"
      id="signinPill"
      type="button"
      disabled
      aria-disabled="true"
      aria-expanded={hasAlert ? "true" : "false"}
      aria-haspopup="true"
      aria-controls="signinDropdown"
    >
      {t.signin.pillLabel}
      <svg class="pill-chevron" viewBox="0 0 12 8" fill="none" aria-hidden="true" width="12" height="8">
        <path d="M1 1.5l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="signin-dropdown" id="signinDropdown" role="menu" hidden={!hasAlert || undefined}>
      <button class="dropdown-close" id="signinDropdownClose" aria-label={t.signin.closeAriaLabel}>✕</button>

      {isLoggedIn ? (
        <a class="dropdown-cta" href={safeCallbackUrl}>{t.signin.continueDashboard}</a>
      ) : (
        <>
          <div class="dropdown-info">
            <p class="dropdown-info-primary">{t.signin.noSignupPrimary}</p>
            <p class="dropdown-info-sub">{t.signin.noSignupSub}</p>
          </div>
          {message && !isLockedOut && (
            <p class="dropdown-notice">{message}</p>
          )}
          {notice && <p class="dropdown-notice dropdown-notice--success">{notice}</p>}

          <!-- Google -->
          <form id="login-google" class="provider-form" method="POST" action="/api/auth/signin/google">
            <input type="hidden" name="callbackUrl" value={safeCallbackUrl} />
            <input type="hidden" name="csrfToken" value={csrfToken} />
            <button class="provider-button google" type="submit" data-provider="google"
              data-needs-csrf={!csrfToken || undefined} disabled={!csrfToken || undefined}>
              <svg class="provider-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#fff" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                <path fill="rgba(255,255,255,0.8)" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="rgba(255,255,255,0.6)" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
                <path fill="rgba(255,255,255,0.7)" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <span class="provider-label">{t.signin.continueGoogle}</span>
              <span class="last-used-badge" data-badge="google" hidden>{t.signin.lastUsed}</span>
            </button>
          </form>

          <div class="dropdown-divider"></div>

          <!-- Email -->
          <div class="email-toggle-wrap">
            <button class="email-toggle-btn" id="emailToggle" type="button" aria-expanded="false">
              {t.signin.emailToggleLabel} <span class="toggle-chevron">›</span>
            </button>
            <div class="email-panel" id="emailPanel" hidden>
              <form id="login-email-password" class="stack email-tab-panel" method="POST" action="/api/auth/callback/credentials">
                <input type="hidden" name="callbackUrl" value={safeCallbackUrl} />
                <input type="hidden" name="csrfToken" value={csrfToken} />
                <label>
                  <span>{t.signin.emailLabel}</span>
                  <input type="email" name="email" placeholder={t.signin.emailPlaceholder} required autocomplete="email" />
                </label>
                <label>
                  <span>{t.signin.passwordLabel}</span>
                  <input type="password" name="password" minlength="10" required autocomplete="current-password" />
                </label>
                <button type="submit" data-needs-csrf={!csrfToken || undefined} disabled={!csrfToken || undefined}>
                  {t.signin.signInEmail}
                </button>
              </form>
            </div>
          </div>
        </>
      )}
    </div>
  </div>

  <!-- ── Main layout ───────────────────────────────────────────────────── -->
  <main class="landing">

    <!-- Header: brand (language switcher + Login are the fixed pills above) -->
    <header class="hub-top">
      <a href="/" class="wordmark" aria-label={t.hero.wordmarkAriaLabel}>
        <img src={Logo.src} width="80" height="80" alt="SusuFinance logo" class="wordmark-img" />
        <span class="wordmark-text">SusuFinance</span>
      </a>
    </header>

    <!-- Said first, before any claim. /howTo opens this way and so should this. -->
    <aside class="hub-honesty">
      <span class="hub-honesty__title">{t.hub.honestyTitle}</span>
      {' '}
      <span class="hub-honesty__body">{t.hub.honestyBody}</span>
    </aside>

    <!-- Hero: the headline, the two sublines, the promise, one door out. -->
    <section class="hub-hero">
      <h1 class="hub-hero__title">{t.hub.title}</h1>
      <p class="hub-hero__sub">{t.hub.sub1}</p>
      <p class="hub-hero__sub">{t.hub.sub2}</p>

      {/* The promise the product rests on. An accent rule AND stronger text —
          never colour alone. */}
      <p class="hub-hero__promise">{t.hub.promise}</p>

      {/* The only call to action. There is nothing to buy, so nothing else asks. */}
      <a class="hub-hero__cta" href="/howTo">{t.hub.cta} →</a>
    </section>

    <!-- Three quiet facts. Not feature cards — each names something the product
         refuses to do, which is the whole argument. -->
    <section class="hub-trust" aria-label={t.hub.trustAria}>
      {t.hub.trust.map((item, i) => (
        <div class="tfact">
          <span class="tfact__k">{item.k}</span>
          <p class="tfact__v">
            {item.v}
            {i === 2 && (
              <>
                {' '}
                <a class="tfact__link" href="https://github.com/dstr88/SusuFinance" target="_blank" rel="noopener noreferrer">
                  {t.hub.githubLink} →
                </a>
              </>
            )}
          </p>
        </div>
      ))}
    </section>

    <!-- Footer: the three things a reader may legitimately want next. -->
    <nav class="hub-foot" aria-label="Secondary">
      <a class="hub-foot__link" href="/changelog">{t.hero.changelogLink}</a>
      <span class="hub-foot__dot" aria-hidden="true">·</span>
      <a class="hub-foot__link" href="mailto:hello@susufinance.com">{t.hub.contactLink}</a>
    </nav>

  </main>

  {isLockedOut && (
    <div class="session-overlay" id="session-overlay">
      <div class="session-popup" role="alertdialog" aria-modal="true" aria-labelledby="session-title">
        <div class="session-popup__icon">🔐</div>
        <h2 id="session-title">{t.sessionPopup.title}</h2>
        <p>{t.sessionPopup.body}</p>
        <div class="session-popup__actions">
          <a class="session-popup__btn session-popup__btn--primary" href="/api/auth/signout">{t.sessionPopup.signOutBtn}</a>
          <button class="session-popup__btn session-popup__btn--ghost" id="session-dismiss">{t.sessionPopup.dismissBtn}</button>
        </div>
      </div>
    </div>
    <script is:inline>
      document.getElementById('session-dismiss')?.addEventListener('click', function() {
        document.getElementById('session-overlay')?.remove();
      });
    </script>
  )}

  <!-- Wallet error hint and default hint as data attrs so JS can reference them -->
  <div
    id="demo-hint-data"
    hidden
    data-hint={t.hero.walletHint}
    data-error-hint={t.hero.walletErrorHint}
  ></div>

  <script>
    import '@/lib/safetyCheck'; // wallet + URL scam checker (custom element)

    // ── CSRF refresh ──────────────────────────────────────────────────
    (async () => {
      try {
        const res = await fetch("/api/auth/csrf", { credentials: "same-origin" });
        if (!res.ok) return;
        const data = await res.json();
        if (!data?.csrfToken) return;
        document.querySelectorAll('input[name="csrfToken"]').forEach((el) => {
          (el as HTMLInputElement).value = data.csrfToken;
        });
        document.querySelectorAll("button[data-needs-csrf]").forEach((b) => {
          b.removeAttribute("disabled");
        });
      } catch (e) {
        console.warn("[login] csrf fetch failed", e);
      }
    })();

    // ── Last-used provider badge ──────────────────────────────────────
    (() => {
      const STORAGE_KEY = 'alms_last_provider';
      const lastProvider = localStorage.getItem(STORAGE_KEY);
      if (lastProvider) {
        const badge = document.querySelector(`[data-badge="${lastProvider}"]`);
        if (badge) {
          badge.removeAttribute('hidden');
          (badge.closest('button') as HTMLElement | null)?.classList.add('last-used');
        }
      }
      document.querySelectorAll('button[data-provider]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const provider = btn.getAttribute('data-provider');
          if (provider) localStorage.setItem(STORAGE_KEY, provider);
        });
      });
    })();

    // ── Sign-in pill toggle ───────────────────────────────────────────
    (() => {
      const pill     = document.getElementById('signinPill') as HTMLButtonElement | null;
      const dropdown = document.getElementById('signinDropdown') as HTMLElement | null;
      const wrap     = document.getElementById('signinPillWrap') as HTMLElement | null;

      if (!pill || !dropdown) return;

      function openDropdown() {
        dropdown!.hidden = false;
        pill!.setAttribute('aria-expanded', 'true');
        pill!.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        setTimeout(() => {
          document.addEventListener('click', outsideClick, { once: true });
        }, 0);
      }

      function closeDropdown() {
        dropdown!.hidden = true;
        pill!.setAttribute('aria-expanded', 'false');
        pill!.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      function outsideClick(e: MouseEvent) {
        if (wrap && !wrap.contains(e.target as Node)) {
          closeDropdown();
        } else if (!dropdown!.hidden) {
          setTimeout(() => {
            document.addEventListener('click', outsideClick, { once: true });
          }, 0);
        }
      }

      pill.addEventListener('click', () => {
        dropdown.hidden ? openDropdown() : closeDropdown();
      });

      // Now that the click actually does something, let it be clicked.
      //
      // This line was missing, and the pill sat `disabled` forever: the only code
      // that removed the attribute targeted `button[data-needs-csrf]`, which the
      // pill is not (it submits nothing — it opens a menu). :disabled styles it to
      // pointer-events:none, so every click fell straight through to the wrapper
      // behind it. No error, no console warning; the button was simply off. The
      // whole sign-in surface on the landing page was unreachable.
      //
      // It belongs HERE, after the listener is attached, not in the CSRF block:
      // what makes the pill safe to click is its handler existing, and CSRF has
      // nothing to do with opening a menu.
      pill.disabled = false;
      pill.removeAttribute('aria-disabled');

      document.getElementById('signinDropdownClose')?.addEventListener('click', closeDropdown);

      document.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Escape' && !dropdown.hidden) closeDropdown();
      });

      if (pill.getAttribute('aria-expanded') === 'true') {
        openDropdown();
      }
    })();

    // ── Email toggle ──────────────────────────────────────────────────
    // The Password/Magic-link tab switcher used to live here and is gone with the
    // markup it drove: EMAIL_SERVER is unset, so "send magic link" sent nothing.
    // Dead listeners left behind in THIS module would be worse than untidy — a
    // throw anywhere in it takes the sign-in pill's toggle down with it, silently,
    // which is precisely how the pill sat dead on the landing page for weeks.
    (() => {
      const toggleBtn = document.getElementById('emailToggle') as HTMLButtonElement | null;
      const panel     = document.getElementById('emailPanel');
      const chevron   = toggleBtn?.querySelector('.toggle-chevron') as HTMLElement | null;

      if (!toggleBtn) return;

      toggleBtn.addEventListener('click', () => {
        const open = !panel?.hidden;
        if (panel) panel.hidden = open;
        toggleBtn.setAttribute('aria-expanded', String(!open));
        if (chevron) chevron.textContent = open ? '›' : '‹';
        toggleBtn.classList.toggle('active', !open);
        if (!open) panel?.querySelector('input')?.focus();
      });
    })();

    // ── Demo invite modal (30s timer, reset on interaction) ──────────
    (() => {
      const overlay  = document.getElementById('hesitationOverlay');
      const closeBtn = document.getElementById('hesitationClose');

      if (!overlay) return;

      let timer: ReturnType<typeof setTimeout>;
      const DELAY = 30_000;
      let shown = false;

      function showModal() {
        if (shown) return;
        shown = true;
        overlay!.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }

      function resetTimer() {
        clearTimeout(timer);
        if (!shown) timer = setTimeout(showModal, DELAY);
      }

      function dismiss() {
        overlay!.classList.add('hidden');
        document.body.style.overflow = '';
      }

      closeBtn?.addEventListener('click', dismiss);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) dismiss();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') dismiss();
      });

      ['click', 'keydown', 'scroll', 'mousemove', 'touchstart'].forEach(ev => {
        document.addEventListener(ev, resetTimer, { passive: true });
      });
      resetTimer();
    })();

    // ── Portfolio card tilt (desktop, reduced-motion respected) ─────
    (() => {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (window.matchMedia('(max-width: 64rem)').matches) return;
      const card  = document.getElementById('portfolioPreviewCard');
      const right = card?.closest('.landing__right') as HTMLElement | null;
      if (!card || !right) return;
      right.addEventListener('mousemove', (e: MouseEvent) => {
        const rect = right.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width  - 0.5) * 14;
        const y = ((e.clientY - rect.top)  / rect.height - 0.5) * -10;
        (card as HTMLElement).style.transform = `perspective(600px) rotateY(${x}deg) rotateX(${y}deg) translateY(var(--float-offset, 0px))`;
      });
      right.addEventListener('mouseleave', () => {
        (card as HTMLElement).style.transform = '';
      });
    })();

    // ── Wallet demo form ──────────────────────────────────────────────
    (() => {
      const EVM_RE        = /^0x[a-fA-F0-9]{40}$/;
      const BTC_BECH_RE   = /^bc1[a-zA-HJ-NP-Z0-9]{25,}$/;
      const BTC_LEGACY_RE = /^[13][a-zA-HJ-NP-Z0-9]{25,34}$/;
      const LTC_BECH_RE   = /^ltc1[a-zA-HJ-NP-Z0-9]{25,}$/;
      const LTC_LEGACY_RE = /^[LM][a-zA-HJ-NP-Z0-9]{25,34}$/;
      const SOL_RE        = /^[1-9A-HJ-NP-Za-km-z]{32,44}$/;

      function isKnownAddress(addr: string): boolean {
        return EVM_RE.test(addr) || BTC_BECH_RE.test(addr) || BTC_LEGACY_RE.test(addr)
          || LTC_BECH_RE.test(addr) || LTC_LEGACY_RE.test(addr) || SOL_RE.test(addr);
      }

      const form  = document.getElementById('demoForm') as HTMLFormElement | null;
      const hint  = document.getElementById('demoHint') as HTMLElement | null;
      const data  = document.getElementById('demo-hint-data') as HTMLElement | null;
      const defaultHint = data?.dataset.hint ?? '';
      const errorHint   = data?.dataset.errorHint ?? '';

      if (!form) return;

      const input = form.querySelector('.landing__demo-input') as HTMLInputElement | null;

      input?.addEventListener('input', () => {
        if (hint) { hint.textContent = defaultHint; hint.classList.remove('demo-hint--error'); }
      });

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn     = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const address = input?.value.trim() ?? '';

        if (address && !isKnownAddress(address)) {
          if (hint) { hint.textContent = errorHint; hint.classList.add('demo-hint--error'); }
          return;
        }

        if (btn) btn.disabled = true;
        window.location.href = address
          ? `/api/demo/start?address=${encodeURIComponent(address)}`
          : '/api/demo/start';
      });
    })();

    // ── Tool carousel (auto-scroll: Check · Track · Verify) ───────────
    (() => {
      const track = document.getElementById('toolTrack');
      if (!track) return;
      const count = track.children.length;
      const dots = Array.from(document.querySelectorAll<HTMLButtonElement>('.tool-dot'));
      const indicator = document.getElementById('toolDotsIndicator');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let i = 0;
      let timer: ReturnType<typeof setInterval> | null = null;

      function render() {
        track!.style.transform = `translateX(${-i * 100}%)`;
        dots.forEach((d, k) => d.setAttribute('aria-selected', k === i ? 'true' : 'false'));
        const active = dots[i];
        if (indicator && active) {
          indicator.style.transform = `translateX(${active.offsetLeft + active.offsetWidth / 2 - 10}px)`;
        }
      }
      function go(n: number) { i = (n + count) % count; render(); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }
      function start() { if (reduce) return; stop(); timer = setInterval(() => go(i + 1), 4500); }

      dots.forEach((d) => d.addEventListener('click', () => { go(Number(d.dataset.i)); start(); }));
      document.getElementById('toolPrev')?.addEventListener('click', () => { go(i - 1); start(); });
      document.getElementById('toolNext')?.addEventListener('click', () => { go(i + 1); start(); });

      const root = document.querySelector('.tool-carousel');
      root?.addEventListener('pointerenter', stop);
      root?.addEventListener('pointerleave', start);
      root?.addEventListener('focusin', stop);
      root?.addEventListener('focusout', start);

      let x0: number | null = null;
      track.addEventListener('pointerdown', (e) => { x0 = e.clientX; stop(); });
      track.addEventListener('pointerup', (e) => {
        if (x0 !== null) { const dx = e.clientX - x0; if (Math.abs(dx) > 40) go(dx < 0 ? i + 1 : i - 1); x0 = null; }
        start();
      });

      render();
      start();
    })();
  </script>

  <style>
    :root {
      color-scheme: dark;
      font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #05060c;
      min-height: 100vh;
      color: #f5f8ff;
    }

    /* ── Page shell ──────────────────────────────────────────── */
    .landing {
      position: relative;
      width: 100%;
      min-height: 100vh;
      display: block;
      background: linear-gradient(160deg, #0d1525 0%, #0a0f1a 60%, #060b14 100%);
    }

    /* ── Hub landing (Header · Hero · Three Doors · Trust) ───── */
    .hub-top {
      max-width: 64rem; margin: 0 auto;
      padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 3rem) 0;
      display: flex; justify-content: center;
    }
    /* ── The honesty note ─────────────────────────────────────
       Said before any claim. Quiet, not an alarm — a plain sentence, no badge.
       /howTo opens this way; a landing page that looked finished while /howTo
       admitted it wasn't would be the lie. */
    .hub-honesty {
      max-width: 46rem; margin: clamp(1.5rem, 4vw, 2.25rem) auto 0;
      padding: 0 clamp(1.5rem, 4vw, 3rem);
      text-align: center; font-size: 0.9rem; line-height: 1.6;
    }
    .hub-honesty__title { color: var(--text-primary); font-weight: 600; }
    .hub-honesty__body  { color: var(--text-muted); }

    /* ── Hero ─────────────────────────────────────────────────
       Type only, no illustration: the audience is on mid-range phones paying for
       data by the megabyte, and the sentence IS the product. */
    .hub-hero {
      max-width: 52rem; margin: 0 auto;
      padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2.5rem);
      text-align: center;
    }
    .hub-hero__title {
      font-size: clamp(1.9rem, 3.2vw + 1rem, 3rem);
      font-weight: 600; letter-spacing: -0.02em; line-height: 1.15;
      color: var(--text-primary); margin: 0 0 1.25rem; text-wrap: balance;
    }
    .hub-hero__sub {
      font-size: clamp(0.98rem, 0.4vw + 0.9rem, 1.1rem); line-height: 1.65;
      color: var(--text-secondary); max-width: 54ch; margin: 0 auto 0.85rem;
      text-wrap: pretty;
    }
    /* The promise. Accent rule AND brighter text — never colour alone. Left
       aligned on purpose: it is a statement, not a slogan. */
    .hub-hero__promise {
      max-width: 34rem; margin: clamp(1.75rem, 4vw, 2.5rem) auto;
      padding: 0.1rem 0 0.1rem 1rem;
      border-left: 2px solid var(--accent);
      text-align: left;
      font-size: clamp(1rem, 0.5vw + 0.9rem, 1.2rem);
      font-weight: 600; line-height: 1.5;
      color: var(--text-primary); text-wrap: balance;
    }
    .hub-hero__cta {
      display: inline-block; min-height: 44px; padding: 0.85rem 1.7rem;
      border-radius: 999px;
      background: var(--accent); color: var(--surface-bg);
      font-size: 1rem; font-weight: 700; text-decoration: none;
      transition: box-shadow 0.15s ease, transform 0.1s ease;
    }
    .hub-hero__cta:hover { box-shadow: 0 0 0 6px var(--accent-glow); transform: translateY(-1px); }
    .hub-hero__cta:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    /* ── Three facts ──────────────────────────────────────────
       Each names something the product refuses to do. The refusal IS the
       argument, so it should not shout. */
    .hub-trust {
      max-width: 60rem; margin: 0 auto;
      padding: clamp(2.5rem, 6vw, 4rem) clamp(1.5rem, 4vw, 3rem) clamp(1.5rem, 3vw, 2rem);
      display: grid; grid-template-columns: 1fr; gap: 0.75rem;
    }
    @media (min-width: 40rem) { .hub-trust { grid-template-columns: repeat(3, 1fr); gap: 1rem; } }
    .tfact {
      background: var(--surface-card); border: 1px solid var(--border-subtle);
      border-radius: 12px; padding: 1rem 1.1rem;
      transition: border-color 0.15s ease;
    }
    .tfact:hover { border-color: var(--border-bright); }
    .tfact__k {
      display: block; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.02em;
      color: var(--text-primary); margin-bottom: 0.35rem;
    }
    .tfact__v { margin: 0; font-size: 0.85rem; line-height: 1.6; color: var(--text-secondary); }
    .tfact__link { color: var(--accent); font-weight: 600; text-decoration: none; white-space: nowrap; }
    .tfact__link:hover { text-decoration: underline; text-underline-offset: 3px; }
    .tfact__link:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

    /* ── Footer ───────────────────────────────────────────────── */
    .hub-foot {
      max-width: 60rem; margin: 0 auto;
      padding: 0 clamp(1.5rem, 4vw, 3rem) clamp(3rem, 6vw, 4.5rem);
      display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.75rem;
    }
    .hub-foot__link {
      display: inline-flex; align-items: center; min-height: 44px; padding: 0 0.25rem;
      font-size: 0.85rem; color: var(--text-muted); text-decoration: none;
      transition: color 0.15s ease;
    }
    .hub-foot__link:hover { color: var(--accent); }
    .hub-foot__link:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .hub-foot__dot { color: var(--text-muted); }


    /* On small screens drop the brand below the fixed language / Login pills.
       7rem, not 5: the pills sit at top:2rem and are now 44px tall (the tap-target
       floor), so they end near 5.25rem — 5rem was tuned when they were 28px and
       the language switcher had started overlapping the logo. */
    @media (max-width: 48rem) { .hub-top { padding-top: 7rem; } }

    /* ── Safety hero (the lead — free, no login) ─────────────── */
    .safety-hero {
      max-width: 46rem;
      margin: 0 auto;
      padding: clamp(2.5rem, 7vw, 5rem) clamp(1.5rem, 4vw, 3rem) clamp(1.25rem, 3vw, 2rem);
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .safety-hero .wordmark { margin-bottom: clamp(1.25rem, 3vw, 2rem); }
    .safety-hero__eyebrow {
      display: inline-block;
      font-size: 0.72rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--accent);
      background: var(--accent-soft);
      border: 1px solid var(--accent-glow);
      border-radius: 999px; padding: 0.3rem 0.9rem;
      margin-bottom: 1rem;
    }
    .safety-hero__headline {
      font-size: clamp(2rem, 4vw + 1rem, 3.25rem);
      font-weight: 600; letter-spacing: -0.02em; line-height: 1.08;
      color: var(--text-primary);
      margin: 0 0 0.9rem; max-width: 18ch; text-wrap: balance;
    }
    .safety-hero__sub {
      font-size: clamp(1rem, 0.5vw + 0.9rem, 1.15rem);
      line-height: 1.55; color: var(--text-secondary);
      max-width: 46ch; text-wrap: balance; margin: 0 0 1.75rem;
    }
    .safety-hero__checker { width: 100%; max-width: 34rem; }
    .safety-hero__hint {
      margin: 0.6rem 0 0; font-size: 0.8rem; color: var(--text-muted);
      line-height: 1.45; max-width: 42ch;
    }
    .safety-hero__chips {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem;
      margin-top: 1.25rem;
    }
    .safety-chip {
      font-size: 0.8rem; color: var(--text-secondary);
      border: 1px solid var(--border-subtle); border-radius: 999px;
      padding: 0.35rem 0.85rem; background: var(--surface-card);
    }
    /* Clear the fixed language pill / sign-in pill on small screens */
    @media (max-width: 48rem) {
      .safety-hero { padding-top: 5.5rem; }
    }

    /* ── Tool carousel (auto-scroll: Check · Track · Verify) ──── */
    .tool-carousel {
      width: 100%; max-width: 42rem; margin: 0 auto;
      padding: clamp(0.25rem, 1vw, 0.5rem) clamp(0.5rem, 3vw, 1.5rem) 0.75rem;
    }
    /* Rotating hero headline lines (carousel slides) */
    .hero-rot__line {
      width: 100%; margin: 0; text-align: center; text-wrap: balance;
      font-size: clamp(1.5rem, 3vw + 0.8rem, 2.5rem);
      font-weight: 600; letter-spacing: -0.02em; line-height: 1.12;
      color: var(--text-primary);
    }
    a.hero-rot__line { text-decoration: none; }
    a.hero-rot__line:hover { text-decoration: underline; text-underline-offset: 5px; }
    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
    }
    .tool-carousel__row { display: flex; align-items: center; gap: 0.6rem; }
    .tool-arrow {
      flex: 0 0 auto; width: 2.25rem; height: 2.25rem; border-radius: 999px;
      display: flex; align-items: center; justify-content: center;
      background: var(--surface-card); border: 1px solid var(--border-subtle);
      color: var(--text-secondary); font-size: 1.4rem; line-height: 1; cursor: pointer;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .tool-arrow:hover { border-color: var(--border-bright); color: var(--text-primary); background: var(--surface-hover); }
    .tool-viewport { flex: 1 1 auto; overflow: hidden; }
    .tool-track { display: flex; transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1); }
    .tool-slide { flex: 0 0 100%; display: flex; align-items: center; justify-content: center; padding: 0.5rem; box-sizing: border-box; }
    .tool-slide .tool-card { width: 100%; }
    .tool-dots { position: relative; display: flex; gap: 1.5rem; width: max-content; margin: 1.1rem auto 0; padding-bottom: 9px; }
    .tool-dot {
      background: none; border: none; padding: 0; cursor: pointer;
      font-size: 1.05rem; line-height: 1; opacity: 0.4;
      transition: opacity 0.2s;
    }
    .tool-dot:hover { opacity: 0.75; }
    .tool-dot[aria-selected="true"] { opacity: 1; }
    /* White indicator underline that slides beneath the active icon, in sync with the cards */
    .tool-dots__indicator {
      position: absolute; bottom: 0; left: 0;
      height: 2px; width: 20px; border-radius: 999px;
      background: var(--text-primary);
      transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
      pointer-events: none;
    }
    @media (prefers-reduced-motion: reduce) {
      .tool-track, .tool-dots__indicator { transition: none; }
    }
    .tool-card {
      display: flex; flex-direction: column; align-items: flex-start; gap: 0.3rem;
      text-align: left; text-decoration: none;
      padding: 1.25rem 1.3rem;
      background: var(--surface-card); border: 1px solid var(--border-subtle);
      border-radius: 16px; transition: border-color 0.15s, transform 0.1s, background 0.15s;
    }
    a.tool-card:hover { border-color: var(--border-bright); background: var(--surface-hover); transform: translateY(-2px); }
    .tool-card__icon { font-size: 1.75rem; line-height: 1; margin-bottom: 0.25rem; }
    .tool-card__title { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin: 0; }
    .tool-card__desc { font-size: 1.05rem; font-weight: 700; color: var(--text-primary); line-height: 1.35; margin: 0.15rem 0 0; flex: 1; }
    .tool-card__tag {
      margin-top: 0.5rem; font-size: 0.72rem; font-weight: 600;
      color: var(--accent); background: var(--accent-soft);
      border-radius: 999px; padding: 0.2rem 0.6rem;
    }

    /* ── Trust strip ─────────────────────────────────────────── */
    .trust-strip {
      max-width: 60rem; margin: 0 auto;
      padding: 0 1.5rem clamp(3rem, 6vw, 5rem);
      text-align: center; font-size: 0.8rem; color: var(--text-muted); line-height: 1.6;
    }

    /* ── Two-column hero grid ────────────────────────────────── */
    .landing__hero {
      max-width: 75rem;
      margin: 0 auto;
      padding-block: clamp(3rem, 8vw, 6rem);
      padding-inline: clamp(1.5rem, 4vw, 3rem);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(2rem, 4vw, 4rem);
      align-items: start;
    }

    .landing__left {
      display: flex;
      flex-direction: column;
    }

    .landing__right {
      display: flex;
      justify-content: flex-end;
      align-items: start;
      position: sticky;
      top: 2rem;
    }

    .landing__right-inner {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 1rem;
    }

    @media (max-width: 64rem) {
      .landing__hero { grid-template-columns: 1fr; gap: 0; }
      .landing__right { display: none; }
    }

    /* ── Wordmark ────────────────────────────────────────────── */
    .wordmark {
      display: inline-flex; align-items: center; gap: 0.75rem;
      text-decoration: none; width: fit-content;
    }
    .wordmark-img {
      width: 5.5rem; height: 5.5rem; border-radius: 1.25rem;
      object-fit: cover;
      border: 1px solid rgba(255,255,255,0.18);
      box-shadow: 0 0.5rem 1.25rem rgba(0,0,0,0.4);
    }
    .wordmark-text {
      font-size: 1.35rem; font-weight: 800; letter-spacing: -0.02em;
      background: linear-gradient(135deg, #a5b4fc, #818cf8);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    }

    /* ── Headline ────────────────────────────────────────────── */
    .hero__copy { margin-top: clamp(1.5rem, 4vw, 3rem); }
    .hero__headline {
      font-size: clamp(2rem, 4vw + 1rem, 3.25rem);
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--text-primary);
      margin: 0 0 1.5rem;
      max-width: 22ch;
    }
    .hero__subheadline {
      font-size: clamp(1rem, 0.5vw + 0.875rem, 1.125rem);
      line-height: 1.5;
      color: var(--text-secondary);
      max-width: 38ch;
      text-wrap: balance;
      margin: 0 0 2rem;
    }

    /* ── Primary demo CTA ────────────────────────────────────── */
    .landing__demo-cta {
      display: block;
      margin-top: clamp(1.5rem, 3vw, 2rem);
      padding: 1rem 1.75rem;
      background: var(--accent);
      color: #05060c;
      font-size: 1.05rem;
      font-weight: 800;
      text-decoration: none;
      border-radius: 0.75rem;
      text-align: center;
      letter-spacing: 0.01em;
      transition: box-shadow 0.15s, transform 0.1s;
    }
    .landing__demo-cta:hover {
      box-shadow: 0 0 2rem var(--accent-glow);
      transform: translateY(-1px);
    }
    .landing__demo-cta-sub {
      margin-top: 0.6rem;
      font-size: 0.82rem;
      color: var(--text-muted);
      text-align: center;
    }

    .hero__social-proof {
      margin-top: 0.75rem;
      font-size: 0.78rem;
      color: var(--text-muted);
      text-align: center;
      letter-spacing: 0.01em;
    }

    /* ── Product Hunt badge ──────────────────────────────────── */
    .ph-badge-link { display: inline-block; margin-top: 1.25rem; }

    /* ── Safety checker ── */
    .landing__checker {
      margin: 1.5rem 0;
      padding: 1rem 1.1rem;
      border: 1px solid var(--border-bright);
      border-radius: 14px;
      background: var(--surface-card);
    }
    .landing__checker-label { font-size: 0.95rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.6rem; }
    .landing__checker-hint { margin: 0.6rem 0 0; font-size: 0.8rem; color: var(--text-muted); line-height: 1.4; }

    /* ── Secondary wallet input ──────────────────────────────── */
    .landing__wallet-secondary {
      margin-top: clamp(1.5rem, 3vw, 2rem);
      padding-top: 1.25rem;
      border-top: 1px solid var(--border-subtle);
    }
    .landing__wallet-label-row {
      display: flex;
      align-items: center;
      margin-bottom: 0.6rem;
      padding-top: 0.5rem;
    }
    .landing__wallet-label {
      font-size: 0.78rem;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .hub-hero .landing__changelog-link {
      display: inline-block;
      margin-top: 1rem;
    }
    .landing__changelog-link {
      font-size: 0.72rem;
      color: rgba(45,212,168,0.9);
      text-decoration: none;
      border: 1px solid rgba(45,212,168,0.65);
      border-radius: 999px;
      padding: 0.28rem 0.75rem;
      letter-spacing: 0.04em;
      background: rgba(45,212,168,0.08);
      transition: color 0.15s, border-color 0.15s, background 0.15s;
      white-space: nowrap;
    }
    .landing__changelog-link:hover {
      color: var(--accent);
      border-color: rgba(45,212,168,0.9);
      background: rgba(45,212,168,0.14);
    }

    /* ── Wallet demo input ───────────────────────────────────── */
    .landing__demo-form {
      display: flex;
      gap: 0;
      border: 1px solid var(--border-bright);
      border-radius: 0.75rem;
      background: var(--surface-card);
      overflow: hidden;
      transition: border-color 0.15s;
    }
    .landing__demo-form:focus-within {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }
    .landing__demo-input {
      flex: 1;
      background: transparent;
      border: 0;
      padding: 1.125rem 1.25rem;
      font-size: 1.125rem;
      color: var(--text-primary);
      font-family: inherit;
      outline: 0;
    }
    .landing__demo-input::placeholder { color: var(--text-muted); }
    .landing__demo-submit {
      background: var(--accent);
      color: var(--surface-bg);
      border: 0;
      padding: 0 1.5rem;
      font-size: 1.25rem;
      font-weight: 600;
      cursor: pointer;
      flex-shrink: 0;
      transition: box-shadow 0.15s;
    }
    .landing__demo-submit:hover { box-shadow: 0 0 1.5rem var(--accent-glow); }
    .landing__demo-hint {
      font-size: 0.875rem;
      color: var(--text-muted);
      margin-top: 0.75rem;
      text-align: center;
    }
    .demo-hint--error { color: var(--loss); }

    /* ── Feature stack ───────────────────────────────────────── */
    .feature-stack {
      margin-top: clamp(3rem, 6vw, 5rem);
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      padding-bottom: 6rem;
    }
    .feature-card {
      display: flex; align-items: flex-start; gap: 0.75rem;
      background: var(--surface-card);
      border: 1px solid var(--border-subtle);
      border-radius: 0.75rem;
      padding: 1rem 1.25rem;
    }
    .fc-icon { font-size: 1.3rem; flex-shrink: 0; margin-top: 0.1rem; }
    .fc-title { font-size: 0.9rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.25rem; }
    .fc-desc  { font-size: 0.8rem; color: var(--text-muted); line-height: 1.5; }
    .fc-anon-link { color: var(--accent); text-decoration: none; white-space: nowrap; }
    .fc-anon-link:hover { text-decoration: underline; }

    /* ── Language switcher (EN / ES / FR) ─────────────────────── */
    .lang-switch {
      position: fixed;
      top: 2rem;
      left: 2rem;
      z-index: 200;
      display: inline-flex;
      flex-direction: row;
      flex-wrap: nowrap;
      width: max-content;
      align-items: center;
      gap: 0.15rem;
      padding: 0.25rem 0.3rem;
      border-radius: 999px;
      border: 1px solid var(--border-bright);
      background: transparent;
      animation: slideInFromRight 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .lang-switch__lang {
      /* 44px floor. This measured 28px — and for a product that speaks three
         languages to people reading on a phone, the language control is the first
         thing a hand reaches for, not an afterthought. */
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      color: var(--text-muted);
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-decoration: none;
      transition: background 0.15s, color 0.15s;
    }
    .lang-switch__lang:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    .lang-switch__lang:hover {
      background: var(--surface-hover);
      color: var(--text-primary);
    }
    .lang-switch__lang[aria-current="true"] {
      background: var(--accent-soft);
      color: var(--text-primary);
    }

    /* ── Sign-in pill (fixed top-right) ─────────────────────── */
    @keyframes slideInFromRight {
      from { opacity: 0; transform: translateX(2.5rem); }
      to   { opacity: 1; transform: translateX(0); }
    }
    .signin-pill-wrap {
      position: fixed;
      top: 2rem;
      right: 2rem;
      z-index: 200;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      animation: slideInFromRight 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
    }
    .signin-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      /* 44px floor: this is the only way in, and it is tapped with a thumb on a
         mid-range phone. It measured 39px. */
      min-height: 44px;
      padding: 0.625rem 1.25rem;
      border-radius: 999px;
      border: 1px solid var(--border-bright);
      background: transparent;
      color: var(--text-secondary);
      font-size: 0.88rem;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: background 0.15s, color 0.15s, transform 0.15s;
      white-space: nowrap;
      max-width: 11.25rem;
      text-align: center;
    }
    .signin-pill:disabled {
      opacity: 0.45;
      cursor: not-allowed;
      pointer-events: none;
    }
    .signin-pill:hover {
      background: var(--surface-hover);
      color: var(--text-primary);
      transform: translateY(-1px);
    }
    .signin-pill.is-open {
      background: var(--surface-hover);
      color: var(--text-primary);
    }
    .pill-chevron { display: none; }

    /* ── Sign-in dropdown ────────────────────────────────────── */
    .dropdown-close {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 0.8rem;
      cursor: pointer;
      padding: 0.25rem 0.4rem;
      border-radius: 0.25rem;
      line-height: 1;
      transition: color 0.15s, background 0.15s;
    }
    .dropdown-close:hover {
      color: var(--text-primary);
      background: var(--surface-hover);
    }
    .signin-dropdown {
      position: absolute;
      top: calc(100% + 0.6rem);
      right: 0;
      width: 20rem;
      background: rgba(10, 15, 26, 0.98);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 1rem;
      padding: 1.25rem;
      box-shadow: 0 1.25rem 3.75rem rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
      backdrop-filter: blur(1rem);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      animation: dropIn 0.18s ease;
    }
    .signin-dropdown[hidden] { display: none; }
    @keyframes dropIn {
      from { opacity: 0; transform: translateY(-6px) scale(0.98); }
      to   { opacity: 1; transform: none; }
    }
    @media (max-width: 25rem) {
      .signin-pill-wrap { right: 0.75rem; }
      .signin-dropdown  { width: calc(100vw - 1.5rem); right: 0; }
    }

    .dropdown-info {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding: 0.55rem 0.75rem;
      background: var(--surface-card-2);
      border: 1px solid var(--border-subtle);
      border-radius: 0.625rem;
    }
    .dropdown-info-primary {
      margin: 0;
      font-size: 0.84rem;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.4;
    }
    .dropdown-info-sub {
      margin: 0;
      font-size: 0.76rem;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .dropdown-notice {
      margin: 0;
      background: var(--loss-bg);
      border: 1px solid var(--loss-border);
      color: #ffb5b5;
      padding: 0.55rem 0.75rem;
      border-radius: 0.625rem;
      font-size: 0.84rem;
      line-height: 1.5;
    }
    .dropdown-notice--success {
      background: var(--gain-bg);
      border-color: var(--gain-border);
      color: #b6f3c4;
    }

    .dropdown-cta {
      display: flex; align-items: center; justify-content: center;
      width: 100%; padding: 0.85rem 1rem;
      border-radius: 0.75rem;
      background: linear-gradient(135deg, #5767ff, #934dff);
      color: #fff; font-size: 0.95rem; font-weight: 700;
      text-decoration: none;
      transition: opacity 0.15s, transform 0.15s;
    }
    .dropdown-cta:hover { opacity: 0.9; transform: translateY(-1px); }

    .dropdown-divider {
      height: 0.0625rem;
      background: rgba(255,255,255,0.08);
      margin: 0.1rem 0;
    }

    /* Providers */
    .provider-form { margin: 0; }
    .provider-button {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.6rem;
      width: 100%; text-decoration: none;
      border-radius: 0.75rem; padding: 0.8rem 1rem;
      border: 1px solid rgba(255,255,255,0.15);
      background: rgba(255,255,255,0.07);
      color: #fff; font-size: 0.92rem; font-weight: 650;
      cursor: pointer;
      transition: transform 0.18s ease, opacity 0.18s ease, border-color 0.18s ease, background 0.18s ease;
      position: relative; flex-direction: row;
    }
    .provider-button:hover {
      opacity: 0.9; transform: translateY(-1px);
      border-color: rgba(255,255,255,0.28);
