---
import type { Lang } from "@/lib/i18n/locale";
import { getFaq } from "@/i18n/faq";

const { lang = "en", audience = "member" } = Astro.props as {
  lang?: Lang;
  audience?: "member" | "admin";
};
const all = getFaq(lang);
// Absent audience means member — the default set, and what the footer shows.
const t = { items: all.items.filter((i) => (i.audience ?? "member") === audience) };
---

<section class="faq-section">
  <div>
    <!-- FAQ -->
    <div class="faq-list">
      {t.items.map((it) => (
        <button class="faq-question" type="button" data-modal={it.id}>
          {it.q}
        </button>
      ))}
    </div>

    {t.items.map((it) => (
      <div class="modal-overlay welcome-modal" id={it.id}>
        <div class="modal-content">
          <button class="modal-close" onclick="closeWelcomeModal(event)">×</button>
          <h2>{it.q}</h2>
          <Fragment set:html={it.a} />
        </div>
      </div>
    ))}
  </div>

  <style>
    /* Page centering container */
    .welcome-page {
      min-height: 70vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem;
    }

    /* Card */
    .hero-card {
      width: 100%;
      max-width: 360px;
      background: #121212;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 12px 30px rgba(0, 0, 0, 0.35);
      display: flex;
      flex-direction: column;
    }

    /* Image */
    .hero-image img {
      width: 100%;
      height: auto;
      display: block;
    }

    /* Info section */
    .hero-info {
      padding: 1.25rem;
      text-align: center;
    }

    .hero-info h2 {
      margin: 0;
      font-size: 1.3rem;
      font-weight: 600;
    }

    .hero-role {
      font-size: 0.9rem;
      opacity: 0.75;
      margin: 0.25rem 0 1rem;
    }

    /* Social buttons */
    .hero-links {
      display: flex;
      gap: 0.5rem;
    }

    .hero-links a {
      flex: 1;
      text-decoration: none;
      font-size: 0.8rem;
      padding: 0.55rem;
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.06);
      color: white;
      transition: all 0.2s ease;
      text-align: center;
    }

    .hero-links a:hover {
      background: rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
    }

    .faq-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.85rem;
      margin-top: 1.5rem;
    }

    @media (max-width: 600px) {
      .faq-list {
        grid-template-columns: 1fr;
      }
    }

    .faq-question {
      width: 100%;
      text-align: left;
      padding: 0.85rem 1rem;
      border-radius: 12px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(255, 255, 255, 0.05);
      color: #fff;
      font-size: 0.98rem;
      cursor: pointer;
      transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }

    .faq-question:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.28);
      transform: translateY(-1px);
    }

    /* modal */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.7);
      align-items: center;
      justify-content: center;
      z-index: 9999;
    }

    .welcome-modal {
      display: none;
    }

    .welcome-modal.is-open {
      display: flex;
    }

    .modal-content {
      background: #121212;
      color: #ffffff;
      max-width: 600px;
      width: 90%;
      padding: 2rem;
      border-radius: 14px;
      box-shadow: 0 0 40px rgba(0, 0, 0, 0.6);
      position: relative;
      animation: modalFadeIn 0.3s ease;
    }

    .modal-close {
      position: absolute;
      top: 12px;
      right: 14px;
      background: none;
      border: none;
      font-size: 1.5rem;
      color: #aaa;
      cursor: pointer;
    }

    .modal-close:hover {
      color: #fff;
    }

    @keyframes modalFadeIn {
      from {
        opacity: 0;
        transform: scale(0.95);
      }
      to {
        opacity: 1;
        transform: scale(1);
      }
    }
  </style>

  <script>
    const modals = Array.from(document.querySelectorAll(".welcome-modal"));

    /** @param {Event} event */
    function closeWelcomeModal(event:any) {
      const targetModal =
        event?.currentTarget instanceof HTMLElement
          ? event.currentTarget.closest(".welcome-modal")
          : null;

      if (targetModal) {
        targetModal.classList.remove("is-open");
      }
    }

    document.querySelectorAll("[data-modal]").forEach((trigger) => {
      trigger.addEventListener("click", () => {
        const id = trigger.getAttribute("data-modal");
        if (!id) return;
        const modal = document.getElementById(id);
        if (modal) {
          modal.classList.add("is-open");
        }
      });
    });
  </script>
</section>
