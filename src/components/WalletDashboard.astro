---
import './WalletDashboard.css';
import { db } from '../lib/db';
import { requireTenantSession } from '../lib/requireTenantSession';
import { jsonForScript } from '../lib/jsonForScript';

const { tenantId } = await requireTenantSession(Astro.request);

const walletResult = await db.execute({
	sql: 'SELECT id, address, label, chains, is_default, created_at FROM wallets WHERE tenant_id = ? ORDER BY created_at DESC',
	args: [tenantId],
});

const wallets = walletResult.rows.map((row) => ({
	id: row.id,
	address: row.address,
	label: row.label,
	isDefault: Boolean(row.is_default),
	createdAt: row.created_at,
	chains: parseChains(row.chains),
}));

const walletCount = wallets.length;
const defaultWallets = wallets.filter((wallet) => wallet.isDefault).length;

const userResult = await db.execute({
	sql: 'SELECT id, full_name, street_address, city, state, postal_code, country, phone_number, email, secondary_email FROM users WHERE tenant_id = ? ORDER BY created_at ASC LIMIT 1',
	args: [tenantId],
});
const primaryUser = userResult.rows[0] ?? null;
const normalizeField = (v: string | number | bigint | ArrayBuffer | null | undefined): string => {
	if (typeof v === 'string') return v;
	if (typeof v === 'number' || typeof v === 'bigint') return String(v);
	if (v instanceof ArrayBuffer) {
		try {
			return new TextDecoder().decode(v);
		} catch {
			return '';
		}
	}
	return '';
};

const fullName = primaryUser ? normalizeField(primaryUser.full_name) : '';
const greetingName = fullName ? fullName.split(' ')[0] : 'Investor';

const serverTimestamp = new Date().toISOString();

function parseChains(payload: unknown) {
	if (typeof payload !== 'string') return [];
	try {
		const parsed = JSON.parse(payload);
		return Array.isArray(parsed) ? parsed : [];
	} catch {
		return [];
	}
}
---

<section class="dashboard">
	<section class="hero">
		<div>
			<p class="hello">Hello, {greetingName}</p>
			<h1>Your portfolio pulse</h1>
		</div>
		<div class="hero__meta">
			<div class="clock">
				<p>As of <span data-clock>{new Date(serverTimestamp).toLocaleString()}</span></p>
				<small>{primaryUser?.city ? `${primaryUser.city}${primaryUser.country ? ` · ${primaryUser.country}` : ''}` : 'Local time'}</small>
			</div>
			<div class="avatar-card">
				<div class="avatar-shell">
					<img data-avatar alt="Avatar preview" />
				</div>
				<label class="upload">
					<input type="file" id="avatar-input" accept="image/*,image/gif" />
					<span>Upload avatar / gif</span>
				</label>
			</div>
		</div>
	</section>

	<header class="dashboard__header">
		<div>
			<p class="eyebrow">Private portfolio cockpit</p>
			<h1>Wallet overview</h1>
			<p class="lede">Centralize every address you care about before piping in Aave and DeFi signals.</p>
		</div>
		<div class="header__stats">
			<article>
				<p>Total wallets</p>
				<strong>{walletCount}</strong>
			</article>
			<article>
				<p>Primary wallets</p>
				<strong>{defaultWallets}</strong>
			</article>
		</div>
	</header>

	<div class="grid">
		<section class="panel wallets">
			<header>
				<div>
					<h2>Tracked wallets</h2>
					<p>Every address saved here will be eligible for data ingestion.</p>
				</div>
				<span class="badge">{walletCount}</span>
			</header>

			<table>
				<thead>
					<tr>
						<th>Label</th>
						<th>Address</th>
						<th>Chains</th>
						<th>Added</th>
						<th>Actions</th>
					</tr>
				</thead>
				<tbody data-wallet-list>
					{wallets.length === 0 ? (
						<tr>
							<td colspan="5" class="empty">No wallets yet. Add one using the form on the right.</td>
						</tr>
					) : (
						wallets.map((wallet) => (
							<tr>
								<td>
									<strong>{wallet.label ?? '—'}</strong>
									{wallet.isDefault && <span class="pill">Default</span>}
								</td>
								<td class="wallet-address">
									<code>{wallet.address}</code>
									<button type="button" class="copy-button" data-copy={wallet.address}>
										Copy
									</button>
								</td>
								<td>{wallet.chains.length ? wallet.chains.join(', ') : '—'}</td>
								<td>
									{wallet.createdAt ? new Date(String(wallet.createdAt)).toLocaleString() : '—'}
								</td>
								<td>
									<div class="row-actions">
										<button type="button" class="ghost" data-action="edit" data-id={wallet.id}>
											Edit
										</button>
										<button type="button" class="ghost danger" data-action="delete" data-id={wallet.id}>
											Delete
										</button>
									</div>
								</td>
							</tr>
						))
					)}
				</tbody>
			</table>
		</section>

		<section class="panel form-panel">
			<header>
				<h2>Add wallet</h2>
				<p>Supports EVM (0x…), Sui, and Bitcoin (bc1…) addresses. You can edit details later.</p>
			</header>

			<form id="wallet-form">
				<input type="hidden" name="walletId" />
				<label class="field">
					<span>Label</span>
					<input type="text" name="label" placeholder="Treasury · Multisig" maxlength="80" />
				</label>
				<label class="field required">
					<span>Address</span>
					<input type="text" name="address" placeholder="0x… or bc1q…" required minlength="26" maxlength="90" />
				</label>
				<label class="field">
					<span>Chains (comma separated)</span>
					<input type="text" name="chains" placeholder="ethereum, polygon, sui, bitcoin" />
				</label>
				<label class="checkbox">
					<input type="checkbox" name="isDefault" />
					<span>Mark as primary</span>
				</label>
				<div class="form-actions">
					<button type="submit" data-submit-label>
						Save wallet
					</button>
					<button type="button" class="ghost" data-cancel-edit hidden>
						Cancel edit
					</button>
					<button type="button" class="ghost danger" data-delete-wallet hidden>
						Delete wallet
					</button>
				</div>
				<p class="form-status" data-status></p>
			</form>
		</section>
	</div>

	<section class="panel profile-panel">
		<header>
			<h2>Profile & preferences</h2>
			<p>Update the metadata used for greetings and downstream reporting.</p>
		</header>
		<form id="profile-form">
			<div class="profile-grid">
				<label class="field required">
					<span>Full name</span>
					<input
						type="text"
						name="fullName"
						value={primaryUser ? normalizeField(primaryUser.full_name) : ''}
						required
						maxlength="120"
					/>
				</label>
				<label class="field required">
					<span>Email</span>
					<input type="email" name="email" value={primaryUser ? normalizeField(primaryUser.email) : ''} required />
				</label>
				<label class="field">
					<span>Secondary email</span>
					<input
						type="email"
						name="secondaryEmail"
						value={primaryUser ? normalizeField(primaryUser.secondary_email) : ''}
					/>
				</label>
				<label class="field">
					<span>Phone</span>
					<input type="tel" name="phoneNumber" value={primaryUser ? normalizeField(primaryUser.phone_number) : ''} />
				</label>
				<label class="field">
					<span>Street address</span>
					<input type="text" name="streetAddress" value={primaryUser ? normalizeField(primaryUser.street_address) : ''} />
				</label>
				<label class="field">
					<span>City</span>
					<input type="text" name="city" value={primaryUser ? normalizeField(primaryUser.city) : ''} />
				</label>
				<label class="field">
					<span>State / Region</span>
					<input type="text" name="state" value={primaryUser ? normalizeField(primaryUser.state) : ''} />
				</label>
				<label class="field">
					<span>Postal code</span>
					<input type="text" name="postalCode" value={primaryUser ? normalizeField(primaryUser.postal_code) : ''} />
				</label>
				<label class="field">
					<span>Country</span>
					<input type="text" name="country" value={primaryUser ? normalizeField(primaryUser.country) : ''} />
				</label>
			</div>
			<button type="submit" class="wide">Save profile</button>
			<p class="form-status" data-profile-status></p>
		</form>
	</section>
	<script type="application/json" id="wallet-data" set:html={jsonForScript(wallets)}></script>
</section>

<script type="module">
	const dataCarrier = document.getElementById('wallet-data');
	const tableBody = document.querySelector('[data-wallet-list]');
	const statusEl = document.querySelector('[data-status]');
	const profileStatus = document.querySelector('[data-profile-status]');
	const form = document.getElementById('wallet-form');
	const profileForm = document.getElementById('profile-form');
	const submitLabel = form ? form.querySelector('[data-submit-label]') : null;
	const cancelEditBtn = form ? form.querySelector('[data-cancel-edit]') : null;
	const deleteWalletBtn = form ? form.querySelector('[data-delete-wallet]') : null;
	const clock = document.querySelector('[data-clock]');
	const avatarInput = document.getElementById('avatar-input');
	const avatarImg = document.querySelector('[data-avatar]');
	const AVATAR_STORAGE_KEY = 'dashboard-avatar';
	const COPY_FEEDBACK_MS = 2000;

	let wallets = [];
	let editingId = null;
	if (dataCarrier?.textContent) {
		try {
			wallets = JSON.parse(dataCarrier.textContent);
		} catch (error) {
			console.error('Failed to parse wallet payload', error);
		}
	}

	if (clock) {
		updateClock();
		setInterval(updateClock, 60 * 1000);
	}

	document.addEventListener('click', async (event) => {
		const target = event.target;
		if (!(target instanceof Element)) return;
		const button = target.closest('button[data-copy]');
		if (!(button instanceof HTMLButtonElement)) return;
		const value = button.dataset.copy ?? '';
		if (!value) return;
		try {
			await copyToClipboard(value);
			showCopyFeedback(button, 'Copied');
		} catch {
			showCopyFeedback(button, 'Failed', true);
		}
	});

	if (avatarImg instanceof HTMLImageElement) {
		const cached = window.localStorage.getItem(AVATAR_STORAGE_KEY);
		if (cached) {
			avatarImg.src = cached;
		} else {
			avatarImg.src =
				'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=200&q=60';
		}
	}

	// Attach listeners for the server-rendered rows on first load
	attachRowListeners();

	if (avatarInput instanceof HTMLInputElement) {
		avatarInput.addEventListener('change', () => {
			if (!avatarInput.files?.length || !(avatarImg instanceof HTMLImageElement)) return;
			const file = avatarInput.files[0];
			if (!file.type.startsWith('image/')) {
				setStatus('Please select an image or gif.', 'error');
				return;
			}
			const reader = new FileReader();
			reader.onload = () => {
				const result = typeof reader.result === 'string' ? reader.result : null;
				if (result && avatarImg instanceof HTMLImageElement) {
					window.localStorage.setItem(AVATAR_STORAGE_KEY, result);
					avatarImg.src = result;
					setStatus('Avatar updated.', 'success');
				}
			};
			reader.readAsDataURL(file);
		});
	}

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!form) return;
		const formData = new FormData(form);
		const rawChains = String(formData.get('chains') ?? '').trim();
		const parsedChains = rawChains
			.split(',')
			.map((chain) => chain.trim().toLowerCase())
			.filter(Boolean);
		// Auto-detect default chains from address format when none are provided
		const address = String(formData.get('address') ?? '').trim();
		const isSuiAddress = address.length === 66 && address.startsWith('0x');
		const isBtcAddress = /^bc1[a-z0-9]{6,87}$/i.test(address) || /^[13][a-km-zA-HJ-NP-Z1-9]{25,34}$/.test(address);
		const defaultChains = isSuiAddress ? ['sui'] : isBtcAddress ? ['bitcoin'] : ['ethereum', 'polygon', 'avalanche'];
		const nextChains = parsedChains.length
			? Array.from(new Set(parsedChains))
			: defaultChains;
		const payload = {
			label: formData.get('label'),
			address: formData.get('address'),
			chains: nextChains,
			isDefault: formData.get('isDefault') === 'on',
		};

		setStatus('Saving wallet…');

		try {
			const isEditing = Boolean(editingId);
			const endpoint = isEditing ? `/api/wallets/${editingId}` : '/api/wallets';
			const method = isEditing ? 'PATCH' : 'POST';
			const response = await fetch(endpoint, {
				method,
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});
			const result = await response.json();
			if (!response.ok) {
				throw new Error(result.message || 'Unable to save wallet');
			}
			if (isEditing) {
				wallets = wallets.map((wallet) => (wallet.id === editingId ? result : wallet));
			} else {
				wallets = [result, ...wallets];
			}
			renderRows();
			resetForm();
			setStatus(isEditing ? 'Wallet updated.' : 'Wallet saved. Syncing history…', 'success');
			if (!isEditing && result?.id && result?.address) {
				try {
					await fetch(`/api/wallets/${result.id}/sync`, { method: 'POST' });
					await fetch(`/api/aave/positions?address=${encodeURIComponent(result.address)}`);
					await fetch(`/api/aave/health?address=${encodeURIComponent(result.address)}`);
					setStatus('Wallet synced.', 'success');
				} catch (syncError) {
					console.error(syncError);
					setStatus('Wallet saved, but sync failed.', 'error');
				}
			}
		} catch (error) {
			console.error(error);
			setStatus(error instanceof Error ? error.message : 'Failed to save wallet', 'error');
		}
	});

	cancelEditBtn?.addEventListener('click', () => {
		resetForm();
		setStatus('Edit cancelled.', 'info');
	});

	deleteWalletBtn?.addEventListener('click', () => {
		if (editingId) handleDelete(editingId);
	});

	profileForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!profileForm) return;
		const formData = new FormData(profileForm);
		const payload = Object.fromEntries(formData.entries());
		setProfileStatus('Saving profile…');
		try {
			const response = await fetch('/api/users', {
				method: 'POST',
				headers: { 'Content-Type': 'application/json' },
				body: JSON.stringify(payload),
			});
			const result = await response.json();
			if (!response.ok) {
				throw new Error(result.message || 'Unable to save profile');
			}
			setProfileStatus('Profile updated.', 'success');
			if (result.fullName) {
				const hello = document.querySelector('.hello');
				if (hello) {
					const firstName = String(result.fullName).split(' ')[0] || 'Investor';
					hello.textContent = `Hello, ${firstName}`;
				}
			}
		} catch (error) {
			console.error(error);
			setProfileStatus(error instanceof Error ? error.message : 'Failed to save profile', 'error');
		}
	});

	function setStatus(message, mode = 'info') {
		if (!statusEl) return;
		statusEl.textContent = message;
		statusEl.dataset.mode = mode;
	}

	function updateClock() {
		if (!clock) return;
		clock.textContent = new Date().toLocaleString();
	}

	function renderRows() {
		if (!tableBody) return;
		tableBody.innerHTML = '';
		if (wallets.length === 0) {
			const tr = document.createElement('tr');
			tr.innerHTML = `<td colspan="5" class="empty">No wallets yet. Add one using the form.</td>`;
			tableBody.appendChild(tr);
			return;
		}
		wallets.forEach((wallet) => {
			const tr = document.createElement('tr');
			tr.innerHTML = `
				<td>
					<strong>${wallet.label ?? '—'}</strong>
					${wallet.isDefault ? '<span class="pill">Default</span>' : ''}
				</td>
				<td class="wallet-address">
					<code>${wallet.address}</code>
					<button type="button" class="copy-button" data-copy="${wallet.address}">Copy</button>
				</td>
				<td>${wallet.chains?.length ? wallet.chains.join(', ') : '—'}</td>
				<td>${new Date(wallet.createdAt).toLocaleString()}</td>
				<td>
					<div class="row-actions">
						<button type="button" class="ghost" data-action="edit" data-id="${wallet.id}">Edit</button>
						<button type="button" class="ghost danger" data-action="delete" data-id="${wallet.id}">Delete</button>
					</div>
				</td>
			`;
			tableBody.appendChild(tr);
		});
		attachRowListeners();
	}

	function attachRowListeners() {
		if (!tableBody) return;
		tableBody.querySelectorAll('button[data-action]').forEach((button) => {
			const id = button.dataset.id;
			if (!id) return;
			if (button.dataset.action === 'edit') {
				button.addEventListener('click', () => beginEdit(id));
			} else if (button.dataset.action === 'delete') {
				button.addEventListener('click', () => handleDelete(id));
			}
		});
	}

	function beginEdit(id) {
		const wallet = wallets.find((entry) => entry.id === id);
		if (!wallet || !form) return;
		editingId = id;
		setInputValue('walletId', id);
		setInputValue('label', wallet.label ?? '');
		setInputValue('address', wallet.address ?? '');
		setInputValue('chains', wallet.chains?.join(', ') ?? '');
		setCheckboxValue('isDefault', Boolean(wallet.isDefault));
		if (submitLabel) submitLabel.textContent = 'Update wallet';
		if (cancelEditBtn) cancelEditBtn.hidden = false;
		if (deleteWalletBtn) deleteWalletBtn.hidden = false;
		form.scrollIntoView({ behavior: 'smooth', block: 'start' });
		setStatus('Editing wallet…', 'info');
	}

	async function handleDelete(id) {
		const wallet = wallets.find((entry) => entry.id === id);
		if (!wallet) return;
		const confirmMsg = `Delete wallet "${wallet.label || wallet.address}"?\n\nThis will permanently delete the wallet and ALL of its transaction history. This cannot be undone.`;
		if (!window.confirm(confirmMsg)) return;
		setStatus('Removing wallet…');
		try {
			const response = await fetch(`/api/wallets/${id}`, { method: 'DELETE' });
			if (!response.ok && response.status !== 204) {
				throw new Error('Failed to delete wallet');
			}
			wallets = wallets.filter((entry) => entry.id !== id);
			renderRows();
			if (editingId === id) {
				resetForm();
			}
			setStatus('Wallet removed.', 'success');
		} catch (error) {
			console.error(error);
			setStatus(error instanceof Error ? error.message : 'Failed to delete wallet', 'error');
		}
	}

	function resetForm() {
		if (!form) return;
		form.reset();
		editingId = null;
		setInputValue('walletId', '');
		if (submitLabel) submitLabel.textContent = 'Save wallet';
		if (cancelEditBtn) cancelEditBtn.hidden = true;
		if (deleteWalletBtn) deleteWalletBtn.hidden = true;
	}

	function setProfileStatus(message, mode = 'info') {
		if (!profileStatus) return;
		profileStatus.textContent = message;
		profileStatus.dataset.mode = mode;
	}

	function setInputValue(name, value) {
		if (!form) return;
		const element = form.elements.namedItem(name);
		if (element instanceof HTMLInputElement) {
			element.value = value;
		}
	}

	function setCheckboxValue(name, checked) {
		if (!form) return;
		const element = form.elements.namedItem(name);
		if (element instanceof HTMLInputElement) {
			element.checked = checked;
		}
	}

	async function copyToClipboard(value) {
		if (navigator?.clipboard?.writeText) {
			return navigator.clipboard.writeText(value);
		}
		const textarea = document.createElement('textarea');
		textarea.value = value;
		textarea.style.position = 'fixed';
		textarea.style.left = '-9999px';
		document.body.appendChild(textarea);
		textarea.focus();
		textarea.select();
		document.execCommand('copy');
		document.body.removeChild(textarea);
	}

	function showCopyFeedback(button, label, isError = false) {
		const original = button.dataset.label ?? button.textContent ?? 'Copy';
		if (!button.dataset.label) {
			button.dataset.label = original;
		}
		button.textContent = label;
		button.classList.toggle('copied', !isError);
		button.classList.toggle('copy-error', isError);
		setTimeout(() => {
			button.textContent = button.dataset.label || 'Copy';
			button.classList.remove('copied', 'copy-error');
		}, COPY_FEEDBACK_MS);
	}
</script>
</script>

