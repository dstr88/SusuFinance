---
import './Footer.css';
import type { Lang } from "@/lib/i18n/locale";
import { getFooter } from "@/i18n/footer";
import DonnieSelfie from "../assets/DonnieSelfie.jpeg";
import SusuFinanceLogo from "../assets/logo-scene.png";
import Welcome from "./Welcome.astro";
import PrivacyPolicy from "./privacy-policy.astro";
import TermsOfService from "./terms-of-service.astro";

const { lang = "en" } = Astro.props as { lang?: Lang };
const t = getFooter(lang);
const year = new Date().getFullYear();
import Faq from './faq.astro';
---

<footer class="site-footer">
  <div class="footer-grid">
    <section class="footer-col footer-license">
      <div class="license-media">
        <img
          src={DonnieSelfie.src}
          alt="Donnie selfie"
          class="license-photo"
          width={120}
          height={120}
          loading="lazy"
        />
        <div class="license-copy">
          <h3>{t.licenseHeading}</h3>
          <p>{t.licenseLine}</p>
          <p>© {year} SusuFinance LLC</p>
        </div>
      </div>
      <a
        href="https://susufinance.com"
        target="_blank"
        rel="noreferrer"
        class="license-logo-link"
        aria-label="SusuFinance"
      >
        <img
          src={SusuFinanceLogo.src}
          alt="SusuFinance"
          class="license-logo"
          width="960"
          height="1104"
          loading="lazy"
        />
      </a>
    </section>

    <section class="footer-col footer-faq">
      {/* The Almstins FAQ that lived here was removed because "the questions a susu
          member actually has are not yet known, and inventing them would be worse
          than asking none". They are known now — written Jul 20 against what the
          member screen actually does. The footer renders in both layouts, so this
          puts them on every page including the lobby. Member items only; the
          organizer's set renders on /admin. */}
      <Faq lang={lang} audience="member" />
      <div class="footer-legal">
        <a href={t.aboutHref} class="footer-legal-link">
          {t.aboutLabel}
        </a>
        <button class="footer-legal-link" type="button" data-footer-modal="privacy-modal">
          {t.privacyLabel}
        </button>
        <button class="footer-legal-link" type="button" data-footer-modal="terms-modal">
          {t.termsLabel}
        </button>
      </div>
    </section>

    <section class="footer-col footer-welcome">
      <Welcome compact lang={lang} />
    </section>
  </div>

  <div class="footer-modal" id="privacy-modal" aria-hidden="true">
    <div class="footer-modal-content" role="dialog" aria-modal="true" aria-label={t.privacyAria}>
      <button class="footer-modal-close" type="button" data-footer-close="privacy-modal">×</button>
      <PrivacyPolicy variant="modal" lang={lang} />
    </div>
  </div>

  <div class="footer-modal" id="terms-modal" aria-hidden="true">
    <div class="footer-modal-content" role="dialog" aria-modal="true" aria-label={t.termsAria}>
      <button class="footer-modal-close" type="button" data-footer-close="terms-modal">×</button>
      <TermsOfService variant="modal" lang={lang} />
    </div>
  </div>
</footer>


<script>
  document.querySelectorAll("[data-footer-modal]").forEach((trigger) => {
    trigger.addEventListener("click", () => {
      const id = trigger.getAttribute("data-footer-modal");
      if (!id) return;
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.add("is-open");
        modal.setAttribute("aria-hidden", "false");
      }
    });
  });

  document.querySelectorAll("[data-footer-close]").forEach((closeButton) => {
    closeButton.addEventListener("click", () => {
      const id = closeButton.getAttribute("data-footer-close");
      if (!id) return;
      const modal = document.getElementById(id);
      if (modal) {
        modal.classList.remove("is-open");
        modal.setAttribute("aria-hidden", "true");
      }
    });
  });
</script>
