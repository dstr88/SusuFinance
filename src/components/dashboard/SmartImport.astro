---
import './SmartImport.css';
// SmartImport.astro
// Drop-zone that auto-detects any supported CSV and routes it to the right tin.
import { getLang } from '@/lib/i18n/locale';
import { getSmartImport } from '@/i18n/components/smartImport';

const lang = getLang(Astro.request);
const t = getSmartImport(lang);
---

<div class="smart-import" id="smart-import">
  <input type="file" accept=".csv,.tsv,.zip,text/csv,text/tab-separated-values,application/zip,application/x-zip-compressed" class="smart-import__input" id="smart-import-input" multiple />

  <div class="smart-import__drop" id="smart-import-drop">
    <svg class="smart-import__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path stroke-linecap="round" stroke-linejoin="round"
        d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
    </svg>
    <p class="smart-import__label">{t.dropLabel}</p>
    <p class="smart-import__sub">Crypto.com · Coinbase · Exodus · Gemini · Kraken · Robinhood · Cash App · Venmo</p>
    <button class="smart-import__btn" id="smart-import-browse">{t.browseFiles}</button>
  </div>

  <div class="smart-import__results" id="smart-import-results"></div>
</div>


<!-- Fixed toast container — appended to body by JS so it's always on top -->
<div id="si-toast-container" class="si-toast"></div>

<!-- i18n island: injects window.__smartImportI18n before the inline script runs -->
<script define:vars={{
  __si18n: {
    // Static strings
    errorUnsupportedType: t.errorUnsupportedType,
    detectingExchange:    t.detectingExchange,
    unknownFormat:        t.unknownFormat,
    // Interpolation templates — locale functions called with sentinel tokens
    tplUploadingFile:     t.uploadingFile('{filename}'),
    tplDetectedImporting: t.detectedImporting('{name}'),
    tplDetectedToast:     t.detectedToast('{name}'),
    tplImportFailed:      t.importFailed('{status}'),
    tplDupesSkipped:      t.dupesSkipped('{count}'),
    tplImportSuccess:     t.importSuccess('{name}', '{inserted}', '{skipped}'),
    tplUnexpectedError:   t.unexpectedError('{message}'),
  }
}}>
  window.__smartImportI18n = __si18n;
</script>

<script is:inline>
(function () {
  const drop    = document.getElementById('smart-import-drop');
  const input   = document.getElementById('smart-import-input');
  const browse  = document.getElementById('smart-import-browse');
  const results = document.getElementById('smart-import-results');
  const toastEl = document.getElementById('si-toast-container');

  if (!drop || !input || !browse || !results) return;

  // ── i18n helpers ──────────────────────────────────────────────────────────
  const _i = window.__smartImportI18n || {};
  function _t(tpl, vars) {
    if (!tpl) return '';
    return Object.keys(vars).reduce(function(s, k) {
      return s.split('{' + k + '}').join(vars[k]);
    }, tpl);
  }
  const i18n = {
    errorUnsupportedType: _i.errorUnsupportedType || 'Not a supported file type. Drop a CSV or ZIP export from a supported exchange.',
    detectingExchange:    _i.detectingExchange    || 'Detecting exchange…',
    unknownFormat:        _i.unknownFormat        || 'Unknown format',
    uploadingFile:  function(f)           { return _t(_i.tplUploadingFile     || 'Uploading {filename}…',                       { filename: f }); },
    detectedImporting: function(n)        { return _t(_i.tplDetectedImporting || 'Detected: {name} — importing…',          { name: n }); },
    detectedToast: function(n)            { return _t(_i.tplDetectedToast     || '{name} detected — importing…',           { name: n }); },
    importFailed:  function(s)            { return _t(_i.tplImportFailed      || 'Import failed ({status})',                         { status: s }); },
    dupesSkipped:  function(c)            { return _t(_i.tplDupesSkipped      || ' · {count} dupes skipped',                   { count: c }); },
    importSuccess: function(n, ins, skip) { return _t(_i.tplImportSuccess     || '{name} — {inserted} rows imported{skipped}',  { name: n, inserted: ins, skipped: skip }); },
    unexpectedError: function(m)          { return _t(_i.tplUnexpectedError   || 'Unexpected error: {message}',                     { message: m }); },
  };

  // ── Toast helpers ─────────────────────────────────────────────────────────
  // Toasts are fixed to the bottom-right corner so they're visible no matter
  // where the user is scrolled on the page.

  // Escape any value that flows into innerHTML. Filenames and server/error
  // messages are attacker-influenced (a CSV named `<img src=x onerror=…>.csv`
  // would otherwise execute when dragged in), so escape before interpolating.
  function escH(v) {
    return String(v ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function showToast(state, message, autoDismissMs) {
    if (!toastEl) return;
    const item = document.createElement('div');
    item.className = `si-toast-item ${state}`;
    item.innerHTML = `<span class="si-toast-msg">${escH(message)}</span>
      <button class="si-toast-close" onclick="this.parentElement.remove()">✕</button>`;
    toastEl.appendChild(item);
    if (autoDismissMs) {
      setTimeout(() => item.remove(), autoDismissMs);
    }
    return item;
  }

  // One persistent "uploading" toast, swapped to success/error when done
  let activeToast = null;

  // Browse button
  browse.addEventListener('click', (e) => { e.stopPropagation(); input.click(); });
  drop.addEventListener('click', () => input.click());
  input.addEventListener('change', () => {
    if (input.files) processFiles(Array.from(input.files));
    input.value = '';
  });

  // Drag & drop
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('drag-over'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('drag-over'));
  drop.addEventListener('drop', (e) => {
    e.preventDefault();
    drop.classList.remove('drag-over');
    const ACCEPTED = ['.csv', '.tsv', '.zip'];
    const files = Array.from(e.dataTransfer?.files ?? []).filter(f =>
      ACCEPTED.some(ext => f.name.toLowerCase().endsWith(ext))
    );
    if (files.length) {
      processFiles(files);
    } else {
      showToast('error', i18n.errorUnsupportedType, 6000);
    }
  });

  async function processFiles(files) {
    for (const file of files) await processOne(file);
  }

  async function processOne(file) {
    // Inline result row (keeps a history below the dropzone)
    const row = addResult('processing', file.name, i18n.detectingExchange);
    // Toast in the corner — immediately visible
    activeToast = showToast('processing', i18n.uploadingFile(file.name), 0);

    try {
      // Step 1: detect
      const detectForm = new FormData();
      detectForm.append('file', file);
      const detectRes  = await fetch('/api/import/detect', { method: 'POST', body: detectForm });
      const detected   = await detectRes.json();

      if (!detected.detected) {
        const msg = detected.error ?? i18n.unknownFormat;
        setResult(row, 'error', file.name, msg);
        swapToast('error', msg, 8000);
        return;
      }

      setResult(row, 'processing', file.name, i18n.detectedImporting(detected.name));
      swapToast('processing', i18n.detectedToast(detected.name), 0);

      // Step 2: import
      const importForm = new FormData();
      importForm.append('file', file);
      const importRes  = await fetch(detected.endpoint, { method: 'POST', body: importForm });
      const result     = await importRes.json();

      if (!importRes.ok || result.error) {
        const msg = result.error ?? i18n.importFailed(importRes.status);
        setResult(row, 'error', file.name, msg);
        swapToast('error', msg, 10000);
        return;
      }

      const inserted = result.insertedNormalized ?? result.inserted ?? result.count ?? '?';
      const dupes    = result.skippedDuplicates  ?? result.skipped  ?? null;
      const skipped  = dupes != null ? i18n.dupesSkipped(dupes) : '';
      const successMsg = i18n.importSuccess(detected.name, inserted, skipped);

      setResult(row, 'success', file.name, successMsg);
      swapToast('success', successMsg, 7000);

      fetch('/api/lifecycle/rebuild', { method: 'POST' }).catch(() => {});

    } catch (err) {
      const msg = i18n.unexpectedError(err?.message ?? String(err));
      setResult(row, 'error', file.name, msg);
      swapToast('error', msg, 10000);
    }
  }

  function swapToast(state, message, autoDismissMs) {
    if (activeToast) activeToast.remove();
    activeToast = showToast(state, message, autoDismissMs);
  }

  function addResult(state, filename, message) {
    const div = document.createElement('div');
    div.className = `si-result si-result--${state}`;
    div.innerHTML = resultHTML(state, filename, message);
    results.prepend(div);
    return div;
  }

  function setResult(div, state, filename, message) {
    div.className = `si-result si-result--${state}`;
    div.innerHTML = resultHTML(state, filename, message);
  }

  function resultHTML(state, filename, message) {
    const icon = state === 'processing'
      ? '<div class="si-spinner"></div>'
      : `<span class="si-icon" style="color:${state === 'success' ? 'var(--gain)' : 'var(--loss)'}">${state === 'success' ? '✓' : '✕'}</span>`;
    return `${icon}<div class="si-text"><div>${escH(message)}</div><div class="si-file">${escH(filename)}</div></div>`;
  }
})();
</script>
