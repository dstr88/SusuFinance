---
import './BookkeepingTin2.css';
import walletIn from '@/assets/walletIn.webp';
import walletOut from '@/assets/walletOut.webp';
import { getLang } from '@/lib/i18n/locale';
import { getBookkeepingTin2 } from '@/i18n/components/bookkeepingTin2';

const { walletId = '', year = new Date().getFullYear() } = Astro.props;
const accordionId = `bookkeeping-tin2-${walletId || 'wallet'}-${year}`;
const lang = getLang(Astro.request);
const t = getBookkeepingTin2(lang);
---

<article class="bookkeeping-tin2" data-accordion-id={accordionId} data-year={year}>
	<header class="tin-header">
		<button class="tin-toggle" type="button" aria-expanded="false">
			<h3 class="tin-title">fa58b</h3>
		</button>
		<button class="tin-close" type="button" aria-label={t.closeLabel}>
			{t.close}
		</button>
	</header>

	<div class="tin-summary">
		<div class="summary-row">
			<div class="summary-left">
				<span class="tx-count">142 tx</span>
				<button class="download-btn" type="button" aria-label={t.downloadLabel}>
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path
							d="M12 3v10m0 0 4-4m-4 4-4-4M4 17h16v3H4z"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
						/>
					</svg>
				</button>
			</div>
			<span class="summary-right">-$3,412 net</span>
		</div>
		<div class="summary-row">
			<span class="summary-label">{t.gas}</span>
			<span class="summary-right">$186</span>
		</div>
		<div class="summary-row">
			<span class="summary-label">{t.lastActivity}</span>
			<span class="summary-right">Dec 28</span>
		</div>
	</div>

	<div class="tin-body">
		<section class="section-block">
			<h4>{t.stillInWallet}</h4>
			<div class="tx-list">
				<button class="tx-row" type="button">
					<span class="tx-date">Dec 28</span>
					<span class="tx-desc">ETH</span>
					<span class="tx-amt">
						<span class="tx-amt-value">0.42</span>
					</span>
					<span class="tx-usd">
						<span class="tx-usd-value">$1,245.19</span>
					</span>
					<span class="tx-status">
						<img class="tx-status-icon" src={walletIn.src} alt={t.inbound} />
					</span>
					<textarea class="tx-notes" placeholder={t.notesPlaceholder}></textarea>
				</button>
				<div class="tx-detail">
					<textarea placeholder={t.noteUnsavedPlaceholder}></textarea>
				</div>
				<button class="tx-row" type="button">
					<span class="tx-date">Nov 18</span>
					<span class="tx-desc">WBTC</span>
					<span class="tx-amt">
						<span class="tx-amt-value">0.12</span>
					</span>
					<span class="tx-usd">
						<span class="tx-usd-value">$4,812.22</span>
					</span>
					<span class="tx-status">
						<img class="tx-status-icon" src={walletIn.src} alt={t.inbound} />
					</span>
					<textarea class="tx-notes" placeholder={t.notesPlaceholder}></textarea>
				</button>
				<div class="tx-detail">
					<textarea placeholder={t.noteUnsavedPlaceholder}></textarea>
				</div>
			</div>
		</section>

		<section class="section-block">
			<h4>{t.transferredOut}</h4>
			<div class="tx-list">
				<button class="tx-row" type="button">
					<span class="tx-date">Oct 02</span>
					<span class="tx-desc">POL</span>
					<span class="tx-amt">
						<span class="tx-amt-value">9,400</span>
					</span>
					<span class="tx-usd">
						<span class="tx-usd-value">$6,030.10</span>
					</span>
					<span class="tx-status">
						<img class="tx-status-icon" src={walletOut.src} alt={t.outbound} />
					</span>
					<textarea class="tx-notes" placeholder={t.notesPlaceholder}></textarea>
				</button>
				<div class="tx-detail">
					<textarea placeholder={t.noteUnsavedPlaceholder}></textarea>
				</div>
				<button class="tx-row" type="button">
					<span class="tx-date">Sep 11</span>
					<span class="tx-desc">AVAX</span>
					<span class="tx-amt">
						<span class="tx-amt-value">18.2</span>
					</span>
					<span class="tx-usd">
						<span class="tx-usd-value">$421.00</span>
					</span>
					<span class="tx-status">
						<img class="tx-status-icon" src={walletOut.src} alt={t.outbound} />
					</span>
					<textarea class="tx-notes" placeholder={t.notesPlaceholder}></textarea>
				</button>
				<div class="tx-detail">
					<textarea placeholder={t.noteUnsavedPlaceholder}></textarea>
				</div>
			</div>
		</section>
	</div>
</article>

<script>
	const tins = document.querySelectorAll('.bookkeeping-tin2');
	tins.forEach((tin) => {
		if (tin.dataset.initialized === 'true') return;
		tin.dataset.initialized = 'true';

		const toggle = tin.querySelector('.tin-toggle');
		const closeBtn = tin.querySelector('.tin-close');
		const downloadBtn = tin.querySelector('.download-btn');
		const rows = tin.querySelectorAll('.tx-row');
		const summary = tin.querySelector('.tin-summary');
		const accordionId = tin.getAttribute('data-accordion-id');
		const year = tin.getAttribute('data-year');

		function setOpen(isOpen) {
			tin.dataset.open = isOpen ? 'true' : 'false';
			toggle?.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
			if (window.matchMedia('(max-width: 640px)').matches) {
				document.documentElement.style.overflow = isOpen ? 'hidden' : '';
				document.body.style.overflow = isOpen ? 'hidden' : '';
			}
		}

		function openTin() {
			window.dispatchEvent(new CustomEvent('bookkeeping:open', { detail: { id: accordionId } }));
			setOpen(true);
		}

		function closeTin() {
			setOpen(false);
		}

		function handleToggle(event) {
			event.stopPropagation();
			if (tin.dataset.open === 'true') {
				closeTin();
			} else {
				openTin();
			}
		}

		toggle?.addEventListener('click', handleToggle);
		summary?.addEventListener('click', (event) => {
			if (tin.dataset.open === 'true') return;
			handleToggle(event);
		});

		closeBtn?.addEventListener('click', (event) => {
			event.stopPropagation();
			closeTin();
		});

		downloadBtn?.addEventListener('click', (event) => {
			event.stopPropagation();
			console.log('download year', year);
		});

		rows.forEach((row) => {
			row.addEventListener('click', () => {
				const detail = row.nextElementSibling;
				if (!detail || !detail.classList.contains('tx-detail')) return;
				const expanded = detail.getAttribute('data-open') === 'true';
				detail.setAttribute('data-open', expanded ? 'false' : 'true');
			});
		});

		window.addEventListener('bookkeeping:open', (event) => {
			const id = event.detail?.id;
			if (id && id !== accordionId) {
				closeTin();
			}
		});
	});
</script>

